                   10734     ;------------------------------------------------------------------------------
                   10735     ;  This file is part of the BL51 / LX51 Banked Linker/Locater package
                   10736     ;  Copyright (c) 1988 - 2001 Keil Elektronik GmbH and Keil Software, Inc.
                   10737     ;  Version 2.21 (Code and Variable Banking for Classic 8051 Derivatives)
                   10738     ;------------------------------------------------------------------------------
                   10739     ;************************ Configuration Section *******************************
                   10740     ; Define maximum Number of Banks                                              *
  0010             10741     ?B_NBANKS       EQU  0x10;                  *
                   10742     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64 *
                   10743     ;                         ; for BL51 the maximum value for ?B_BANKS is 32     *
                   10744     ;                         ; for LX51 the maximum value for ?B_BANKS is 64     *
                   10745     ;                                                                             *
  0001             10746     ?B_MODE         EQU  1    ; 0 for Bank-Switching via 8051 Port                *
A51 MACRO ASSEMBLER  L51_BANK                                                             04/23/2026 10:22:04 PAGE    44

                   10747     ;                         ; 1 for Bank-Switching via XDATA Port               *
                   10748     ;                         ; 4 for user-provided bank switch code              *
                   10749     ;                                                                             *
  0000             10750     ?B_RTX          EQU  0    ; 0 for applications without real-time OS           *
                   10751     ;                         ; 1 for applications using the RTX-51 real-time OS  *
                   10752     ;                                                                             *
  0000             10753     ?B_VAR_BANKING  EQU  0    ; Variable Banking via L51_BANK (far memory support)*
                   10754     ;                         ; 0 Variable Banking does not use L51_BANK.A51      *
                   10755     ;                         ; 1 Variable Banking uses this L51_BANK.A51 module  *
                   10756     ; Notes: ?B_VAR_BANKING uses the 'far' and 'far const' C51 memory types to    *
                   10757     ;        extent the space for variables in RAM and/or ROM of classic 8051     *
                   10758     ;        device.  The same hardware as for code banking is used.  Program     *
                   10759     ;        code banking and variable banking share the same hardware I/O pins.  *
                   10760     ;        The C51 Compiler must be used with the VARBANKING directive.         *
                   10761     ;        Variable Banking is only supported with the LX51 linker/locater.     *
                   10762     ;                                                                             *
  00FF             10763     ?B_RST_BANK     EQU  0xFF ; specifies the active code bank number after CPU   *
                   10764     ;                         ; Reset.  Used to reduce the entries in the         *
                   10765     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables    *
                   10766     ;                         ; this LX51 linker/locater optimization.            *
                   10767     ; Note:  Interbank Call Table optimization is only possible with LX51.        *
                   10768     ;                                                                             *
                   10769     ;-----------------------------------------------------------------------------*
                   10770     ;                                                                             *
                             ENDIF;                                                                        *
                   10783     ;                                                                             *
                   10784     IF  ?B_MODE = 1;                                                              *
                   10785     ;-----------------------------------------------------------------------------*
                   10786     ; if ?BANK?MODE is 1 define the following values                              *
                   10787     ; For Bank-Switching via XDATA Port define XDATA Port Address / Bits          *
  FFFF             10788     ?B_XDATAPORT    EQU     0FFFFH   ; default is XDATA Port Address 0FFFFH       *
  0000             10789     ?B_FIRSTBIT     EQU     0        ; default is Bit 0                           *
                   10790     ;-----------------------------------------------------------------------------*
                   10791     ENDIF;                                                                        *
                   10792     ;                                                                             *
                             ENDIF;                                                                        *
                   10851     ;                                                                             *
                             ENDIF;                                                                        *
                   10872     ;                                                                             *
                   10873     ;******************************************************************************
                   10874     ;                                                                             *
                   10875     ; THEORY OF OPERATION                                                         *
                   10876     ; -------------------                                                         *
                   10877     ; The section below describes the code generated by BL51 or LX51 and the      *
                   10878     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                   10879     ; function that is located in a code memory bank and called from the common   *
                   10880     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                   10881     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                   10882     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                   10883     ;                                                                             *
                   10884     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                   10885     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                   10886     ;                                                                             *
                   10887     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                   10888     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                   10889     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                   10890     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                   10891     ;                                                                             *
                   10892     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                   10893     ;             for the current active bank on the STACK and switches to the    *
                   10894     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                   10895     ;             register.  It is allowed to modify the following registers in   *
                   10896     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                   10897     ;                                                                             *
                   10898     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                   10899     ;             used at the end of a user function to return to the calling     *
A51 MACRO ASSEMBLER  L51_BANK                                                             04/23/2026 10:22:04 PAGE    45

                   10900     ;             code bank.  Only the following registers may be altered in the  *
                   10901     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                   10902     ;                                                                             *
                   10903     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                   10904     ; variable to restore the code bank after a task switch.  To get correct      *
                   10905     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                   10906     ; switch is done, or the code banking sequences must be interrupt protected.  *
                   10907     ;******************************************************************************
                   10908     
                   10909                     NAME    ?BANK?SWITCHING
                   10910     
                   10911                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                   10912                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                   10916     
                   10917     ; Standard SFR Symbols required in L51_BANK.A51
  00E0             10918     ACC     DATA    0E0H
  00F0             10919     B       DATA    0F0H
  0082             10920     DPL     DATA    82H
  0083             10921     DPH     DATA    83H
  00A8             10922     IE      DATA    0A8H
  00AF             10923     EA      BIT     IE.7
                   10924     
                   10925     
                   10926     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 16
  000F             10934       MASK          EQU     00001111B
                             ENDIF
                   10940     
                             ENDIF  ; close block IF ?B_MODE = 0 *******************************************
