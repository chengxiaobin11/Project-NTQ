              #if(_DP_MST_AUTO_SEARCH_SUPPORT == _ON)
                  if((GET_SOURCE_SCAN_TYPE() != _SOURCE_SWITCH_FIXED_PORT) &&
                     (GET_SOURCE_JUDGE(g_ucSearchIndex) == _FALSE) &&
                     (SysSourceGetInputPort() == ScalerDpRxMstGetInputPort(ScalerDpRxMstGetCapablePort())))
                  {
