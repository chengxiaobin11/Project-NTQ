 172   1          for(ucDDRSel = _DDR2_DEV_SEQ_BEGIN; ucDDRSel < _DDR2_DEV_SEQ_END; ucDDRSel++)
 173   1          {
 174   2              //==============================
 175   2              // DLL Setting
 176   2              //==============================
 177   2              // PHY & MAC Frequency Ratio 1:2
 178   2              ScalerSetDWord(DDR2_GET_REG(P8F_D8_BIST_2TO1_0_3, ucDDRSel), 0xB0000000);
