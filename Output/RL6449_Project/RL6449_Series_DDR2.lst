  69          //--------------------------------------------------
  70          // Description  : DDR Power On/Off
  71          // Input Value  : None
  72          // Output Value : None
  73          //--------------------------------------------------
  74          void ScalerDDR2PowerControl(bit bOn)
  75          {
  76   1          if(bOn == _ON)
  77   1          {
  78   2              // Set MPLL CLK
  79   2              ScalerPLLSetMPLLFreq((DWORD)_MEMORY_PLL_CLOCK * 1000);
  80   2      
  81   2              // Set DDR PLL CLK
  82   2              ScalerPLLSetDDR2PLLFreq((DWORD)_MEMORY_DATA_RATE_SPEED * 1000);
  83   2      
  84   2              //------------------------------
  85   2              // DC Sys Initial
  86   2              //------------------------------
  87   2              ScalerDDR2DCSysInitial();
  88   2      
  89   2              //------------------------------
  90   2              // DC PHY Initial
  91   2              //------------------------------
  92   2              ScalerDDR2DCPHYInitial();
  93   2          }
  94   1          else
  95   1          {
  96   2              // Disable CLK output, Reset PLL, Disable PLL
  97   2              ScalerPLLDDR2PLLOutputCtrl(_DISABLE);
  98   2              ScalerPLLDDR2PLLCtrl(_DISABLE);
  99   2      
 100   2              // Power down MPLL
 101   2              ScalerSetBit(P0_F8_MPLL_WD, ~_BIT0, _BIT0);
 102   2          }
 103   1      }
