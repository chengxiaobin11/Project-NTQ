 347          //--------------------------------------------------
 348          // Description  : Calculate write level config
 349          // Input Value  : pstDDR2PLLPhase
 350          // Output Value : DWORD (32bit) of register setting
 351          //--------------------------------------------------
 352          DWORD ScalerDDR2CalcWrlvlConfig(StructDDR2PLLPI code *pstDDR2PLLPhase)
 353          {
 354   1          StructDDR2PLLPI stTheoPI;
 355   1          DWORD ulWrlvlConfig = 0;
 356   1      
 357   1          stTheoPI.ucDQS0 = pstDDR2PLLPhase->ucDQS0 % _TOT_THEO_PI_NUM;
 358   1          stTheoPI.ucDQS1 = pstDDR2PLLPhase->ucDQS1 % _TOT_THEO_PI_NUM;
 359   1          stTheoPI.ucDQ0 = pstDDR2PLLPhase->ucDQ0 % _TOT_THEO_PI_NUM;
 360   1          stTheoPI.ucDQ1 = pstDDR2PLLPhase->ucDQ1 % _TOT_THEO_PI_NUM;
 361   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_DDR2                                                04/23/2026 13:54:38 PAGE 8   

 362   1          // DQS0
 363   1          ulWrlvlConfig |= ((stTheoPI.ucDQS0 < (53 + 0)) ? 0x00000000 :
 364   1                            ((stTheoPI.ucDQS0 < (21 + 64)) ? 0x00000010 :
 365   1                             ((stTheoPI.ucDQS0 < (53 + 64)) ? 0x00001000 : 0x00001010)));
 366   1          // DQS1
 367   1          ulWrlvlConfig |= ((stTheoPI.ucDQS1 < (53 + 0)) ? 0x00000000 :
 368   1                            ((stTheoPI.ucDQS1 < (21 + 64)) ? 0x00000020 :
 369   1                             ((stTheoPI.ucDQS1 < (53 + 64)) ? 0x00002000 : 0x00002020)));
 370   1          // DQ0
 371   1          ulWrlvlConfig |= ((stTheoPI.ucDQ0 < (53 + 0)) ? 0x00000000 :
 372   1                            ((stTheoPI.ucDQ0 < (21 + 64)) ? 0x00000100 :
 373   1                             ((stTheoPI.ucDQ0 < (53 + 64)) ? 0x00010000 : 0x00010100)));
 374   1          // DQ1
 375   1          ulWrlvlConfig |= ((stTheoPI.ucDQ1 < (53 + 0)) ? 0x00000000 :
 376   1                            ((stTheoPI.ucDQ1 < (21 + 64)) ? 0x00000200 :
 377   1                             ((stTheoPI.ucDQ1 < (53 + 64)) ? 0x00020000 : 0x00020200)));
 378   1      
 379   1          return ulWrlvlConfig;
 380   1      }
