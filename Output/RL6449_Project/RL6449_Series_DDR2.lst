 192   2              ScalerSetDWord(DDR2_GET_REG(P8E_58_READ_CTRL0_SET1_3, ucDDRSel), 0x0000000B); // slice_1: DQS_1
 193   2              // Apply read delay setting
 194   2              ScalerSetDWord(DDR2_GET_REG(P8F_80_DPI_CTRL1_3, ucDDRSel), 0x0000000C);
 195   2      
 196   2              //------------------------------
 197   2              // Read DQ delay tap
 198   2              //------------------------------
 199   2              // RDQ delay tap - rising
 200   2              ScalerSetDWord(DDR2_GET_REG(P8E_B8_DQS_IN_DLY0_SET0_3, ucDDRSel), 0x05050505); // slice_0: DQ_03~D
             -Q_00
 201   2              ScalerSetDWord(DDR2_GET_REG(P8E_BC_DQS_IN_DLY0_SET1_3, ucDDRSel), 0x05050505); // slice_1: DQ_11~D
             -Q_08
 202   2              ScalerSetDWord(DDR2_GET_REG(P8E_C8_DQS_IN_DLY1_SET0_3, ucDDRSel), 0x05050505); // slice_0: DQ_07~D
             -Q_04
 203   2              ScalerSetDWord(DDR2_GET_REG(P8E_CC_DQS_IN_DLY1_SET1_3, ucDDRSel), 0x05050505); // slice_1: DQ_15~D
             -Q_12
 204   2              // RDQ delay tap - falling
 205   2              ScalerSetDWord(DDR2_GET_REG(P8E_D8_DQS_IN_DLY2_SET0_3, ucDDRSel), 0x05050505); // slice_0: DQ_03~D
             -Q_00
 206   2              ScalerSetDWord(DDR2_GET_REG(P8E_DC_DQS_IN_DLY2_SET1_3, ucDDRSel), 0x05050505); // slice_1: DQ_11~D
             -Q_08
 207   2              ScalerSetDWord(DDR2_GET_REG(P8E_E8_DQS_IN_DLY3_SET0_3, ucDDRSel), 0x05050505); // slice_0: DQ_07~D
             -Q_04
 208   2              ScalerSetDWord(DDR2_GET_REG(P8E_EC_DQS_IN_DLY3_SET1_3, ucDDRSel), 0x05050505); // slice_1: DQ_15~D
             -Q_12
 209   2              // Apply read delay setting
 210   2              ScalerSetDWord(DDR2_GET_REG(P8F_80_DPI_CTRL1_3, ucDDRSel), 0x0000000C);
 211   2      
 212   2              //------------------------------
 213   2              // Rx FIFO latency
 214   2              //------------------------------
 215   2              ScalerSetDWord(DDR2_GET_REG(P8E_64_READ_CTRL1_3, ucDDRSel), 0x0001000A);
 216   2              // Apply read delay setting
