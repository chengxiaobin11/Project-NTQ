 389          void ScalerDDR2RotationSetClientMux(void)
 390          {
 391   1          switch(GET_ROT_TYPE())
 392   1          {
 393   2              case _ROT_CW180:
 394   2      #if(_DISPLAY_HOR_MIRROR_SUPPORT == _ON)
                      case _ROT_VER_MIRROR:
              #endif
 397   2                  // _ROT_CW180, _ROT_VER_MIRROR: set disp client mux different from cap client
 398   2                  // M1
 399   2                  ScalerSetBit(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, ~_BIT4, ((ScalerGetBit(P37_B0_M_DOMAIN_CLIENT_M
             -UX_CTRL0, _BIT0) == _BIT0) ? 0x00 : _BIT4));
 400   2                  // M2
 401   2                  ScalerSetBit(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, ~_BIT5, ((ScalerGetBit(P37_B0_M_DOMAIN_CLIENT_M
             -UX_CTRL0, _BIT1) == _BIT1) ? 0x00 : _BIT5));
 402   2                  break;
 403   2      
 404   2              default:
 405   2                  // Other cases: set disp client mux as cap client
 406   2                  // M1
 407   2                  ScalerSetBit(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, ~_BIT4, ((ScalerGetBit(P37_B0_M_DOMAIN_CLIENT_M
             -UX_CTRL0, _BIT0) == _BIT0) ? _BIT4 : 0x00));
 408   2                  // M2
 409   2                  ScalerSetBit(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, ~_BIT5, ((ScalerGetBit(P37_B0_M_DOMAIN_CLIENT_M
             -UX_CTRL0, _BIT1) == _BIT1) ? _BIT5 : 0x00));
 410   2                  break;
 411   2          }
 412   1      }
