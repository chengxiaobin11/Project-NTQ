 110          void ScalerDDR2DCSysInitial(void)
 111          {
 112   1          BYTE ucDDRSel = 0;
 113   1      
 114   1          for(ucDDRSel = _DDR2_DEV_SEQ_BEGIN; ucDDRSel < _DDR2_DEV_SEQ_END; ucDDRSel++)
 115   1          {
 116   2              // (_BIT1 | _BIT0): Page size selection: 00=512bytes, 01=1024bytes, 10=2048bytes, 11=4096bytes
 117   2              ScalerSetDWord(DDR2_GET_REG(P8A_04_DC_SYS_MISC3, ucDDRSel), 0x00010100);
 118   2      
 119   2              // Set DDR2 M1 Client Priority Counter
 120   2              // Cleint0 M1 FRC Capature
 121   2              ScalerSetDWord(DDR2_GET_REG(P8A_80_DC_DEBUG3, ucDDRSel), 0x0010002F);
 122   2      
 123   2              // Cleint2 M1 FRC Display
 124   2              ScalerSetDWord(DDR2_GET_REG(P8A_88_DC_PRIORITY3_CTRL2, ucDDRSel), 0x0020003F);
 125   2      
 126   2              // Cleint4 M1 OD Write
 127   2              ScalerSetDWord(DDR2_GET_REG(P8A_90_DC_PRIORITY3_CTRL4, ucDDRSel), 0x0040005F);
 128   2      
 129   2              // Cleint6 M1 OD Read
 130   2              ScalerSetDWord(DDR2_GET_REG(P8A_98_DC_PRIORITY3_CTRL6, ucDDRSel), 0x0050006F);
 131   2      
 132   2              // Set DDR2 M2 Client Priority Counter
 133   2              // Cleint1 M2 FRC Capature
 134   2              ScalerSetDWord(DDR2_GET_REG(P8A_84_DC_PRIORITY3_CTRL1, ucDDRSel), 0x0010002F);
 135   2      
 136   2              // Cleint3 M2 FRC Display
 137   2              ScalerSetDWord(DDR2_GET_REG(P8A_8C_DC_PRIORITY3_CTRL3, ucDDRSel), 0x0020003F);
 138   2      
 139   2              // Cleint5 M2 OD Write
 140   2              ScalerSetDWord(DDR2_GET_REG(P8A_94_DC_PRIORITY3_CTRL5, ucDDRSel), 0x0040005F);
 141   2      
 142   2              // Cleint8 M2 OD Read
 143   2              ScalerSetDWord(DDR2_GET_REG(P8A_A0_DC_PRIORITY3_CTRL8, ucDDRSel), 0x0050006F);
 144   2      
 145   2              // CleintB MCU Read/Write
 146   2              ScalerSetDWord(DDR2_GET_REG(P8A_AC_DC_PRIORITY3_CTRLB, ucDDRSel), 0x009F009F);
 147   2          }
 148   1      
 149   1      #if(_MEMORY_SIZE_CONFIG == _16M_16BIT_DDR2_1PC)
              
                  // Set DDR2 Clint Mux
                  ScalerSetByte(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, ((_DDR2_PRIMARY_DEVICE == _DDR2_A) ? 0x00 : 0x33));
                  ScalerSetByte(P37_B1_M_DOMAIN_CLIENT_MUX_CTRL1, ((_DDR2_PRIMARY_DEVICE == _DDR2_A) ? 0x00 : 0x33));
              
              #elif(_MEMORY_SIZE_CONFIG == _16M_16BIT_DDR2_2PCS)
 156   1      
 157   1          // Set DDR2 Clint Mux
 158   1          ScalerSetByte(P37_B0_M_DOMAIN_CLIENT_MUX_CTRL0, 0x22);
 159   1          ScalerSetByte(P37_B1_M_DOMAIN_CLIENT_MUX_CTRL1, 0x22);
 160   1      #endif
 161   1      }
