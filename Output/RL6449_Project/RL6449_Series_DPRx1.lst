 241   1      
 242   1          // Source Read 692DFh(HPrime) INT
 243   1          ScalerSetByte(PBA_B7_AUX_IRQ_ADDR1_MSB, 0x06);
 244   1          ScalerSetByte(PBA_B8_AUX_IRQ_ADDR1_MSB1, 0x92);
 245   1          ScalerSetByte(PBA_B9_AUX_IRQ_ADDR1_LSB, 0xDF);
