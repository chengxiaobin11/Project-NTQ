 210          // Output Value : None
 211          //--------------------------------------------------
 212          void ScalerDpRx1AuxIntInitial(void)
 213          {
 214   1          // Enable 068xxx INT
 215   1          ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT1 | _BIT0), _BIT1);
 216   1          ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 217   1      
 218   1          // Disable other DPCD, Aux Timeout, Receiving Aux INT.
 219   1          ScalerSetBit(PBA_DC_AUX_IRQ_STATUS, ~(_BIT5 | _BIT3 | _BIT2), 0x00);
 220   1      
 221   1          // Disable Aux Phy Int
 222   1          ScalerSetBit(PBA_77_AUX_DIG_PHY7, ~_BIT7, 0x00);
 223   1      
 224   1          // Enable DPCD INT
 225   1          ScalerSetByte(PBA_DE_AUX_DPCD_IRQ_EN, 0xE5);
 226   1      
 227   1          // I2c slave addr 50 Interrupt
 228   1          ScalerSetByte(PBA_F3_IIC_SLAVE_ADD, 0xA1);
 229   1      
 230   1          // Internal IRQ Enable (Global)
 231   1          ScalerGlobalIRQControl(_ENABLE);
C51 COMPILER V9.60.0.0   RL6449_SERIES_DPRX1                                               04/23/2026 13:54:41 PAGE 5   

 232   1      
