 257   1          ScalerSetByte(PBA_B4_AUX_IRQ_ADDR0_MSB, 0x30);
 258   1          ScalerSetByte(PBA_B5_AUX_IRQ_ADDR0_MSB1, 0x22);
 259   1          ScalerSetByte(PBA_B6_AUX_IRQ_ADDR0_LSB, 0x00);
 260   1      
 261   1          // Clear Read DPCD 022xxh INT Flag
 262   1          ScalerSetBit(PBA_FB_DUMMY_1, ~(_BIT7 | _BIT5 | _BIT3 | _BIT1), _BIT7);
 263   1      
 264   1          // Enable Read DPCD 022xxh INT
 265   1          ScalerSetBit(PBA_FB_DUMMY_1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT3 | _BIT1), _BIT6);
 266   1      
 267   1          // Disable Wildcard IRQ for Error Counter
 268   1          ScalerSetBit(PBA_FB_DUMMY_1, ~(_BIT7 | _BIT5 | _BIT3 | _BIT1 | _BIT0), 0x00);
 269   1      
 270   1          // Use Wildcard 3 to DPCD 0x0021xh, LSB 4 Bits Discarded
 271   1          ScalerSetByte(PBA_BD_AUX_IRQ_ADDR3_MSB, 0x10);
 272   1          ScalerSetByte(PBA_BE_AUX_IRQ_ADDR3_MSB1, 0x02);
 273   1          ScalerSetByte(PBA_BF_AUX_IRQ_ADDR3_LSB, 0x10);
