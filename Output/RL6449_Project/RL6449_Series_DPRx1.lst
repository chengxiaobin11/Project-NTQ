 119          //--------------------------------------------------
 120          // Description  : Initial Setting for DP Digital Aux, Analog Aux
 121          // Input Value  : None
 122          // Output Value : None
 123          //--------------------------------------------------
 124          void ScalerDpRx1AuxPowerOnInitial(void)
 125          {
 126   1          // Digital Aux Power On, DPCD REG Power On, MSG Power On.
 127   1          ScalerSetBit(PBA_C0_DPCD_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT1 | _BIT0), 0x00);
 128   1      
 129   1          // Average 8 cycles as Start Postion, Aux Clk Select to 27MHz, no Swap
 130   1          ScalerSetByte(PBA_72_AUX_DIG_PHY2, 0xC0);
 131   1      
 132   1      #if(_DP_AUX_REPLY_CLK_SEL_FROM == _DP_AUX_REPLY_SEL_IOSC)
 133   1          // Aux Clk Select Manual Mode, Aux New Mode
 134   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), _BIT6);
 135   1      #else
                  // Aux Clk Select Source, Aux New Mode
                  ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
 139   1      
 140   1          // HW Fake Link Training Disable.
 141   1          ScalerSetBit(PBA_C6_AUX_PHY_DIG2, ~_BIT4, 0x00);
 142   1      
 143   1          // Set Aux Precharge Number.
 144   1          ScalerSetBit(PBA_74_AUX_DIG_PHY4, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT0));
 145   1      
 146   1          // Aux Auto Mode, Using Default Average Number.
 147   1          ScalerSetByte(PBA_75_AUX_DIG_PHY5, 0x0D);
 148   1      
 149   1          // Aux Reply Timeout Setting
 150   1          ScalerSetByte(PBA_A2_AUX_RESERVE2, _DP_AUX_REPLY_TIMEOUT_USER_SETTING);
 151   1      
 152   1          // Enble Aux Channel.
 153   1          ScalerSetBit(PBA_D0_AUX_MODE_SET, ~(_BIT3 | _BIT2 | _BIT0), _BIT0);
 154   1      
 155   1          // Fast IIC Clock.
 156   1          ScalerSetBit(PBA_D1_DP_IIC_SET, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_DP_AUX_IIC_SCL_CLK_SETTING << 4));
 157   1      
 158   1          // Set aux mac clk use xclk
 159   1          ScalerSetBit(PBA_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT3 | _BIT1 | _BIT0), _BIT3);
 160   1      
 161   1          // Not Reply when Aux Error.
 162   1          ScalerSetBit(PBA_DB_AUX_STATUS, ~(_BIT5 | _BIT4), _BIT4);
 163   1          ScalerSetBit(PBA_76_AUX_DIG_PHY6, ~(_BIT7 | _BIT6), _BIT6);
 164   1      
 165   1          // Aux Ack Timer.
 166   1          ScalerSetBit(PBA_F0_AUX_TX_TIMER, ~(_BIT5 | _BIT2), (_BIT5 | _BIT2));
 167   1      
 168   1          // I2C timeout setting
 169   1          ScalerSetByte(PBA_F1_AUX_TX_TIMER_2, _DP_AUX_I2C_REPLY_TIMEOUT_SETTING);
 170   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_DPRX1                                               04/23/2026 13:54:41 PAGE 4   

 171   1          // Disable Reply IIC Defer Before Data Ready.
 172   1          ScalerSetBit(PBA_F4_MCUIIC, ~(_BIT6 | _BIT5), 0x00);
 173   1      
 174   1          // Enable Aux Error Handler.
 175   1          ScalerSetBit(PBA_78_AUX_DIG_PHY8, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT5 | _
             -BIT4));
 176   1      
 177   1          // Toggle Aux Auto K
 178   1          ScalerSetBit(PBA_65_AUX_5, ~_BIT7, 0x00);
 179   1          ScalerSetBit(PBA_65_AUX_5, ~_BIT7, _BIT7);
 180   1      
 181   1          // Aux Mode Set (Diff Mode or Single-ended mode) && Aux RX1 Resistance Setting
 182   1          ScalerDpRx1AuxSet();
 183   1      
 184   1          // Set Aux Talk Mode ADJR
 185   1          ScalerSetByte(PBA_67_DIG_TX_03, 0x88);
 186   1      
 187   1          ScalerSetBit(PBA_60_DIG_TX_04, ~(_BIT1 | _BIT0), _BIT0);
 188   1      
 189   1          // Aux comm current select max
 190   1          ScalerSetBit(PBA_64_AUX_4, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 191   1      
 192   1          // Set Aux D_2 = ~D_1 for Aux Single Ended Mode
 193   1          ScalerSetBit(PBA_79_AUX_DIG_PHY9, ~_BIT7, _BIT7);
 194   1      
 195   1          // Clear the Clock Divider for AUX MAC and PHY
 196   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 197   1          ScalerSetBit(PBA_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 198   1      
 199   1          // Aux ps clk from IOSC
 200   1          ScalerSetBit(P0_0B_POWER_CTRL, ~(_BIT5 | _BIT4), 0x00);
 201   1      
 202   1          // Set the Clock Divider = 1 for AUX MAC and PHY
 203   1          ScalerSetBit(PBA_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 204   1          ScalerSetBit(PBA_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 205   1      }
