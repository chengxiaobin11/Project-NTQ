 517          void ScalerDisplayDPTxPhyInitial(void)
 518          {
 519   1          // Set DISP mode is Dp Tx
 520   1          ScalerSetBit(P39_00_LVDS_DISP_TYPE, ~(_BIT2 | _BIT1 | _BIT0), _BIT2);
 521   1      
 522   1          // Set Link Clk Source Selection of CKRD
 523   1          ScalerSetBit(P38_2A_VBY1_LCLK_SOURCE_CTRL, ~(_BIT3 | _BIT2 | _BIT1), 0x00);
 524   1      
 525   1          // Set Link Clk Source
 526   1          ScalerSetBit(P38_2A_VBY1_LCLK_SOURCE_CTRL, ~_BIT0, _BIT0);
 527   1      
 528   1          // Set Dptx Digital Phy Initial
 529   1          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~(_BIT4 | _BIT0), (_BIT4 | _BIT0));
 530   1      
 531   1          // Set eDP mode
 532   1          ScalerSetBit(P38_89_PHY0_TXBIST_01_H2, ~(_BIT6 | _BIT5 | _BIT4), (_BIT6 | _BIT5));
 533   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_DISPLAYDPTX                                         04/23/2026 13:54:39 PAGE 10  

 534   1          // Enable Vby1 Phy power
 535   1          ScalerDisplayDPTxAnalogPhyConrol(_ENABLE);
 536   1      
 537   1          // Initial Z0 for DPTx
 538   1          ScalerDisplayDPTxSetZ0();
 539   1      
 540   1          // Lane Skew Setting for 8 Lane
 541   1          ScalerSetBit(P38_85_PHY0_TXBIST_00_H2, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), ((_DISPLAY_DP
             -_TX_SKEW_LANE0 << 3) | _DISPLAY_DP_TX_SKEW_LANE1));
 542   1          ScalerSetByte(P38_86_PHY0_TXBIST_00_H1, ((_DISPLAY_DP_TX_SKEW_LANE2 << 5) | (_DISPLAY_DP_TX_SKEW_LANE3
             - << 2) | (_DISPLAY_DP_TX_SKEW_LANE0 >> 1)));
 543   1          ScalerSetByte(P38_87_PHY0_TXBIST_00_L2, ((_DISPLAY_DP_TX_SKEW_LANE0 << 7) | (_DISPLAY_DP_TX_SKEW_LANE1
             - << 4) | (_DISPLAY_DP_TX_SKEW_LANE2 << 1) | (_DISPLAY_DP_TX_SKEW_LANE3 >> 2)));
 544   1          ScalerSetBit(P38_88_PHY0_TXBIST_00_L1, ~(_BIT7 | _BIT6), (_DISPLAY_DP_TX_SKEW_LANE3 << 6));
 545   1      
 546   1          // Waiting for PHY initial
 547   1          ScalerTimerDelayXms(10);
 548   1      }
