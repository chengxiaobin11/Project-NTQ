 550          //--------------------------------------------------
 551          // Description  : Dp Tx SSC Set
 552          // Input Value  :
 553          // Output Value :
 554          //--------------------------------------------------
 555          void ScalerDisplayDPTxSSCSet(bit bSscEn)
 556          {
 557   1          if(bSscEn == _ENABLE)
 558   1          {
 559   2              PDATA_WORD(0) = (WORD)((ScalerGetBit(P38_DC_DPTX_CMU12, 0x1F) << 4) | (ScalerGetByte(P38_DD_DPTX_C
             -MU13) >> 4));
 560   2              PDATA_WORD(1) = (WORD)((ScalerGetBit(P38_DD_DPTX_CMU13, 0x0F) << 8) | ScalerGetByte(P38_DE_DPTX_CM
             -U14));
 561   2      
 562   2              // Calculate SSC Frequency = 30~33k
 563   2              PDATA_WORD(3) = (((_EXT_XTAL / _DISPLAY_DP_TX_SSC_FREQ) + 2) & 0xFFFC);
 564   2      
 565   2              // Calculate SSC downspread
 566   2              PDATA_WORD(2) = ((((DWORD)PDATA_WORD(0) + 4) * 4096 + PDATA_WORD(1))) * 16 / 200 / PDATA_WORD(3) /
             - 15 * _PANEL_DPTX_SPREAD_RANGE;
 567   2      
 568   2              // Set SSC Frequency = 30~33k
 569   2              ScalerSetByte(P38_E0_DPTX_CMU16, (BYTE)(PDATA_WORD(3) >> 8));
 570   2              ScalerSetByte(P38_E1_DPTX_CMU17, (BYTE)PDATA_WORD(3));
 571   2      
 572   2              // Set SSC downspread
 573   2              ScalerSetByte(P38_E2_DPTX_CMU18, (BYTE)(PDATA_WORD(2) >> 8));
 574   2              ScalerSetByte(P38_E3_DPTX_CMU19, (BYTE)PDATA_WORD(2));
 575   2      
 576   2              // [5] 1: Enable SSC, 0: disable
 577   2              // [4] 0: 1st Order SDM, 1:2nd Order SDM
 578   2              // [3] 0: Triangular wave, 1: Square wave
 579   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~(_BIT5 | _BIT4 | _BIT3), _BIT5);
 580   2          }
 581   1          else
 582   1          {
 583   2              // Disable SSC
 584   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT5, 0x00);
 585   2          }
 586   1      }
