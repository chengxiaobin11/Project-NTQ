  69          // Description  : Enable/Disable double buffer
  70          // Input Value  : bEn --> _ENABLE or _DISABLE
  71          // Output Value : None
  72          //--------------------------------------------------
  73          void ScalerGlobalDoubleBufferEnable(bit bEn)
  74          {
  75   1          ScalerVgipDoubleBufferEnable(_DISABLE);
  76   1          ScalerMDomainDisplayTimingGenDBEnable(_DISABLE);
  77   1      
  78   1          if(bEn == _ENABLE)
  79   1          {
  80   2              // IMD Double Buffer Enable
  81   2              ScalerSetBit(P31_C0_I_DB_CTRL, ~(_BIT7 | _BIT6), _BIT7);
  82   2      
  83   2              // I Domain Double Buffer Disable
  84   2              ScalerSetBit(P31_A0_I_DB_CTRL0, ~(_BIT7 | _BIT3 | _BIT2), 0x00);
  85   2      
  86   2      #if(_LOCAL_DIMMING_SUPPORT == _OFF)
  87   2              // D Domain Double Buffer Disable
  88   2              ScalerSetBit(P31_B0_D_DB_CTRL0, ~(_BIT7 | _BIT6), 0x00);
  89   2      #endif
  90   2          }
  91   1          else
  92   1          {
  93   2              ScalerSetBit(P31_C0_I_DB_CTRL, ~(_BIT7 | _BIT6), 0x00);
  94   2          }
  95   1      }
