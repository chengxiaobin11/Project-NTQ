  48          bit ScalerIDomainCheckDigitalCapture(void)
  49          {
  50   1      #if(_PIXEL_SHIFT_SUPPORT == _ON)
              
              #if(_FREESYNC_SUPPORT == _ON)
                  if(GET_FREESYNC_ENABLED() == _TRUE)
                  {
                      return _TRUE;
                  }
              #endif
              
                  return _FALSE;
              
              #else
  62   1      
  63   1          return _TRUE;
  64   1      
  65   1      #endif
  66   1      }


