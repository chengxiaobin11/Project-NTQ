              //--------------------------------------------------
C51 COMPILER V9.60.0.0   RL6449_SERIES_MEMORY                                              04/23/2026 13:54:49 PAGE 8   

              // Description  : Set Shift One Line ON/OFF for Free Sync
              // Input Value  :
              // Output Value :
              //--------------------------------------------------
              void ScalerMemorySetShiftOneLine(bit bEnable)
              {
                  if(bEnable == _ENABLE)
                  {
                      // Get FIFO Size
                      WORD usFifoWidth = ScalerMemoryGetFifoWidth();
              
                      // Set Rotation Pixel Number
                      ScalerSetByte(P20_F1_ROTATION_IN_WID_H, HIBYTE(usFifoWidth));
                      ScalerSetByte(P20_F2_ROTATION_IN_WID_L, LOBYTE(usFifoWidth));
              
                      // Enable Function On The Porch
                      ScalerTimerWaitForEvent(_EVENT_IEN_STOP);
              
                      // Enable Rotate Shift One Line
                      ScalerSetBit(P20_F0_ROTATION_CTRL0, ~_BIT1, _BIT1);
              
                      if(GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER)
                      {
                          // Set IVS Reset M-Domain FIFO
                          ScalerSetBit(P5_AE_DISP_M1_DISP_CTRL2, ~_BIT4, _BIT4);
                      }
                      else
                      {
                          // Set DVS Reset M-Domain FIFO
                          ScalerSetBit(P5_AE_DISP_M1_DISP_CTRL2, ~_BIT4, 0x00);
                      }
              
                      if(ScalerGetBit(P20_F0_ROTATION_CTRL0, _BIT1) == _BIT1)
                      {
                          g_stMDomainInputData.usVStart = 1;
                      }
              
                      // Check if SD DRR should be enabled
                      if(ScalerGetBit(P0_23_SCALE_DOWN_CTRL_M1, _BIT0) == _BIT0)
                      {
                          ScalerSetBit(P0_26_SD_FILTER_CONTROL_REG_M1, ~_BIT1, _BIT1);
                          ScalerSetBit(P40_26_SD_FILTER_CONTROL_REG_M2, ~_BIT1, _BIT1);
                      }
                      else
                      {
                          ScalerSetBit(P0_26_SD_FILTER_CONTROL_REG_M1, ~_BIT1, 0x00);
                          ScalerSetBit(P40_26_SD_FILTER_CONTROL_REG_M2, ~_BIT1, 0x00);
                      }
                  }
                  else
                  {
                      // Disable Rotate Shift One Line
                      ScalerSetBit(P20_F0_ROTATION_CTRL0, ~_BIT1, 0x00);
              
                      // Set DVS Reset M-Domain FIFO
                      ScalerSetBit(P5_AE_DISP_M1_DISP_CTRL2, ~_BIT4, 0x00);
              
                      // Disable SD DRR
                      ScalerSetBit(P0_26_SD_FILTER_CONTROL_REG_M1, ~_BIT1, 0x00);
                      ScalerSetBit(P40_26_SD_FILTER_CONTROL_REG_M2, ~_BIT1, 0x00);
                  }
              }
