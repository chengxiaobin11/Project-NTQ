 378          //                usVerSize --> Vertical size
 379          // Output Value : Line Step and Block Step
 380          //--------------------------------------------------
 381          void ScalerMemoryCalculateLineStepAndBlockStep(DWORD ulHorSize, WORD usVerSize, StructMemoryLineBlockStep 
             -*pstStep)
 382          {
 383   1          pstStep->ulLineStep = ScalerMemoryAddressConversion(ulHorSize);
 384   1          pstStep->ulBlockStep = ScalerMemoryAddressConversion((DWORD)usVerSize * ulHorSize);
 385   1      }
 386          #endif
