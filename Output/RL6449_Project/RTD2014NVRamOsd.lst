1104          
1105          //--------------------------------------------------
1106          // Description  : Get the free page number of flash
1107          // Input Value  : None
1108          // Output Value : Free page index
1109          //--------------------------------------------------
1110          BYTE RTDFlashGetFreePage(void)
1111          {
1112   1          BYTE ucPageID = _START_OF_PAGEID;
1113   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1114   1      
1115   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1116   1          if(g_ulFlashMoveCount > 0)
1117   1          {
1118   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1119   2              {
1120   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1121   3              }
1122   2              else
1123   2              {
1124   3                  ucFreePage = g_ucFlashLastPage + 1;
1125   3              }
1126   2          }
1127   1      
1128   1          // Check the supposed free page is actual free page which has not been used ever
1129   1          do
1130   1          {
1131   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1132   2              {
1133   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1134   3                  {
1135   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1136   4                  }
1137   3                  else
1138   3                  {
1139   4                      ucFreePage += 1;
1140   4                  }
1141   3      
1142   3                  ucPageID = _START_OF_PAGEID;
1143   3              }
1144   2              else
1145   2              {
1146   3                  ucPageID++;
1147   3              }
1148   2          }
1149   1          while(ucPageID <= _END_OF_PAGEID);
1150   1      
C51 COMPILER V9.60.0.0   RTD2014NVRAMOSD                                                   04/23/2026 13:55:17 PAGE 20  

1151   1          return ucFreePage;
1152   1      }
1153          
1154          //--------------------------------------------------
1155          // Description  : Check the page is vaild or not
1156          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1157          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1158          //--------------------------------------------------
1159          bit RTDFlashIsPageInfoValid(BYTE ucPage)
1160          {
1161   1          WORD usPageInfoAddr = ucPage * _FLASH_PAGE_SIZE;
