                     (GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270))
                  {
                      ucTmp = 0x4E;  // 18 Pixel
                  }
                  else
              #endif
2151   1          {
2152   2              ucTmp = 0x4C;  // 12 Pixel
2153   2          }
2154   1      
2155   1          ScalerOsdCharCommandAllByteSeries(g_usFontSelectStart, ucTmp, 0, ucColor, (WORD)ucWidth * ucHeight);
2156   1      
2157   1          g_ucOsdWidth = ucWidth; // for calculation (unit: word count)
2158   1          g_ucOsdHeight = ucHeight;
2159   1          SET_OSD_MAPA_COL_MAX(WIDTH(g_ucOsdWidth));
