2128   1          
2129   1          for(ucI = 0; ucI < ucHeight; ucI++)
2130   1          {
2131   2              ScalerOsdCommandAllByte(ucI, 0x80, ucTmp, ucWidth);
2132   2          }
2133   1          
2134   1          // Row Command end
2135   1          ScalerOsdCommandByte(ucHeight, _OSD_BYTE0, 0x00);
