                  usPixelClkLBound -= PDATA_WORD(0);
              
                  for(ucIndex = 0; ucIndex < (sizeof(tDrrFreeSyncHdmiTimingInfo) / sizeof(tDrrFreeSyncHdmiTimingInfo[0])
             -); ucIndex++)
                  {
                      if((GET_HDMI_FREESYNC_IHWIDTH(ucIndex) == GET_INPUT_TIMING_HWIDTH()) && (GET_HDMI_FREESYNC_IVHEIGH
             -T(ucIndex) == GET_INPUT_TIMING_VHEIGHT()) &&
                         ((GET_HDMI_FREESYNC_IHTOTAL(ucIndex) <= usRefHtotalHBound) && (GET_HDMI_FREESYNC_IHTOTAL(ucInde
             -x) >= usRefHtotalLBound)) &&
                         ((GET_HDMI_FREESYNC_ICLK(ucIndex) <= usPixelClkHBound) && (GET_HDMI_FREESYNC_ICLK(ucIndex) >= u
             -sPixelClkLBound)))
                      {
                          *pusVfreqMax = GET_HDMI_FREESYNC_IVFREQ(ucIndex);
              
                          DebugMessageScaler("ucIndex if Drr user define timing ", ucIndex);
                          return _HDMI_FREESYNC_WITH_IVF_MAX;
                      }
                  }
              
                  *pusVfreqMax = 0;
                  return _HDMI_FREESYNC_WITHOUT_IVF_MAX;
              }
