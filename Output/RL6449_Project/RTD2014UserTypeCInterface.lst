                              default:
                              case _TYPE_C_U3_OFF:
              
                                  // Decide Sink Pin Config Type Capability is _TYPE_C_PIN_ASSIGNMENT_CAP_CE
                                  return _TYPE_C_PIN_ASSIGNMENT_CAP_CE;
                          }
              #endif
              
              #if(_D6_DP_TYPE_C_CONNECTOR_SUPPORT == _ON)
