             -1 & 0x03) << 8)) * 10;
                  SET_OSDINFO_TYPEC_CURRENT(usTemp);
              
                  usTemp = ((((g_unSMBusRdDataPool.stRdGetPDOStatus.ucByte1 & 0xFC) >> 2)+ ((g_unSMBusRdDataPool.stRdGet
             -PDOStatus.ucByte2 & 0xFF) << 6)) * 50);
                  SET_OSDINFO_TYPEC_VOLTAGE(usTemp);
                  */
              
                  return _TRUE;
              }
              #endif
              
