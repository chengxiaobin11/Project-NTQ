A51 MACRO ASSEMBLER  STARTUP                                                              04/23/2026 13:53:41 PAGE   175

                   11475     ;
                   11476     ;------------------------------------------------------------------------------
                   11477     ;
                   11478     ;  User-defined Power-On Initialization of Memory
                   11479     ;
                   11480     ;  With the following EQU statements the initialization of memory
                   11481     ;  at processor reset can be defined:
                   11482     ;
                   11483     ;               ; the absolute start-address of IDATA memory is always 0
  0100             11484     IDATALEN        EQU     0100H     ; the length of IDATA memory in bytes.
                   11485     ;
                   11486     ; the absolute start-address of XDATA memory
  D700             11487     XDATASTART      EQU     (0xD700)
                   11488     ; the length of XDATA memory in bytes.
  2000             11489     XDATALEN        EQU     ((0xF6FF) - (0xD700) + 1)
                   11490     ;
  0000             11491     PDATASTART      EQU     0H      ; the absolute start-address of PDATA memory
  0000             11492     PDATALEN        EQU     0H      ; the length of PDATA memory in bytes.
                   11493     ;
                   11494     ;  Notes:  The IDATA space overlaps physically the DATA and BIT areas of the
                   11495     ;          8051 CPU. At minimum the memory space occupied from the C51
                   11496     ;          run-time routines must be set to zero.
                   11497     ;------------------------------------------------------------------------------
                   11498     ;
                   11499     ;  Reentrant Stack Initilization
                   11500     ;
                   11501     ;  The following EQU statements define the stack pointer for reentrant
                   11502     ;  functions and initialized it:
                   11503     ;
                   11504     ;  Stack Space for reentrant functions in the SMALL model.
  0000             11505     IBPSTACK        EQU     0       ; set to 1 if small reentrant is used.
  0100             11506     IBPSTACKTOP     EQU     0FFH+1  ; set top of stack to highest location+1.
                   11507     ;
                   11508     ;  Stack Space for reentrant functions in the LARGE model.
  0000             11509     XBPSTACK        EQU     0       ; set to 1 if large reentrant is used.
  0000             11510     XBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11511     ;
                   11512     ;  Stack Space for reentrant functions in the COMPACT model.
  0000             11513     PBPSTACK        EQU     0       ; set to 1 if compact reentrant is used.
  0000             11514     PBPSTACKTOP     EQU     0FFFFH+1; set top of stack to highest location+1.
                   11515     ;
                   11516     ;------------------------------------------------------------------------------
                   11517     ;
                   11518     ;  Page Definition for Using the Compact Model with 64 KByte xdata RAM
                   11519     ;
                   11520     ;  The following EQU statements define the xdata page used for pdata
                   11521     ;  variables. The EQU PPAGE must conform with the PPAGE control used
                   11522     ;  in the linker invocation.
                   11523     ;
  0000             11524     PPAGEENABLE     EQU     0       ; set to 1 if pdata object are used.
                   11525     ;
  0000             11526     PPAGE           EQU     0       ; define PPAGE number.
                   11527     ;
  00A0             11528     PPAGE_SFR       DATA    0A0H    ; SFR that supplies uppermost address byte
                   11529     ;               (most 8051 variants use P2 as uppermost address byte)
                   11530     ;
                   11531     ;------------------------------------------------------------------------------
                   11532     
                   11533     ; Standard SFR Symbols
  00E0             11534     ACC     DATA    0E0H
  00F0             11535     B       DATA    0F0H
  0081             11536     SP      DATA    81H
  0082             11537     DPL     DATA    82H
  0083             11538     DPH     DATA    83H
