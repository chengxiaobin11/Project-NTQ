                   11465     ;  STARTUP.A51:  This code is executed after processor reset.
                   11466     ;
                   11467     ;  To translate this file use A51 with the following invocation:
                   11468     ;
                   11469     ;     A51 STARTUP.A51
                   11470     ;
                   11471     ;  To link the modified STARTUP.OBJ file to your application use the following
                   11472     ;  BL51 invocation:
