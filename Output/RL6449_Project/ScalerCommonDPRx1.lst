                  SET_DP_RX1_MEASURE_POP_UP_MST2SST();
              
                  // Get Measure Result
                  PDATA_DWORD(1) = 0;
                  ScalerRead(PA_58_MN_MEAS_CTRL, 3, &pData[5], _AUTOINC);
              
