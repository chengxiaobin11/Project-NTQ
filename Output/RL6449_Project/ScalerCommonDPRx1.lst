                  ScalerSetBit(PA_58_MN_MEAS_CTRL, ~_BIT7, 0x00);
                  ScalerSetBit(PA_58_MN_MEAS_CTRL, ~_BIT7, _BIT7);
              
                  if(ScalerTimerPollingFlagProc(_DP_MEASURE_POLLING_TIMEOUT, PA_58_MN_MEAS_CTRL, _BIT6, _TRUE) == _FALSE
             -)
