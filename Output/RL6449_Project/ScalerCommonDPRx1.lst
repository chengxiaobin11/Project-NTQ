 517          //--------------------------------------------------
 518          // Description : DP Signal Detection Measure
 519          // Input Value  : DP Lane Select, Measure target, Measure Period
 520          // Output Value : Measure Counter
 521          //--------------------------------------------------
 522          WORD ScalerDpRx1SignalDetectMeasureCount(BYTE ucDpLaneSel, EnumDpMeasureTarget enumDpMeasureTarget, EnumDp
             -MeasurePeriod enumDpMeasurePeriod)
 523          {
 524   1          WORD usDpMeasureCount = 0;
 525   1      
 526   1          // [1:0] freqdet_lane_sel
 527   1          ScalerSetBit(PB0_51_DP_SIG_DET_1, ~(_BIT1 | _BIT0), (ucDpLaneSel & (_BIT1 | _BIT0)));
 528   1      
 529   1          // [5] ln_ck_sel
 530   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT5, enumDpMeasureTarget);
 531   1      
 532   1          switch(enumDpMeasurePeriod)
 533   1          {
 534   2              case _DP_MEASURE_PERIOD_1000_CYCLE:
 535   2      
 536   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
 537   2                  // [4:0] DP_XTAL_CYCLE = 5'b00011
 538   2                  ScalerSetBit(PB0_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
C51 COMPILER V9.60.0.0   SCALERCOMMONDPRX1                                                 04/23/2026 13:54:19 PAGE 10  

 539   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b0
                          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT0, 0x00);
              #endif
 543   2                  break;
 544   2      
 545   2              case _DP_MEASURE_PERIOD_2000_CYCLE:
 546   2              default:
 547   2      
 548   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
 549   2                  // [4:0] DP_XTAL_CYCLE = 5'b00100
 550   2                  ScalerSetBit(PB0_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 551   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b1
                          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT0, _BIT0);
              #endif
 555   2                  break;
 556   2          }
 557   1      
 558   1          // [6] LANE_COUNT_CLEAR = 0 -> Keep the LANE_COUNT value
 559   1          ScalerSetBit(PB0_52_DP_SIG_DET_2, ~_BIT6, 0x00);
 560   1      
 561   1          // [7] DP_SIG_DET_EN = 1'b1 -> Enable Signal Detection
 562   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 563   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, _BIT7);
 564   1      
 565   1          // Delay Time us [5,150] Polling for Measure Done
 566   1          for(pData[0] = 0; pData[0] <= 30; pData[0]++)
 567   1          {
 568   2              DELAY_5US();
 569   2      
 570   2              if(ScalerGetBit(PB0_50_DP_SIG_DET_0, _BIT6) == _BIT6)
 571   2              {
 572   3                  usDpMeasureCount = ((((WORD)ScalerGetByte(PB0_53_DP_SIG_DET_3)) << 8) | ScalerGetByte(PB0_54_D
             -P_SIG_DET_4));
 573   3      
 574   3                  break;
 575   3              }
 576   2          }
 577   1      
 578   1          // [7] DP_SIG_DET_EN = 0 -> Disable Signal Detection
 579   1          ScalerSetBit(PB0_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 580   1      
 581   1          return usDpMeasureCount;
 582   1      }
