 404          //--------------------------------------------------
 405          // Description : DP Link Rate Detect
 406          // Input Value  : None
 407          // Output Value : Link Rate
 408          //--------------------------------------------------
 409          BYTE ScalerDpRx1LinkRateDetect(void)
 410          {
 411   1          BYTE ucDpLinkRate = 0;
 412   1          BYTE ucDpLinkRateDecide = _DP_LINK_NONE;
 413   1      
 414   1          do
 415   1          {
 416   2              if(ucDpLinkRate == 0)
C51 COMPILER V9.60.0.0   SCALERCOMMONDPRX1                                                 04/23/2026 13:54:19 PAGE 8   

 417   2              {
 418   3                  if(_HW_DP_D1_MAX_LINK_RATE_SUPPORT > ScalerDpRx1GetDpcdInfo(0x00, 0x00, 0x01))
 419   3                  {
 420   4                      ucDpLinkRate = _HW_DP_D1_MAX_LINK_RATE_SUPPORT;
 421   4                  }
 422   3                  else
 423   3                  {
 424   4                      ucDpLinkRate = ScalerDpRx1GetDpcdInfo(0x00, 0x00, 0x01);
 425   4                  }
 426   3              }
 427   2              else if(ucDpLinkRate == _DP_LINK_HBR3)
 428   2              {
 429   3                  ucDpLinkRate = _DP_LINK_HBR2;
 430   3              }
 431   2              else if(ucDpLinkRate == _DP_LINK_HBR2)
 432   2              {
 433   3                  ucDpLinkRate = _DP_LINK_HBR;
 434   3              }
 435   2              else if(ucDpLinkRate == _DP_LINK_HBR)
 436   2              {
 437   3                  ucDpLinkRate = _DP_LINK_RBR;
 438   3              }
 439   2      
 440   2              if(ScalerDpRx1LinkRateCheck(ucDpLinkRate) == _TRUE)
 441   2              {
 442   3                  ucDpLinkRateDecide = ucDpLinkRate;
 443   3      
 444   3                  break;
 445   3              }
 446   2          }
 447   1          while(ucDpLinkRate != _DP_LINK_RBR);
 448   1      
 449   1          return ucDpLinkRateDecide;
 450   1      }
