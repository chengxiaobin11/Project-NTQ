                  DebugMessageRx1("MST ####Calculated usVTotal####", usTempVTotal);
              
                  DebugMessageRx1("7.MST DelayTime", (((ulVBs2bsLengN & 0x000FFFFF) / (_GDI_CLK_KHZ)) + 2));
                  DebugMessageRx1("7.MST Frame[N] VBS2BS Counter", ulVBs2bsLengN);
