              bit ScalerHdcp2RepeaterHmacSha256Calculate(BYTE *pucInputArray1, BYTE *pucInputArray2, BYTE ucInputArray1B
             -lockNumber)
              {
                  BYTE ucTemp = 0;
                  BYTE pucSHA256Input[64] = {0};
              
                  for(pData[0] = 0; pData[0] < 64; pData[0]++)
                  {
                      // K0 XOR ipad = 512 bit
                      *(pucInputArray2 + pData[0]) = *(pucInputArray2 + pData[0]) ^ 0x36;
