                  memcpy(&pucHMACSHA256CipherInput[16], pucHdcp2dKey1, 16);
                  memset(&pucHMACSHA256CipherInput[32], 0, 32);
              
                  pData[0] = ((*pucRxinfo & _BIT0) << 4 | (*(pucRxinfo + 1) >> 4)) * 5;
