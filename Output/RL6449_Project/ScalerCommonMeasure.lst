  48          //--------------------------------------------------
  49          // Description  : Initial H Boundary for Auto Function Measure
  50          // Input Value  : H Boundary Start/End
  51          // Output Value : None
  52          //--------------------------------------------------
  53          void ScalerMeasureAutoFuncHBoundInitial(WORD usHBoundStart, WORD usHBoundEnd)
  54          {
  55   1          // Set H boundary
  56   1          ScalerSetByte(P0_70_H_BOUNDARY_H, (((HIBYTE(usHBoundStart) & 0x0F) << 4) | (HIBYTE(usHBoundEnd) & 0x0F
             -)));
  57   1          ScalerSetByte(P0_71_H_BOUNDARY_STA_L, LOBYTE(usHBoundStart));
  58   1          ScalerSetByte(P0_72_H_BOUNDARY_END_L, LOBYTE(usHBoundEnd));
  59   1      
  60   1          ScalerSetBit(P0_77_GRN_NOISE_MARGIN, ~_BIT1, ((HIBYTE(usHBoundStart) >> 3) & _BIT1));
  61   1          ScalerSetBit(P0_77_GRN_NOISE_MARGIN, ~_BIT0, ((HIBYTE(usHBoundEnd) >> 4) & _BIT0));
  62   1      }
  63          #endif // End of #if(_DIGITAL_PORT_SUPPORT == _ON)
