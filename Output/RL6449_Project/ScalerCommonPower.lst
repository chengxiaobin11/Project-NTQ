  40          void ScalerPowerXtalPower(BYTE ucOn);
  41          
  42          
  43          //****************************************************************************
  44          // FUNCTION DEFINITIONS
  45          //****************************************************************************
  46          //--------------------------------------------------
  47          // Description  : Xtal Power Control.
C51 COMPILER V9.60.0.0   SCALERCOMMONPOWER                                                 04/23/2026 13:54:27 PAGE 2   

  48          // Input Value  : ucOn    --> On/Off Select.
  49          // Output Value : None
  50          //--------------------------------------------------
  51          void ScalerPowerXtalPower(BYTE ucOn)
  52          {
  53   1          if(ucOn == _ON)
  54   1          {
  55   2              // Xtal has power down
  56   2              if(ScalerGetBit(P80_0E_XTAL_CTRL0, _BIT7) == 0x00)
  57   2              {
  58   3                  // Bit4~3 : 00 --> XI/XO Pad Driving to Strong
  59   3                  ScalerSetBit(P80_0F_XTAL_CTRL1, ~(_BIT4 | _BIT3), 0x00);
  60   3      
  61   3                  // Power On External Xtal
  62   3                  ScalerSetBit(P80_0E_XTAL_CTRL0, ~_BIT7, _BIT7);
  63   3      
  64   3                  // Waiting for xtal stable.
  65   3                  ScalerTimerDelayXms(6);
  66   3              }
  67   2      
  68   2              // Bit4~3 : 00 --> XI/XO Pad Driving to weak
  69   2              ScalerSetBit(P80_0F_XTAL_CTRL1, ~(_BIT4 | _BIT3), (_BIT4 | _BIT3));
  70   2          }
  71   1          else
  72   1          {
  73   2              // Power down External Xtal
  74   2              ScalerSetBit(P80_0E_XTAL_CTRL0, ~_BIT7, 0x00);
  75   2      
  76   2              // Bit4~3 : 00 --> XI/XO Pad Driving to weak
  77   2              ScalerSetBit(P80_0F_XTAL_CTRL1, ~(_BIT4 | _BIT3), (_BIT4 | _BIT3));
  78   2          }
  79   1      }
  80          


