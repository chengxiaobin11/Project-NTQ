 102          //--------------------------------------------------
 103          void ScalerDDomainPatternGenAdjustColor10bit(WORD usRed, WORD usGreen, WORD usBlue) // 10bit
 104          {
 105   1          ScalerSetByte(P7_F3_DISP_PG_R_INITIAL, (usRed >> 2));
 106   1          ScalerSetByte(P7_F4_DISP_PG_G_INITIAL, (usGreen >> 2));
 107   1          ScalerSetByte(P7_F5_DISP_PG_B_INITIAL, (usBlue >> 2));
 108   1          ScalerSetByte(P7_FC_D_PG_INITIAL_M_STEP_L, ((usRed & 0x03) << 4) | ((usGreen & 0x03) << 2) | (usBlue &
             - 0x03));
