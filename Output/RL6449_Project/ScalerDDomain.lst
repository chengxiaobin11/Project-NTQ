  64          //--------------------------------------------------
  65          // Description  : Display Pattern Gen Enable
  66          // Input Value  : _ENABLE or _DISABLE
  67          // Output Value : None
  68          //--------------------------------------------------
  69          void ScalerDDomainPatternGenEnable(bit bEnable)
  70          {
  71   1          if(bEnable == _ENABLE)
  72   1          {
  73   2              // Enable D Domain PG
  74   2              ScalerSetBit(P7_F0_DISP_PG_R_CTRL, ~_BIT7, _BIT7);
  75   2          }
  76   1          else
  77   1          {
  78   2              // Disable D Domain PG
  79   2              ScalerSetBit(P7_F0_DISP_PG_R_CTRL, ~_BIT7, 0x00);
  80   2          }
  81   1      }
  82          
  83          //--------------------------------------------------
  84          // Description  : Set Display Pattern Gen Color
  85          // Input Value  : RGB Color
  86          // Output Value : None
  87          //--------------------------------------------------
  88          void ScalerDDomainPatternGenAdjustColor(BYTE ucRed, BYTE ucGreen, BYTE ucBlue)
  89          {
  90   1          ScalerSetByte(P7_F3_DISP_PG_R_INITIAL, ucRed);
  91   1          ScalerSetByte(P7_F4_DISP_PG_G_INITIAL, ucGreen);
  92   1          ScalerSetByte(P7_F5_DISP_PG_B_INITIAL, ucBlue);
  93   1          ScalerSetBit(P7_FC_D_PG_INITIAL_M_STEP_L, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
  94   1      }
  95          
  96          #if(_OGC_GEN_TYPE == _OGC_GEN_1)
  97          #if((_OGC_SUPPORT == _ON) || (_OCC_SUPPORT == _ON) || (_OGC_DICOM_SUPPORT == _ON))
  98          //--------------------------------------------------
