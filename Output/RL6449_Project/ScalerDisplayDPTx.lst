 313          void ScalerDisplayDPTx1Initial(void)
 314          {
 315   1          ScalerDisplayDPTx1AuxInitial();
 316   1      
 317   1          ScalerDisplayDPTx1HpdInitial();
 318   1      
 319   1          // Enable DPTX1 Small FIFO ouput 10bits data for each lane of Analog PHY driver ciruit.
 320   1          ScalerSetBit(P9C_10_DPTX_SFIFO_CTRL0, ~_BIT7, _BIT7);
 321   1      
 322   1          // Enable Arbiter Stuffing and Framing
 323   1          ScalerSetBit(P9C_C9_ARBITER_CTRL, ~_BIT0, _BIT0);
 324   1      
 325   1          SET_DISPLAY_DP_TX1_INPUT_COLOR_DEPTH(_PANEL_DISP_BIT_MODE);
 326   1          SET_DISPLAY_DP_TX1_INPUT_COLOR_SPACE(_COLOR_SPACE_RGB);
 327   1      
 328   1      #if(_PANEL_DPTX_HPD_DETECT == _ON)
                  SET_DISPLAY_DP_TX1_STREAM_OUTPUT(_DISABLE);
                  CLR_DISPLAY_DP_TX1_FORCE_TO_LT();
              #endif
 332   1      }
