                  SET_DISPLAY_DP_TX2_LANE0_CURRENT_PRE_EMPHASIS(_DISPLAY_DP_TX_LEVEL_0);
                  CLR_DISPLAY_DP_TX2_LANE0_CURRENT_PRE_EMPHASIS_MAX_REACH();
              
