                                  }
                                  else
                                  {
                                      // Disable Timeout Retry
                                      ScalerSetBit(P9F_B0_AUX_RETRY_2, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), 0x00);
              
                                      // CLR Flag
                                      ScalerSetByte(P9F_B1_AUX_IRQ_EVENT, 0x3F);
              
                                      // Reset AUX FIFO
