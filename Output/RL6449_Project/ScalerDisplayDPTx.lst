 339          bit ScalerDisplayDPTx1LinkConfig(void)
 340          {
 341   1          SET_DISPLAY_DP_TX1_LT_RESULT(_DISPLAY_DP_TX_TRAINING_NO_RESULT);
 342   1          SET_DISPLAY_DP_TX1_LT_STATE(_DISPLAY_DP_TX_TRAINING_PATTERN1);
 343   1      
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 7   

 344   1          // Set Power Normal
 345   1          pData[0] = 0x01;
 346   1          if(ScalerDisplayDPTx1NativeAuxWrite(0x00, 0x06, 0x00, 1, pData) == _FALSE)
 347   1          {
 348   2              return _FALSE;
 349   2          }
 350   1      
 351   1          ScalerTimerDelayXms(10);
 352   1      
 353   1          // Read Sink Power Status
 354   1          if(ScalerDisplayDPTx1NativeAuxRead(0x00, 0x06, 0x00, 1, pData) == _FALSE)
 355   1          {
 356   2              return _FALSE;
 357   2          }
 358   1      
 359   1          // Check if Power State is Normal
 360   1          if(pData[0] != 0x01)
 361   1          {
 362   2              return _FALSE;
 363   2          }
 364   1      
 365   1          // Read Sink Cabability
 366   1          if(ScalerDisplayDPTx1NativeAuxRead(0x00, 0x00, 0x00, 16, pData) == _FALSE)
 367   1          {
 368   2              return _FALSE;
 369   2          }
 370   1      
 371   1          if(_PANEL_DPTX_LINK_RATE >= _PANEL_DPTX_LINK_HBR2)
 372   1          {
 373   2              // Check TP3 support
 374   2              if((_PANEL_DPTX_LT_TPS3_SUPPORT_BY_USER == _ON) && ((pData[2] & _BIT6) == _BIT6))
 375   2              {
 376   3                  SET_DISPLAY_DP_TX1_TP3_SUPPORT();
 377   3              }
 378   2              else
 379   2              {
 380   3                  CLR_DISPLAY_DP_TX1_TP3_SUPPORT();
 381   3              }
 382   2          }
 383   1          else
 384   1          {
 385   2              CLR_DISPLAY_DP_TX1_TP3_SUPPORT();
 386   2          }
 387   1      
 388   1          // Set Link Rate
 389   1          SET_DISPLAY_DP_TX1_MAX_LINK_RATE(_PANEL_DPTX_LINK_RATE);
 390   1      
 391   1          // Set Lane Number
 392   1          if(_PANEL_DPTX_LANE_NUMBER >= _PANEL_DPTX_LANE_NUMBER_4)
 393   1          {
 394   2              SET_DISPLAY_DP_TX1_LANE_NUM(_DP_FOUR_LANE);
 395   2          }
 396   1          else if(_PANEL_DPTX_LANE_NUMBER == _PANEL_DPTX_LANE_NUMBER_2)
 397   1          {
 398   2              SET_DISPLAY_DP_TX1_LANE_NUM(_DP_TWO_LANE);
 399   2          }
 400   1          else
 401   1          {
 402   2              SET_DISPLAY_DP_TX1_LANE_NUM(_DP_ONE_LANE);
 403   2          }
 404   1      
 405   1          // Set Enhanceed Framing
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 8   

 406   1          SET_DISPLAY_DP_TX1_ENHANCE_FRAMING((bit)(pData[2] & _BIT7));
 407   1      
 408   1          // Set Max Downspread
 409   1          SET_DISPLAY_DP_TX1_DOWN_SPREAD((bit)(pData[3] & _BIT0));
 410   1      
 411   1          // Set Framing Change for eDP
 412   1          SET_DISPLAY_DP_TX1_FRAMING_CHANGE_CAPABLE((bit)(pData[13] & _BIT1));
