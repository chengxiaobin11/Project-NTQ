                  ScalerRead(P0_2B_DISPLAY_FORMAT_DATA_PORT, 2, &pData[6], _NON_AUTOINC);
              
                  // Vtotal
                  g_stDisplayDPTx2TimingInfo.usVTotal = ((PDATA_WORD(0) + 1) & 0x1FFF);
              
