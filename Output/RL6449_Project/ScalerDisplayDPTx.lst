                  ScalerSetByte(P9F_A4_AUXTX_REQ_CMD, (ucCommand | ((ulAddr & 0xF0000) >> 16)));
                  ScalerSetByte(P9F_A5_AUXTX_REQ_ADDR_M, ((ulAddr & 0xFF00) >> 8));
                  ScalerSetByte(P9F_A6_AUXTX_REQ_ADDR_L, (ulAddr & 0xFF));
              
                  ucLength = ucLength - ucCheckLength;
              
                  if(ucLength == 0)
                  {
                      ucLength = 1;
                  }
                  else if(ucLength > 16)
                  {
                      ucLength = 16;
                  }
              
                  // Set Read Length : TX_LEN = ucLength-1
                  ScalerSetByte(P9F_A7_AUXTX_REQ_LEN, (ucLength - 1));
              
                  // Reset AUX Start Bit
                  ScalerSetBit(P9F_A3_AUXTX_TRAN_CTRL, ~_BIT0, 0x00);
              
                  // Enable Aux to Start Read
                  ScalerSetBit(P9F_A3_AUXTX_TRAN_CTRL, ~_BIT0, _BIT0);
              
                  do
                  {
                      // Delay Time us [400,x]
                      DELAY_XUS(400);
              
