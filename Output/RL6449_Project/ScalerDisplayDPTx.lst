              //--------------------------------------------------
              bit ScalerDisplayDPTxStableDetect(void)
              {
              #if(_DISPLAY_DP_TX_PORT_1 == _ON)
              #if(_PANEL_DPTX_SET_HPD_DETECT_SEQUENCE == _HPD_DETECT_AFTER_VIDEO_STREAM)
                  if(GET_DISPLAY_DP_TX1_STREAM_OUTPUT() != _ENABLE)
                  {
                      return _TRUE;
