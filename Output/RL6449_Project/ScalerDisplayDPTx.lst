              //--------------------------------------------------
              // Description  : Dp Tx2 INT Handle
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDisplayDPTx2IrqIntHandler_EXINT0(void) using 1
              {
                  // Short HPD IRQ
                  if((ScalerGetBit_EXINT(P9E_72_HPD_IRQ_EN, _BIT6) == _BIT6) &&
                     (ScalerGetBit_EXINT(P9E_71_HPD_IRQ, _BIT6) == _BIT6))
                  {
                      ScalerSetBit_EXINT(P9E_71_HPD_IRQ, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1), _BIT6
             -);
              
                      if(ScalerDisplayDPTx2NativeAuxRead_EXINT0(0x00, 0x02, 0x00, 6, pData_EXINT) == _TRUE)
                      {
                          // Link Status Change Irq
                          if(((GET_DISPLAY_DP_TX2_LANE_NUM() == 1) && ((pData_EXINT[2] & 0x07) != 0x07)) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() == 2) && ((pData_EXINT[2] & 0x77) != 0x77)) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() == 4) && (((pData_EXINT[2] & 0x77) != 0x77) || ((pData_EXIN
             -T[3] & 0x77) != 0x77))) ||
                             ((GET_DISPLAY_DP_TX2_LANE_NUM() != 1) && ((pData_EXINT[4] & 0x01) != 0x01)))
                          {
                              SET_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
                          }
              
                          // Downstream Port Status Change
                          if((pData_EXINT[4] & _BIT6) == _BIT6)
                          {
                              SET_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
                          }
                      }
                  }
              }
              #endif
              #endif
              
              //--------------------------------------------------
              // Description  : Dp Tx Aux PHY Set
              // Input Value  :
              // Output Value :
              //--------------------------------------------------
              void ScalerDisplayDPTx2AuxPHYSet(BYTE ucMode)
              {
                  if(ucMode == _DISPLAY_DP_TX_AUX_SINGLE_MODE)
                  {
              #if((_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_0_ADJR_0_LDO_3BIT) ||\
                  (_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_1_ADJR_1_LDO_3BIT))
                      // Set Aux Tx LDO
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT7 | _BIT6 | _BIT5), (_PANEL_DPTX_AUX_SWING_LEVEL << 5));
              
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 105 

              #elif(_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_2_ADJR_1_LDO_4BIT)
                      // Set Aux Tx LDO
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_PANEL_DPTX_AUX_SWING_LEVEL << 4));
              #endif
              
                      // Set ADJR P
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
              
                      // [5]Enable Single-Ended Mode, [4:3]Aux Vth-->50mV, [0]Aux 50ohm auto K(Enable Big_Z0_P)
                      ScalerSetBit(P9F_62_AUX_2, ~(_BIT5 | _BIT4 | _BIT3 | _BIT0), (_BIT5 | _BIT3 | _BIT0));
              
                      // Enable Enlarge Z0-N and Set ADJR-N = 0
                      ScalerSetBit(P9F_66_AUX_6, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT4);
              
                      // Set TX ADJR-P and ADJR-N
                      ScalerSetByte(P9F_67_DIG_TX_03, 0x00);
                  }
                  else
                  {
              #if((_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_0_ADJR_0_LDO_3BIT) ||\
                  (_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_1_ADJR_1_LDO_3BIT))
                      // Set Aux Tx LDO
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT7 | _BIT6 | _BIT5), (_PANEL_DPTX_AUX_SWING_LEVEL << 5));
              
              #elif(_HW_AUX_TALK_MODE_LDO_VOL_TYPE == _AUX_TALK_MODE_GEN_2_ADJR_1_LDO_4BIT)
                      // Set Aux Tx LDO
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_PANEL_DPTX_AUX_SWING_LEVEL << 4));
              #endif
              
                      // [5]Disable Single-Ended Mode, [4:3]Aux Vth-->50mV
                      ScalerSetBit(P9F_62_AUX_2, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
              
              #if(_PANEL_DPTX_AUX_RX_BIG_Z0_ENABLE == _ENABLE)
                      // Enable Big_Z0_P
                      ScalerSetBit(P9F_62_AUX_2, ~_BIT0, _BIT0);
              
                      // Set ADJR-P
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
              
                      // Enable Big_Z0_N and Set ADJR-N
                      ScalerSetBit(P9F_66_AUX_6, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | _BIT1 | _BIT0));
              #else
                      // Disable Big_Z0_P
                      ScalerSetBit(P9F_62_AUX_2, ~_BIT0, 0x00);
              
                      // Set ADJR-P
                      ScalerSetBit(P9F_61_AUX_1, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT3);
              
                      // Disable Big_Z0_N and Set ADJR-N
                      ScalerSetBit(P9F_66_AUX_6, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT3);
              #endif
              
                      // TX Z0 hand mode setting
                      ScalerSetByte(P9F_67_DIG_TX_03, 0x88);
                  }
              
                  // Aux comm current select max
                  ScalerSetBit(P9F_64_AUX_4, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              }
              
              //--------------------------------------------------
              // Description  : Set Analog Phy Mux for TPS3 Pattern
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 106 

              // Input Value  : None
              // Output Value : _ON or _OFF
              //--------------------------------------------------
              void ScalerDisplayDPTx2SetTps3PatternMux(bit bAphyMux)
              {
                  if(bAphyMux == _ON)
                  {
              #if(_PANEL_DPTX_LANE_SWAP == _ENABLE)
                      // Set TX2 DPHY to APHY mux from MAC1
                      ScalerSetByte(P38_81_DPTX_LANE_SWAP7_6, 0x01);
                      ScalerSetByte(P38_82_DPTX_LANE_SWAP5_4, 0x23);
              #else
                      // Set TX2 DPHY to APHY mux from MAC1
                      ScalerSetByte(P38_81_DPTX_LANE_SWAP7_6, 0x32);
                      ScalerSetByte(P38_82_DPTX_LANE_SWAP5_4, 0x10);
              #endif // End of #if(_PANEL_DPTX_LANE_SWAP ==  _ENABLE)
                  }
                  else
                  {
              #if(_PANEL_DPTX_LANE_SWAP == _ENABLE)
                      // Set TX2 DPHY to APHY mux from MAC1
                      ScalerSetByte(P38_81_DPTX_LANE_SWAP7_6, 0x45);
                      ScalerSetByte(P38_82_DPTX_LANE_SWAP5_4, 0x67);
              #else
                      // Set TX2 DPHY to APHY mux from MAC1
                      ScalerSetByte(P38_81_DPTX_LANE_SWAP7_6, 0x76);
                      ScalerSetByte(P38_82_DPTX_LANE_SWAP5_4, 0x54);
              #endif // End of #if(_PANEL_DPTX_LANE_SWAP ==  _ENABLE)
                  }
              }
              
              //--------------------------------------------------
              // Description  : Dp Tx Main Link Power on
              // Input Value  :
              // Output Value :
              //--------------------------------------------------
              void ScalerDisplayDPTx2SignalInitialSetting(void)
              {
              #if(_PANEL_DPTX_LANE_PN_SWAP == _ENABLE)
                  // Set Swap For Lane PN
                  ScalerSetBit(P38_80_DPTX_PN_SWAP1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT7 | _BIT6 | _BIT5 | _BIT4));
              #else
                  // Set No Swap For Lane PN
                  ScalerSetBit(P38_80_DPTX_PN_SWAP1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), 0x00);
              #endif
              
              #if(_PANEL_DPTX_LANE_SWAP == _ENABLE)
                  if(GET_DISPLAY_DP_TX2_LANE_NUM() == _DP_TWO_LANE)
                  {
                      // Set TX2 DPHY to APHY mux from MAC1 lane 4 5 --> 5 4
                      ScalerSetByte(P38_82_DPTX_LANE_SWAP5_4, 0x45);
                  }
                  else
                  {
