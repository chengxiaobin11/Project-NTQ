              #if(_DISPLAY_DP_TX_PORT_2 == _ON)
              #if(_PANEL_DPTX_SET_HPD_DETECT_SEQUENCE == _HPD_DETECT_AFTER_VIDEO_STREAM)
                  if(GET_DISPLAY_DP_TX2_STREAM_OUTPUT() != _ENABLE)
                  {
                      return _TRUE;
                  }
              #endif
              
                  if(ScalerDisplayDPTx2HpdDetect() == _TRUE)
                  {
                      return _FALSE;
                  }
