              //--------------------------------------------------
              // Description  : DP Tx Hpd Initial
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDisplayDPTx2HpdInitial(void)
              {
                  // Set HPD 0.5ms Timer to 0.25ms
                  ScalerSetBit(P9E_73_HPD_TIMER1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), _BIT4);
                  ScalerSetByte(P9E_74_HPD_TIMER2, 0xA5);
              
                  // Set HPD 1ms Timer to 2ms
                  ScalerSetBit(P9E_73_HPD_TIMER1, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT0));
                  ScalerSetByte(P9E_75_HPD_TIMER3, 0x2C);
              
                  // Set HPD 30ms Timer
                  ScalerSetByte(P9E_78_HPD_TIMER6, 0xC5);
                  ScalerSetByte(P9E_79_HPD_TIMER7, 0xBD);
              
                  // Enable HPD Detection
                  ScalerSetBit(P9E_70_HPD_CTRL, ~_BIT7, 0x00);
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 96  

                  ScalerSetBit(P9E_70_HPD_CTRL, ~_BIT7, _BIT7);
              
                  // Clear HPD IRQ Flag
                  ScalerSetByte(P9E_71_HPD_IRQ, 0xFE);
              
                  // Disable Short IRQ and Disable Long IRQ
                  ScalerSetByte(P9E_72_HPD_IRQ_EN, 0x00);
              
              #if(_PANEL_DPTX_HPD_DETECT == _ON)
              #if(_PANEL_DPTX_HPD_UNPLUG_TIME == _DPTX_HPD_TIME_2_MS)
                  // Set HPD 10ms Timer to 2ms
                  ScalerSetByte(P9E_78_HPD_TIMER6, 0x0D);
                  ScalerSetByte(P9E_79_HPD_TIMER7, 0x2C);
              #else
                  // Set HPD 10ms Timer to 30ms
                  ScalerSetByte(P9E_78_HPD_TIMER6, 0xC5);
                  ScalerSetByte(P9E_79_HPD_TIMER7, 0xBD);
              #endif
              #endif
              
              #if((_PANEL_DPTX_HPD_DETECT == _ON) && (_PANEL_DPTX_IRQ_HPD_DETECT == _ON))
                  // Enable IRQ HPD Int, Disable Long HPD Int
                  ScalerSetBit(P9E_72_HPD_IRQ_EN, ~(_BIT6 | _BIT5), _BIT6);
              
                  CLR_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
              #else
                  // Disable IRQ HPD Int and Long HPD Int
                  ScalerSetBit(P9E_72_HPD_IRQ_EN, ~(_BIT6 | _BIT5), 0x00);
              #endif
              }
              
              #if(_PANEL_DPTX_HPD_DETECT == _ON)
              //--------------------------------------------------
              // Description  : Display DP Tx HPD Detection
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              bit ScalerDisplayDPTx2HpdDetect(void)
              {
                  // Determine Current HPD Event Status
                  // Current HPD Level HIGH
                  if(GET_DISPLAY_DP_TX2_HPD_DEBOUNCE_LEVEL() == _HIGH)
                  {
                      // Long HPD
                      if(ScalerGetBit(P9E_71_HPD_IRQ, _BIT2) == _BIT2)
                      {
                          // Clr All flag
                          ScalerSetByte(P9E_71_HPD_IRQ, 0xFE);
              
                          SET_DISPLAY_DP_TX2_FORCE_TO_LT();
              
                          return _TRUE;
                      }
              
              #if(_PANEL_DPTX_IRQ_HPD_DETECT == _ON)
                      // IRQ HPD
                      if(GET_DISPLAY_DP_TX2_IRQ_HPD_DETECTED() == _TRUE)
                      {
                          CLR_DISPLAY_DP_TX2_IRQ_HPD_DETECTED();
              
                          SET_DISPLAY_DP_TX2_FORCE_TO_LT();
              
C51 COMPILER V9.60.0.0   SCALERDISPLAYDPTX                                                 04/23/2026 13:53:51 PAGE 97  

                          return _TRUE;
                      }
              #endif
                  }
              
                  return _FALSE;
              }
              
