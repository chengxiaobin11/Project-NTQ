 447          bit ScalerFRCCheckDoubleFrameBuffer(WORD usInputHWidth, WORD usInputVHeight)
 448          {
 449   1          WORD usDHF = ((DWORD)GET_D_CLK_FREQ() * 10 / g_stMDomainOutputData.usHTotal); // unit: 0.1ms
 450   1          WORD usPreReadLine = ScalerFRCCalculatePreReadLine(usInputVHeight);
 451   1      
 452   1          // Consider Double Frame Size
C51 COMPILER V9.60.0.0   SCALERFRC                                                         04/23/2026 13:53:55 PAGE 9   

 453   1          if(_MEMORY_ROW > ((DWORD)usInputHWidth * GET_MEMORY_DATA_BIT() / _MEMORY_BIT_NUM * usInputVHeight * 2 
             -/ _MEMORY_COL_PER_BANK / _MEMORY_BANK))
 454   1          {
 455   2              return _TRUE;
 456   2          }
 457   1          else
 458   1          {
 459   2              // the number that multiple by 10 or 100 below is to get the digit after decimal point
 460   2              PDATA_WORD(0) = (DWORD)(usPreReadLine + g_stMDomainOutputData.usVHeight) * 100 / usDHF;
 461   2              PDATA_WORD(1) = (DWORD)g_stMDomainInputData.usVHeight * 100 / g_stMDomainInputData.usHFreq;
 462   2      
 463   2              // get the ratio of ((dden/dhf) / (iden/ihf)) or ((iden/ihf) / (dden/dhf))
 464   2              if(PDATA_WORD(0) > PDATA_WORD(1))
 465   2              {
 466   3                  PDATA_WORD(0) = PDATA_WORD(0) * 10 / PDATA_WORD(1);
 467   3              }
 468   2              else
 469   2              {
 470   3                  PDATA_WORD(0) = PDATA_WORD(1) * 10 / PDATA_WORD(0);
 471   3              }
 472   2      
 473   2              // 11 & 18 are from experiment
 474   2              // >18 or <11 are not suitable for one frame frc, force to double frame
 475   2              if((PDATA_WORD(0) < 11) || (PDATA_WORD(0) > 18))
 476   2              {
 477   3                  return _TRUE;
 478   3              }
 479   2          }
 480   1      
 481   1          return _FALSE;
 482   1      }
