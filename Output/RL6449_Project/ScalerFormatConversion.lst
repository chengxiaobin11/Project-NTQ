 108          //--------------------------------------------------
 109          // Description  : Control half scaling down on/off
C51 COMPILER V9.60.0.0   SCALERFORMATCONVERSION                                            04/23/2026 13:53:55 PAGE 3   

 110          // Input Value  : _ENABLE or _DISABLE
 111          // Output Value : None
 112          //--------------------------------------------------
 113          void ScalerFmtCnvHalfSDControl(bit bEnable)
 114          {
 115   1          if(bEnable == _ENABLE)
 116   1          {
 117   2              // Enable 1/2 SD
 118   2              ScalerSetBit(P31_05_FC_SD_CTRL, ~_BIT7, 0x00);
 119   2              ScalerSetBit(P31_06_FC_EO_LINE_CTRL, ~_BIT7, 0x00);
 120   2          }
 121   1          else
 122   1          {
 123   2              // Disable 1/2 SD
 124   2              ScalerSetBit(P31_05_FC_SD_CTRL, ~_BIT7, _BIT7);
 125   2          }
 126   1      }
 127          
 128          //--------------------------------------------------
 129          // Description  : Half Scaling down status
 130          // Input Value  : None
 131          // Output Value : _TRUE or _FALSE
 132          //--------------------------------------------------
 133          bit ScalerFmtCnvHalfSDGetStatus(void)
 134          {
 135   1          return ((ScalerGetBit(P31_05_FC_SD_CTRL, _BIT7) == 0x00) && (ScalerGetBit(P31_06_FC_EO_LINE_CTRL, _BIT
             -7) == 0x00));
 136   1      }
 137          
 138          //--------------------------------------------------
 139          // Description  : Set the first pixel for half scaling down
 140          // Input Value  : usHstart --> H start
 141          // Output Value : None
 142          //--------------------------------------------------
 143          void ScalerFmtCnvHalfSDSetFirstPixel(WORD usHstart)
 144          {
 145   1          if((LOBYTE(usHstart) & _BIT0) == 0x00)
 146   1          {
 147   2              // Set first pixel = even
 148   2              ScalerSetBit(P31_05_FC_SD_CTRL, ~_BIT3, _BIT3);
 149   2          }
 150   1          else
 151   1          {
 152   2              // Set first pixel = odd
 153   2              ScalerSetBit(P31_05_FC_SD_CTRL, ~_BIT3, 0x00);
 154   2          }
 155   1      }
