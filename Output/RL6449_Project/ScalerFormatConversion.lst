  48          //--------------------------------------------------
  49          // Description  : EVEN/Odd status
  50          // Input Value  : None
  51          // Output Value : _TRUE or _FALSE
  52          //--------------------------------------------------
  53          bit ScalerFmtCnvFtoPGetStatus(void)
  54          {
  55   1          return (ScalerGetBit(P31_06_FC_EO_LINE_CTRL, _BIT7) == _BIT7);
  56   1      }
  57          
  58          //--------------------------------------------------
  59          // Description  : Set V start line toggle for E/O mode
  60          // Input Value  : None
  61          // Output Value : None
  62          //--------------------------------------------------
  63          void ScalerFmtCnvFtoPInterlaceSetting(void)
  64          {
  65   1          // Check V start changes by field
  66   1          if(ScalerGetBit(P0_13_M1_VGIP_ODD_CTRL, _BIT6) == 0x00)
  67   1          {
  68   2              // Disable Vst toggle
  69   2              ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT7, 0x00);
  70   2          }
  71   1          else
  72   1          {
  73   2              // Enable Vst toggle
  74   2              ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT7, _BIT7);
  75   2      
  76   2              // Check V start is even or odd
  77   2              if((GET_ACTIVE_V_START() & 0x0001) == 0x0001)
  78   2              {
  79   3                  // Check the field with larger V start
  80   3                  if(ScalerGetBit(P0_13_M1_VGIP_ODD_CTRL, _BIT7) == 0x00)
  81   3                  {
  82   4                      ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT6, 0x00);
  83   4                  }
  84   3                  else
  85   3                  {
  86   4                      ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT6, _BIT6);
  87   4                  }
  88   3      
  89   3                  // Disable VGIP odd delay 1 line
  90   3                  ScalerSetBit(P0_13_M1_VGIP_ODD_CTRL, ~_BIT6, 0x00);
  91   3                  ScalerSetBit(P40_13_M2_VGIP_ODD_CTRL, ~_BIT6, 0x00);
  92   3              }
  93   2              else
  94   2              {
  95   3                  // Check the field with larger V start
  96   3                  if(ScalerGetBit(P0_13_M1_VGIP_ODD_CTRL, _BIT7) == 0x00)
  97   3                  {
  98   4                      ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT6, _BIT6);
  99   4                  }
 100   3                  else
 101   3                  {
 102   4                      ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT6, 0x00);
 103   4                  }
 104   3              }
 105   2          }
 106   1      }
