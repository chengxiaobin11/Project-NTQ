 198          //--------------------------------------------------
 199          // Description  : IVSdelay need to setting several times
 200          // Input Value  : Initial IVS delay
 201          // Output Value : N.A.
 202          //--------------------------------------------------
 203          void ScalerIDomainVgipIVDelayIVstStepAdjust(WORD usInitialIVDelay)
 204          {
 205   1          WORD usIVDelayStep = 1;
 206   1          WORD usIVDelayTemp = 0;
 207   1          BYTE ucSettingCounter = 0;
 208   1      
 209   1          WORD usDVtotal = GET_MDOMAIN_OUTPUT_VTOTAL();
 210   1      
 211   1          // Measure DVtotal in frame sync mode
 212   1          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, 0x00);
 213   1          ScalerSetBit(P0_44_LAST_LINE_H, ~_BIT7, _BIT7);
 214   1      
 215   1          GET_DVTOTAL_LASTLINE(usDVtotal);
 216   1          SET_MDOMAIN_OUTPUT_VTOTAL(usDVtotal);
 217   1      
 218   1          if(g_stMDomainOutputData.usVTotal > (g_stMDomainOutputData.usVBackStart + g_stMDomainOutputData.usVBac
             -kHeight + _PANEL_FRONT_PORCH_LIMIT))
 219   1          {
 220   2              usIVDelayStep = (g_stMDomainOutputData.usVTotal - g_stMDomainOutputData.usVBackStart - g_stMDomain
             -OutputData.usVBackHeight - _PANEL_FRONT_PORCH_LIMIT);
 221   2              usIVDelayStep = GET_DWORD_MUL_DIV(usIVDelayStep, g_stMDomainInputData.usVTotal, g_stMDomainOutputD
             -ata.usVTotal);
 222   2      
 223   2              if(usIVDelayStep < 1)
C51 COMPILER V9.60.0.0   SCALERIDOMAIN                                                     04/23/2026 13:53:57 PAGE 5   

 224   2              {
 225   3                  usIVDelayStep = 1;
 226   3              }
 227   2          }
 228   1          else
 229   1          {
 230   2              DebugMessageFS("warning !!! Aspect ratio/ overscan maybe have garbage", 0);
 231   2          }
 232   1      
 233   1          ucSettingCounter = (abs(usInitialIVDelay - ScalerVgipGetCaptureVDelay()) / usIVDelayStep) + 1;
 234   1      
 235   1          do
 236   1          {
 237   2              if(usInitialIVDelay > ScalerVgipGetCaptureVDelay())
 238   2              {
 239   3                  // Set VGIP V delay
 240   3                  ScalerVgipSetCaptureVDelay(usInitialIVDelay);
 241   3      
 242   3                  // Set VGIP V Capture  Start Position
 243   3                  ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart);
 244   3              }
 245   2              else
 246   2              {
 247   3                  if((ScalerVgipGetCaptureVDelay() - usInitialIVDelay) <= usIVDelayStep)
 248   3                  {
 249   4                      // Set VGIP V delay
 250   4                      ScalerVgipSetCaptureVDelay(usInitialIVDelay);
 251   4      
 252   4                      // Set VGIP V Capture  Start Position
 253   4                      ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart);
 254   4                  }
 255   3                  else
 256   3                  {
 257   4                      usIVDelayTemp = ScalerVgipGetCaptureVDelay() - usIVDelayStep;
 258   4      
 259   4                      // Step adjust IVdelay
 260   4                      ScalerVgipSetCaptureVDelay(usIVDelayTemp);
 261   4      
 262   4                      // Step adjust IVstart
 263   4                      ScalerVgipSetCaptureVStartPosition(g_stMDomainInputData.usVStart + usInitialIVDelay - usIV
             -DelayTemp);
 264   4                  }
 265   3      
 266   3                  DebugMessageFS("IVDelay step step", ScalerVgipGetCaptureVDelay());
 267   3              }
 268   2      
 269   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
 270   2      
 271   2              ucSettingCounter--;
 272   2          }
 273   1          while((usInitialIVDelay != ScalerVgipGetCaptureVDelay()) && (ucSettingCounter > 0));
 274   1      }
