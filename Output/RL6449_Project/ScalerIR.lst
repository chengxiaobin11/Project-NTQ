  71          // Description  : IRDA Initial Settings
  72          // Input Value  : None
  73          // Output Value : None
  74          //--------------------------------------------------
  75          void ScalerIRHWModeInitial(void)
  76          {
  77   1          // Sample clock divider
  78   1          ScalerSetByte(P23_AA_IR_SF2, HIBYTE(_IR_HW_XTAL_SAMPLE_CLK_DIV));
  79   1          ScalerSetByte(P23_AB_IR_SF3, LOBYTE(_IR_HW_XTAL_SAMPLE_CLK_DIV));
  80   1      
  81   1      
  82   1          // Clear interrupt flag
  83   1          ScalerSetBit(P23_BB_IR_SR3, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT6 | _BIT5 |
             - _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
  84   1      
  85   1          // Enable HW interrupt
  86   1          ScalerSetBit(P23_B2_IR_CR2, ~_BIT2, _BIT2);
  87   1      
  88   1          // _BIT0: Enable IR
  89   1          ScalerSetBit(P23_B2_IR_CR2, ~_BIT0, _BIT0);
  90   1      }
