 169          //--------------------------------------------------
 170          // Description  : IR interrupt Handler
 171          // Input Value  : None
 172          // Output Value : None
 173          //--------------------------------------------------
 174          void ScalerIRHWModeIntHandler_EXINT0(void) using 1
 175          {
 176   1          BYTE ucTemp = 0;
 177   1      
 178   1          if((ScalerGetBit_EXINT(P23_B2_IR_CR2, _BIT2) == _BIT2) && (ScalerGetBit_EXINT(P23_BB_IR_SR3, (_BIT1 | 
             -_BIT0)) != 0x00))
 179   1          {
 180   2              ScalerSetBit_EXINT(P23_BB_IR_SR3, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
 181   2              if((GET_IR_HW_RECEIVED() == _TRUE) || (ScalerGetBit_EXINT(P23_BB_IR_SR3, (_BIT6 | _BIT5 | _BIT4)) 
             -!= 0x00))
 182   2              {
 183   3                  // Read out unused code to avoid buffer pointer in disorder
 184   3                  ucTemp = ScalerGetByte_EXINT(P23_B4_IR_RP0);
 185   3                  ucTemp = ScalerGetByte_EXINT(P23_B5_IR_RP1);
 186   3                  ucTemp = ScalerGetByte_EXINT(P23_B6_IR_RP2);
 187   3                  ucTemp = ScalerGetByte_EXINT(P23_B7_IR_RP3);
 188   3                  ucTemp = ScalerGetByte_EXINT(P23_DC_IR_RP2_0);
 189   3                  ucTemp = ScalerGetByte_EXINT(P23_DD_IR_RP2_1);
 190   3                  ucTemp = ScalerGetByte_EXINT(P23_DE_IR_RP2_2);
 191   3                  ucTemp = ScalerGetByte_EXINT(P23_DF_IR_RP2_3);
 192   3      
 193   3                  // Clear error flag
 194   3                  ScalerSetBit_EXINT(P23_BB_IR_SR3, ~(_BIT6 | _BIT5 | _BIT4), (_BIT6 | _BIT5 | _BIT4));
 195   3                  // Reset IR
 196   3                  ScalerSetBit_EXINT(P23_B0_IR_CR0, ~(_BIT7), _BIT7);
 197   3              }
 198   2              else
 199   2              {
 200   3                  // Get code
 201   3                  g_pucIRCode[0] = ScalerGetByte_EXINT(P23_B4_IR_RP0);
 202   3                  g_pucIRCode[1] = ScalerGetByte_EXINT(P23_B5_IR_RP1);
 203   3                  g_pucIRCode[2] = ScalerGetByte_EXINT(P23_B6_IR_RP2);
 204   3                  g_pucIRCode[3] = ScalerGetByte_EXINT(P23_B7_IR_RP3);
 205   3                  g_pucIRCode[4] = ScalerGetByte_EXINT(P23_DC_IR_RP2_0);
 206   3                  g_pucIRCode[5] = ScalerGetByte_EXINT(P23_DD_IR_RP2_1);
 207   3                  g_pucIRCode[6] = ScalerGetByte_EXINT(P23_DE_IR_RP2_2);
 208   3                  g_pucIRCode[7] = ScalerGetByte_EXINT(P23_DF_IR_RP2_3);
 209   3      
 210   3                  SET_IR_HW_RECEIVED();
 211   3              }
 212   2          }
 213   1      
 214   1      }
