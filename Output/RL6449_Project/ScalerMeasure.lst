 820          //--------------------------------------------------
 821          // Description  : Calculate active region area in pixles
 822          // input region cnt calculation:
 823          // single   = IHtotal * (IVheight - 1) + IHwidth
 824          // even/odd = (IHtotal * (IVheight / 2 - 1) + IHwidth) * 2
 825          //          = IHtotal * (IVheight - 2) + IHwidth * 2
 826          // Input Value  : usHWidth       --> target H width
 827          //                usVHeight      --> target V height
 828          //                usHTotal      --> target H total
 829          // Output Value : active region area in pixel
 830          //--------------------------------------------------
 831          DWORD ScalerMeasureGetdActiveRegionPixels(WORD usHWidth, WORD usVHeight, WORD usHTotal)
 832          {
 833   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 834   1          if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
 835   1          {
 836   2              return (DWORD)(usVHeight - 2) * usHTotal + usHWidth * 2;
 837   2          }
 838   1      #endif
 839   1      
 840   1          return (DWORD)(usVHeight - 1) * usHTotal + usHWidth;
 841   1      }
