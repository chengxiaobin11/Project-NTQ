              //--------------------------------------------------
              // Description  : Transfer D domain to I domain measure H result
              // Input Value  : enumInputDataPath --> input data path, D domain Hactive data
              // Output Value : I domain Hactive data
              //--------------------------------------------------
              WORD ScalerMeasureTransDDomainToIDomainHorizonalPosition(WORD usIHWidth, WORD usDDomainHpos)
              {
                  WORD usActHStart = 0x00;
                  WORD usActHEnd = 0x00;
                  WORD usActHwidth = 0x00;
              
                  ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_05_DISPLAY_HOR_ACT_STA_H, 2, &pData[0]
             -, _AUTOINC);
                  usActHStart = ((pData[0] & 0x1F) << 8) | (pData[1]);
                  ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_07_DISPLAY_HOR_ACT_END_H, 2, &pData[0]
             -, _AUTOINC);
                  usActHEnd = ((pData[0] & 0x1F) << 8) | (pData[1]);
              
                  usActHwidth = usActHEnd - usActHStart;
              
                  return (DWORD)usDDomainHpos * usIHWidth / usActHwidth;
              }
              
              //--------------------------------------------------
              // Description  : Transfer D domain to I domain measure V result
              // Input Value  : enumInputDataPath --> input data path, D domain Vactive data
              // Output Value : I domain Vactive data
              //--------------------------------------------------
              WORD ScalerMeasureTransDDomainToIDomainVerticalPosition(WORD usIVHeight, WORD usDDomainVpos)
              {
                  WORD usActVStart = 0x00;
                  WORD usActVEnd = 0x00;
                  WORD usActVheight = 0x00;
              
                  ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_10_DISPLAY_VER_ACT_STA_H, 2, &pData[0]
             -, _AUTOINC);
                  usActVStart = ((pData[0] & 0x1F) << 8) | (pData[1]);
                  ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_12_DISPLAY_VER_ACT_END_H, 2, &pData[0]
             -, _AUTOINC);
                  usActVEnd = ((pData[0] & 0x1F) << 8) | (pData[1]);
              
                  usActVheight = usActVEnd - usActVStart;
C51 COMPILER V9.60.0.0   SCALERMEASURE                                                     04/23/2026 13:54:00 PAGE 22  

              
                  return (DWORD)usDDomainVpos * usIVHeight / usActVheight;
              }
              
              //--------------------------------------------------
              // Description  : Auto measure initial value for setting HV boundary
              // Input Value  : DHstart, DHend, DVstart, DVend, Main or Sub enable
              // Output Value : None
              //--------------------------------------------------
              void ScalerMeasureDynamicColorInitial(WORD usDHStart, WORD usDHEnd, WORD usDVStart, WORD usDVEnd)
              {
                  WORD usIHStart = 0;
                  WORD usIHEnd = 0;
                  WORD usIVStart = 0;
                  WORD usIVEnd = 0;
              
                  // Transfer D domain active to I domain active
                  usIHStart = ScalerMeasureTransDDomainToIDomainHorizonalPosition(g_stInputTimingData.usHWidth, usDHStar
             -t);
                  usIHEnd = ScalerMeasureTransDDomainToIDomainHorizonalPosition(g_stInputTimingData.usHWidth, usDHEnd);
                  usIVStart = ScalerMeasureTransDDomainToIDomainVerticalPosition(g_stInputTimingData.usVHeight, usDVStar
             -t);
                  usIVEnd = ScalerMeasureTransDDomainToIDomainVerticalPosition(g_stInputTimingData.usVHeight, usDVEnd);
              
              #if(_FORMAT_CONVERSION_SUPPORT == _ON)
                  if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
                  {
                      usIVStart /= 2;
                      usIVEnd /= 2;
                  }
              
                  if(ScalerFmtCnvHalfSDGetStatus() == _TRUE)
                  {
                      usIHStart /= 2;
                      usIHEnd /= 2;
                  }
              #endif
              
                  // set auto boundary
                  ScalerMeasureAutoFuncHBoundInitial(g_stActiveRegion.usHActiveStart + usIHStart,
                                                     g_stActiveRegion.usHActiveStart + usIHEnd);
              
                  ScalerMeasureAutoFuncVBoundInitial(g_stActiveRegion.usVActiveStart + usIVStart,
                                                     g_stActiveRegion.usVActiveStart + usIVEnd);
              
                  // Auto Balance result mode (old mode)
                  ScalerSetBit(P0_76_RED_NOISE_MARGIN, ~_BIT0, 0x00);
              
                  // accumulation mode
                  ScalerSetBit(P0_7D_AUTO_ADJ_CTRL1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_BIT5 | _BIT4));
              }
              
              //--------------------------------------------------
              // Description  : MeasureAuto ready status
              // Input Value  : R/G/B Channel, Main or Sub enable
              // Output Value : None
              //--------------------------------------------------
              void ScalerMeasureDynamicColorSetAutoMeasure(BYTE ucColor)
              {
                  switch(ucColor)
                  {
                      case _AUTO_RED_CHANNEL:
C51 COMPILER V9.60.0.0   SCALERMEASURE                                                     04/23/2026 13:54:00 PAGE 23  

                          ScalerSetBit(P0_7A_AUTO_ADJ_CTRL0, ~(_BIT1 | _BIT0), _BIT1);
                          break;
              
                      case _AUTO_GREEN_CHANNEL:
                          ScalerSetBit(P0_7A_AUTO_ADJ_CTRL0, ~(_BIT1 | _BIT0), _BIT0);
                          break;
              
                      case _AUTO_BLUE_CHANNEL:
                          ScalerSetBit(P0_7A_AUTO_ADJ_CTRL0, ~(_BIT1 | _BIT0), 0x00);
                          break;
              
                      case _AUTO_RGB_CHANNEL:
                          ScalerSetBit(P0_7A_AUTO_ADJ_CTRL0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
                          break;
              
                      default:
                          break;
                  }
              
                  // restart auto-function
                  if(ScalerGetBit(P0_7D_AUTO_ADJ_CTRL1, _BIT0) == 0x00)
                  {
                      ScalerSetBit(P0_7D_AUTO_ADJ_CTRL1, ~_BIT0, _BIT0);
                  }
              }
              
              //--------------------------------------------------
              // Description  : Get Auto measure value for dynamic crosshair color
              // Input Value  : pstActiveRegion --> measure result pointer
              //                main, sub enable or not
              //                bWait --> wait auto-function stop or not
              // Output Value : _TRUE if auto-function measure passed
              //--------------------------------------------------
              bit ScalerMeasureDynamicColorGetResult(BYTE *pucColorAverageValue, bit bWait)
              {
                  DWORD ulAutoSum = 0;
                  DWORD ulArea = 0;
                  StructAutoActiveData stAutoData;
                  memset(&stAutoData, 0, sizeof(stAutoData));
              
                  if(bWait == _NOT_WAIT)
                  {
                      if(ScalerGetBit(P0_7D_AUTO_ADJ_CTRL1, _BIT0) != 0x00)
                      {
                          return _FALSE;
                      }
                  }
              
                  // pop up H/V start
                  ScalerMeasureGetAutoResult(&stAutoData, ((ScalerGetBit(P0_7D_AUTO_ADJ_CTRL1, _BIT0) != 0x00) ? _WAIT :
             - _NOT_WAIT));
              
                  ulAutoSum += (((DWORD)ScalerGetByte(P0_84_AUTO_PHASE_3) << 24) | ((DWORD)ScalerGetByte(P0_85_AUTO_PHAS
             -E_2) << 16) | ((DWORD)ScalerGetByte(P0_86_AUTO_PHASE_1) << 8) | (DWORD)ScalerGetByte(P0_87_AUTO_PHASE_0));
                  ulArea += ((DWORD)stAutoData.usHActiveEnd - stAutoData.usHActiveStart + 1) * ((DWORD)stAutoData.usVAct
             -iveEnd - stAutoData.usVActiveStart + 1);
              
                  if(ScalerGetBit(P0_7A_AUTO_ADJ_CTRL0, (_BIT1 | _BIT0)) == (_BIT1 | _BIT0))
                  {
                      ulAutoSum /= 3;
                  }
              
C51 COMPILER V9.60.0.0   SCALERMEASURE                                                     04/23/2026 13:54:00 PAGE 24  

                  if(ulArea > 0)
                  {
                      *pucColorAverageValue = ulAutoSum / ulArea;
                  }
                  else
                  {
                      *pucColorAverageValue = 0;
                  }
              
                  return _TRUE;
              }
