 605          bit ScalerMeasureInputActiveRegionChange(void)
 606          {
 607   1          // Pop out region count result
 608   1          PDATA_DWORD(0) = ScalerMeasureGetInputRegionCountResult(_NOT_WAIT);
 609   1      
 610   1          // Disable Input Region Measure
 611   1          ScalerSetBit(P30_40_I_ACT_MEAS_CTRL, ~_BIT0, 0x00);
