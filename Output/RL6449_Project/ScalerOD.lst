  53          //****************************************************************************
  54          // FUNCTION DEFINITIONS
  55          //****************************************************************************
  56          #if(_OD_SUPPORT == _ON)
  57          //--------------------------------------------------
  58          // Description  : Get OD compression bit number
  59          //                according to available memory space & BW.
  60          // Input Value  : Remaining space & BW
  61          // Output Value : OD compression bit number(10x)
  62          //--------------------------------------------------
  63          BYTE ScalerODGetCompressionBitNum(DWORD ulMemoryRemainSpace, WORD usMemoryRemainBW)
  64          {
  65   1          WORD usODUseSpace = 0;
  66   1          WORD usODUseBW = 0;
  67   1      
  68   1          DebugMessageMemory("4. Remaining BW for OD", usMemoryRemainBW);
  69   1          DebugMessageMemory("4. Remaining Space for OD", ulMemoryRemainSpace);
  70   1      
  71   1          // Disable OD for emissive panel
  72   1          if((_PANEL_PIXEL_TYPE == _PANEL_PIXEL_OLED) || (_PANEL_PIXEL_TYPE == _PANEL_PIXEL_MICRO_LED))
  73   1          {
  74   2              return _OFF;
  75   2          }
  76   1      
  77   1          //=============================================
  78   1          // OD compression bit num: 7.5bits / pixel
  79   1          //=============================================
  80   1          if(CHECK_OD_MODE_AVAILABLE(_OD_SUPERPIXEL1X2_75BIT_BIT_NUM) == _TRUE)
  81   1          {
  82   2              usODUseSpace = ScalerMDomainODCalculateMemoryUseSpace(_OD_SUPERPIXEL1X2_75BIT_BIT_NUM);
  83   2              usODUseBW = ScalerMDomainODCalculateMemoryUseBW(_OD_SUPERPIXEL1X2_75BIT_BIT_NUM);
  84   2      
  85   2              DebugMessageMemory("4. 7_5_bit OD BW", usODUseBW);
  86   2              DebugMessageMemory("4. 7_5_bit OD Size", usODUseSpace);
  87   2              if((usODUseSpace < ulMemoryRemainSpace) && (usODUseBW < usMemoryRemainBW))
  88   2              {
  89   3                  return _OD_SUPERPIXEL1X2_75BIT_BIT_NUM;
  90   3              }
  91   2          }
  92   1          //=============================================
  93   1          // OD compression bit num: 6 bits / pixel
  94   1          //=============================================
  95   1          if(CHECK_OD_MODE_AVAILABLE(_OD_SUPERPIXEL1X4_60BIT_BIT_NUM) == _TRUE)
  96   1          {
  97   2              usODUseSpace = ScalerMDomainODCalculateMemoryUseSpace(_OD_SUPERPIXEL1X4_60BIT_BIT_NUM);
  98   2              usODUseBW = ScalerMDomainODCalculateMemoryUseBW(_OD_SUPERPIXEL1X4_60BIT_BIT_NUM);
  99   2      
 100   2              DebugMessageMemory("4. 6_0_bit OD BW", usODUseBW);
 101   2              DebugMessageMemory("4. 6_0_bit OD Size", usODUseSpace);
 102   2              if((usODUseSpace < ulMemoryRemainSpace) && (usODUseBW < usMemoryRemainBW))
 103   2              {
 104   3                  return _OD_SUPERPIXEL1X4_60BIT_BIT_NUM;
 105   3              }
 106   2          }
 107   1          //=============================================
 108   1          // Otherwise, OD off
 109   1          //=============================================
C51 COMPILER V9.60.0.0   SCALEROD                                                          04/23/2026 13:54:01 PAGE 3   

 110   1          return _OFF;
 111   1      }
