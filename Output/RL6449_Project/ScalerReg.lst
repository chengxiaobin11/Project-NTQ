  48          //****************************************************************************
  49          //--------------------------------------------------
  50          // Description  : Calculate OSD Burst Write Timeout
  51          // Input Value  :
  52          // Output Value : Burst Write Required Time
  53          //--------------------------------------------------
  54          BYTE ScalerBurstWriteTimeoutCal(void)
  55          {
  56   1          WORD usTimeout = 0;
  57   1      
  58   1          // Time of MCU Write Cycle > 21 x TDCLK + 28 x TDCLK + (8 + 4 x _NUM_FONT_WIDTH_4_SERIAL) x TDCLK
  59   1          // => Tm2pll x Flash Div x Mcu Div x (0xFFFB x 2 + 4) > (49 + 8 + 4 x _NUM_FONT_WIDTH_4_SERIAL) x TDCL
             -K
  60   1          // => 0xFFFB > (57 + 4 x _NUM_FONT_WIDTH_4_SERIAL) x TDCLK / (2 x Tm2pll x Flash Div x Mcu Div) - 2
  61   1          usTimeout = (DWORD)(57 + 4 * _NUM_FONT_WIDTH_4_SERIAL) * _M2PLL_CLK_MHZ * 1000 * 2 / ((DWORD)GET_D_CLK
             -_FREQ() * _FLASH_CLK_DIV * _MCU_CLK_DIV) - 2;
  62   1      
  63   1          // Double timeout if OSD double function is enabled
  64   1          if(ScalerOsdGetDoubleFunctionH() == _ENABLE)
  65   1          {
  66   2              usTimeout *= 2;
  67   2          }
  68   1      
  69   1          if(usTimeout > 0xFF)
  70   1          {
  71   2              return 0xFF;
  72   2          }
  73   1      
  74   1          return (BYTE)usTimeout;
  75   1      }


