             -ing 1
 119          {
 120   1          ScalerSetByte_EXINT(P2D_21_HDCP_MSGWAP, ucSubAddr);
 121   1      
 122   1          // Load Value To FW
 123   1          for(pData_EXINT[0] = ucSubAddr; pData_EXINT[0] < (ucSubAddr + ucLength); pData_EXINT[0]++)
 124   1          {
 125   2              pucReadArray[pData_EXINT[0] - ucSubAddr] = ScalerGetByte_EXINT(P2D_22_HDCP_MSGWDP);
