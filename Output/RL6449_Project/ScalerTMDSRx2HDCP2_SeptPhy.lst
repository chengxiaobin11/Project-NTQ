 127   1      }
 128          //--------------------------------------------------
 129          // Description  : HDCP 1.4 Switch to HDCP 2.2 (Can't change the enable/disable procedure)
 130          // Input Value  : None
 131          // Output Value : None
 132          //--------------------------------------------------
 133          void ScalerTMDSRx2Hdcp2Enable_EXINT0(void) using 1
 134          {
 135   1          MCU_FE69_DDC2_EDID_IRQ |= _BIT2;
 136   1      
 137   1          // set a check duration = 2ms for cover max time(=500us)of Tx read RxStatus (offset address = 0x70)
 138   1          // each loop time = 40us
 139   1          for(pData_EXINT[0] = 0; pData_EXINT[0] < 50; pData_EXINT[0]++)
 140   1          {
 141   2              DELAY_40US_EXINT();
 142   2      
 143   2              if((MCU_FE69_DDC2_EDID_IRQ & _BIT2) == _BIT2)
 144   2              {
 145   3                  MCU_FE69_DDC2_EDID_IRQ |= _BIT2;
 146   3              }
 147   2              else
 148   2              {
 149   3                  break;
 150   3              }
 151   2          }
 152   1      
 153   1          // Detectd DDC non-Toggle or Timeout to Enable HDCP 2.2 Function
 154   1          // Enable HDCP 2.2 Module
 155   1          ScalerSetBit_EXINT(P2D_26_HDCP_I2C_CTRL_0, ~_BIT7, _BIT7);
 156   1      
 157   1          // Disable HDCP 1.4 Module
 158   1          ScalerSetBit_EXINT(P71_C0_HDCP_CR, ~_BIT0, 0x00);
 159   1      }
