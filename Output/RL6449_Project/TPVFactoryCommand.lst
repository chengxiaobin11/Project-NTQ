1191          //        VCP TPVPORT2: {HDMI3=BIT7,HDMI4/Option Port=BIT6,MHL_HDMI=BIT5,MHL_HMDI2=BIT4,MHL_HDMI3=BIT3,MHL_HDM
             -I4=BIT2,BIT1:0-Write Disable,1-Write Enable,BIT0:0-EDID in EEPROM,1-EDID in FLASH}
1192          //        VCP TPVPORT3: {HDMI2.0_HDMI1=BIT7,HDMI2.0_HDMI2=BIT6,HDMI2.0_HDMI3=BIT5,HDMI2.0_HDMI4=BIT4,DP3=BIT3}
1193          //        Sample(_HDMI_SUPPORT == _ON):g_pucDdcciTxBuf[3] = (_BIT7 |_BIT5 |_BIT3);   // VGA1 DVI1 HDMI1
1194          // Input Value  : None
1195          // Output Value : None
