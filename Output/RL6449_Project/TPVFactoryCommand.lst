1352          void TPVFCReplyCommand(BYTE ucResult, BYTE ucLength)
1353          {
1354   1          WORD usCRC = 0;
1355   1          BYTE i = 0;
1356   1      
1357   1          for(i = 0; i < ucLength; i++ )
1358   1          {
1359   2              usCRC = TPVFCCrc16(g_pucDdcciRxBuf[_FC_BYTE4 + i], usCRC);
1360   2          }
1361   1      
1362   1          g_pucDdcciTxBuf[_DDCCI_SOURCE] = _DDCCI_DEST_ADDRESS;
1363   1          g_pucDdcciTxBuf[_DDCCI_LENGTH] = _DDCCI_CONTROL_STATUS_FLAG | 0x03;
1364   1          g_pucDdcciTxBuf[_DDCCI_COMMAND] = ucResult;
1365   1          g_pucDdcciTxBuf[3] = (BYTE)((usCRC&0xff00)>>8);
1366   1          g_pucDdcciTxBuf[4] = (BYTE)(usCRC&0x00ff);
1367   1          g_pucDdcciTxBuf[5] = UserCommonDdcciCalCheckSum();
1368   1      
1369   1          ScalerMcuDdcciSendData(g_pucDdcciTxBuf);
1370   1      }
