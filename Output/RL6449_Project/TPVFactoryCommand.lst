 296          void TPVNVRamSaveFactoryDate(void)
 297          {
 298   1        #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                  UserCommonEepromWrite(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
              
                #else
 302   1        UserCommonFlashSaveItem(_FLASH_ITEMID_FACTORY_DATA, (BYTE *)(&g_stFactoryData), sizeof(StructFactoryType)
             -);
 303   1        #endif
 304   1      }
 305          
 306          void TPVNVRamLoadFactoryDate(void)
 307          {
 308   1        #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                  UserCommonEepromRead(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
                //UserNVRamCheckRange(g_stFactoryData);
              
                #else
 313   1        if(UserCommonFlashLoadItem(_FLASH_ITEMID_FACTORY_DATA, pData, sizeof(StructFactoryType)) == _TRUE)
 314   1        {
 315   2          memcpy(&g_stFactoryData, pData, sizeof(StructFactoryType));
 316   2        }
 317   1        else
 318   1        {
 319   2          g_stFactoryData = g_stFactoryDataDefault;
 320   2        }
 321   1        #endif
 322   1      }
 323          
 324          void TPVNVRamRestoreFactoryDate(void)
 325          {
 326   1        g_stFactoryData = g_stFactoryDataDefault;
 327   1      
 328   1        #if(_SYSTEM_EEPROM_EMULATION_SUPPORT == _OFF)
                UserCommonEepromWrite(_TPV_FACTORY_ADDRESS, sizeof(StructFactoryType), (BYTE *)(&g_stFactoryData));
              
                #else
 332   1        if(UserCommonFlashLoadItem(_FLASH_ITEMID_FACTORY_DATA, pData, 1) == _TRUE)
 333   1        {
 334   2          TPVNVRamSaveFactoryDate();
 335   2        }
 336   1        #endif
 337   1      }
