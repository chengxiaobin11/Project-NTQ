1326          // Description  : TPV Factory Command CRC calculation
1327          // Input Value  : None
1328          // Output Value : CRC
1329          //--------------------------------------------------
1330          WORD TPVFCCrc16(BYTE nData, WORD nCRC)
1331          {
1332   1          BYTE nMask;
1333   1          bit fFeedback;
1334   1          for (nMask= 0x80; nMask; nMask >>= 1)
1335   1          {
1336   2              fFeedback= (bit)(((nCRC & 0x8000) ? 1 : 0) ^ ((nMask & nData) ? 1 : 0));
1337   2              nCRC <<= 1;
1338   2              if (fFeedback)
1339   2              {
1340   3                  nCRC ^= 0x1021;
1341   3              }
1342   2          }
1343   1      
1344   1          return nCRC;
1345   1      }
