1014          //--------------------------------------------------
1015          // Description  :  Calculate percent to real value for input range for 2 Sectors
1016          // Input Value  :  ucPercentValue --> input percent value
1017          //                 usMax          --> the max value
1018          //                 usMin          --> the min value
1019          //                 usCenter       --> the Center Value
1020          // Output Value :  Real value
1021          //--------------------------------------------------
1022          WORD UserCommonAdjustPercentToRealValue(BYTE ucPercentValue, WORD usMax, WORD usMin, WORD usCenter)
1023          {
1024   1          DWORD ulTemp = 0;
1025   1      
1026   1          ucPercentValue = MINOF(100, ucPercentValue);
1027   1      
1028   1          if(ucPercentValue > 50)
1029   1          {
1030   2              ulTemp = (((DWORD)(ucPercentValue - 50) * (usMax - usCenter) * 10) / 50);
1031   2          }
1032   1          else if(ucPercentValue < 50)
1033   1          {
1034   2              ulTemp = (((DWORD)ucPercentValue * (usCenter - usMin) * 10) / 50);
1035   2          }
1036   1          else
1037   1          {
1038   2              return usCenter;
1039   2          }
1040   1      
1041   1          if((ulTemp % 10) > 5)
1042   1          {
1043   2              ulTemp = ulTemp + 10;
1044   2          }
1045   1      
1046   1          if(ucPercentValue > 50)
1047   1          {
1048   2              return (WORD)((ulTemp / 10) + usCenter);
1049   2          }
1050   1          else
1051   1          {
1052   2              return (WORD)((ulTemp / 10) + usMin); // <= 50
1053   2          }
1054   1      }
