 970          //--------------------------------------------------
 971          // Description  :  Calculate value to percent for input range for 2 Sectors
 972          // Input Value  :  usRealValue --> input real value
 973          //                 usMax       --> the max value
 974          //                 usMin       --> the min value
 975          //                 usCenter    --> the Center Value
 976          // Output Value :  Percent
 977          //--------------------------------------------------
 978          BYTE UserCommonAdjustRealValueToPercent(WORD usRealValue, WORD usMax, WORD usMin, WORD usCenter)
 979          {
 980   1          WORD usTemp = 0;
 981   1          usRealValue = MINOF(usRealValue, usMax);
 982   1          usRealValue = MAXOF(usRealValue, usMin);
 983   1      
 984   1          if((usMax <= usMin) || (usCenter <= usMin) || (usCenter >= usMax))
 985   1          {
 986   2              usTemp = 0;
 987   2          }
 988   1          else
 989   1          {
 990   2              if(usRealValue < usCenter)
 991   2              {
 992   3                  usTemp = (((DWORD)(usRealValue - usMin) * 10000) / (usCenter - usMin)) / 2;
 993   3              }
 994   2              else if(usRealValue > usCenter)
 995   2              {
 996   3                  usTemp = (((DWORD)(usRealValue - usCenter) * 10000) / (usMax - usCenter)) / 2 + 5000;
 997   3              }
 998   2              else
 999   2              {
C51 COMPILER V9.60.0.0   USERCOMMONADJUST                                                  04/23/2026 13:55:00 PAGE 18  

1000   3                  return 50;
1001   3              }
1002   2          }
1003   1      
1004   1          if((usTemp % 100) > 49)
1005   1          {
1006   2              usTemp = usTemp + 100;
1007   2          }
1008   1      
1009   1          usTemp = usTemp / 100;
1010   1      
1011   1          return ((BYTE)usTemp);
1012   1      }
