 171          BYTE UserCommonDdcciCalCheckSum(void)
 172          {
 173   1          BYTE ucCount = 0;
 174   1          BYTE ucCheckLen = 0;
 175   1          BYTE ucSum = _DDCCI_VIRTUAL_HOST_ADDRESS;
 176   1      
 177   1          ucCheckLen = (g_pucDdcciTxBuf[_DDCCI_LENGTH] & 0x7F) + 2;
 178   1      
 179   1          for(ucCount = 0; ucCount < ucCheckLen; ucCount++)
 180   1          {
 181   2              ucSum = ucSum ^ g_pucDdcciTxBuf[ucCount];
 182   2          }
 183   1      
 184   1          return ucSum;
 185   1      }
