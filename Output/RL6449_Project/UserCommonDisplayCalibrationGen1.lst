              void UserCommonDdcciDispCalibSetPWMValue(void)
              {
              #if(_DEVICE_LED_DRIVER_TYPE != _DEVICE_LED_DRIVER_NONE)
                  ScalerColorDDomainDBEnable(_ENABLE);
                  ScalerColorDDomainDBTriggerEvent(_DB_VS_TRIGGER);
