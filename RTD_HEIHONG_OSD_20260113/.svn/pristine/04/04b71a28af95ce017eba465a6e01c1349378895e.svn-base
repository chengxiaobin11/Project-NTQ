 123          //--------------------------------------------------
 124          // Description  : Initial Setting for DP Digital Aux, Analog Aux
 125          // Input Value  : None
 126          // Output Value : None
 127          //--------------------------------------------------
 128          void ScalerDpRx0AuxPowerOnInitial(void)
 129          {
 130   1          // Digital Aux Power On, DPCD REG Power On, MSG Power On.
 131   1          ScalerSetBit(PB7_C0_DPCD_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT1 | _BIT0), 0x00);
 132   1      
 133   1          // Average 8 cycles as Start Postion, Aux Clk Select to 27MHz, no Swap
 134   1          ScalerSetByte(PB7_72_AUX_DIG_PHY2, 0xC0);
 135   1      
 136   1      #if(_DP_AUX_REPLY_CLK_SEL_FROM == _DP_AUX_REPLY_SEL_IOSC)
 137   1          // Aux Clk Select Manual Mode, Aux New Mode
 138   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), _BIT6);
 139   1      #else
                  // Aux Clk Select Source, Aux New Mode
                  ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
 143   1      
 144   1          // HW Fake Link Training Disable.
 145   1          ScalerSetBit(PB7_C6_AUX_PHY_DIG2, ~_BIT4, 0x00);
 146   1      
 147   1          // Set Aux Precharge Number.
 148   1          ScalerSetBit(PB7_74_AUX_DIG_PHY4, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT0));
 149   1      
 150   1          // Aux Auto Mode, Using Default Average Number.
 151   1          ScalerSetByte(PB7_75_AUX_DIG_PHY5, 0x0D);
 152   1      
 153   1          // Aux Reply Timeout Setting
 154   1          ScalerSetByte(PB7_A2_AUX_RESERVE2, _DP_AUX_REPLY_TIMEOUT_USER_SETTING);
 155   1      
 156   1          // Enble Aux Channel.
 157   1          ScalerSetBit(PB7_D0_AUX_MODE_SET, ~(_BIT3 | _BIT2 | _BIT0), _BIT0);
 158   1      
 159   1          // Fast IIC Clock.
 160   1          ScalerSetBit(PB7_D1_DP_IIC_SET, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_DP_AUX_IIC_SCL_CLK_SETTING << 4));
 161   1      
 162   1          // Set aux mac clk use xclk
 163   1          ScalerSetBit(PB7_DA_AUX_FIFO_RST, ~(_BIT4 | _BIT3 | _BIT1 | _BIT0), _BIT3);
 164   1      
 165   1          // Not Reply when Aux Error.
 166   1          ScalerSetBit(PB7_DB_AUX_STATUS, ~(_BIT5 | _BIT4), _BIT4);
 167   1          ScalerSetBit(PB7_76_AUX_DIG_PHY6, ~(_BIT7 | _BIT6), _BIT6);
 168   1      
 169   1          // Aux Ack Timer.
 170   1          ScalerSetBit(PB7_F0_AUX_TX_TIMER, ~(_BIT5 | _BIT2), (_BIT5 | _BIT2));
C51 COMPILER V9.60.0.0   RL6449_SERIES_DPRX0                                               10/18/2025 16:53:29 PAGE 4   

 171   1      
 172   1          // I2C timeout setting
 173   1          ScalerSetByte(PB7_F1_AUX_TX_TIMER_2, _DP_AUX_I2C_REPLY_TIMEOUT_SETTING);
 174   1      
 175   1          // Disable Reply IIC Defer Before Data Ready.
 176   1          ScalerSetBit(PB7_F4_MCUIIC, ~(_BIT6 | _BIT5), 0x00);
 177   1      
 178   1          // Enable Aux Error Handler.
 179   1          ScalerSetBit(PB7_78_AUX_DIG_PHY8, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT5 | _
             -BIT4));
 180   1      
 181   1          // Toggle Aux Auto K
 182   1          ScalerSetBit(PB7_65_AUX_5, ~_BIT7, 0x00);
 183   1          ScalerSetBit(PB7_65_AUX_5, ~_BIT7, _BIT7);
 184   1      
 185   1          // Aux Mode Set (Diff Mode or Single-ended mode) && Aux RX0 Resistance Setting
 186   1          ScalerDpRx0AuxSet();
 187   1      
 188   1          // Set Aux Talk Mode ADJR
 189   1          ScalerSetByte(PB7_67_DIG_TX_03, 0x88);
 190   1      
 191   1          ScalerSetBit(PB7_60_DIG_TX_04, ~(_BIT1 | _BIT0), _BIT0);
 192   1      
 193   1          // Aux comm current select max
 194   1          ScalerSetBit(PB7_64_AUX_4, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 195   1      
 196   1          // Set Aux D_2 = ~D_1 for Aux Single Ended Mode
 197   1          ScalerSetBit(PB7_79_AUX_DIG_PHY9, ~_BIT7, _BIT7);
 198   1      
 199   1          // Clear the Clock Divider for AUX MAC and PHY
 200   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 201   1          ScalerSetBit(PB7_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
 202   1      
 203   1          // Aux ps clk from IOSC
 204   1          ScalerSetBit(P0_0B_POWER_CTRL, ~(_BIT5 | _BIT4), 0x00);
 205   1      
 206   1          // Set the Clock Divider = 1 for AUX MAC and PHY
 207   1          ScalerSetBit(PB7_73_AUX_DIG_PHY3, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 208   1          ScalerSetBit(PB7_B0_AUX_PAYLOAD_CLEAR, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 209   1      }
