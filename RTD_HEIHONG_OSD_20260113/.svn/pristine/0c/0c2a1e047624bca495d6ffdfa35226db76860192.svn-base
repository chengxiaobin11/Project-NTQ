                if(BackUpTempVFreq != ucTempVfreq)
                {
                  if((GET_INPUT_TIMING_HWIDTH() >= 1000) && (GET_INPUT_TIMING_VHEIGHT() >= 1000))
                  {
                    OsdFuncPutIcon1BitAndColorWidthHeight(ROW(1), COL(_OSD_MAIN_MENU_WIDTH/2+15+8), 0x00, WIDTH(2), HEIGHT(
             -1), COLOR(_CP_WHITE, _CP_BG));
                    OsdPropShowNumber(ROW(1),  COL(_OSD_MAIN_MENU_WIDTH/2+15+8), ucTempVfreq, (_ALIGN_LEFT | _FORCE_SHOW_NU
             -MBER_OFF | _SHOW_2), _PFONT_PAGE_ITEM_9, ((_CP_WHITE<<4)|_CP_BG));
                    RTDOsdTableFuncPutStringProp(1, COL(_OSD_MAIN_MENU_WIDTH/2+15+10), _PFONT_PAGE_ITEM_10,_OSD_STRING_HZ,0
             -, ((_CP_WHITE<<4)|_CP_BG), _ENGLISH);
                  }
                  else if((GET_INPUT_TIMING_HWIDTH() < 1000) && (GET_INPUT_TIMING_VHEIGHT() < 1000))
                  {
                    OsdFuncPutIcon1BitAndColorWidthHeight(ROW(1), COL(_OSD_MAIN_MENU_WIDTH/2+15+7), 0x00, WIDTH(2), HEIGHT(
             -1), COLOR(_CP_WHITE, _CP_BG));
                    OsdPropShowNumber(ROW(1),  COL(_OSD_MAIN_MENU_WIDTH/2+15+7), ucTempVfreq, (_ALIGN_LEFT | _FORCE_SHOW_NU
             -MBER_OFF | _SHOW_2), _PFONT_PAGE_ITEM_9, ((_CP_WHITE<<4)|_CP_BG));
                    RTDOsdTableFuncPutStringProp(1, COL(_OSD_MAIN_MENU_WIDTH/2+15+9), _PFONT_PAGE_ITEM_10,_OSD_STRING_HZ,0,
             - ((_CP_WHITE<<4)|_CP_BG), _ENGLISH);
                  }
                  else
                  {
              
                    OsdFuncPutIcon1BitAndColorWidthHeight(ROW(1), COL(_OSD_MAIN_MENU_WIDTH/2+15+7), 0x00, WIDTH(2), HEIGHT(
             -1), COLOR(_CP_WHITE, _CP_BG));
                      OsdPropShowNumber(ROW(1),  COL(_OSD_MAIN_MENU_WIDTH/2+15+7), ucTempVfreq, (_ALIGN_LEFT | _FORCE_SHOW
             -_NUMBER_OFF | _SHOW_2), _PFONT_PAGE_ITEM_9, ((_CP_WHITE<<4)|_CP_BG));
                        RTDOsdTableFuncPutStringProp(1, COL(_OSD_MAIN_MENU_WIDTH/2+15+9), _PFONT_PAGE_ITEM_10,_OSD_STRING
             -_HZ,0, ((_CP_WHITE<<4)|_CP_BG), _ENGLISH);
                  }
