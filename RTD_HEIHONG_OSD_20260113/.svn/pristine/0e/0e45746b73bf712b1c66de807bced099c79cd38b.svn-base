 278          //--------------------------------------------------
 279          // Description  : M2PLL Power COntrol.
 280          // Input Value  : ucOn    --> ON/OFF.
 281          // Output Value : None
 282          //--------------------------------------------------
 283          void ScalerPLLM2PLLPower(BYTE ucOn)
 284          {
 285   1      #if(_M2PLL_STRUCT_TYPE == _M2PLL_STRUCT_M_N)
 286   1          if(ucOn == _ON)
 287   1          {
 288   2              // Power Off M2PLL
 289   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, _BIT0);
 290   2      
 291   2              // In fact, we can move the m/n code setting to scaler initial
 292   2              // Set M2PLL M Code
 293   2              ScalerSetByte(P1_E0_M2PLL_M, (_M2PLL_PLL_M - 2));
 294   2      
C51 COMPILER V9.60.0.0   SCALERPLL                                                         10/18/2025 16:52:47 PAGE 6   

 295   2              // Set M2PLL N Code
 296   2              ScalerSetByte(P1_E1_M2PLL_N, (((_M2PLL_PLL_O >> 1) << 4) | (_M2PLL_PLL_N - 2)));
 297   2      
 298   2              // Set Rs, Cs, Icp
 299   2              ScalerSetByte(P1_E4_M2PLL_CRNT, 0x73);
 300   2      
 301   2              // DPLL VCORSTB Set to Normal
 302   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT1, (_DPLL_VCORSTB_NORMAL_VALUE << 1));
 303   2      
 304   2              // Power On M2PLL
 305   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, 0x00);
 306   2              DELAY_XUS(150);
 307   2      
 308   2              // Reset PFD, LPF
 309   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT5, _BIT5);
 310   2              DELAY_5US();
 311   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT5, 0x00);
 312   2      
 313   2              // Wait for M2PLL Stable (1ms)
 314   2              DELAY_XUS(1000);
 315   2          }
 316   1          else
 317   1          {
 318   2              // Power Off M2PLL
 319   2              ScalerSetBit(P1_E5_M2PLL_WD, ~_BIT0, _BIT0);
 320   2          }
 321   1      
 322   1      #elif(_M2PLL_STRUCT_TYPE == _M2PLL_STRUCT_N_F)
              
                  DWORD ulNFcode = _M2PLL_DEFAULT_N_F_CODE;
                  BYTE pucNFvalue[4];
                  memset(pucNFvalue, 0, sizeof(pucNFvalue));
              
                  if(ucOn == _ON)
                  {
              #if(_LC_TANK_SUPPORT == _ON)
                      // M2PLL clock selection from LC tank or Xtal
                      ScalerSetBit(P41_03_PLL_IN_CONTROL, ~(_BIT7 | _BIT6), ((_XTALESS_SUPPORT == _ON) ? 0x00 : _BIT6));
              
              #if((_XTALESS_SUPPORT == _ON) && (_EFUSE_SUPPORT == _ON))
                      // Read Out eFuse Data
                      ScalerEfuseGetData(_EFUSE_M2PLL_N_F_CODE, 4, pucNFvalue);
              
                      ulNFcode = (((DWORD)pucNFvalue[0] << 24) | ((DWORD)pucNFvalue[1] << 16) | ((DWORD)pucNFvalue[2] <<
             - 8) | pucNFvalue[3]);
                      ulNFcode = (ulNFcode == 0) ? _M2PLL_DEFAULT_N_F_CODE : ulNFcode;
              #endif
              #endif
              
                      // Dobule Buffer for Prediv, Outputdiv, Bpn
                      ScalerSetBit(P41_03_PLL_IN_CONTROL, ~_BIT0, _BIT0);
              
                      // Power On LDO
                      ScalerSetBit(P41_09_M2PLL_LDO, ~_BIT7, _BIT7);
              
                      // Set Icp = 5uA
                      ScalerSetByte(P41_06_M2PLL_0, 0x79);
              
                      // Set PI current 3.33uA
                      ScalerSetByte(P41_07_M2PLL_1, 0x26);
              
                      // Set NF code
C51 COMPILER V9.60.0.0   SCALERPLL                                                         10/18/2025 16:52:47 PAGE 7   

                      ScalerSetDWord(P41_0D_N_F_CODE_1, ulNFcode);
              
                      // N.F double buffer
                      ScalerSetBit(P41_0C_N_F_CODE_0, ~_BIT0, _BIT0);
              
                      // DPLL VCORSTB Set to Normal
                      ScalerSetBit(P41_08_M2PLL_CONTROL, ~_BIT1, (_DPLL_VCORSTB_NORMAL_VALUE << 1));
              
                      // Disable PI Bypass
                      ScalerSetBit(P41_07_M2PLL_1, ~_BIT2, 0x00);
              
                      // Power On M2PLL
                      ScalerSetBit(P41_08_M2PLL_CONTROL, ~_BIT0, 0x00);
              
                      // Wait for M2PLL Stable (1ms)
                      DELAY_XUS(1000);
                  }
                  else
                  {
                      // Power Off M2PLL
                      ScalerSetBit(P41_08_M2PLL_CONTROL, ~_BIT0, _BIT0);
                  }
              #endif // End of #if(_M2PLL_STRUCT_TYPE == _M2PLL_STRUCT_M_N)
 379   1      }
