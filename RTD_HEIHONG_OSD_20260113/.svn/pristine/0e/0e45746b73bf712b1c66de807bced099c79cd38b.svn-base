 386          void ScalerM2PLLDiv(BYTE ucDiv)
 387          {
 388   1          // Internal Xtal Freq. From M2PLL divider
 389   1          ScalerSetBit(P0_22_M1_FIFO_CLOCK_SELECT, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3), ucDiv << 3);
 390   1      }
