              //--------------------------------------------------
              void ScalerPLLSetDPLLOffset(WORD usOffset)
              {
                  ScalerSetBit(P1_C4_DCLK_FINE_TUNE_OFFSET_MSB, ~0x0F, (HIBYTE(usOffset) & 0x0F));
                  ScalerSetByte(P1_C5_DCLK_FINE_TUNE_OFFSET_LSB, LOBYTE(usOffset));
              
