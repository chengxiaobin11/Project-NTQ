              bit ScalerDpRx1Hdcp2VComputeProc(void)
              {
                  BYTE pucRxInfo[2] = {0};
                  BYTE pucSeqNumV[3] = {0};
              
                  pucRxInfo[0] = ScalerDpRx1GetDpcdInfo(0x06, 0x93, 0x30);
