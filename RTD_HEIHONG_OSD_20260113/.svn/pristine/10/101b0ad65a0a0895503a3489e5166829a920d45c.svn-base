             -, pucRxInfo, pucSeqNumV) == _FALSE)
                  {
                      return _FALSE;
                  }
              
                  SET_DP_RX1_AUX_MANUAL_MODE();
              
                  for(pData[0] = 0; pData[0] < 3; pData[0]++)
                  {
                      // Load MSB of V' into DPCD table
                      ScalerDpRx1SetDpcdValue(0x06, 0x93, (0x32 + pData[0]), pucSeqNumV[pData[0]]);
                  }
              
