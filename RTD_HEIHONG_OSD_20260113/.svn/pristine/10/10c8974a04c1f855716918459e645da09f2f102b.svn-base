 269          void OsdPaletteLoadPigment(BYTE ucPaletteIndex, BYTE *pucColorPaletteArray, BYTE ucColorPaletteCount)
 270          {
 271   1          BYTE ucAddr = ucPaletteIndex * 16;
 272   1          BYTE ucI = 0;
 273   1      
 274   1          for(ucI = 0; ucI < ucColorPaletteCount; ucI++)
 275   1          {
 276   2              ScalerOsdSetColorPalette(ucAddr + ucI, *(pucColorPaletteArray + (ucI * 3)), *(pucColorPaletteArray
             - + (ucI * 3) + 1), *(pucColorPaletteArray + (ucI * 3) + 2));
 277   2          }
 278   1      }
 279          
