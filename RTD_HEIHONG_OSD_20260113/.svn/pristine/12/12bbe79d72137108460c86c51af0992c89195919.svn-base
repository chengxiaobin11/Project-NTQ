  57          //--------------------------------------------------
  58          // Description  : OD on/off
  59          // Input Value  : enumOn --> _FUNCTION_ON/_FUNCTION_OFF
  60          // Output Value : None
  61          //--------------------------------------------------
  62          void ScalerODEnable(EnumFunctionOnOFF enumOn)
  63          {
  64   1          //=================
  65   1          // Enable OD
  66   1          //=================
  67   1          if((enumOn == _FUNCTION_ON) && (GET_OD_USE_BIT() != _OFF))
  68   1          {
  69   2              // Disable OD clock gated
  70   2              ScalerSetBit(P1_DC_DCLK_GATED_CTRL2, ~_BIT2, _BIT2);
  71   2      
  72   2      #if(_FRC_SUPPORT == _ON)
  73   2              DebugMessageFRC("OD_ON", 0);
  74   2      
  75   2              if(GET_DYNAMIC_OD_STATUS() == _ENABLE)
  76   2              {
  77   3                  DebugMessageFRC("Dynamic OD", GET_MEMORY_DVF_SELECT());
  78   3      
  79   3                  // Enable DEN_START IRQ
  80   3                  SET_OD_CURR_DYNAMIC_STATUS(_ENABLE);
  81   3                  ScalerGlobalSetInterrupt(_IRQ_DEN_START, _ENABLE);
  82   3              }
  83   2              else
  84   2              {
  85   3                  DebugMessageFRC("Static OD", 0);
  86   3      
  87   3                  // Enable OD function, disable DEN_START IRQ
  88   3                  SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
  89   3                  ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
  90   3                  ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
  91   3              }
  92   2      #else
                      // Enable OD function
                      ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
              #endif
  96   2          }
  97   1          //=================
  98   1          // Disable OD
  99   1          //=================
 100   1          else
 101   1          {
 102   2              // Disable OD clock gated
 103   2              ScalerSetBit(P1_DC_DCLK_GATED_CTRL2, ~_BIT2, _BIT2);
 104   2      
 105   2      #if(_FRC_SUPPORT == _ON)
 106   2              DebugMessageFRC("OD_OFF", 0);
 107   2      
 108   2              SET_OD_CURR_DYNAMIC_STATUS(_DISABLE);
 109   2              ScalerGlobalSetInterrupt(_IRQ_DEN_START, _DISABLE);
C51 COMPILER V9.60.0.0   RL6449_SERIES_OD                                                  10/18/2025 16:25:52 PAGE 3   

 110   2      #endif
 111   2              // Disable OD function
 112   2              ScalerSetBit(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 113   2      
 114   2              //=================
 115   2              // Clock Gated
 116   2              //=================
 117   2              if(enumOn == _FUNCTION_CLOCK_GATED)
 118   2              {
 119   3                  ScalerTimerWaitForEvent(_EVENT_DVS);
 120   3                  ScalerTimerDelayXms(2);
 121   3      
 122   3                  // Enable OD clock gated
 123   3                  ScalerSetBit(P1_DC_DCLK_GATED_CTRL2, ~_BIT2, 0x00);
 124   3              }
 125   2          }
 126   1      }
