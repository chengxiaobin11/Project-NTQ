 128          //--------------------------------------------------
 129          // Description  : Initialize OD memory start address
 130          // Input Value  : None
 131          // Output Value : None
 132          //--------------------------------------------------
 133          void ScalerODSetMemoryStartAddress(void)
 134          {
 135   1          DWORD ulODUseSpace = 0;
 136   1          DWORD ulODUseSpaceInRow = 0;
 137   1      
 138   1          //=============================================
 139   1          // Calculate memory usage
 140   1          //=============================================
 141   1          ulODUseSpace = ((DWORD)CEILING(_PANEL_DH_WIDTH, _OD_PIXEL_PER_COMP)) * _PANEL_DV_HEIGHT * GET_OD_USE_B
             -IT() / 10;
 142   1      
 143   1          // OD memory access unit: 64bit
 144   1          ulODUseSpace = CEILING(ulODUseSpace, _OD_FIFO_BUS_WIDTH);
 145   1      
 146   1          ulODUseSpaceInRow = ulODUseSpace / _MEMORY_BIT_NUM / (_MEMORY_COL_PER_BANK * _MEMORY_BANK) + 1;
 147   1      
 148   1      
 149   1          //=============================================
 150   1          // Set start address
 151   1          //=============================================
 152   1      #if(_MEMORY_SIZE_CONFIG == _16M_16BIT_DDR2_1PC)
              
                  ulODUseSpaceInRow = CEILING_OF_INT_DIVISION(ulODUseSpaceInRow, _OD_PATH_NUM);
              
                  // OD M1
                  PDATA_DWORD(1) = (DWORD)_MEMORY_ROW - ulODUseSpaceInRow;
                  PDATA_DWORD(0) = PDATA_DWORD(1) << _OD_ROW_ADDR_SHIFT_BIT_NUM;
                  ScalerSetBit(P3_DA_LS_DDR_START_ADDR_MSB, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (pData[0] & 0x0F));
                  ScalerSetByte(P3_DB_LS_DDR_START_ADDR_H, pData[1]);
                  ScalerSetByte(P3_DC_LS_DDR_START_ADDR_M, pData[2]);
                  ScalerSetByte(P3_DD_LS_DDR_START_ADDR_L, pData[3]);
              
                  // OD M2
                  PDATA_DWORD(1) -= ulODUseSpaceInRow;
                  PDATA_DWORD(0) = PDATA_DWORD(1) << _OD_ROW_ADDR_SHIFT_BIT_NUM;
                  ScalerSetBit(P43_DA_LS_DDR_START_ADDR_MSB, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (pData[0] & 0x0F));
                  ScalerSetByte(P43_DB_LS_DDR_START_ADDR_H, pData[1]);
                  ScalerSetByte(P43_DC_LS_DDR_START_ADDR_M, pData[2]);
                  ScalerSetByte(P43_DD_LS_DDR_START_ADDR_L, pData[3]);
C51 COMPILER V9.60.0.0   RL6449_SERIES_OD                                                  10/18/2025 16:25:52 PAGE 4   

              
              #else // _MEMORY_SIZE_CONFIG == _16M_16BIT_DDR2_2PCS
 173   1      
 174   1          PDATA_DWORD(0) = ((DWORD)_MEMORY_ROW - ulODUseSpaceInRow) << _OD_ROW_ADDR_SHIFT_BIT_NUM;
 175   1      
 176   1          // OD M1
 177   1          ScalerSetBit(P3_DA_LS_DDR_START_ADDR_MSB, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (pData[0] & 0x0F));
 178   1          ScalerSetByte(P3_DB_LS_DDR_START_ADDR_H, pData[1]);
 179   1          ScalerSetByte(P3_DC_LS_DDR_START_ADDR_M, pData[2]);
 180   1          ScalerSetByte(P3_DD_LS_DDR_START_ADDR_L, pData[3]);
 181   1      
 182   1          // OD M2
 183   1          ScalerSetBit(P43_DA_LS_DDR_START_ADDR_MSB, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (pData[0] & 0x0F));
 184   1          ScalerSetByte(P43_DB_LS_DDR_START_ADDR_H, pData[1]);
 185   1          ScalerSetByte(P43_DC_LS_DDR_START_ADDR_M, pData[2]);
 186   1          ScalerSetByte(P43_DD_LS_DDR_START_ADDR_L, pData[3]);
 187   1      #endif
 188   1      }
