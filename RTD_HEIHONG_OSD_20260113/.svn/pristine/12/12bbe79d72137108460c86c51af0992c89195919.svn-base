 191          //--------------------------------------------------
 192          // Description  : Dynamic OD handler interrupt process (EXINT0 only)
 193          //                Dynamically enable/disable OD for memory bandwidth saving
 194          // Input Value  : None
 195          // Output Value : None
 196          //--------------------------------------------------
 197          void ScalerODIntHandler_EXINT0(void) using 1
 198          {
 199   1          // DEN_START event
 200   1          if(ScalerGetBit_EXINT(P0_05_IRQ_CTRL1, (_BIT3 | _BIT2)) == (_BIT3 | _BIT2))
 201   1          {
 202   2              BYTE ucBackupDataPortAddr = 0;
 203   2              BYTE ucFreerunDVSCount = 0;
 204   2      
 205   2              // Set DEN_START flag
 206   2              SET_EVENT_DEN_START_INT(_TRUE);
 207   2      
 208   2              // Clear DEN_START IRQ flag
 209   2              ScalerSetBit_EXINT(P0_05_IRQ_CTRL1, ~(_BIT6 | _BIT4 | _BIT2), _BIT2);
 210   2      
 211   2              //=======================================================
 212   2              // Get current serial number in repeated frame sequence
 213   2              //=======================================================
 214   2              // Backup data port address
 215   2              ucBackupDataPortAddr = ScalerGetByte_EXINT(P0_2A_DISPLAY_FORMAT_ADDR_PORT);
 216   2      
 217   2              // Get current free run DVS counter
 218   2              ScalerSetByte_EXINT(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_28_FREE_RUN_DVS_CNT);
 219   2              ucFreerunDVSCount = ScalerGetByte_EXINT(P0_2B_DISPLAY_FORMAT_DATA_PORT);
 220   2      
 221   2              // Resume data port address
 222   2              ScalerSetByte_EXINT(P0_2A_DISPLAY_FORMAT_ADDR_PORT, ucBackupDataPortAddr);
 223   2      
 224   2              //=======================================================
 225   2              // Set OD control registers according to current state
 226   2              //=======================================================
 227   2              switch(GET_MEMORY_DVF_SELECT())
 228   2              {
 229   3                  //====================================
 230   3                  // DVF = 2 IVF, EX: 30 to 60Hz
 231   3                  //====================================
 232   3                  // I-domain frame:          |______F1_______|______F2_______|______F3_______|
C51 COMPILER V9.60.0.0   RL6449_SERIES_OD                                                  10/18/2025 16:25:52 PAGE 5   

 233   3                  // D-domain frame:           |__F0___|__F0___|__F1___|__F1___|__F2___|__F2___|
 234   3                  // <Free run DVS count>:     |___0___|___1___|___0___|___1___|___0___|___1___|
 235   3                  // <OD control>:             |___on__|__off__|___on__|__off__|___on__|__off__|
 236   3                  // OD actual(DB effective):  |_______|___ON__|__OFF__|___ON__|__OFF__|___ON__|
 237   3                  // OD memory access:         |_______|_______|___R___|___W___|___R___|___W___|
 238   3                  case _2_IVF:
 239   3                      switch(ucFreerunDVSCount)
 240   3                      {
 241   4                          case 0:
 242   4                              // Enable OD
 243   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 244   4                              break;
 245   4      
 246   4                          case 1:
 247   4                              // Disable OD
 248   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 249   4                              break;
 250   4      
 251   4                          default:
 252   4                              break;
 253   4                      }
 254   3                      break;
 255   3      
 256   3                  //====================================
 257   3                  // DVF = 2.5 IVF, EX: 24 to 60Hz
 258   3                  //====================================
 259   3                  // I-domain frame:          |________F1_________|________F2_________|________F3_________|_____
             -___F4_________|
 260   3                  // D-domain frame:           |__F0___|__F0___|__F0___|__F1___|__F1___|__F2___|__F2___|__F2___|
             -__F3___|__F3___|
 261   3                  // <Free run DVS count>:     |___0___|___1___|___2___|___3___|___4___|___0___|___1___|___2___|
             -___3___|___4___|
 262   3                  // <OD control>:             |__off__|___on__|__off__|___on__|__off__|__off__|___on__|__off__|
             -___on__|__off__|
 263   3                  // OD actual(DB effective):  |_______|__OFF__|___ON__|__OFF__|___ON__|__OFF__|__OFF__|___ON__|
             -__OFF__|___ON__|
 264   3                  // OD memory access:         |_______|_______|___W___|___R___|___W___|___R___|_______|___W___|
             -___R___|___W___|
 265   3                  case _2_5_IVF:
 266   3                      switch(ucFreerunDVSCount)
 267   3                      {
 268   4                          case 0:
 269   4                          case 2:
 270   4                          case 4:
 271   4                              // Disable OD
 272   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), 0x00);
 273   4                              break;
 274   4      
 275   4                          case 1:
 276   4                          case 3:
 277   4                              // Enable OD
 278   4                              ScalerSetBit_EXINT(P3_A1_LS_CTRL0, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 279   4                              break;
 280   4      
 281   4                          default:
 282   4                              break;
 283   4                      }
 284   3                      break;
 285   3      
 286   3                  //====================================
 287   3                  // DVF = 3 IVF, EX: 24 to 72Hz
 288   3                  //====================================
C51 COMPILER V9.60.0.0   RL6449_SERIES_OD                                                  10/18/2025 16:25:52 PAGE 6   

 289   3                  // I-domain frame:          |__________F1___________|__________F2___________|__________F3_____
             -______|
 290   3                  // D-domain frame:           |__F0___|__F0___|__F0___|__F1___|__F1___|__F1___|__F2___|__F2___|
