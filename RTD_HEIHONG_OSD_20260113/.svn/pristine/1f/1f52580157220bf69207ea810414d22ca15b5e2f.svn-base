  48          //****************************************************************************
  49          //--------------------------------------------------
  50          // Description  : Initial for VGIP Input
  51          // Input Value  : Input Source Type
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerVgipInputInitial(EnumSourceTypeDef enumSourceType, EnumSourceSearchPort enumSourceSearchPort)
  55          {
  56   1          enumSourceType = enumSourceType;
  57   1      
  58   1          // Initial format conversion
  59   1          ScalerFmtCnvInitialSetting(enumSourceSearchPort);
  60   1      
  61   1          // Set source from format conversion; Disable Double buffer, Analog Capture, and Stop generate DE
  62   1          ScalerSetBit(P0_10_M1_VGIP_CTRL, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2));
  63   1      
  64   1          // HS Sync Edge select to Positive, Disable 1 clock Delay Mode
  65   1          ScalerSetBit(P0_12_M1_VGIP_DELAY_CTRL, ~(_BIT4 | _BIT3 | _BIT2), 0x00);
  66   1      
  67   1          // Set M2 VGIP state
  68   1          ScalerSetBit(P40_10_M2_VGIP_CTRL, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2));
  69   1          ScalerSetBit(P40_12_M2_VGIP_DELAY_CTRL, ~(_BIT4 | _BIT3 | _BIT2), 0x00);
  70   1      
  71   1          // Reset field detect edge
  72   1          ScalerSetBit(P0_11_M1_VGIP_SIGINV, ~(_BIT5 | _BIT3), 0x00);
  73   1          ScalerSetBit(P40_11_M2_VGIP_SIGINV, ~(_BIT5 | _BIT3), 0x00);
  74   1      
  75   1      #if(_FREESYNC_SUPPORT == _ON)
                  if((GET_FREESYNC_ENABLED() == _TRUE) && (enumSourceType == _SOURCE_DP))
                  {
                      // Enable bypass Vsync
                      ScalerVgipVsBypassEnable(_ENABLE);
                  }
                  else
                  {
                      // Disable bypass Vsync
                      ScalerVgipVsBypassEnable(_DISABLE);
                  }
              #else
  87   1          // Disable bypass Vsync
  88   1          ScalerVgipVsBypassEnable(_DISABLE);
  89   1      #endif
  90   1      
  91   1          // Set clock gating
  92   1          // ScalerSetBit(P80_1F_S1_ICLK_GATED_CTRL1, ~_BIT3, 0x00);
  93   1          // ScalerSetBit(PC0_1F_S2_ICLK_GATED_CTRL1, ~_BIT3, 0x00);
  94   1      
  95   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
  96   1          // Set to analog measure
  97   1          ScalerVgipSetDigitalCaptureStatus(_DISABLE);
  98   1      #endif
  99   1      
 100   1          // Initial IVS/IHS Delay for Capture and Auto
 101   1          ScalerVgipSetCaptureHDelay(0x00);
 102   1          ScalerVgipSetCaptureVDelay(0x00);
 103   1      
 104   1      #if((_MEASURE_ADJUSTED_IHF_SUPPORT == _ON) || (_MEASURE_ADJUSTED_IVF_SUPPORT == _ON))
 105   1          ScalerVgipSetCaptureHStartPosition(0x00);
 106   1          ScalerVgipSetCaptureVStartPosition(0x00);
 107   1      
 108   1          // Set to digital measure
 109   1          ScalerVgipSetDigitalCaptureStatus(_ENABLE);
C51 COMPILER V9.60.0.0   RL6449_SERIES_VGIP                                                10/18/2025 16:53:48 PAGE 3   

 110   1      #endif
 111   1      }


