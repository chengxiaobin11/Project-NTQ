 331          //--------------------------------------------------
 332          // Description  : Reset DPTX PLL Setting, Disable DPTX PLL Spread Spectrum Output
 333          // Input Value  : None
 334          // Output Value : None
 335          //--------------------------------------------------
 336          void ScalerPLLDPTxPLLReset(void)
 337          {
 338   1          // Check SSC is enable or not
 339   1          if(ScalerGetBit(P38_D5_DPTX_CMU5, _BIT5) != 0x00)
 340   1          {
 341   2              // Disable SSC
 342   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT5, 0x00);
 343   2      
 344   2              // SSC Off stable
 345   2              ScalerTimerDelayXms(2);
 346   2          }
 347   1      
 348   1          // Disable CMU Power
 349   1          ScalerSetBit(P38_A0_DPTX_PHY_CTRL0, ~_BIT4, 0x00);
 350   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_PLL                                                 10/18/2025 16:53:41 PAGE 7   

 351   1          // Disabe DP TX Power
 352   1          ScalerSetBit(P38_A0_DPTX_PHY_CTRL0, ~_BIT7, 0x00);
 353   1      }
