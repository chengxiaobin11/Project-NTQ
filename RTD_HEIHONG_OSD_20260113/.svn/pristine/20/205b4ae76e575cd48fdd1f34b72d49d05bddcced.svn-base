  84          
  85          //--------------------------------------------------
  86          // Description  : Get DPLL Ref Clk from DPTx PLL or Xtal
  87          // Input Value  : Dclk
  88          // Output Value : DPTx PLL clk or Xtal Clk
  89          //--------------------------------------------------
  90          DWORD ScalerPLLGetDPLLRefClk(DWORD ulFreq)
  91          {
  92   1      #if((_PANEL_STYLE == _PANEL_VBO) || (_PANEL_STYLE == _PANEL_DPTX))
  93   1          DWORD ulMacClk = 0;
  94   1      #if(_PANEL_STYLE == _PANEL_VBO)
  95   1          DWORD ulDPTxClkIn = 0;
  96   1      #endif
  97   1      #endif
  98   1      
  99   1          ulFreq = ulFreq;
 100   1      
 101   1      #if(_PANEL_STYLE == _PANEL_VBO)
 102   1      
 103   1          ulMacClk = (ulFreq * _VBO_BYTE_MODE) / _VBO_OUTPUT_PORT;
 104   1      
 105   1      #elif(_PANEL_STYLE == _PANEL_DPTX)
              
                  if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_RBR)
                  {
                      ulMacClk = _DPTX_PHY_RATE_RBR / 10;
C51 COMPILER V9.60.0.0   RL6449_SERIES_PLL                                                 10/18/2025 16:53:41 PAGE 3   

                  }
                  else if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_HBR)
                  {
                      ulMacClk = _DPTX_PHY_RATE_HBR / 10;
                  }
                  else if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_HBR2)
                  {
                      ulMacClk = _DPTX_PHY_RATE_HBR2 / 10;
                  }
              
              #endif // End of #if(_PANEL_STYLE == _PANEL_VBO)
 121   1      
 122   1      #if(_PANEL_STYLE == _PANEL_DPTX)
              
                  ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT1), 0x00);
              
                  return (_EXT_XTAL);
              
              #elif(_PANEL_STYLE == _PANEL_VBO)
 129   1      
 130   1          ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT1), _BIT1);
 131   1      
 132   1          if(ulMacClk > _DPTX_CLK_IN_BOUNDRY_2)
 133   1          {
 134   2              ulDPTxClkIn = ulMacClk / 16;
 135   2              ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT3 | _BIT2), (_BIT3 | _BIT2));
 136   2          }
 137   1          else if(ulMacClk > _DPTX_CLK_IN_BOUNDRY_1)
 138   1          {
 139   2              ulDPTxClkIn = ulMacClk / 8;
 140   2              ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT3 | _BIT2), (_BIT3));
 141   2          }
 142   1          else if(ulMacClk > _DPTX_CLK_IN_BOUNDRY_0)
 143   1          {
 144   2              ulDPTxClkIn = ulMacClk / 4;
 145   2              ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT3 | _BIT2), (_BIT2));
 146   2          }
 147   1          else
 148   1          {
 149   2              ulDPTxClkIn = ulMacClk / 2;
 150   2              ScalerSetBit(P1_D8_DPLL_RELOAD_CTRL, ~(_BIT3 | _BIT2), 0x00);
 151   2          }
 152   1      
 153   1          return (ulDPTxClkIn);
 154   1      
 155   1      #endif // End of #if(_PANEL_STYLE == _PANEL_DPTX)
 156   1      }
 157          
 158          #if((_PANEL_STYLE == _PANEL_VBO) || (_PANEL_STYLE == _PANEL_DPTX))
 159          //--------------------------------------------------
 160          // Description  : Set DPLL Referenced DPTX PLL: Frequency, VCO Band
 161          // Input Value  : Target Freq
 162          // Output Value : None
 163          //--------------------------------------------------
 164          void ScalerPLLSetDPLLRefPLL(DWORD ulFreq)
 165          {
 166   1          WORD usNCode = 0;
 167   1          WORD usFCode = 0;
 168   1          DWORD ulCMUFreq = 0;
 169   1      
 170   1      #if(_PANEL_STYLE == _PANEL_VBO)
 171   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_PLL                                                 10/18/2025 16:53:41 PAGE 4   

 172   1          ulCMUFreq = (ulFreq * _VBO_BYTE_MODE * 10) / _VBO_OUTPUT_PORT;
 173   1      
 174   1          // Set Center SSC
 175   1          ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT6, _BIT6);
 176   1      
 177   1          if(ScalerGetBit(P38_A0_DPTX_PHY_CTRL0, _BIT4) == 0x00)
 178   1          {
 179   2              // Disable SSC Function
 180   2              ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT5, 0x00);
 181   2          }
 182   1      
 183   1      #elif(_PANEL_STYLE == _PANEL_DPTX)
              
                  if(ScalerGetBit(P38_A0_DPTX_PHY_CTRL0, _BIT4) == _BIT4)
                  {
                      return;
                  }
              
                  ulFreq = ulFreq;
              
                  // HBR2 = 5.4GHz, HBR = 2.7GHz, RBR = 1.62GHz
                  if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_RBR)
                  {
                      ulCMUFreq = _DPTX_PHY_RATE_RBR;
                  }
                  else if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_HBR)
                  {
                      ulCMUFreq = _DPTX_PHY_RATE_HBR;
                  }
                  else if(_PANEL_DPTX_LINK_RATE == _PANEL_DPTX_LINK_HBR2)
                  {
                      ulCMUFreq = _DPTX_PHY_RATE_HBR2;
                  }
              
                  // Set Down SSC
                  ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT6, 0x00);
              
                  // Disable SSC Function
                  ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT5, 0x00);
              
              #endif
 213   1      
 214   1          // Enable Power of DPTX
 215   1          ScalerSetBit(P38_A0_DPTX_PHY_CTRL0, ~_BIT7, _BIT7);
 216   1      
 217   1          // Divider for Postdivider of CMU and Pre-divder of CMU
 218   1          ScalerSetBit(P38_D2_DPTX_CMU2, ~(_BIT4 | _BIT1 | _BIT0), 0x00);
 219   1      
 220   1          // LDO voltage Setting
 221   1          ScalerSetBit(P38_D3_DPTX_CMU3, ~(_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT1 | _BIT0), (_BIT6 | _BIT4 | _BIT
             -2 | _BIT0));
 222   1      
 223   1          // CLKRD duty set to 4'b1111 @0638 as AMlee suggests.
 224   1          // Good Phase setting H/L = 4/6
 225   1          ScalerSetBit(P38_C2_DPTX_CKRDDUTY_SPD_SEL0, ~0xFF, 0xFF);
 226   1      
 227   1          // [7] 0:CCO Mode, 1:VCO Mode
 228   1          // [6] 0:Small Kvco, 1:Big Kvco
 229   1          // [5] 0:3rd LPF, 1:2nd LPF
 230   1          // [4] 0:1pF, 1:2pF (CMU'S LPF Cp)
 231   1          // [3] 0:Use PI, 1:Bypass PI
 232   1          // [2:0] PI Current setting
C51 COMPILER V9.60.0.0   RL6449_SERIES_PLL                                                 10/18/2025 16:53:41 PAGE 5   

 233   1          ScalerSetBit(P38_D0_DPTX_CMU0, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT
             -6 | _BIT5 | _BIT4 | _BIT1 | _BIT0));
 234   1      
 235   1          if(ulCMUFreq > _DPTX_PLL_BOUNDRY_3)
 236   1          {
 237   2              // Phy range = 3~6 GHz
 238   2              ulCMUFreq = ulCMUFreq;
 239   2      
 240   2              // VCO = 3~6 GHz, spdsel = div1
 241   2              ScalerSetBit(P38_C3_DPTX_CKRDDUTY_SPD_SEL1, ~(_BIT1 | _BIT0), 0x00);
 242   2      
 243   2              // [6:4] CMU'S LPF Rs
 244   2              // [3:0] CMU'S CP Current
 245   2              ScalerSetBit(P38_D1_DPTX_CMU1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT6 | 
             -_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1));
 246   2          }
 247   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_2)
 248   1          {
 249   2              // Phy range = 1.5 ~ 3 GHz
 250   2              ulCMUFreq = ulCMUFreq * 2;
 251   2      
 252   2              // VCO = 3~6 GHz, spdsel = div2
 253   2              ScalerSetBit(P38_C3_DPTX_CKRDDUTY_SPD_SEL1, ~(_BIT1 | _BIT0), _BIT0);
 254   2      
 255   2              // [6:4] CMU'S LPF Rs
 256   2              // [3:0] CMU'S CP Current
 257   2              ScalerSetBit(P38_D1_DPTX_CMU1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT6 | 
             -_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1));
 258   2          }
 259   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_1)
 260   1          {
 261   2              // Phy range = 1.5 ~ 3 GHz
 262   2              ulCMUFreq = ulCMUFreq * 2;
 263   2      
 264   2              // VCO = 3~6 GHz, spdsel = div2
 265   2              ScalerSetBit(P38_C3_DPTX_CKRDDUTY_SPD_SEL1, ~(_BIT1 | _BIT0), _BIT0);
 266   2      
 267   2              // [6:4] CMU'S LPF Rs
 268   2              // [3:0] CMU'S CP Current
 269   2              ScalerSetBit(P38_D1_DPTX_CMU1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | 
             -_BIT2));
 270   2          }
 271   1          else if(ulCMUFreq > _DPTX_PLL_BOUNDRY_0)
 272   1          {
 273   2              // Phy range = 0.75 ~ 1.5 GHz
 274   2              ulCMUFreq = ulCMUFreq * 4;
 275   2      
 276   2              // VCO = 3~6 GHz, spdsel = div4
 277   2              ScalerSetBit(P38_C3_DPTX_CKRDDUTY_SPD_SEL1, ~(_BIT1 | _BIT0), _BIT1);
 278   2      
 279   2              // [6:4] CMU'S LPF Rs
 280   2              // [3:0] CMU'S CP Current
 281   2              ScalerSetBit(P38_D1_DPTX_CMU1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | 
             -_BIT2));
 282   2          }
 283   1          else
 284   1          {
 285   2              // VCO = 375 ~ 750 MHz
 286   2              ulCMUFreq = ulCMUFreq * 8;
 287   2      
 288   2              // VCO = 3~6 GHz, spdsel = div8
 289   2              ScalerSetBit(P38_C3_DPTX_CKRDDUTY_SPD_SEL1, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
C51 COMPILER V9.60.0.0   RL6449_SERIES_PLL                                                 10/18/2025 16:53:41 PAGE 6   

 290   2      
 291   2              // [6:4] CMU'S LPF Rs
 292   2              // [3:0] CMU'S CP Current
 293   2              ScalerSetBit(P38_D1_DPTX_CMU1, ~(_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | 
             -_BIT2));
 294   2          }
 295   1      
 296   1          // Count N.F Code
 297   1          usNCode = ulCMUFreq / (_EXT_XTAL * 2) - 4;
 298   1          usFCode = ulCMUFreq % (_EXT_XTAL * 2);
 299   1      
 300   1          if(usFCode != 0)
 301   1          {
 302   2              ulCMUFreq = ((DWORD)usFCode << 12);
 303   2              usFCode = ulCMUFreq / (_EXT_XTAL * 2);
 304   2          }
 305   1      
 306   1          // N Code = 9 bit
 307   1          // F Code = 12 bit
 308   1          usNCode &= 0x1FF;
 309   1          usFCode &= 0xFFF;
 310   1      
 311   1          ScalerSetByte(P38_DE_DPTX_CMU14, (BYTE)usFCode);
 312   1          ScalerSetByte(P38_DD_DPTX_CMU13, ((BYTE)(usNCode << 4) | (BYTE)(usFCode >> 8)));
 313   1          ScalerSetByte(P38_DC_DPTX_CMU12, (BYTE)(_BIT7 | (usNCode >> 4)));
 314   1      
 315   1          // Enable CMU power
 316   1          ScalerSetBit(P38_A0_DPTX_PHY_CTRL0, ~_BIT4, _BIT4);
 317   1      
 318   1          // Wait for CMU Stable
 319   1          ScalerTimerDelayXms(2);
 320   1      
 321   1          // Enable Watch Dog
 322   1          ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT7, _BIT7);
 323   1      
 324   1          // Wait Watch Dog to check PLL is stable or not
 325   1          ScalerTimerPollingFlagProc(2, P38_D4_DPTX_CMU4, _BIT7, _TRUE);
 326   1      
 327   1          // Disable WD
 328   1          ScalerSetBit(P38_D5_DPTX_CMU5, ~_BIT7, 0x00);
 329   1      }
