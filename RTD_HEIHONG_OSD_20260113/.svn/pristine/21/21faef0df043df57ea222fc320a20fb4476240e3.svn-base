 166          //--------------------------------------------------
 167          // Description  : Check memory
 168          // Input Value  : None
 169          // Output Value : Memory check pass or fail
 170          //--------------------------------------------------
 171          bit ScalerMDomainMemoryCheck(void)
 172          {
 173   1          if((GET_V_SCALE_DOWN() == _TRUE) && (GET_MDOMAIN_OUTPUT_HTOTAL() > (GET_MDOMAIN_OUTPUT_HWIDTH() << 1))
             -)
 174   1          {
 175   2      #if(_FRC_SUPPORT == _ON)
 176   2              // Iclk > 600M && frame buffer, ignore overflow
 177   2              if(ScalerGetBit(P0_0D_WATCH_DOG_CTRL1, _BIT7) == 0x00)
 178   2              {
 179   3                  // Check Input HVsync error flag, Display Vsync timeout flag
 180   3                  if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5)) != 0x00) ||
 181   3                     (ScalerGetBit(P0_0C_WATCH_DOG_CTRL0, _BIT0) != 0x00))
 182   3                  {
 183   4                      return _FALSE;
 184   4                  }
 185   3              }
 186   2              else
 187   2      #endif
 188   2              {
 189   3                  // Check fifo overflow and Input HVsync error flag, Display Vsync timeout flag
 190   3                  if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5 | _BIT1)) != 0x00) ||
 191   3                     (ScalerGetBit(P0_0C_WATCH_DOG_CTRL0, _BIT0) != 0x00))
 192   3                  {
 193   4                      return _FALSE;
 194   4                  }
 195   3              }
 196   2          }
 197   1          else
 198   1          {
 199   2      #if(_FRC_SUPPORT == _ON)
 200   2              // Iclk > 600M && frame buffer, ignore overflow
 201   2              if(GET_IGNORE_OVERFLOW_FLAG() == _TRUE)
 202   2              {
 203   3                  // Check fifo underflow and Input HVsync error flag, Display Vsync timeout flag
 204   3                  if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5 | _BIT0)) != 0x00) ||
 205   3                     (ScalerGetBit(P0_0C_WATCH_DOG_CTRL0, _BIT0) != 0x00))
 206   3                  {
 207   4                      return _FALSE;
 208   4                  }
 209   3              }
 210   2              else
 211   2      #endif
 212   2              {
 213   3                  // Check fifo underflow & overflow and Input HVsync error flag, Display Vsync timeout flag
 214   3                  if((ScalerGetBit(P0_02_STATUS0, (_BIT6 | _BIT5 | _BIT1 | _BIT0)) != 0x00) ||
 215   3                     (ScalerGetBit(P0_0C_WATCH_DOG_CTRL0, _BIT0) != 0x00))
 216   3                  {
 217   4                      return _FALSE;
 218   4                  }
 219   3              }
 220   2          }
 221   1      
 222   1          return _TRUE;
 223   1      }
