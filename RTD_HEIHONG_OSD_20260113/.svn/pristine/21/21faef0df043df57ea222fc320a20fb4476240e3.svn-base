C51 COMPILER V9.60.0.0   RL6449_SERIES_MDOMAIN                                             10/18/2025 16:53:37 PAGE 2   

  48          // Output Value : None
  49          // Note : Only for Frame Sync case
  50          //--------------------------------------------------
  51          void ScalerMDomainControlDBApply(void)
  52          {
  53   1          bit bFreeRunEn = _FALSE;
  54   1      
  55   1          // Enable double buffer
  56   1          if((GET_MEMORY_SELECT() == _FRAME_SYNC_LINE_BUFFER) || (GET_MEMORY_SELECT() == _FRAME_SYNC_MEMORY) || 
             -(GET_MEMORY_SELECT() == _MN_FRAME_SYNC_MEMORY))
  57   1          {
  58   2              if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT1) == _BIT1)
  59   2              {
  60   3                  // Avoid (Current_IVStart + IVHeight) > IVToal + New_IVSDelay in digital capture
  61   3                  PDATA_WORD(0) = (g_stInputTimingData.usVStart + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  62   3              }
  63   2              else
  64   2              {
  65   3                  // Avoid (Current_IVSDelay + IVStart + IVHeight) > IVToal + New_IVSDelay in analog capture
  66   3                  PDATA_WORD(0) = (ScalerVgipGetCaptureVDelay() + ScalerVgipGetCaptureVStartPosition() + g_stMDo
             -mainInputData.usVHeight);
  67   3              }
  68   2      
  69   2              bFreeRunEn = (PDATA_WORD(0) > g_stMDomainInputData.usVTotal) ? (_TRUE) : (_FALSE);
  70   2      
  71   2      
  72   2              if(bFreeRunEn == _TRUE)
  73   2              {
  74   3                  ScalerTimerWaitForEvent(_EVENT_DEN_START);
  75   3      
  76   3                  // Set Free run
  77   3                  ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, 0x00);
  78   3      
  79   3                  ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_BIT7, 0x
             -00);
  80   3              }
  81   2      
  82   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
  83   2      
  84   2              if(bFreeRunEn == _TRUE)
  85   2              {
  86   3                  switch(GET_MEMORY_DVF_SELECT())
  87   3                  {
  88   4                      case _1_IVF:
  89   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
  90   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
  91   4      
  92   4                          // Set Frame sync
  93   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
  94   4                          break;
  95   4      
  96   4                      case _2_IVF:
  97   4                      case _3_IVF:
  98   4                          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_27_N_FOR_MN_FRAME_RATE
             -, 1, &pData[15], _NON_AUTOINC);
  99   4      
 100   4                          ScalerTimerWaitForEvent(_EVENT_IEN_STOP);
 101   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
 102   4      
 103   4                          while(pData[15] > 0)
 104   4                          {
C51 COMPILER V9.60.0.0   RL6449_SERIES_MDOMAIN                                             10/18/2025 16:53:37 PAGE 3   

 105   5                              pData[15] --;
 106   5                              ScalerTimerWaitForEvent(_EVENT_DEN_START);
 107   5                          }
 108   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 109   4      
 110   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
 111   4                          ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_
             -BIT7, _BIT7);
 112   4                          break;
 113   4      
 114   4                      case _2_5_IVF:
 115   4                          // Measure DVtotal in current mode
 116   4                          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, _BIT5);
 117   4                          ScalerSetBit(P0_44_LAST_LINE_H, ~_BIT7, _BIT7);
 118   4      
 119   4                          // Get N frame
 120   4                          ScalerGetDataPortByte(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_27_N_FOR_MN_FRAME_RATE
             -, 1, &pData[15], _NON_AUTOINC);
 121   4      
 122   4                          // Get free run DVtotal
 123   4                          PDATA_WORD(6) = GET_FREE_RUN_DVTOTAL();
 124   4      
 125   4                          ScalerTimerWaitForEvent(_EVENT_IEN_STOP);
 126   4                          ScalerTimerWaitForEvent(_EVENT_IVS);
 127   4      
 128   4                          GET_DVTOTAL_LASTLINE(PDATA_WORD(0));
 129   4      
 130   4                          if(PDATA_WORD(0) < (PDATA_WORD(6) * 7 / 10))
 131   4                          {
 132   5                              while(pData[15] > 0)
 133   5                              {
 134   6                                  pData[15] --;
 135   6                                  ScalerTimerWaitForEvent(_EVENT_DEN_START);
 136   6                              }
 137   5                          }
 138   4                          else
 139   4                          {
 140   5                              ScalerTimerWaitForEvent(_EVENT_DEN_START);
 141   5                          }
 142   4      
 143   4                          ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
 144   4      
 145   4                          ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT3, _BIT3);
 146   4                          ScalerSetDataPortBit(P0_2A_DISPLAY_FORMAT_ADDR_PORT, _P0_2B_PT_25_MN_FRAME_RATE_EN, ~_
             -BIT7, _BIT7);
 147   4                          ScalerSetBit(P0_43_FS_DELAY_FINE_TUNE, ~_BIT5, 0x00);
 148   4                          break;
 149   4      
 150   4                      default:
 151   4                          break;
 152   4                  }
 153   3              }
 154   2          }
 155   1          else
 156   1          {
 157   2              ScalerGlobalIDomainDBApply(_DB_APPLY_POLLING);
 158   2          }
 159   1          ScalerGlobalDDomainDBApply(_DB_APPLY_POLLING);
 160   1      
 161   1      #if(_LOCAL_DIMMING_SUPPORT == _ON)
                  ScalerColorDDomainDBApply(_DB_APPLY_POLLING);
              #endif
C51 COMPILER V9.60.0.0   RL6449_SERIES_MDOMAIN                                             10/18/2025 16:53:37 PAGE 4   

 164   1      }
