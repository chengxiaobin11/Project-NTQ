 225          //--------------------------------------------------
 226          // Description  : Apply Display Timing Gen Double Buffer
 227          // Input Value  : None
 228          // Output Value : None
 229          //--------------------------------------------------
 230          void ScalerMDomainDisplayTimingGenDBApply(EnumDBApply enumDBApply)
 231          {
 232   1          if(enumDBApply != _DB_APPLY_NONE)
 233   1          {
 234   2              // Check if Display Timing Gen DB is enabled
 235   2              if(ScalerGetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _BIT7) == 0x00)
 236   2              {
 237   3                  return;
 238   3              }
 239   2      
 240   2              // Check D domain status
 241   2              if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
 242   2                 (GET_DPLL_POWER_STATUS() == _FALSE))
 243   2              {
 244   3                  // Disable Double Buffer
 245   3                  ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 246   3                  return;
 247   3              }
 248   2      
 249   2              // Apply Display Timing Gen Double Buffer
 250   2              ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT6, _BIT6);
 251   2      
 252   2              if(enumDBApply == _DB_APPLY_POLLING)
 253   2              {
 254   3                  // Wait Display Timing Gen double buffer
 255   3                  if(ScalerTimerPollingFlagProc(_DOUBLE_BUFFER_WAIT_TIME, P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, _B
             -IT6, 0) == _FALSE)
 256   3                  {
 257   4                      // Disable Double Buffer
 258   4                      ScalerSetBit(P0_2F_DISPLAY_FORMAT_DOUBLE_BUFFER, ~_BIT7, 0x00);
 259   4                  }
 260   3              }
 261   2          }
 262   1      }
