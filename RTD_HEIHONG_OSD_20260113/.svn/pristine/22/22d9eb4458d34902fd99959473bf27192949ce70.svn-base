6050   1          // [5] edge_det_mode = 1 --> Edge Lag Data
6051   1          // [4] transition_only = 1 --> Only Transition Bit is Effective
6052   1          // [3] le_auto_reload = 0 --> Disable Auto-reload LE Coefficient
6053   1          // [2:0] tap1_delay[2:0] = 3'b010 --> Tap1+LE Delay 2us after Tap0
6054   1          ScalerSetByte(P1D_E0_MODE_TIMER, 0xF2);
6055   1      
