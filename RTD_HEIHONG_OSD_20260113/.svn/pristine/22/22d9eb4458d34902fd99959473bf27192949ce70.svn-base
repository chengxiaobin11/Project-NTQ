4690          bit ScalerDpRx0DeOnlyJudge(WORD *pusDpVtotal, WORD usHBs2BsCount, DWORD ulVBs2BsCount)
4691          {
4692   1          WORD usMeasureDpVtotal = 0;
4693   1          WORD usDiffVtotal = 0;
4694   1      
4695   1          if(ScalerDpRx0DeOnlyTimngCheck(ulVBs2BsCount) == _TRUE)
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 79  

4696   1          {
4697   2              usMeasureDpVtotal = ScalerDpRx0GetVtotalbyMeasure(usHBs2BsCount, ulVBs2BsCount);
4698   2      
4699   2              usDiffVtotal = abs(usMeasureDpVtotal - *pusDpVtotal);
4700   2      
4701   2              if((usDiffVtotal >= 4) && (usDiffVtotal <= 6))
4702   2              {
4703   3                  DebugMessageRx0("Votal (Measure vs MSA) is different!!", usDiffVtotal);
4704   3      
4705   3                  *pusDpVtotal = usMeasureDpVtotal;
4706   3      
4707   3                  return _TRUE;
4708   3              }
4709   2          }
4710   1      
4711   1          return _FALSE;
4712   1      }
