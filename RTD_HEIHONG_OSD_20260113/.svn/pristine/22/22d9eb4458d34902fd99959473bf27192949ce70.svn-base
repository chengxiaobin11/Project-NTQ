5448   1      
5449   1          // 2% Tolerance
5450   1          if((ABSDWORD(PDATA_WORD(2), usVTotalCount)) > (usVTotalCount * 2 / 100))
5451   1          {
5452   2              return _FALSE;
5453   2          }
5454   1      
5455   1          return _TRUE;
5456   1      }
