5388   1          {
5389   2              PDATA_WORD(0) = ((((WORD)ScalerGetByte(PB_53_DP_SIG_DET_3)) << 8) | ScalerGetByte(PB_54_DP_SIG_DET
             -_4));
5390   2          }
5391   1          else
