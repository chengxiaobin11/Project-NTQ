                  ScalerSetBit(PBB_D7_DPTX_CTSFIFO_CTRL, ~_BIT2, _BIT2);
              
              #if(_DP_FREESYNC_SUPPORT == _ON)
                  if(GET_DP_MST_FREESYNC_ENABLED() == _TRUE)
