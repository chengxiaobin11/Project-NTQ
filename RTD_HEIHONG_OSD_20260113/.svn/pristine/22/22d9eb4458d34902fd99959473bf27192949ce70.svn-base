 210          #if(_D0_DP_EXIST == _ON)
 211          //--------------------------------------------------
 212          // Description  : DP Adjust Vsync Delay
 213          // Input Value  : None
 214          // Output Value : None
 215          //--------------------------------------------------
 216          void ScalerDpRx0AdjustVsyncDelay(void)
 217          {
 218   1          DWORD ulBStoVSDelayDeltaOverflow = 0;
 219   1          DWORD ulBStoVSDelayDeltaUnderflow = 0;
 220   1      
 221   1          if(ScalerGetBit(PB5_21_PG_CTRL_1, (_BIT1 | _BIT0)) == 0x00)// Fifo Ok
 222   1          {
 223   2              return;
 224   2          }
 225   1          else if(ScalerGetBit(PB5_21_PG_CTRL_1, _BIT0) == _BIT0) // Fifo Overflow
 226   1          {
 227   2              // Get Htotal
 228   2              ScalerRead(PB6_08_MSA_HTT_0, 2, &pData[0], _AUTOINC);
 229   2      
 230   2              // ((Link Clk * 256)/ Stream CLK) * Htotal / 256 --> 1 Line
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 5   

 231   2              ulBStoVSDelayDeltaOverflow = (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270UL) * 256) / (
             -(DWORD)GET_INPUT_PIXEL_CLK()) * ((DWORD)PDATA_WORD(0)) / 256;
 232   2      
 233   2              DebugMessageRx0("7. Fifo Overflow --> nVidia Case", ulBStoVSDelayDeltaOverflow);
 234   2          }
 235   1          else if(ScalerGetBit(PB5_21_PG_CTRL_1, _BIT1) == _BIT1) // Fifo Underflow
 236   1          {
 237   2              // Get Hactive
 238   2              ScalerRead(PB6_0C_MSA_HWD_0, 2, &pData[0], _AUTOINC);
 239   2      
 240   2              if(PDATA_WORD(0) != 1366)
 241   2              {
 242   3                  return;
 243   3              }
 244   2      
 245   2              PDATA_WORD(0) = PDATA_WORD(0) - 2;
 246   2      
 247   2              // Set Hactive
 248   2              ScalerSetByte(PB5_45_MN_DPF_HWD_M, pData[0]);
 249   2              ScalerSetByte(PB5_46_MN_DPF_HWD_L, pData[1]);
 250   2      
 251   2              // ((Link Clk * 2)/ Stream CLK) --> 2 pixels
 252   2              ulBStoVSDelayDeltaUnderflow = (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270) * 2) / ((DW
             -ORD)GET_INPUT_PIXEL_CLK());
 253   2      
 254   2              DebugMessageRx0("7. Fifo Underflow --> QD882 Case", ulBStoVSDelayDeltaUnderflow);
 255   2          }
 256   1      
 257   1          // For Initial Value Before Use PDATA_DWORD(0)
 258   1          pData[0] = 0;
 259   1      
 260   1          // Get BStoVSDelay Even
 261   1          ScalerRead(PB5_32_EVBLK2VS_H, 3, &pData[1], _AUTOINC);
 262   1      
 263   1          // For Initial Value Before Use PDATA_DWORD(1)
 264   1          pData[4] = 0;
 265   1      
 266   1          // Get BStoVSDelay Odd
 267   1          ScalerRead(PB5_35_OVBLK2VS_H, 3, &pData[5], _AUTOINC);
 268   1      
 269   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 270   1          PDATA_DWORD(0) = PDATA_DWORD(0) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 271   1      
 272   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 273   1          PDATA_DWORD(1) = PDATA_DWORD(1) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 274   1      
 275   1          // Set Even Field BS to VS Delay
 276   1          ScalerSetByte(PB5_32_EVBLK2VS_H, pData[1]);
 277   1          ScalerSetByte(PB5_33_EVBLK2VS_M, pData[2]);
 278   1          ScalerSetByte(PB5_34_EVBLK2VS_L, pData[3]);
 279   1      
 280   1          // Set Odd Field BS to VS Delay
 281   1          ScalerSetByte(PB5_35_OVBLK2VS_H, pData[5]);
 282   1          ScalerSetByte(PB5_36_OVBLK2VS_M, pData[6]);
 283   1          ScalerSetByte(PB5_37_OVBLK2VS_L, pData[7]);
 284   1      
 285   1          // Enable Double Buffer
 286   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT6, _BIT6);
 287   1      
 288   1          // Reset Display Format Gen
 289   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT7, 0x00);
 290   1          ScalerSetBit(PB5_30_DPF_CTRL_0, ~_BIT7, _BIT7);
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 6   

 291   1      
 292   1          // Polling Vertical BS
 293   1          if(ScalerDpRx0PollingFlagLinkCheck(50, PB6_01_DP_VBID, _BIT0, _TRUE) == _FALSE)
 294   1          {
 295   2              return;
 296   2          }
 297   1      
 298   1          // Delay for PG Stable
 299   1          if(ScalerDpRx0TimerDelayXmsLinkCheck(_DP_ONE_FRAME_TIME_MAX) == _FALSE)
 300   1          {
 301   2              return;
 302   2          }
 303   1      }
