 305          #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 306          //--------------------------------------------------
 307          // Description  : Check VGIP VS bypass for DP
 308          // Input Value  : None
 309          // Output Value : _TRUE / _FALSE
 310          //--------------------------------------------------
 311          bit ScalerDpRx0CheckVgipVsBypass(void)
 312          {
 313   1          // Get Hstart
 314   1          ScalerRead(PB5_43_MN_DPF_HST_M, 2, &pData[0], _AUTOINC);
 315   1      
 316   1          // Get Vstart
 317   1          ScalerRead(PB5_4B_MN_DPF_VST_M, 2, &pData[2], _AUTOINC);
 318   1      
 319   1          // Check for nVedia 2560x1440@144Hz timing (reduced blanking)
 320   1          if((PDATA_WORD(0) < _VGIP_IH_CAPTURE_MIN_VALUE) ||
 321   1             (PDATA_WORD(1) <= _VGIP_IV_CAPTURE_MIN_VALUE))
 322   1          {
 323   2              DebugMessageRx0("DP RX0 VGIP VS Bypass Mode", PDATA_WORD(0));
 324   2      
 325   2              return _TRUE;
 326   2          }
 327   1      
 328   1          return _FALSE;
 329   1      }
 330          #endif
