5394   2              {
5395   3                  PDATA_WORD(0) = 0x4E20;
5396   3              }
5397   2              else if(ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR)
5398   2              {
5399   3                  PDATA_WORD(0) = 0x2710;
5400   3              }
5401   2              else // Both Default && _DP_LINK_RBR Case
5402   2              {
5403   3                  PDATA_WORD(0) = 0x1770;
5404   3              }
5405   2          }
5406   1      
5407   1          // [7] DP_SIG_DET_EN = 0 -> Disable Signal Detection
