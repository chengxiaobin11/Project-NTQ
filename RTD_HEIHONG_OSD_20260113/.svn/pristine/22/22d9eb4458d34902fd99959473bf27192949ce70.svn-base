             -_FALSE)
5422   1          {
5423   2              return _FALSE;
5424   2          }
5425   1      
5426   1          // Pop up The result
5427   1          SET_DP_RX0_MEASURE_POP_UP();
5428   1      
5429   1          // Reset pData to avoid checking fail (F17)
5430   1          PDATA_DWORD(0) = 0;
5431   1      
5432   1          // Get Measure Result
5433   1          ScalerRead(PB5_58_MN_MEAS_CTRL, 3, &pData[1], _AUTOINC);
5434   1      
5435   1          // Get Measure Htotal Counts
5436   1          ScalerRead(PB5_5B_MN_MEAS_HLN_M, 2, &pData[6], _AUTOINC);
5437   1      
