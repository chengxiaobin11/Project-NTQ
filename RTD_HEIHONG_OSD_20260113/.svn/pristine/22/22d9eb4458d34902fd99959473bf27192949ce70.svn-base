4616          WORD ScalerDpRx0GetVtotalbyMeasure(WORD usHBs2BsCount, DWORD ulVBs2BsCount)
4617          {
4618   1          DWORD ulLinkClk = 0;
4619   1          DWORD ulHTotalCount = 0;
4620   1          WORD usDpVtotal = 0;
4621   1      
4622   1          // =========== Link Clock Measure Start ===========
4623   1          PDATA_WORD(0) = ScalerDpRx0SignalDetectMeasureCount(_D0_DP_LANE0, _DP_MEASURE_TARGET_CDR_CLOCK, _DP_ME
             -ASURE_PERIOD_2000_CYCLE);
4624   1      
4625   1          if(PDATA_WORD(0) == 0)
4626   1          {
4627   2              if(ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR3)
4628   2              {
4629   3                  PDATA_WORD(0) = _DP_VCO_TARGET_COUNT_2000_HBR3;
4630   3              }
4631   2              else if(ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR2)
4632   2              {
4633   3                  PDATA_WORD(0) = _DP_VCO_TARGET_COUNT_2000_HBR2;
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 78  

4634   3              }
4635   2              else if(ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR)
4636   2              {
4637   3                  PDATA_WORD(0) = _DP_VCO_TARGET_COUNT_2000_HBR;
4638   3              }
4639   2              else // Both Default && _DP_LINK_RBR Case
4640   2              {
4641   3                  PDATA_WORD(0) = _DP_VCO_TARGET_COUNT_2000_RBR;
4642   3              }
4643   2          }
4644   1      
4645   1          PDATA_DWORD(0) = (((DWORD)PDATA_WORD(0)) * _GDI_CLK_KHZ);
4646   1      
4647   1          // Link Clk in KHz
4648   1          ulLinkClk = (PDATA_DWORD(0) / 1000);
4649   1      
4650   1          // HTotal Count in GDI clk(0.1Hz)
4651   1          ulHTotalCount = ((DWORD)usHBs2BsCount * _GDI_CLK_KHZ * 2 * 10 + (ulLinkClk >> 1)) / ulLinkClk;
4652   1      
4653   1          // VTotal in line_number
4654   1          usDpVtotal = (ulVBs2BsCount * 10 + (ulHTotalCount >> 1)) / ulHTotalCount;
4655   1      
4656   1          return usDpVtotal;
4657   1      }
4658          //--------------------------------------------------
4659          // Description  : Judge timing for using DE-Only mode or not
4660          // Input Value  : usMeasureDpVtotal
4661          // Output Value : _TRUE or _FALSE
4662          //--------------------------------------------------
4663          bit ScalerDpRx0DeOnlyTimngCheck(DWORD ulVBs2BsCount)
4664          {
4665   1          DWORD ulFrameRate = 0;
4666   1      
4667   1          // Get Hactive
4668   1          ScalerRead(PB6_0C_MSA_HWD_0, 2, &pData[0], _AUTOINC);
4669   1      
4670   1          // Get Vactive
4671   1          ScalerRead(PB6_16_MSA_VHT_0, 2, &pData[2], _AUTOINC);
4672   1      
4673   1          // Frame Rate (Unit is 0.01Hz)
4674   1          ulFrameRate = (_GDI_CLK_KHZ * 100000 + (ulVBs2BsCount >> 1)) / ulVBs2BsCount;
4675   1      
4676   1          // Timing-1 : 1280x1024@120Hz (Source : Apple MacBook Air 13" / ChipSet : Apple M1)
4677   1          if((PDATA_WORD(0) == 0x500) && (PDATA_WORD(1) == 0x400) &&
4678   1             ((ulFrameRate >= 11800) && (ulFrameRate <= 12200)))
4679   1          {
4680   2              return _TRUE;
4681   2          }
4682   1      
4683   1          return _FALSE;
4684   1      }
4685          //--------------------------------------------------
4686          // Description  : Judge for using DE-Only mode or not
4687          // Input Value  : usMeasureDpVtotal
4688          // Output Value : _TRUE or _FALSE
