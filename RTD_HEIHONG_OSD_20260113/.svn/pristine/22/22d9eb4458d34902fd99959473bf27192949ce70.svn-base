                  ScalerDpRx0AuxIntInitial();
              
                  SET_DP_RX0_LINK_TRAINING_STATUS(_DP_LINK_TRAINING_NONE);
              
                  SET_DP_RX0_FAKE_LINK_TRAINING();
              
