              //--------------------------------------------------
              // Description  : Handle DP MST to SST Flow
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerDpRx0MstToSstProc(void)
              {
                  if(GET_DP_TX_STREAM_SOURCE() == _DP_TX_SOURCE_NONE)
                  {
                      if(ScalerDpRx0MstToSstScanInputPort() == _TRUE)
                      {
                          if(ScalerDpRx0MstToSstMeasureInput() == _TRUE)
                          {
