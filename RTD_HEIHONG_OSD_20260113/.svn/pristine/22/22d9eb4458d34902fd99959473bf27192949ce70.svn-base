                      }
              
                      memcpy(&g_pucDpTxHdcpKsvFifo[PDATA_WORD(1)], g_pucDpTxHdcp2ReceiverId, 5);
                      PDATA_WORD(1) += 5;
              
              #if(_DP_HDCP14_CTS_SUPPORT == _ON)
                      bLoadAksv = _FALSE;
              #endif
                  }
                  else if(GET_DP_TX_HDCP_DOWNSTREAM_SUPPORTED() == _TRUE)
              #else
                  if(GET_DP_TX_HDCP_DOWNSTREAM_SUPPORTED() == _TRUE)
              #endif
                  {
