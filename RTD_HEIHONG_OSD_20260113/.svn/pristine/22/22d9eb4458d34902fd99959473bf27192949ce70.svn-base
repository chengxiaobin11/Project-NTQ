 501          //--------------------------------------------------
 502          // Description  : DP BS to VS Delay Calculation
 503          // Input Value  : None
 504          // Output Value : BS to VS Delay
 505          //--------------------------------------------------
 506          DWORD ScalerDpRx0GetBStoVSDelay(void)
 507          {
 508   1          DWORD ulVFrontPorch = 0;
 509   1          DWORD ulHFrontPorch = 0;
 510   1          WORD usFifoOffset = 0;
 511   1      
 512   1          // Get Htotal
 513   1          ScalerRead(PB6_08_MSA_HTT_0, 2, &pData[2], _AUTOINC);
 514   1      
 515   1          // VFrontPorch = 3 * Htotal * (Link Clk / Stream CLK)
 516   1          ulVFrontPorch = ((DWORD)GET_DP_RX0_VFRONT_PORCH()) * ((DWORD)PDATA_WORD(1) * 256) / ((DWORD)GET_INPUT_
             -PIXEL_CLK()) *
 517   1                          ((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00) * 270) / 256;
 518   1      
 519   1          // Get Hactive
 520   1          ScalerRead(PB6_0C_MSA_HWD_0, 2, pData, _AUTOINC);
 521   1      
 522   1          // Get HSW
 523   1          pData[4] = ScalerGetBit(PB6_0E_MSA_HSW_0, (_BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0));
 524   1          pData[5] = ScalerGetByte(PB6_0F_MSA_HSW_1);
 525   1      
 526   1          // Get HSW min by Measure clock
 527   1          PDATA_WORD(3) = ((DWORD) _DP_HSYNC_WIDTH_MEASURE_COUNTER * GET_INPUT_PIXEL_CLK() * 100) / _MEASURE_CLK
             - + 1;
 528   1      
 529   1          // Check HSW <= HSW min
 530   1          if(PDATA_WORD(2) <= PDATA_WORD(3))
 531   1          {
 532   2              // Check if H porch is more than HSW min
 533   2              if((PDATA_WORD(1) - PDATA_WORD(0)) >= PDATA_WORD(3))
 534   2              {
 535   3                  // HSW = HSW min
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 10  

 536   3                  PDATA_WORD(2) = PDATA_WORD(3);
 537   3              }
 538   2              else
 539   2              {
 540   3                  // HSW = Max H Porch
 541   3                  PDATA_WORD(2) = (PDATA_WORD(1) - PDATA_WORD(0));
 542   3              }
 543   2          }
 544   1      
 545   1          // DPF H Front Porch must not be less than 8 (HW constraint)
 546   1          // Check if H porch is more than 8
 547   1          if((PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(2)) <= _DP_HSYNC_FRONT_PORCH)
 548   1          {
 549   2              // HSW < HSW min
 550   2              if(PDATA_WORD(2) < PDATA_WORD(3))
 551   2              {
 552   3                  // Hstart = HSW
 553   3                  PDATA_WORD(4) = PDATA_WORD(2);
 554   3              }
 555   2              else if((PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(3) >= _DP_HSYNC_FRONT_PORCH))
 556   2              {
 557   3                  // HSW = H porch - _DP_HSYNC_FRONT_PORCH
 558   3                  PDATA_WORD(2) = PDATA_WORD(1) - PDATA_WORD(0) - _DP_HSYNC_FRONT_PORCH;
 559   3      
 560   3                  // Hstart = HSW
 561   3                  PDATA_WORD(4) = PDATA_WORD(2);
 562   3              }
 563   2              else
 564   2              {
 565   3                  // HSW = HSW min
 566   3                  PDATA_WORD(2) = PDATA_WORD(3);
 567   3      
 568   3                  // Hstart = HSW min
 569   3                  PDATA_WORD(4) = PDATA_WORD(3);
 570   3              }
 571   2          }
 572   1          else
 573   1          {
 574   2              // Hstart = Htotal - Hactive - _DP_HSYNC_FRONT_PORCH
 575   2              PDATA_WORD(4) = PDATA_WORD(1) - PDATA_WORD(0) - _DP_HSYNC_FRONT_PORCH;
 576   2          }
 577   1      
 578   1          // HFrontPorch = (Htotal - Hactive - Hstart) * (Link Clk / Stream CLK)
 579   1          ulHFrontPorch = (((DWORD)(PDATA_WORD(1) - PDATA_WORD(0) - PDATA_WORD(4))) * (((DWORD)ScalerDpRx0GetDpc
             -dInfo(0x00, 0x01, 0x00)) * 270) / ((DWORD)GET_INPUT_PIXEL_CLK()));
 580   1      
 581   1          pData[15] = GET_COLOR_DEPTH();
 582   1      
 583   1          // DP fifo size = 256 x 96bit
 584   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 585   1          {
 586   2              // FifoOffset = (1/2 * (256 * 96) / (2 * depth per color)), color format is YCbCr 4:2:2
 587   2              usFifoOffset = _HW_DP_RX_VIDEO_FIFO_SIZE / (4 * (WORD)pData[15]);
 588   2          }
 589   1          else
 590   1          {
 591   2              // FifoOffset = (1/2 * (256 * 96) / (3 * depth per color)), color format is RGB or YCbCr 4:4:4 or 
             -others
 592   2              usFifoOffset = _HW_DP_RX_VIDEO_FIFO_SIZE / (6 * (WORD)pData[15]);
 593   2          }
 594   1      
 595   1          // FifoOffset = (1/2 * (256 * 96) / (3 * depth per color)) * (Link Clk / Stream CLK))
C51 COMPILER V9.60.0.0   SCALERDPRX0_SEPTPHY                                               10/18/2025 16:52:55 PAGE 11  

 596   1          usFifoOffset = (WORD)(((DWORD)usFifoOffset) * (((DWORD)ScalerDpRx0GetDpcdInfo(0x00, 0x01, 0x00)) * 270
             -) / ((DWORD)GET_INPUT_PIXEL_CLK()));
 597   1      
 598   1          return ((ulVFrontPorch + ulHFrontPorch + (DWORD)usFifoOffset) / 2);
 599   1      }
