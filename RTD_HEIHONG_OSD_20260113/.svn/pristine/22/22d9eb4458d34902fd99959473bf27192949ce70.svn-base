 340   1          {
 341   2              // Branch IEEE OUI For DP1.4
 342   2              ScalerDpRx0SetDpcdValue(0x00, 0x05, 0x00, _DP_1_4_BRANCH_RTK_IEEE_OUI_L);
 343   2              ScalerDpRx0SetDpcdValue(0x00, 0x05, 0x01, _DP_1_4_BRANCH_RTK_IEEE_OUI_M);
