                      ScalerSetByte(PB_31_SHA_DATA1, 0x00);
                      ScalerSetByte(PB_32_SHA_DATA2, 0x00);
                      ScalerSetByte(PB_33_SHA_DATA3, 0x00);
                      ScalerSetByte(PB_34_SHA_DATA4, 0x00);
              
