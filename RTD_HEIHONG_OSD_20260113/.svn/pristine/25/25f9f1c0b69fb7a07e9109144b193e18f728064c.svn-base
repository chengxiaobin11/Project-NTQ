    {RTDFactoryLogoOnOffEnter,                      RTDFactoryLogoOnOffRight,                       RTDFactoryLogoOnOffLeft,                        RTDFactoryLogoOnOffExit,},
    
    {RTDFactoryBurnAudioTestAdjustEnter,            RTDFactoryBurnAudioTestAdjustLeft,              RTDFactoryBurnAudioTestAdjustRight,             RTDFactoryBurnAudioTestAdjustExit,},
};

//--------------------------------------------------
// Description  :
// Input Value  :
// Output Value :
//--------------------------------------------------
void RTDFactoryMenuOperation(void)
{
    if((GET_OSD_STATE() >= _MENU_FACTORY_AUTOCOLOR) &&
       (GET_OSD_STATE() < _MENU_FACTORY_OSD_END) &&
       (GET_KEYMESSAGE() < _KEY_AMOUNT))
    {
    	if(GET_KEYMESSAGE()==_RIGHT_KEY_MESSAGE)
        (*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][_LEFT_KEY_MESSAGE])();
		else if(GET_KEYMESSAGE()==_LEFT_KEY_MESSAGE)
			(*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][_RIGHT_KEY_MESSAGE])();
		else
			(*OperationFactoryTable[GET_OSD_STATE() - _MENU_FACTORY_AUTOCOLOR][GET_KEYMESSAGE()])();
    }
}
#if _HDCP_KEY_WIRTE_FLAG

bit IS_HDCP_KEY_READY(void)
{   
    BYTE pucReadArray[8] = {0};
#if(_HDCP_2_2_KEY_LOCATION == _TABLE_LOCATION_FLASH)	
    UserCommonFlashRead(_RX_HDCP_2_2_KEY_FLASH_BANK, _RX_HDCP_2_2_KEY_ADDRESS_FLASH+0x45F-6, 8, pucReadArray);
#elif(_HDCP_1_4_KEY_LOCATION == _TABLE_LOCATION_FLASH)
    UserCommonFlashRead(_RX_HDCP_1_4_KEY_FLASH_BANK, _RX_HDCP_1_4_KEY_ADDRESS_FLASH +375-6 , 8, pucReadArray);
#else
    return 0;
#endif

//	if((pucReadArray[0] == 0xff)&&(pucReadArray[1] == 0xff)&&(pucReadArray[2] == 0xff)&&(pucReadArray[3] == 0xff)&&(pucReadArray[4] == 0xff)&&(pucReadArray[5] == 0xff)&&(pucReadArray[6] == 0xff)&&(pucReadArray[7] == 0xff))
    DebugMessageOsd("pucReadArray[7]", pucReadArray[7]);
    DebugMessageOsd("pucReadArray[6]", pucReadArray[6]);
	if((pucReadArray[6] != 0xff)&&(pucReadArray[7] == 0XFF))
    {
        return 1;
    }
   else
    {
        return 0;
    }


}

#endif
