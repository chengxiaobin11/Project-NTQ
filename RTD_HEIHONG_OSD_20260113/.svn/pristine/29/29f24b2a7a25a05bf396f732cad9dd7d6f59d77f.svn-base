  74          //--------------------------------------------------
  75          // Description  : Power On/Off ADC Bandgap.
  76          // Input Value  : On or Off
  77          // Output Value : None
  78          //--------------------------------------------------
  79          void ScalerADCBandgap(bit bSelect)
  80          {
  81   1          if(bSelect == _ON)
  82   1          {
  83   2              // ADC ldo Output Not Short to Ground
  84   2              // ADC Bandgap/mbias On
  85   2              ScalerSetBit(P0_C6_ADC_POWER, ~(_BIT4 | _BIT3), _BIT3);
  86   2      
  87   2              // Bit3: SOG0 Bias Current from ADC
  88   2              // Bit1: Bias Current of SOG normal
  89   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~(_BIT3 | _BIT1), _BIT3);
  90   2          }
  91   1          else
  92   1          {
  93   2              // Bit3: SOG0 Bias Current from POR
  94   2              // Bit1: Bias Current of SOG standby
  95   2              ScalerSetBit(P0_D4_ADC_SOG_CTRL, ~(_BIT3 | _BIT1), _BIT1);
  96   2      
  97   2              // ADC ldo Output Not Short to Ground
  98   2              // ADC Bandgap/mbias Off
  99   2              ScalerSetBit(P0_C6_ADC_POWER, ~(_BIT4 | _BIT3), _BIT4);
 100   2          }
 101   1      }
