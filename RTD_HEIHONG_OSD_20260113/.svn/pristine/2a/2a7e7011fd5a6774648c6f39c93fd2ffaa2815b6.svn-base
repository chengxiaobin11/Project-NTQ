              // Write Command
              code StructSMBusWrSetSSMode tSMBusWrSetSSMode[1] = {{0x31, 0x01, 0x01}};
              code StructSMBusWRDetectDSPSSMode tSMBusWDetectDspSSMode[1] = {{0x30, 0x03, 0x00, 0x00, 0x04}};
              
