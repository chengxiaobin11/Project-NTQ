  48          // Description  : Internal Oscillator Triming.
  49          // Input Value  : None
  50          // Output Value : None
  51          //--------------------------------------------------
  52          void ScalerIOSCTrimming(void)
  53          {
  54   1          SBYTE chcTempInx = 0;
  55   1      
  56   1          // Disable auto trimming.
  57   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT7, 0x00);
  58   1      
  59   1          // 27Mhz
  60   1          ScalerSetBit(P6_A6_EMB_BGRES1, ~_BIT7, _BIT7);
  61   1      
  62   1          // Enable IOSC
  63   1          ScalerSetBit(P6_A3_EMBEDDED_OSC_CTRL, ~_BIT7, _BIT7);
  64   1      
  65   1          ScalerTimerDelayXms(2);
  66   1      
  67   1          // Trim Resolution select, Fosc=counter * Fxtal / 1000
  68   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT5, 0x00);
  69   1      
  70   1          // Wait time for Internal OSC Stable->15*2^10 Tref
  71   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT4, _BIT4);
  72   1      
  73   1          // Wait time for trimming->4*2^10 Tref
  74   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~(_BIT3 | _BIT2), (_BIT3 | _BIT2));
  75   1      
  76   1          // Set internal oscillator divider(Divider = 1)
  77   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~(_BIT1 | _BIT0), _IOSC_DIV);
  78   1      
  79   1      #if(_INTERNAL_OSC_XTAL == _IOSC27000K)
                  // Trimming comparason target 0x75D --> 27M
                  ScalerSetByte(P6_A1_OSC_TRIM_CTRL1, 0x5D);
                  ScalerSetBit(P6_A5_EMB_BGRES, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x07);
              
              #elif(_INTERNAL_OSC_XTAL == _IOSC28000K)
  85   1          // Trimming comparason target 0x7A4 --> 28M
  86   1          ScalerSetByte(P6_A1_OSC_TRIM_CTRL1, 0xA4);
  87   1          ScalerSetBit(P6_A5_EMB_BGRES, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x07);
  88   1      #endif
  89   1      
  90   1          // Switch to hardware trimming result.
  91   1          ScalerSetBit(P6_A2_OSC_TRIM_CTRL2, ~_BIT7, 0x00);
  92   1      
  93   1          // Thermal compensation factor, 11 for the best
  94   1          ScalerSetBit(P6_A6_EMB_BGRES1, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
  95   1      
  96   1          // Enable trimming
  97   1          ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT7, _BIT7);
  98   1      
  99   1          //-------Use manual mode go back recheck best step start --------
 100   1          // Wait for auto trimming stop, time-consuming ~= 3.36ms
 101   1          if(ScalerTimerPollingFlagProc(10, P6_A0_OSC_TRIM_CTRL0, _BIT6, _TRUE) == _FALSE)
 102   1          {
 103   2              return;
 104   2          }
 105   1      
 106   1          // Back up final result of auto trimming
 107   1          pData[0] = (ScalerGetBit(P6_A2_OSC_TRIM_CTRL2, (_BIT5 | _BIT4 | _BIT3)) >> 3) | (ScalerGetBit(P6_A2_OS
             -C_TRIM_CTRL2, (_BIT2 | _BIT1 | _BIT0)) << 3);
 108   1          pData[3] = ((pData[0] & 0x38) >> 3) | ((pData[0] & 0x07) << 3);
C51 COMPILER V9.60.0.0   SCALERCOMMONIOSC                                                  10/18/2025 16:53:11 PAGE 3   

 109   1      
 110   1          // Get target iosc cycle counter
 111   1          PDATA_WORD(5) = (ScalerGetBit(P6_A5_EMB_BGRES, (_BIT3 | _BIT2 | _BIT1 | _BIT0)) << 8) | ScalerGetByte(
             -P6_A1_OSC_TRIM_CTRL1);
 112   1      
 113   1          // Initial variable
 114   1          PDATA_WORD(7) = 0xFFF;
 115   1      
 116   1          // Change to manual trimming mode
 117   1          ScalerSetBit(P6_A3_EMBEDDED_OSC_CTRL, ~_BIT6, 0x00);
 118   1          ScalerSetBit(P6_A2_OSC_TRIM_CTRL2, ~_BIT7, _BIT7);
 119   1      
 120   1          for(chcTempInx = -1; chcTempInx < 2; chcTempInx++)
 121   1          {
 122   2              pData[1] = pData[0] + chcTempInx;
 123   2              pData[2] = ((pData[1] & 0x38) >> 3) | ((pData[1] & 0x07) << 3);
 124   2      
 125   2              // Apply trimming step
 126   2              ScalerSetBit(P6_A3_EMBEDDED_OSC_CTRL, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), pData[2] &
             - 0x3F);
 127   2      
 128   2              // Restart trimming
 129   2              ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT7, 0x00);
 130   2              ScalerSetBit(P6_A0_OSC_TRIM_CTRL0, ~_BIT7, _BIT7);
 131   2      
 132   2              // Polling trimming finished, time-cunsuming ~= 440us
 133   2              ScalerTimerPollingFlagProc(10, P6_A0_OSC_TRIM_CTRL0, _BIT6, _TRUE);
 134   2      
 135   2              // Get iosc cycle counter in current step
 136   2              PDATA_WORD(6) = (ScalerGetBit(P6_A5_EMB_BGRES, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) << 4) | ScalerGetB
             -yte(P6_A4_OSC_TRIM_CNT);
 137   2      
 138   2              // Record minimum step
 139   2              if(ABSDWORD(PDATA_WORD(6), PDATA_WORD(5)) < PDATA_WORD(7))
 140   2              {
 141   3                  PDATA_WORD(7) = ABSDWORD(PDATA_WORD(6), PDATA_WORD(5));
 142   3                  pData[3] = pData[2];
 143   3              }
 144   2          }
 145   1      
 146   1          // Apply the best trimming step
 147   1          ScalerSetBit(P6_A3_EMBEDDED_OSC_CTRL, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), pData[3] & 0x3
             -F);
 148   1          //-------Use manual mode go back recheck best step end , total time-consuming ~= 5.36ms ----------
 149   1      }


