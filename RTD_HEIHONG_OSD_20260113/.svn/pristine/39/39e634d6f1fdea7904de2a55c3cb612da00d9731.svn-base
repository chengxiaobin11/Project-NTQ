6002   3      
6003   3      #if(_DP_SUPPORT == _ON)
6004   3                  // DP Audio Capability Status Check
6005   3                  if((GET_PORT_TYPE(SysSourceGetInputPortType(SysSourceGetInputPort())) == _PORT_DP) &&
6006   3                     (ScalerAudioDpGetCapabilityState(ScalerAudioGetDigitalAudioPortMapping()) == _AUDIO_DP_DPCD
             -_NOT_SUPPORT))
6007   3                  {
6008   4                      DebugMessageAudio("Audio Ready False : DP Audio Capability Not Support", 0);
6009   4      
6010   4                      bAudioStatus = _FALSE;
6011   4                  }
6012   3      #endif // End of #if(_DP_SUPPORT == _ON)
6013   3      
6014   3                  // Playback Status Check
6015   3                  if(SysAudioGetAudioState() == _AUDIO_STATUS_PLAYBACK)
6016   3                  {
6017   4                      if(ScalerAudioLPCMCheckChange() == _TRUE)
6018   4                      {
6019   5                          DebugMessageAudio("Audio Ready False : LPCM Status Change", 0);
6020   5      
6021   5                          bAudioStatus = _FALSE;
6022   5                      }
6023   4                  }
6024   3              }
6025   2      
6026   2              return bAudioStatus;
6027   2          }
6028   1      
6029   1          return _FALSE;
6030   1      }
