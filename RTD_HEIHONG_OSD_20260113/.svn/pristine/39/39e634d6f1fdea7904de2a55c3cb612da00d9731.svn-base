4303          void UserCommonInterfaceNVRamRestoreHDCP(void)
4304          {
4305   1          BYTE ucCount = 0;
4306   1          BYTE pucBuffer[16] = {0};
4307   1      
4308   1      #if((_HDCP_1_4_KEY_LOCATION == _TABLE_LOCATION_FLASH) || (_HDCP_1_4_KEY_LOCATION == _TABLE_LOCATION_SYSTEM
