void UserInterfaceAdjustDCRHandler(void)
{
#if(_DEF_OPPOSITE_DCR)
	if(GET_OSD_DCR_STATUS() != _OFF || GET_OSD_DCR_OPPOSITE() != _OFF)
#else
    if(GET_OSD_DCR_STATUS() == _ON)
