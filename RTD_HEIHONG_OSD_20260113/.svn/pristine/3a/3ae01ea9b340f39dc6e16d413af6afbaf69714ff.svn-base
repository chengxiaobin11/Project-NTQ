		bMute = _AMP_MUTE_OFF;			

#if(_EMBEDDED_DAC_SUPPORT == _ON)
    if((UserInterfaceGetAudioDACOutput() == _AUDIO_DAC_OUTPUT_BOTH) || (UserInterfaceGetAudioDACOutput() == _AUDIO_DAC_OUTPUT_SPEAKER))
    {
        PCB_AMP_MUTE(bMute);
    }
#endif
}

