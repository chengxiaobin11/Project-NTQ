#if(_INSTANT_TIMER_EVENT_0 == _ON)
//--------------------------------------------------
// Description  : Action in Timer0 int defined by User
// Input Value  : None
// Output Value : None
//--------------------------------------------------
#pragma save
#pragma OT(8)
void UserInterfaceTimer0InstantAccess_EXINT(void)
{
    if(GET_OSD_LOGO_ON() == _ON)
    {
        if(g_ucLogoTimerCounter != 0xFF)
        {
            g_ucLogoTimerCounter++;
        }

        switch(g_ucLogoTimerCounter)
        {
            case _USER_SHOW_LOGO_STEP:
            case (_USER_SHOW_LOGO_STEP * 2):
            case (_USER_SHOW_LOGO_STEP * 3):
            case (_USER_SHOW_LOGO_STEP * 4):
            case (_USER_SHOW_LOGO_STEP * 5):
            case (_USER_SHOW_LOGO_STEP * 6):
            case (_USER_SHOW_LOGO_STEP * 7):

                ScalerOsdSetTransparency_EXINT(0xFF - (g_ucLogoTimerCounter / _USER_SHOW_LOGO_STEP) * 36);

                break;

            default:

                break;
        }
    }
}
#pragma restore
#endif

#if(_INSTANT_TIMER_EVENT_1 == _ON)
#if(_LED_EFFECT_TJMODE14==_ON)
BYTE led_time = 0;
BYTE led_flag = 0;
BYTE led_start = 0;

#endif

#if(_IR_VIRTUAL)	
BYTE tcc_time = 0,ir_up_time = 0,wave_H_count = 0,data_count = 0;
bit f_time1ms = 0,f_count_H = 0,f_guide = 0,f_resaveok = 0;
DWORD r_data = 0;
#endif

//--------------------------------------------------
// Description  : Action in Timer1 int defined by User
// Input Value  : None
// Output Value : None
//--------------------------------------------------
#pragma save
#pragma OT(8)
void UserInterfaceTimer1InstantAccess_EXINT(void)
{

//Ń­»·
#if 0//(_IR_VIRTUAL)	

    tcc_time++;
    
    if(tcc_time>9)
    {
      f_time1ms=1;
      tcc_time=0;
      ir_up_time++;
    }
    
    if(IR_STATUS==1)
    {
        f_count_H=1;
        wave_H_count++;
        if(wave_H_count>60)
        {
          wave_H_count=60;
          data_count=0;
          f_guide=0;
        }
    }
    else
    {
        if(f_count_H==1)
        {
           f_count_H=0;
           if(f_guide==0)
           {  
            if(((wave_H_count>=12)&&(wave_H_count<=58)))
            {
                f_guide=1;
            }      
                  
                  wave_H_count=0;
           }
           else
           {
              if(wave_H_count>=2&&wave_H_count<=9)
              {
                r_data=r_data>>1;
                r_data=r_data&0x7fffffff;        //  bit0
                data_count++;
              }
              if(wave_H_count>=10&&wave_H_count<=24)
              {
                r_data=r_data>>1;
                r_data=r_data|0x80000000;        //  bit1
                data_count++;
              }
              if(wave_H_count<=1||wave_H_count>=25)
              { 
                data_count=0; f_guide=0;
              }
               wave_H_count=0;
           }
         }
    }
    
    if(data_count>=32)
   {
           data_count=0;
           f_guide=0;
           wave_H_count=0;
           f_resaveok=1;
   }
#endif



#if(_LED_EFFECT_TJMODE14==_ON)

if(led_start == 1)
{


	led_start =2;
	led_time = 0;
	led_flag = 0;
}
else if(led_start == 2)
{
	led_time++;

	switch(led_flag)
	{
		case 0x00:
			OSD_LED_CONTRL_SCL(LED_LOW);
			if(led_time >= 32)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_HIGH);  //µÍ 32ms  ===>¸ß
				led_flag =1;
				
			}
			break;
			
		case 0x01:
			if(led_time >=8)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_LOW);// ¸ß8 ms //ÍęłÉ ŇýµĽÂë====  >µÍ
				led_flag =2;
			}		
			break;
			
		case 0x02:

			if(led_time >=4)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_HIGH);// µÍ4ms===>¸ß
				led_flag =3;
			}		

		break;

		case 0x03:


		if(((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeIn)&&(GET_OSD_LED_COLOR()!=LightColorMode_Spectrum))\
			||(GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeOut))	
		{
			
				if(led_time >= 12)
				{
					led_time = 0;
					OSD_LED_CONTRL_SCL(LED_LOW);// ¸ß 12ms	 ÍęłÉĘýľÝ 1 ===>µÍ
					led_flag =4;
				}	


		}
		else 
		{



					if(led_time >= 4)
					{
						led_time = 0;
						OSD_LED_CONTRL_SCL(LED_LOW);// ¸ß 4ms	ÍęłÉĘýľÝ 0 ===>µÍ
						led_flag =4;
					}	

		}
		
		break;
///////////////////////////////////////////////
		case 0x04:
		
			if(led_time >= 4)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_HIGH);//µÍ4ms====>¸ß
				led_flag =5;
			}		
		
		break;

		case 0x05:

if((GET_OSD_LED_LIGHTMODE()==LightMode_Breathe)\
||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeIn)&&(GET_OSD_LED_COLOR()==LightColorMode_Spectrum))\
||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeOut)&&((GET_OSD_LED_COLOR()>=LightColorMode_Green)&&(GET_OSD_LED_COLOR()<=LightColorMode_Yellow))))
{
					if(led_time >= 12)
					{
						led_time = 0;
						OSD_LED_CONTRL_SCL(LED_LOW);// ¸ß 12ms	 ÍęłÉĘýľÝ 1 ===>µÍ
						led_flag =6;
					}	


}

else
{


					if(led_time >= 4)
					{
						led_time = 0;
						OSD_LED_CONTRL_SCL(LED_LOW);// ¸ß4ms   ÍęłÉĘýľÝ0 ===>µÍ
						led_flag =6;
					}	



}

			
		
	
		
		break;
///////////////////////////////////////////////
		case 0x06:
	
		if(led_time >= 4)
		{
			led_time = 0;
			OSD_LED_CONTRL_SCL(LED_HIGH);//µÍ4ms ====>¸ß
			led_flag =7;
		}		
		
		break;		

		case 0x07:

if(((GET_OSD_LED_LIGHTMODE()==LightMode_Static)&&((GET_OSD_LED_COLOR()>=LightColorMode_Blue)&&(GET_OSD_LED_COLOR()<=LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_Breathe)&&((GET_OSD_LED_COLOR()>=LightColorMode_Gyan)&&(GET_OSD_LED_COLOR()<=LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeIn)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Purple)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeOut)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Red)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow))))

{


				if(led_time >= 12)
				{
					led_time = 0;
					OSD_LED_CONTRL_SCL(LED_LOW);//¸ß12ms===ÍęłÉĘýľÝ1====>µÍ
					led_flag =8;
				}		


}

	
else
{

				if(led_time >= 4)
				{
					led_time = 0;
					OSD_LED_CONTRL_SCL(LED_LOW);//¸ß4ms===ÍęłÉĘýľÝ0====>µÍ
					led_flag =8;
				}		



}
	
		
		break;	

////////////////////////////////////////////////////////
		case 0x08:
	
		if(led_time >= 4)
		{
			led_time = 0;
			OSD_LED_CONTRL_SCL(LED_HIGH); //µÍ4ms ====>¸ß
			led_flag =9;
		}	
		
		break;	

		case 0x09:

if(((GET_OSD_LED_LIGHTMODE()==LightMode_Static)&&((GET_OSD_LED_COLOR()==LightColorMode_Red)||(GET_OSD_LED_COLOR()==LightColorMode_Green)||(GET_OSD_LED_COLOR()==LightColorMode_Purple)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_Breathe)&&((GET_OSD_LED_COLOR()==LightColorMode_Green)||(GET_OSD_LED_COLOR()==LightColorMode_Blue)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeIn)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Blue)||(GET_OSD_LED_COLOR()==LightColorMode_Gyan)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeOut)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Red)||(GET_OSD_LED_COLOR()==LightColorMode_Gyan)||(GET_OSD_LED_COLOR()==LightColorMode_Purple))))
{


			if(led_time >= 12)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_LOW);//¸ß12ms===ÍęłÉĘýľÝ1====>µÍ
				led_flag =10;
			}		



}

else
{

			if(led_time >= 4)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_LOW);//¸ß4ms===ÍęłÉĘýľÝ0====>µÍ
				led_flag =10;
			}		

}
			
		

		
		break;	

case 0x0a:

if(led_time >= 4)
{
	led_time = 0;
	OSD_LED_CONTRL_SCL(LED_HIGH);//µÍ4ms ====>¸ß
	led_flag =0x0b;
}		

break;		


		case 0x0b:

if(((GET_OSD_LED_LIGHTMODE()==LightMode_Static)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Green)||(GET_OSD_LED_COLOR()==LightColorMode_Gyan)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_Breathe)&&((GET_OSD_LED_COLOR()==LightColorMode_Red)||(GET_OSD_LED_COLOR()==LightColorMode_Blue)||(GET_OSD_LED_COLOR()==LightColorMode_Purple)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeIn)&&((GET_OSD_LED_COLOR()==LightColorMode_Spectrum)||(GET_OSD_LED_COLOR()==LightColorMode_Green)||(GET_OSD_LED_COLOR()==LightColorMode_Gyan)||(GET_OSD_LED_COLOR()==LightColorMode_Yellow)))\
	||((GET_OSD_LED_LIGHTMODE()==LightMode_MarqueeOut)&&((GET_OSD_LED_COLOR()==LightColorMode_Red)||(GET_OSD_LED_COLOR()==LightColorMode_Blue)||(GET_OSD_LED_COLOR()==LightColorMode_Purple))))
{


			if(led_time >= 12)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_LOW);//¸ß12ms===ÍęłÉĘýľÝ1====>µÍ
				led_flag =0x0c;
			}		



}

else
{

			if(led_time >= 4)
			{
				led_time = 0;
				OSD_LED_CONTRL_SCL(LED_LOW);//¸ß4ms===ÍęłÉĘýľÝ0====>µÍ
				led_flag =0x0c;
			}		

}
			
		

		
		break;	


		
///////////////////////////////////////////////////
		case 0x0c:
		
		if(led_time >= 8)
		{
			led_time = 0;
			OSD_LED_CONTRL_SCL(LED_HIGH);//µÍ8ms   ÍęłÉ˝áĘřÂë======>¸ß
			led_start = 0;
			led_flag = 0;
		}		
		
		break;	
		

	}

}		








#endif
}

