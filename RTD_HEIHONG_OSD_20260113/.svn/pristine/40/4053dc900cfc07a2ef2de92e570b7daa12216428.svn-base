6238          bit ScalerFlashErasePage(BYTE ucBank, BYTE ucPage)
6239          {
6240   1          // The access bank is smaller than than the start bank
6241   1          if(ucBank < MCU_FFFD_XDATA_BANK_START)
6242   1          {
6243   2              return _FALSE;
6244   2          }
6245   1      
6246   1          if(g_ucFlashType == _FLASH_UNDETECT)
6247   1          {
6248   2              ScalerFlashDetectFlashType();
6249   2          }
6250   1      
6251   1          if(g_ucFlashType >= (sizeof(tFlashInformation) / sizeof(tFlashInformation[0])))
6252   1          {
6253   2              return _FALSE;
6254   2          }
6255   1      
6256   1          ScalerFlashWREN(ucBank, ucPage);
6257   1      
6258   1          // Sector Erase
6259   1          MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0xB8, _CKCON_MCU_SLOW_CYCLE);
6260   1          MCU_FF61_COMMON_OP_CODE = tFlashInformation[g_ucFlashType].ucPageEraseOpCode;
6261   1          // Set WR address
6262   1          MCU_FF64_FLASH_PROG_ISP0 = ucBank;
6263   1          MCU_FF65_FLASH_PROG_ISP1 = (BYTE)((ucPage << 4) & 0xF0);
6264   1          MCU_FF66_FLASH_PROG_ISP2 = 0x00;
6265   1          // Start Bit0
6266   1          MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0xB9, _CKCON_MCU_SLOW_CYCLE);
6267   1      
6268   1          // No need to polling, 8051 will halt when common instruction executes
6269   1      
6270   1          MCU_FF61_COMMON_OP_CODE = 0xFF;
6271   1      
6272   1          ScalerFlashWRDis();
6273   1      
6274   1          return _TRUE;
6275   1      }
