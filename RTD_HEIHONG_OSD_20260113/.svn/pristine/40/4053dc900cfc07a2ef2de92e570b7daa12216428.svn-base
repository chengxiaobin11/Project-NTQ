                              MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0x20, _CKCON_MCU_SLOW_CYCLE);
                              MCU_FF61_COMMON_OP_CODE = 0x4D;
                              MCU_SET_BYTE_WITH_CKCON(MCU_FF60_COMMON_INST_EN, 0x21, _CKCON_MCU_SLOW_CYCLE);
