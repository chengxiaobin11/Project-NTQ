                              ScalerFlashSet2ByteWRSR(tFlashInformation[g_ucFlashType].ucProtectWRSR, 0x00, _FALSE);
                              ScalerFlashSetWREN(tFlashInformation[g_ucFlashType].ucWRDisOpCode);
