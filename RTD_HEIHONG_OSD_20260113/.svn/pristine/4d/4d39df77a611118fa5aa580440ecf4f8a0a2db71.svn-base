 127          //--------------------------------------------------
 128          // Description  : Set Rotation double switch style
 129          // Input Value  : bInputFasterStatus
 130          // Output Value : None
 131          //--------------------------------------------------
 132          void ScalerRotationSetRotInputSlowerFasterStyle(bit bInputFasterStatus)
 133          {
 134   1          // Rotation double switch style
 135   1          if(bInputFasterStatus == _FALSE)
 136   1          {
 137   2              // input slower than display
 138   2              ScalerSetBit(P5_49_CAP_M1_ROTATION, ~_BIT2, 0x00);
 139   2              ScalerSetBit(P45_49_CAP_M2_ROTATION, ~_BIT2, 0x00);
 140   2          }
 141   1          else
 142   1          {
 143   2              // input faster than display
 144   2              ScalerSetBit(P5_49_CAP_M1_ROTATION, ~_BIT2, _BIT2);
 145   2              ScalerSetBit(P45_49_CAP_M2_ROTATION, ~_BIT2, _BIT2);
 146   2          }
 147   1      }
 148          
 149          //--------------------------------------------------
 150          // Description  : Set Rotation Enable/Disable
 151          // Input Value  : bEn --> Enable/Disable
 152          // Output Value : None
 153          //--------------------------------------------------
 154          void ScalerRotationSetEnable(bit bEn)
 155          {
 156   1          if(bEn == _DISABLE)
 157   1          {
 158   2              // Set Rotation Disable
 159   2              ScalerSetBit(P20_F0_ROTATION_CTRL0, ~(_BIT7), 0x00);
 160   2          }
 161   1          else
 162   1          {
 163   2              if(ScalerGetBit(P20_F0_ROTATION_CTRL0, _BIT7) == 0x00)
 164   2              {
 165   3                  // Set Rotation Enable
 166   3                  ScalerSetBit(P20_F0_ROTATION_CTRL0, ~(_BIT7), _BIT7);
 167   3              }
 168   2          }
 169   1      }
