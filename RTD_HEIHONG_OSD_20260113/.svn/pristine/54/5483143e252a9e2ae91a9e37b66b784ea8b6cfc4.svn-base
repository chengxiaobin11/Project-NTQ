		case _MENU_FUN_MPRT:
#endif
			return 1;
		break;
		

		
		//case _MENU_FUN_LED:
		case _MENU_FUN_AUDIO_SOURCE:
		case _MENU_FUN_KVM:
#if(_DEF_OPPOSITE_DCR)
