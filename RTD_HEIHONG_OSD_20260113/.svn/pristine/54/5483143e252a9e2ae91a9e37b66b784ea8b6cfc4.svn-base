#endif

			return 3;
		break;
		
		case _MENU_FUN_POWER_OFF:			
			return 7;
		break;

		
		case _MENU_FUN_LANGUAGE:
			return _LANGUAGE_AMOUNT;
		break;
		
		case _MENU_FUN_SIGNAL:	

			return (_OSD_INPUT_AMOUNT-1);
		break;
		
		case _MENU_FUN_HOTLEFT:	

			return GET_OSD_HOTKEY_LEFT();
		break;
		
		case _MENU_FUN_HOTRIGHT:	

			return GET_OSD_HOTKEY_RIGHT();
		break;
		
#if(_VGA_SUPPORT == _ON)

		case _MENU_FUN_AUTO_ADJUST:
		case _MENU_FUN_AUTO_COLOR:	
#endif
		case _MENU_FUN_RESET:
		
			 return 0;
		break;
//		case _MENU_FUN_LOWBLUE:
//			
//			return GET_OSD_LOW_BLUE();
//		break;


        case _MENU_FUN_COLORGAMUT: 
			return 3;	
		break; 

        case _MENU_FUN_LOWBLUE: 
			return 3;	
		break; 
#if(_DEF_CT_JX)
        case _MENU_FUN_COLORTEMP:	
            return 6;

#else
        case _MENU_FUN_COLORTEMP:		
#endif
        case _MENU_FUN_GAMMA: 
            return 4;	
		break;
		
#if(_LED_EFFECT_TJMODE14)
      case _MENU_FUN_LIGHTMODE: 
          return 4;   
      break;
      case _MENU_FUN_COLOR: 
          return 6;   
      break;
#endif
#if(_DEF_HOTKEY_REPLACE)
		case _MENU_FUN_HOT_REPLACE_LEFT:
		case _MENU_FUN_HOT_REPLACE_RIGHT:
		case _MENU_FUN_HOT_REPLACE_EXIT:
			return 11;
		break;
#endif
		
		case _MENU_FUN_SATURATION: 
			return GET_OSD_SATURATION();
			
		break;

		
        default:
            return 0;
            break;
		
	}
}

//--------------------------------------------------
// Description  :	
// Input Value  : 
// Output Value : 
//--------------------------------------------------
void SG_PutStringProp(BYTE ucRow, BYTE ucCol, BYTE ucFptsSelect, BYTE ucString, BYTE ucStateIndex,BYTE COLOR,BYTE ucLanguage)
{
	BYTE ShowType = (BYTE)GetOsdShowType(ucStateIndex);
	BYTE OsdValue = (BYTE)GetOsdValue(ucStateIndex);
	BYTE Arrow_FptSelect = _PFONT_PAGE_ITEM_1 + ((ucRow -_ITEM_1_ROW)/2);
	BYTE ucSliderCol = _ITEM_3_COL;

    
	RTDOsdTableFuncPutStringProp( ucRow,  ucCol,  ucFptsSelect,  ucString,  ucStateIndex-_MENU_FUN_BACKLIGHT, COLOR, ucLanguage);



#if(_NAVIGAT_MENU_SURPPORT)
		if(GET_OSD_STATE() == _MENU_NAVIGAT_NONE)
#else
		if(GET_OSD_STATE() == _MENU_NONE)
#endif
		{
			ucSliderCol = _HOTKEY_SLIDER_COL;		
		}
    if(ucStateIndex == _MENU_FUN_OSD_RORATE)
    {
        if(OsdValue == _OSD_ROTATE_DEGREE_270)
            OsdValue = _OSD_ROTATE_DEGREE_180;
        else if(OsdValue == _OSD_ROTATE_DEGREE_180)
            OsdValue = _OSD_ROTATE_DEGREE_270;
    }

	switch(ShowType)
	{
		case _TYPE_SLIDER:
			
			OsdDispSliderAndNumber(ucRow,ucStateIndex,OsdValue);
			break;
			
		case _TYPE_ARROW:
			
			//RTDOsdTableFuncPutStringProp(ucRow, ucSliderCol, _PFONT_PAGE_ITEM_7, _OSD_STRING_ARROW, 0, COLOR,_ENGLISH);
		//	RTDOsdTableFuncPutStringProp(ucRow, ucSliderCol+13, _PFONT_PAGE_ITEM_8, _OSD_STRING_ARROW, 1, COLOR,_ENGLISH);
            if(OSD_ITEM_MASK_GET(ucStateIndex))
            COLOR = ((_CP_GRAY<<4)|_CP_BG);

#if(_DEF_STA_SIX_COLOR)
			if(ucStateIndex == _MENU_FUN_SAT_STATE || ucStateIndex == _MENU_FUN_HUE_STATE)
			{
				break;
			}
#endif

			
//DebugMessageOsd("wwq1",ucStateIndex);
//DebugMessageOsd("_MENU_FUN_ECO",_MENU_FUN_ECO);
//DebugMessageOsd("_MENU_FUN_POWER_OFF",_MENU_FUN_POWER_OFF);
//DebugMessageOsd("GET_OSD_STATE_PREVIOUS()",GET_OSD_STATE_PREVIOUS());
//DebugMessageOsd("GET_OSD_STATE()",GET_OSD_STATE());




			RTDOsdTableFuncPutStringProp(ucRow, ucSliderCol, Arrow_FptSelect, ucStateIndex, OsdValue, COLOR, GET_OSD_LANGUAGE());
			break;
			
		case _TYPE_SUBMENU:
			
			if(ucSliderCol ==  _HOTKEY_SLIDER_COL)
			{
			//	RTDOsdTableFuncPutStringProp(ucRow, ucSliderCol, _PFONT_PAGE_ITEM_7, _OSD_STRING_ARROW, 0, COLOR,_ENGLISH);
			//	RTDOsdTableFuncPutStringProp(ucRow, ucSliderCol+13, _PFONT_PAGE_ITEM_8, _OSD_STRING_ARROW, 1, COLOR,_ENGLISH);
			//	RTDOsdTableFuncPutStringCenter(ucRow, ucSliderCol+1, ucSliderCol+12, Arrow_FptSelect, ucStateIndex, OsdValue, COLOR, 0, _ENGLISH);
			}
			break;

	}
	
}
#if(_DEF_OSD_EDID_INFO)
void RTDOsdTableFuncPutStringProp_EDIDInfo(BYTE ucRow, BYTE ucCol, BYTE ucFptsSelect, BYTE *pArray,BYTE COLOR)
{
	bit bEndFlag = 0;
	BYTE current_page = 0;
	BYTE current_page1 = 0;
	BYTE current_page2 = 0;
	BYTE pre_page = 0;
	
	
	BYTE xdata ucpTemp[27] = {0};
	BYTE *pFontTable = 0;
	BYTE i = 0;

	BYTE ucLanguage = _ENGLISH;

	
	pData[0] = ucLanguage;
   
	
	while(pData[0] != _ENGLISH)
	{
		if(*pArray == _END_)
		{
			pData[0]--;
		}
		pArray++;
	}

	pData[1] = OsdPropGetFontPointer(ucFptsSelect);

	// reorder
	SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT6);
	SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~(_BIT7 | _BIT5)));

	pData[2] = 0;
	pData[3] = 0;
	pData[4] = 0;
	pData[5] = 0;
	pData[9] = 0;
	
	while(*(pArray + pData[2]) != _END_)
	{
		switch(*(pArray + pData[2]))
		{
			case _END_:
				bEndFlag = 1;
				break;
				
			case  _PAGE_:
				current_page = *(pArray + pData[2] + 1);
				pData[2] += 2;
				pre_page = current_page;
					
				pData[3] = *(pArray + pData[2]);
				pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);
				pData[2]++;
				
				break;
			default:
				current_page = pre_page;
				pData[3] = *(pArray + pData[2]);
				pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);
				pData[2]++;
				break;
		}

		if(pData[5] == 0)
		{
			pData[5] = pData[4];
		}

		SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT3);    // first bits shift direction: left shift
		SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~_BIT2)); // left bits shift direction: rigth shift
		SCALEROSD_FONT_ROTATE_1_2_BITS_SHIFT_SET(((pData[4] - pData[5]) << 4) | pData[5]); // first bits shift and second bits shift

		pData[6] = pData[2];
		pData[7] = pData[5];
		//Keep_page1 = 0;
		//Keep_page2 = 0;
		for(pData[0] = 0; pData[0] < 9; pData[0]++)
		{
			SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT0); // restart from last three bytes

			PDATA_WORD(7) = pData[3] * 27 + pData[0] * 3;

			pFontTable = tFONT_STRING_TABLE[current_page];//1	//�ֿ�

			SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
			SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
			SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));

			pData[2] = pData[6];
			pData[5] = pData[7];
			
			if((pData[5] == 12) || (*(pArray + pData[2]) == _END_))
			{
				SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
				SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
				SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
			}
			else
			{
				if(*(pArray + pData[2]) == _PAGE_)
				{
				current_page1 = *(pArray + pData[2] + 1);//0
				pData[2] += 2;
				//Keep_page1 = 1;
				pre_page = current_page1;
				}
				else
				{
				current_page1 = current_page;
				pre_page = current_page;
				}
				
				
				pData[8] = *(pArray + pData[2]);

				pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page1]+2*pData[8]+1);


				pData[2] ++;

				PDATA_WORD(7) = pData[8] * 27 + pData[0] * 3;
				
				pFontTable = tFONT_STRING_TABLE[current_page1];



				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));

				pData[5] += pData[4];
			}

			while((pData[5] < 12) && (*(pArray + pData[2]) != _END_))
			{
				SCALEROSD_FONT_ROTATE_3_L_BITS_SHIFT_SET((pData[5] << 4) | pData[5]); // third bits shift and left bits shift

				switch(*(pArray + pData[2]))
				{
					case _END_:
						bEndFlag = 1;
						break;

					case  _PAGE_:
						current_page2 = *(pArray + pData[2] + 1);
						pre_page = current_page2;
						pData[2] += 2;
						pData[8] = *(pArray + pData[2]);
						pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[8]+1);    
						pData[2] ++;
						
						break;

					default:
						current_page2 = current_page1;
						pre_page = current_page1;
						pData[8] = *(pArray + pData[2]);
						pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[8]+1);    
						pData[2] ++;
						break;
				}

				pData[5] += pData[4];

				PDATA_WORD(7) = pData[8] * 27 + pData[0] * 3;
				
				pFontTable = tFONT_STRING_TABLE[current_page2];

				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));
			}

			ucpTemp[pData[0] * 3 + 2] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
			ucpTemp[pData[0] * 3 + 1] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
			ucpTemp[pData[0] * 3] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
		}

		if(pData[5] <= 12)
		{
			pData[5] = 0;
		}
		else
		{
			pData[5] = pData[5] - 12;
			pData[2]--;
		}

		// Write the pro font data to sram
		//COsdFxLoadFontDataAddrCal(ucBankupFontPointer);

		PDATA_WORD(7) = (WORD)pData[1] * 9;
		PDATA_WORD(7) += g_usFontTableStart;

		if(ucFptsSelect!=_PFONT_PAGE_0)
		PDATA_WORD(7) += 0x100*9;
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
	if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
	{
	
		ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _ENABLE, _ENABLE);
		ScalerOsdCompressionCtrl(_OSD_DECODE_NON_COMPRESSED, _OSD_COMPRESSION_ENABLE);
	}
	else
#endif
	{

		ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _DISABLE);
		ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
	}

		if(PDATA_WORD(7) > 4095)
		{
			ScalerOsdScrambleLoadFontAddrHsbSet();
		}
		else
		{
			ScalerOsdScrambleLoadFontAddrHsbClr();
		}

		   ScalerOsdAddrSet(_OSD_SRAM, _OSD_BYTEALL, PDATA_WORD(7), _DISABLE);
		ScalerOsdBurstWriteDataPort(ucpTemp, 27, GET_CURRENT_BANK_NUMBER(), _BURSTWRITE_DATA_OSD, _BURSTWRITE_FROM_XRAM);

		// OSD HW needs time to process it and then write decompressed data into SRAM.
		// The value 1ms is enough at all.
		ScalerTimerDelayXms(1);

		ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
		
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
	if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
	{	
		ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _ENABLE);
	}
#endif

		ScalerOsdScrambleLoadFontAddrHsbClr();


#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
		if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_90)
		{
			PDATA_WORD(7) = (WORD)((g_ucOsdWidth-ucRow-1) + g_ucOsdWidth * (ucCol+ pData[9])) ;
		}
		else if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270)
		{
			PDATA_WORD(7) = (WORD)(g_ucOsdHeight - 1 - ucCol - pData[9]) * g_ucOsdWidth + ucRow;
		}
		else
#endif
		{
			PDATA_WORD(7) = (WORD)ucRow * g_ucOsdWidth + ucCol + pData[9];
		}

		//ScalerOsdCommandByte(PDATA_WORD(7) + g_usFontSelectStart, _OSD_BYTE1, pData[1]);
		if(ucFptsSelect!=_PFONT_PAGE_0)
			ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x6C, pData[1], COLOR);
		else
			ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x4C, pData[1], COLOR);

		pData[9]++; // Record the length of prop string
		
		// Increase the sram address pointer		
		pData[1] = OsdPropSetFontPointer(ucFptsSelect,pData[1]);
		
	}// End of while(*(pArray + stringcnt) != _END_)

	if(ucFptsSelect == _PFONT_PAGE_0)
	{
		g_ucFontPointer0 = pData[1];
	}
	else if(ucFptsSelect == _PFONT_PAGE_1)
	{
		g_ucFontPointer1 = pData[1];
	}

#if((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))
	
	else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect <= _PFONT_PAGE_ITEM_10)))
	{
		g_ucFontPointer2 = pData[1];
	}
#else

	else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect <= _PFONT_PAGE_ITEM_9)))
	{
		g_ucFontPointer2 = pData[1];
	}


#endif
}





#endif

//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void RTDOsdTableFuncPutStringProp(BYTE ucRow, BYTE ucCol, BYTE ucFptsSelect, BYTE ucString, BYTE ucStringIndex,BYTE COLOR,BYTE ucLanguage)
{
		bit bEndFlag = 0;
		BYTE current_page = 0;
        BYTE current_page1 = 0;
		BYTE current_page2 = 0;
		BYTE pre_page = 0;
		BYTE debug_flag = 0;
        //BYTE Keep_page1 = 0;
		//BYTE Keep_page2 = 0;
		//BYTE current_page2 = 0;
		
		
		BYTE xdata ucpTemp[27] = {0};
		BYTE *pFontTable = 0;
		BYTE *pArray = 0;	 
		BYTE i = 0;
		BYTE tempdata[20]= {0};

#if(_DEF_REAL_TIME_HZ)
		BYTE xdata tempdata_x[16];
#endif

		
		if(ucString == _OSD_STRING_NOW_RESOLUTION)
		{
			//RTDOsdTableFuncGetTiMing_17(tempdata);
			RTDOsdTableFuncGetShowResolutionStringAddress();
			for(i = 0; i < 16; i++)
			{
				tempdata[i] = pData[i];
			}
			if(tempdata[15] != _END_)	//����ֱ�����ʾ��������
				tempdata[16] = _END_;
			pArray = tempdata;
			i = 0;	
		}
		else
		{
#if(_DEF_REAL_TIME_HZ)
			if(ucString == _OSD_PINLVXIANSHI_HZ)
			{
				RTDOsdRealTimeHz();
				for(i = 0; i < 16; i++)
				{
					tempdata_x[i] = pData[i];
				}
				pArray = tempdata_x;
				i = 0;
			}
			else
#endif 
				pArray = OsdPropGetStringTableAddress(ucString, ucStringIndex,&ucLanguage);
		}
		pData[0] = ucLanguage;
	   
		
		while(pData[0] != _ENGLISH)
		{
			if(*pArray == _END_)
			{
				pData[0]--;
			}
			pArray++;
		}
	
		pData[1] = OsdPropGetFontPointer(ucFptsSelect);
	
		// reorder
		SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT6);
		SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~(_BIT7 | _BIT5)));
	
		pData[2] = 0;
		pData[3] = 0;
		pData[4] = 0;
		pData[5] = 0;
		pData[9] = 0;
		
		while(*(pArray + pData[2]) != _END_)
		{
			switch(*(pArray + pData[2]))
			{
				case _END_:
					bEndFlag = 1;
					break;
					
                case  _PAGE_:
					current_page = *(pArray + pData[2] + 1);
                    pData[2] += 2;
					pre_page = current_page;
						
					pData[3] = *(pArray + pData[2]);
                    pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);
					pData[2]++;
					
					break;
				default:
					current_page = pre_page;
                    pData[3] = *(pArray + pData[2]);
                    pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);
					pData[2]++;
					break;
			}
	
			if(pData[5] == 0)
			{
				pData[5] = pData[4];
			}
	
			SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT3);    // first bits shift direction: left shift
			SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~_BIT2)); // left bits shift direction: rigth shift
			SCALEROSD_FONT_ROTATE_1_2_BITS_SHIFT_SET(((pData[4] - pData[5]) << 4) | pData[5]); // first bits shift and second bits shift
	
			pData[6] = pData[2];
			pData[7] = pData[5];
	        //Keep_page1 = 0;
			//Keep_page2 = 0;
			for(pData[0] = 0; pData[0] < 9; pData[0]++)
			{
				SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT0); // restart from last three bytes
	
				PDATA_WORD(7) = pData[3] * 27 + pData[0] * 3;

				pFontTable = tFONT_STRING_TABLE[current_page];//1	//�ֿ�
	
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
				SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));
	
				pData[2] = pData[6];
				pData[5] = pData[7];
	            
				if((pData[5] == 12) || (*(pArray + pData[2]) == _END_))
				{
					SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
					SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
					SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
				}
				else
				{
				    if(*(pArray + pData[2]) == _PAGE_)
				    {
                    current_page1 = *(pArray + pData[2] + 1);//0
                    pData[2] += 2;
					//Keep_page1 = 1;
					pre_page = current_page1;
					}
					else
					{
					current_page1 = current_page;
					pre_page = current_page;
					}
					
					
					pData[8] = *(pArray + pData[2]);
	
					pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page1]+2*pData[8]+1);
	
	
					pData[2] ++;
	
					PDATA_WORD(7) = pData[8] * 27 + pData[0] * 3;
					
					pFontTable = tFONT_STRING_TABLE[current_page1];
	
	
	
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));
	
					pData[5] += pData[4];
				}
	
				while((pData[5] < 12) && (*(pArray + pData[2]) != _END_))
				{
					SCALEROSD_FONT_ROTATE_3_L_BITS_SHIFT_SET((pData[5] << 4) | pData[5]); // third bits shift and left bits shift
	
					switch(*(pArray + pData[2]))
					{
						case _END_:
							bEndFlag = 1;
							break;

						case  _PAGE_:
							current_page2 = *(pArray + pData[2] + 1);
							pre_page = current_page2;
							pData[2] += 2;
							pData[8] = *(pArray + pData[2]);
							pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[8]+1);    
							pData[2] ++;
							
							break;
	
						default:
							current_page2 = current_page1;
							pre_page = current_page1;
							pData[8] = *(pArray + pData[2]);
							pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[8]+1);    
							pData[2] ++;
							break;
					}
	
					pData[5] += pData[4];
	
					PDATA_WORD(7) = pData[8] * 27 + pData[0] * 3;
					
					pFontTable = tFONT_STRING_TABLE[current_page2];
	
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
					SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));
				}
	
				ucpTemp[pData[0] * 3 + 2] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
				ucpTemp[pData[0] * 3 + 1] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
				ucpTemp[pData[0] * 3] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
			}
	
			if(pData[5] <= 12)
			{
				pData[5] = 0;
			}
			else
			{
				pData[5] = pData[5] - 12;
				pData[2]--;
			}
	
			// Write the pro font data to sram
			//COsdFxLoadFontDataAddrCal(ucBankupFontPointer);
	
			PDATA_WORD(7) = (WORD)pData[1] * 9;
			PDATA_WORD(7) += g_usFontTableStart;

			if(ucFptsSelect!=_PFONT_PAGE_0)
			PDATA_WORD(7) += 0x100*9;
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
		if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
		{
		
			ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _ENABLE, _ENABLE);
			ScalerOsdCompressionCtrl(_OSD_DECODE_NON_COMPRESSED, _OSD_COMPRESSION_ENABLE);
		}
		else
#endif
		{
	
			ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _DISABLE);
			ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
		}
	
			if(PDATA_WORD(7) > 4095)
			{
				ScalerOsdScrambleLoadFontAddrHsbSet();
			}
			else
			{
				ScalerOsdScrambleLoadFontAddrHsbClr();
			}
	
			   ScalerOsdAddrSet(_OSD_SRAM, _OSD_BYTEALL, PDATA_WORD(7), _DISABLE);
			ScalerOsdBurstWriteDataPort(ucpTemp, 27, GET_CURRENT_BANK_NUMBER(), _BURSTWRITE_DATA_OSD, _BURSTWRITE_FROM_XRAM);
	
			// OSD HW needs time to process it and then write decompressed data into SRAM.
			// The value 1ms is enough at all.
			ScalerTimerDelayXms(1);
	
			ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
			
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
		if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
		{	
			ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _ENABLE);
		}
#endif
	
			ScalerOsdScrambleLoadFontAddrHsbClr();
	
	
#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
			if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_90)
			{
				PDATA_WORD(7) = (WORD)((g_ucOsdWidth-ucRow-1) + g_ucOsdWidth * (ucCol+ pData[9])) ;
			}
			else if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270)
			{
				PDATA_WORD(7) = (WORD)(g_ucOsdHeight - 1 - ucCol - pData[9]) * g_ucOsdWidth + ucRow;
			}
			else
#endif
			{
				PDATA_WORD(7) = (WORD)ucRow * g_ucOsdWidth + ucCol + pData[9];
			}
	
			//ScalerOsdCommandByte(PDATA_WORD(7) + g_usFontSelectStart, _OSD_BYTE1, pData[1]);
			if(ucFptsSelect!=_PFONT_PAGE_0)
				ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x6C, pData[1], COLOR);
			else
				ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x4C, pData[1], COLOR);
	
			pData[9]++; // Record the length of prop string
			
			// Increase the sram address pointer		
			pData[1] = OsdPropSetFontPointer(ucFptsSelect,pData[1]);
			
		}// End of while(*(pArray + stringcnt) != _END_)
	
		if(ucFptsSelect == _PFONT_PAGE_0)
		{
			g_ucFontPointer0 = pData[1];
		}
		else if(ucFptsSelect == _PFONT_PAGE_1)
		{
			g_ucFontPointer1 = pData[1];
		}

#if((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))
		
		else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect <= _PFONT_PAGE_ITEM_10)))
		{
			g_ucFontPointer2 = pData[1];
		}
#else

		else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect <= _PFONT_PAGE_ITEM_9)))
		{
			g_ucFontPointer2 = pData[1];
		}


#endif
}






//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void RTDOsdTableFuncPutStringCenter(BYTE ucRow, BYTE ucColStart, BYTE ucColEnd, BYTE ucFptsSelect, BYTE ucString, BYTE ucStringIndex, BYTE ucCOLOR,SBYTE ucCenterOffset , BYTE ucLanguage)
{
    bit bEndFlag = 0;
	BYTE current_page = 0;
    BYTE current_page1 = 0;
	BYTE current_page2 = 0;
	BYTE pre_page = 0;
	
    //BYTE current_page = 0;
    BYTE xdata ucpTemp[27] = {0};
    bit bMode = _CENTER;
    BYTE *pFontTable = 0;
    BYTE *pArray = 0;    
	BYTE i = 0;
	BYTE xdata tempdata[16];


	
	if(ucString == _OSD_STRING_NOW_RESOLUTION)
	{	
	
		RTDOsdTableFuncGetShowResolutionStringAddress();
		for(i = 0; i < 16; i++)
		{
			tempdata[i] = pData[i];
		}
		
		pArray = tempdata;

	}
	else
	{
#if(_DEF_REAL_TIME_HZ)
		if(ucString == _OSD_PINLVXIANSHI_HZ)
		{
			RTDOsdRealTimeHz();
			for(i = 0; i < 16; i++)
			{
				tempdata[i] = pData[i];
			}
			pArray = tempdata;
		}
		else
#endif
		pArray = OsdPropGetStringTableAddress(ucString, ucStringIndex,&ucLanguage);

	}
	
    pData[0] = ucLanguage;
    
    while(pData[0] != _ENGLISH)
    {
        if(*pArray == _END_)
        {
            pData[0]--;
        }
        pArray++;
    }

#if ((_JAPANESE_SUPPORT==_ON))
	if(ucString == _OSD_STRING_POWEROFF_SHOW&&ucStringIndex==0)
	{

		BYTE abcd[50];
		if(g_usPowerDownCount_MSG)
		memcpy(abcd,pArray,50);
		if(ucLanguage==_JAPANESE)
		{
		i=0;
		while(1)
		{
			i++;
			if(*(abcd+i)==_6_)
				break;
		}
			*(abcd+i) = _0_+g_usPowerDownCount_MSG/10;
			*(abcd+i+1) = _0_+g_usPowerDownCount_MSG%10;
		}
		else
			{
		*(abcd+1) = _0_+g_usPowerDownCount_MSG/10;
		*(abcd+2) = _0_+g_usPowerDownCount_MSG%10;
			}
		pArray = abcd;
	}


#endif

    pData[1] = OsdPropGetFontPointer(ucFptsSelect);
    
    // reorder
    SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT6);
    SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~(_BIT7 | _BIT5)));

    pData[2] = 0;
    pData[3] = 0;
    pData[4] = 0;
    pData[7] = 0;
    pData[10] = 0;
    
    while(*(pArray + pData[2]) != _END_)
    {
        switch(*(pArray + pData[2]))
        {
            case _END_:

                break;
			case _PAGE_:
					current_page = *(pArray + pData[2] + 1);
                    pData[2] += 2;
					pre_page = current_page;
						
					pData[3] = *(pArray + pData[2]);
                    pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);
					pData[2]++;
            default:
                
                pData[3] = *(pArray + pData[2]);
                     
                pData[4] += *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[3]+1);    
               
                pData[2]++;
                break;
        }
    }
    pData[5] = ucColStart + (((((WORD)((ucColEnd - ucColStart + 1) * 12 ) - pData[4]) / 2) + ucCenterOffset) / 12);
    pData[0] = ((((WORD)((ucColEnd - ucColStart + 1) * 12 ) - pData[4]) / 2) + ucCenterOffset) % 12;

/*//for Right mode
    ucCol = (ucColEnd - (ucCharWidth/12) -1);
    ucBlinking = 12 - (ucCharWidth % 12);
*/  

    pData[4] = 0;
    pData[2] = 0;    


    if(pData[0] == 0)
    {
        bMode = _NORMAL;
    }
    else
    {    
        bMode = _CENTER;
    }
    current_page = 0;
    while(*(pArray + pData[2]) != _END_)
    {
        switch(*(pArray + pData[2]))
        {
            case _END_:
                bEndFlag = 1;
                break;
			case  _PAGE_:
				current_page = *(pArray + pData[2] + 1);
			    pData[2] += 2;

				if(bMode == _CENTER)
                {
                    pData[6] = _;
                }
                else
                {
                    pData[6] = *(pArray + pData[2]);
                }


            
                if(bMode == _CENTER)
                {
                    pData[4] = pData[0];
                }
                else
                {                    
                    pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[6]+1);    
                }
			


                pData[2]++;
				break;

            default:
                current_page = pre_page;
                if(bMode == _CENTER)
                {
                    pData[6] = _;
                }
                else
                {
                    pData[6] = *(pArray + pData[2]);
                }


            
                if(bMode == _CENTER)
                {
                    pData[4] = pData[0];
                }
                else
                {                    
                    pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page]+2*pData[6]+1);    
                }
			


                pData[2]++;
                break;
        }

        if(pData[7] == 0)
        {
            pData[7] = pData[4];
        }

        SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT3);    // first bits shift direction: left shift
        SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() & (~_BIT2)); // left bits shift direction: rigth shift
        SCALEROSD_FONT_ROTATE_1_2_BITS_SHIFT_SET(((pData[4] - pData[7]) << 4) | pData[7]); // first bits shift and second bits shift

        pData[8] = pData[2];
        pData[9] = pData[7];

        if(bMode == _CENTER)
        {
            pData[8] = 0;
            pData[6] =0;
            pData[2] = 0;
            bMode = _NORMAL;
        }

        for(pData[0] = 0; pData[0] < 9; pData[0]++)
        {
            SCALEROSD_FONT_ROTATE_SETTING_SET(SCALEROSD_FONT_ROTATE_SETTING_GET() | _BIT0);  // restart from last three bytes
            PDATA_WORD(7)= pData[6] * 27 + pData[0] * 3;

			pFontTable = tFONT_STRING_TABLE[current_page];

            SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
            SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
            SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));

            pData[2] = pData[8];
            pData[7] = pData[9];


            if((pData[7] == 12) || (*(pArray + pData[2]) == _END_))
            {
                SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
                SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
                SCALEROSD_FONT_ROTATE_INPUT_SET(0x00);
            }
            else
            {
				if(*(pArray + pData[2]) == _PAGE_)
				{
				current_page1 = *(pArray + pData[2] + 1);//0
				pData[2] += 2;
				//Keep_page1 = 1;
				pre_page = current_page1;
				}
				else
				{
				current_page1 = current_page;
				pre_page = current_page;
				}

			
                pData[3] = *(pArray + pData[2]);
                pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page1]+2*pData[3]+1);    
				
				

                pData[2] ++;

                PDATA_WORD(7) = pData[3] * 27 + pData[0] * 3;
				
				pFontTable = tFONT_STRING_TABLE[current_page1];
				
                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));

                pData[7] += pData[4];
            }

            while((pData[7] < 12) && (*(pArray + pData[2]) != _END_))
            {
                SCALEROSD_FONT_ROTATE_3_L_BITS_SHIFT_SET((pData[7] << 4) | pData[7]); // third bits shift and left bits shift

                switch(*(pArray + pData[2]))
                {
                    case _END_:
                        bEndFlag = 1;
                        break;
					case  _PAGE_:
						current_page2 = *(pArray + pData[2] + 1);
			    		pData[2] += 2;

						pData[3] = *(pArray + pData[2]);
                            
						pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[3]+1);	
						
                        pData[2] ++;
						pre_page = current_page2;
                        break;
                    default:
						current_page2 = current_page1;
						pre_page = current_page1;
                        pData[3] = *(pArray + pData[2]);
                            
						pData[4] = *(tOSD_CHARWIDTH_TABLE[current_page2]+2*pData[3]+1);	
						
                        pData[2] ++;
                        break;
                }

                pData[7] += pData[4];

                PDATA_WORD(7) = pData[3] * 27 + pData[0] * 3;

				pFontTable = tFONT_STRING_TABLE[current_page2];

                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7)));
                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 1));
                SCALEROSD_FONT_ROTATE_INPUT_SET(*(pFontTable + PDATA_WORD(7) + 2));
            }

            ucpTemp[pData[0] * 3 + 2] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
            ucpTemp[pData[0] * 3 + 1] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
            ucpTemp[pData[0] * 3] = SCALEROSD_FONT_ROTATE_ONPUT_GET();
        }

        if(pData[7] <= 12)
        {
            pData[7] = 0;
        }
        else
        {
            pData[7] = pData[7] - 12;
            pData[2] --;
        }

        // Write the pro font data to sram
        //COsdFxLoadFontDataAddrCal(ucBankupFontPointer);

        PDATA_WORD(7) = (WORD)pData[1] * 9;
		if(ucFptsSelect!=_PFONT_PAGE_0)
        PDATA_WORD(7) += 0x100* 9;
        PDATA_WORD(7) += g_usFontTableStart;
        
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
				if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
				{
					ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _ENABLE, _ENABLE);
					ScalerOsdCompressionCtrl(_OSD_DECODE_NON_COMPRESSED, _OSD_COMPRESSION_ENABLE);
				}
				else
#endif
				{
					ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _DISABLE);
					ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
				}

        
        if(PDATA_WORD(7) > 4095)
        {
            ScalerOsdScrambleLoadFontAddrHsbSet();
        }
        else
        {
            ScalerOsdScrambleLoadFontAddrHsbClr();
        }
		
				ScalerOsdAddrSet(_OSD_SRAM, _OSD_BYTEALL, PDATA_WORD(7), _DISABLE);
		
				ScalerOsdBurstWriteDataPort(ucpTemp, 27, GET_CURRENT_BANK_NUMBER(), _BURSTWRITE_DATA_OSD, _BURSTWRITE_FROM_XRAM);
		
				// OSD HW needs time to process it and then write decompressed data into SRAM.
				// The value 1ms is enough at all.
				ScalerTimerDelayXms(1);
		
				ScalerOsdCompressionCtrl(_OSD_DECODE_COMPRESSED, _OSD_COMPRESSION_DISABLE);
		
#if((_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE) || (_OSD_ROTATE_FUNCTION == _OSD_ROTATE_HARDWARE))
				if(GET_OSD_ROTATE_STATUS() != _OSD_ROTATE_DEGREE_0)
				{
					ScalerOsdFontRotateCtrl(GET_OSD_ROTATE_STATUS(), _DISABLE, _ENABLE);
				}
#endif
				ScalerOsdScrambleLoadFontAddrHsbClr();
		
#if(_OSD_ROTATE_FUNCTION == _OSD_ROTATE_SOFTWARE)
				if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_90)
				{
					PDATA_WORD(7) = (WORD)((g_ucOsdWidth-ucRow-1) + g_ucOsdWidth * (pData[5] + pData[10]));
				}
				else if(GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270)
				{
					PDATA_WORD(7) = (WORD)(g_ucOsdHeight - 1 - pData[5] - pData[10]) * g_ucOsdWidth + ucRow;
				}
				else
#endif
				{
					PDATA_WORD(7) = (WORD)ucRow * g_ucOsdWidth + pData[5] + pData[10];
				}
		

        //ScalerOsdCommandByte(PDATA_WORD(7) + g_usFontSelectStart, _OSD_BYTE1, pData[1]);
        
		if(ucFptsSelect!=_PFONT_PAGE_0)
			ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x6C, pData[1], ucCOLOR);
		else
        	ScalerOsdCommandAllByte(PDATA_WORD(7) + g_usFontSelectStart, 0x4C, pData[1], ucCOLOR);
        pData[10] ++; // Record the length of prop string

        // Increase the sram address pointer
        pData[1] = OsdPropSetFontPointer(ucFptsSelect,pData[1]);
        
    }// End of while(*(pArray + stringcnt) != _END_)

    if(ucFptsSelect == _PFONT_PAGE_0)
    {
        g_ucFontPointer0 = pData[1];
    }
    else if(ucFptsSelect == _PFONT_PAGE_1)
    {
        g_ucFontPointer1 = pData[1];
    }


#if((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))
	
    else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect  <= _PFONT_PAGE_ITEM_10)))
    {
        g_ucFontPointer2 = pData[1];
    }
#else

    else if((ucFptsSelect == _PFONT_PAGE_2) || ((ucFptsSelect >= _PFONT_PAGE_ITEM_1) && (ucFptsSelect  <= _PFONT_PAGE_ITEM_9)))
    {
        g_ucFontPointer2 = pData[1];
    }


#endif
}


//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
void OsdPropShowNumber(BYTE ucRow, BYTE ucCol, DWORD ulValue, BYTE ucPar, BYTE ucFontPoint, BYTE ucColor)
{
    BYTE ucIndex = 0;
    BYTE ucTemp = 0;
    BYTE ucI = 0;
    BYTE pucDataSN[16] = {0};
//60
    pucDataSN[5] = (_0_ + (ulValue / 100000));//  0
    pucDataSN[4] = (_0_ + (ulValue % 100000 / 10000));//0
    pucDataSN[3] = (_0_ + (ulValue % 10000) / 1000);//0
    pucDataSN[2] = (_0_ + (ulValue % 1000) / 100);//0
    pucDataSN[1] = (_0_ + (ulValue % 100) / 10);//6
    pucDataSN[0] = (_0_ + (ulValue % 10));//0

    for(ucIndex = 0; ucIndex < 6; ucIndex++)
    {
    	//�ж����ǲ��Ƿ�0 �Ӷ��ж����м�λ��
        if(pucDataSN[5 - ucIndex] != ((bit)(ucPar & _BIT1) ? _ : _0_))//ucIndex=4
        {
            ucIndex = 5 - ucIndex;  // 1
            break;
        }
    }

    if((ulValue == 0) && ((bit)(ucPar & 0x02) == 0))
    {
        ucIndex = 0;
    }

    if((bit)(ucPar & _BIT1) != 0)
    {
        ucTemp = (ucPar & 0x70) >> 4;
        ucIndex = (ucPar & 0x70) >> 4;
    }
    else
    {
        ucTemp = (ucPar & 0x70) >> 4;      //   1

        if(ucTemp < ucIndex)
        {
            ucTemp = ucIndex;
        }
    }

    for(ucI = 0; ucI <= ucTemp; ucI++)
    {
        if(ucIndex >= ucTemp)
        {
            pucDataSN[ucI + 8] = pucDataSN[ucIndex - ucI];
        }
        else
        {
            if(ucI < (ucTemp - ucIndex))
            {
                pucDataSN[ucI + 8] = 0x00;
            }
            else
            {
                pucDataSN[ucI + 8] = pucDataSN[ucIndex - (ucI - (ucTemp - ucIndex))];
            }
        }
    }
    if((ucPar & 0x01) == _ALIGN_LEFT) // Align Right
    {
        pucDataSN[8 + ucTemp + 1] = _; // clear
        pucDataSN[8 + ucTemp + 2] = _; // clear
        pucDataSN[8 + ucTemp + 3] = _END_;
    }
    else
    {
        pucDataSN[8 + ucTemp + 1] = _END_;
    }

#if 0
	if(pucDataSN[8] == 0 && pucDataSN[9] == 0) //��λ��
	{
		pucDataSN[8] = pucDataSN[10];
		pucDataSN[10] = _;
	
}
	else if(pucDataSN[8] == 0 && pucDataSN[9] != 0)
	{
		pucDataSN[8] = pucDataSN[9];
		pucDataSN[9] = pucDataSN[10];
		pucDataSN[10] = 0;
	}
#endif
	if(ucTemp >= ucIndex)
    	g_pucShowNumberAddress = &pucDataSN[8+(ucTemp - ucIndex)];
	else
    	g_pucShowNumberAddress = &pucDataSN[8];
		
    if((ucPar & 0x01) == _ALIGN_RIGHT)        // Align Right
    {
        RTDOsdTableFuncPutStringProp(ucRow, ROW(ucCol - ucTemp), ucFontPoint, _OSD_STRING_SHOW_NUMBER, 0,ucColor, _ENGLISH);
    }
    else
    {
        RTDOsdTableFuncPutStringProp(ucRow, ucCol, ucFontPoint,_OSD_STRING_SHOW_NUMBER,0, ucColor, _ENGLISH);
    }
}





//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
BYTE *OsdPropGetStringTableAddress(BYTE ucString ,BYTE ucIndex,BYTE * ucLanguage)
{
    BYTE *pucArray = tsOsdNull;



    switch(ucString)
    {
		case _OSD_STRING_TITLE:
		
			pucArray =tOSD_MENU_TITLE_TABLE[ucIndex]; 
#if(_OSD_7PAGE || _DEF_PAGE8)
			if(ucIndex==8)
			*ucLanguage = _ENGLISH; 
#else
			
			if(ucIndex==7)
			*ucLanguage = _ENGLISH; 
#endif
		break;
#if(_LED_EFFECT_TJMODE14)
         case _MENU_FUN_LIGHTMODE:
                 pucArray = tsOSD_Light_STATUS[ucIndex];
                 
             if((*ucLanguage == _CHINESE_S))
                 break;
             *ucLanguage = _ENGLISH;
         break;



         case _MENU_FUN_COLOR:

             pucArray = tsOSD_Light_Color_STATUS[ucIndex];
             if((*ucLanguage == _CHINESE_S))
                 break;
                 *ucLanguage = _ENGLISH;
         break;
#endif

		case _OSD_STRING_FACTORY:
		
			pucArray =tsOSD_FACTORY; 
			*ucLanguage = _ENGLISH; 
		break;
		
            case _MENU_FUN_CROSS:
                pucArray = tsOSD_ON_OFF_STATUS[ucIndex];
            break;
		case _OSD_STRING_ITEM:
			pucArray =tOSD_STRING_ITEM_TABLE[ucIndex];
			ucIndex += _MENU_FUN_BACKLIGHT;
            #if _FREESYNC_SUPPORT
			if(ucIndex == _MENU_FUN_FREESYNC)
			{
				*ucLanguage = _ENGLISH; 
			}
            #if _MD2769
            if(ucIndex == _MENU_FUN_FREESYNC&&GET_INPUT_TIMING_VFREQ() >= 1440)
            {
                pucArray = tsOSD_FREESYNC_TJ;
				*ucLanguage = _ENGLISH; 
            }
            #endif
            #endif
			if((ucIndex == _MENU_FUN_HDR)||(ucIndex == _MENU_FUN_FLICKER_FREE)||(ucIndex == _MENU_FUN_HOTLEFT)||(ucIndex == _MENU_FUN_HOTRIGHT)||(ucIndex == _MENU_FUN_MPRT)||(ucIndex == _MENU_FUN_KVM))
				*ucLanguage = _ENGLISH; 
			else if((ucIndex == _MENU_FUN_OVERCLOCK)||(ucIndex == _MENU_FUN_DDCCI)||(ucIndex == _MENU_FUN_AUDIO_SOURCE)||(ucIndex == _MENU_FUN_CHAOPING_TISHI))
				*ucLanguage = _ENGLISH; 
		break;
		
		case _MENU_FUN_LANGUAGE:
			pucArray =tOSD_LANGUAGE_PAGE_TABLE_TJ; 
            #if(_DEF_HSBL)
			*ucLanguage = _ENGLISH; 
            #endif
		break;


		
		case _OSD_STRING_SHOW_NUMBER:
		
            pucArray = g_pucShowNumberAddress;
		break;
	    

		case _MENU_FUN_ECO:
			pucArray = tsOSD_ECO_STATUS[ucIndex];
#if(_DEF_HSBL)
			if(ucIndex == _COLOREFFECT_STANDARD)
				*ucLanguage = _ENGLISH; 
#endif
		break;

#if(_DEF_2795E06)
		case _MENU_FUN_KVM:
			pucArray = tsOSD_KVM_OPTION[ucIndex];
			if(ucIndex != 0)
				*ucLanguage = _ENGLISH;
		break;
#endif


#if(_DEF_STA_SIX_COLOR)
		case _MENU_FUN_SAT_STATE:
		case _MENU_FUN_HUE_STATE:
			pucArray = tsOSD_STA_SIX_COLOR[ucIndex];
			*ucLanguage = _ENGLISH;
		break;
#endif			

		case _MENU_FUN_HDR:
			pucArray = tOSD_HDR_STATUS[ucIndex];
		    break;

		case _MENU_FUN_DP_VER:
			pucArray = tOSD_DP_VERSION_SELECT[ucIndex];			
			*ucLanguage = _ENGLISH;
		    break;

		case _MENU_FUN_ASPECT:
			pucArray = tsOSD_ASPECT_STATUS[ucIndex];
            if(ucIndex != _OSD_ASPECT_RATIO_16_BY_9&&ucIndex != _OSD_ASPECT_RATIO_USER)
            {
                *ucLanguage = _ENGLISH;
            }
		    break;
		
		case _MENU_FUN_COLORTEMP:
#if(_DEF_CT_JX)
			if((ucIndex == _CT_USER)||(ucIndex >= _CT_GAMMA18))
			{
				pucArray = tOSD_CT_STATUS[_CT_USER];
			}
			else
			{
				pucArray = tOSD_CT_STATUS[ucIndex];
				*ucLanguage = _ENGLISH;
			}
#else
			pucArray = tOSD_CT_STATUS[ucIndex];
			if((ucIndex == _CT_5800)||(ucIndex == _CT_SRGB))
				*ucLanguage = _ENGLISH;
            #if(Project_ID == ID_TJ_2556E01_SN270CS03_1_LOGO_FUEGO_27TZ180FIG2_FHD165_20240104)
    			if((ucIndex == _CT_7500&&_MD2769==_OFF&&*ucLanguage!=_CHINESE_S&&*ucLanguage!=_RUSSIAN))
    				*ucLanguage = _ENGLISH;
            #endif
#endif
		break;

		case _MENU_FUN_LED:
			pucArray = tsOSD_LED_STATUS[ucIndex];
			if(ucIndex == 2)
				*ucLanguage = _ENGLISH;
		break;

		case _MENU_FUN_POWER_OFF:

			pucArray = tOSD_SLEEP_ON_OFF_TABLE[ucIndex];
			if(ucIndex!=0)
			*ucLanguage = _ENGLISH;
		break;

		case _MENU_FUN_VIVID:
		case _MENU_FUN_HDR_COLOR:
#if(_MPRT_WEAK_MID_HIGH)	
		case _MENU_FUN_MPRT:
#endif

#if(_MPRT_WEAK_MID_HIGH)
     		pucArray = tsOSD_ON_OFF_STATUS[ucIndex];
#else
			pucArray = tsOSD_VIVID_STATUS[ucIndex];
#endif
		break;


		case _MENU_FUN_AUDIO_SOURCE:
			pucArray = tsOSD_AUDIO_SOURCE[ucIndex];
				*ucLanguage = _ENGLISH;
		break;
			

#if(!_OD_WEAK_MID_HIGH)
		case _MENU_FUN_OD:
#endif
		case _MENU_FUN_DCR:
		case _MENU_FUN_AUDOIMUTE:
        #if _FREESYNC_SUPPORT
		case _MENU_FUN_FREESYNC:
        #endif
		case _MENU_FUN_FV_INFORMATION:		
		case _MENU_FUN_DDCCI:
		case _MENU_FUN_FLICKER_FREE:

#if(!_MPRT_WEAK_MID_HIGH)	
		case _MENU_FUN_MPRT:
#endif	
		case _MENU_FUN_OVERCLOCK:
		case _MENU_FUN_DCC:
		case _MENU_FUN_CHAOPING_TISHI:
			pucArray = tsOSD_ON_OFF_STATUS[ucIndex];
		break;


#if(_OD_WEAK_MID_HIGH)
		case _MENU_FUN_OD:
			pucArray = tsOSD_VIVID_STATUS[ucIndex];
		break;
#endif
		
        
		case _MENU_FUN_LOWBLUE:
			pucArray = tsOSD_VIVID_STATUS[ucIndex];
		break;
		case _MENU_FUN_HOTLEFT:	
		case _MENU_FUN_HOTRIGHT:
			pucArray = tOSD_STRING_ITEM_TABLE[ucIndex];//tsOSD_HOTKEY_TYPE[ucIndex];
            #if _FREESYNC_SUPPORT
			if(ucIndex == _MENU_FUN_FREESYNC)
			{
				*ucLanguage = _ENGLISH; 
			}
            #endif
			if((ucIndex == _MENU_FUN_HDR)||(ucIndex == _MENU_FUN_FLICKER_FREE)||(ucIndex == _MENU_FUN_HOTLEFT)||(ucIndex == _MENU_FUN_HOTRIGHT)||(ucIndex == _MENU_FUN_MPRT) || (ucIndex == _MENU_FUN_LED)||(ucIndex == _MENU_FUN_KVM))
				*ucLanguage = _ENGLISH; 
			else if((ucIndex == _MENU_FUN_OVERCLOCK)||(ucIndex == _MENU_FUN_DDCCI)||(ucIndex == _MENU_FUN_AUDIO_SOURCE)||(ucIndex == _MENU_FUN_CHAOPING_TISHI))
				*ucLanguage = _ENGLISH; 

		break;
			
			
		case _MENU_FUN_OSD_RORATE:
            
    			pucArray = tsOSD_OSDRotation_table[ucIndex];
        		if(ucIndex!=0)
    			*ucLanguage = _ENGLISH;
		break;
			

		case _MENU_FUN_SIGNAL:
			pucArray = tOSD_SOURCE_TYPE_STATUS[ucIndex];

#if(_SOURCE_AUTO_ON)
			if(ucIndex == 0)
			{
                *ucLanguage = _ENGLISH;
			}
			else
#endif
			{
				*ucLanguage = _ENGLISH;
			}
		break;

        case _OSD_STRING_MODEL_VER:
			pucArray = tOSD_STRING_MODEL_VER[0];
			*ucLanguage = _ENGLISH;
		    break;
		
		case _OSD_STRING_SIGNAL:
			pucArray = tOSD_SOURCE_TYPE_STATUS[ucIndex];
			if(ucIndex == 0)
			{
			    *ucLanguage = _ENGLISH;
			}
			else
			{
				*ucLanguage = _ENGLISH;
			}
		break;
		
		case _OSD_STRING_NO_SIGNAL:

			pucArray = tsOSD_NO_SIGNAL;//tsOSD_WarningNosignalwillenterstandbymodeshortly_table
		break;
		case _OSD_STRING_POWEROFF_SHOW:
			
			pucArray = tOSD_POWEROFF_SHOW[ucIndex];
		break;

		case _OSD_STRING_NOW_RESOLUTION1:

			pucArray = tsOSD_RESOLUTION;
		break;
		case _OSD_STRING_NOW_WINDOW:

			pucArray = tsOSD_WINDOW1;
		break;
        
		case _OSD_STRING_NOW_SOURCE1:

			pucArray = tsOSD_SIGNAL_SOURCE1;
		break;
        


#if(_DEF_HOTKEY_REPLACE)
		case _MENU_FUN_HOT_REPLACE_LEFT:
		case _MENU_FUN_HOT_REPLACE_RIGHT:
		case _MENU_FUN_HOT_REPLACE_EXIT:
			pucArray = tsOSD_HOTKEY_REPLACE[ucIndex];
		break;
#endif

#if(_DEF_OPPOSITE_DCR)
		case _MENU_FUN_DCR_OPPOSITE:
			pucArray = tsOSD_STANDARD_HIGH[ucIndex];
		break;
#endif
		case _OSD_STRING_RGB:

			pucArray = tsOSD_USER_table[ucIndex];
		break;
		case _OSD_STRING_HZ:

			pucArray =tsOSD_HZ;
		break;


		case _OSD_STRING_NO_SUPPORT:

			pucArray = tsOSD_OutOfRange;
		break;
		
		case _OSD_STRING_POWER_SAVING:

			pucArray = tsOSD_EnterPowerSaving;//tsOSD_POWER_SAVING;
		break;

		case _OSD_STRING_NOW_RESOLUTION:

			pucArray = RTDOsdTableFuncGetShowResolutionStringAddress();
		break;
			
		case _MENU_FUN_COLORGAMUT:
		
				pucArray = tsOSD_COLORGAMUT_STATUS[ucIndex];
				if(ucIndex!=3)
				*ucLanguage = _ENGLISH;
			break;


		

		case _MENU_FUN_GAMMA:

			pucArray = tsOSD_GAMMA_STATUS[ucIndex];
			
//			if(ucIndex!=0)	
			*ucLanguage = _ENGLISH;
		break;
		

#if _ENABLE_ENERGE_NOTICE_MENU			
		case _OSD_STRING_ENERGY_NOTICE_1:
            pucArray = tsOSD_ENERGE_NOTICE1;
			break;
		case _OSD_STRING_ENERGY_NOTICE_2:
            pucArray = tsOSD_ENERGE_NOTICE2;
			break;
        case _OSD_STRING_ENERGY_NOTICE_3:
            pucArray = tsOSD_ENERGE_NOTICE3;
			break;
#endif

		case _OSD_YES_NO:
			pucArray = tsOSD_YESNO[ucIndex];
			break;


#if _LONG_PRESS_MENU_LOCK_OSD_ENABLE
		case _OSD_STRING_FUN_LOCK_MENU:
			pucArray = tsOSD_LOCK_OSD_STATUS[ucIndex];
			break;

#endif

#if _LONG_PRESS_POWER_LOCK_POWER_KEY_ENABLE
		case _OSD_STRING_FUN_LOCK_POWER_KEY:
            pucArray = tsOSD_LOCK_POWER_KEY_STATUS[ucIndex];
			break;
#endif

#if(_DEF_REAL_TIME_HZ)
		case _OSD_PINLVXIANSHI_HZ:
			pucArray = RTDOsdRealTimeHz();
			break;
            #endif 


#if(_REMIND_ENERGY_EFFICIENCY_FUNCTION==_ON)
				
		case _OSD_STRING_ENERGY_CONSUMPTION_SHOW_SHOW_1:

			pucArray = tsOSD_ENERGY_CONSUMPTION_SHOW_SHOW_1;
		break;
		case _OSD_STRING_ENERGY_CONSUMPTION_SHOW_SHOW_2:

			pucArray = tsOSD_ENERGY_CONSUMPTION_SHOW_SHOW_2;
		break;

		case _OSD_STRING_ENERGY_CONSUMPTION_SHOW_SHOW_3:

			pucArray = tsOSD_ENERGY_CONSUMPTION_SHOW_SHOW_3;
		break;

		case _OSD_STRING_ENERGY_CONSUMPTION_SHOW_SHOW_4:

			pucArray = tsOSD_YES_NO_STATUS[ucIndex];
		//	*ucLanguage = _ENGLISH;
		break;
		
#endif

			
        default:
            break;
    }

    return pucArray;
}

#endif//#if(_OSD_TYPE == _REALTEK_2014_OSD)

