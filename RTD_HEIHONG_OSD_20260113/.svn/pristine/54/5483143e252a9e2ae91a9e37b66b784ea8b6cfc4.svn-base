BYTE* RTDOsdTableFuncGetShowResolutionStringAddress(void)
{
	WORD temp = 0;
	BYTE i = 0;
	
	if(GET_INPUT_TIMING_HWIDTH() >= 1000) 
	{
		i +=4;//1920*1080
	}
	else
	{
		i +=3;
	}

	if((GET_INPUT_TIMING_VHEIGHT() >= 1000)||((GET_INPUT_TIMING_INTERLACE_FLG())&&(GET_INPUT_TIMING_VHEIGHT() >= 500)))
	{
		i +=4;//1920*1080
	}
	else
	{
		i +=3;
	}
	
	 i+=4;//HZ,�ո�,_END
	//i+=1;//�ո�
   // i+=2;//HZ
	if(GET_INPUT_TIMING_VFREQ() >= 1000)
	{
		i += 3;//100HZ
	}
	else
	{
		i += 2;
	}


	if(GET_INPUT_TIMING_INTERLACE_FLG())
	{
#if 0//
		if(GET_INPUT_TIMING_VHEIGHT() <= 600 && GET_INPUT_TIMING_VFREQ() <= 710) //(GET_OSD_FREE_SYNC_STATUS() != _ON && GET_INPUT_TIMING_VFREQ() <= 710)
#endif
			i += 1;//1080i
	}

	if(i < 16)//pData������16λ, ���ΪpData[15]  �����pData[16]д�ǲ���ȫ��,���׳�����   һ��ֱ��ʲ��ᳬ��16λ,�������ֱ��� 1920x1080i 120HZ��ᳬ��
	pData[i] = _END_;		
	pData[--i] =_z_;	  
	pData[--i] = _H_;
   // i=i-3;
	temp = GET_INPUT_TIMING_VFREQ();
#if 1
	if(temp >= 1445 && temp <= 1449)
		temp = 1440;
	else if(temp >= 1655 && temp <= 1659)
		temp = 1650;
#endif
	if((temp % 10) >5)
		temp = temp / 10 + 1;
	else	
		temp /= 10;

	if((temp%10) == 1)
	{
		temp = temp-1;
	}
	while(1)
	{
		pData[--i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{	//++i;
			break;
		}
		//i--;
	}
	//i-=1;
	pData[--i] =_xfb_;	//@	   

	temp = GET_INPUT_TIMING_VHEIGHT();

	if(GET_INPUT_TIMING_INTERLACE_FLG())
	{
#if 0//
		if(GET_INPUT_TIMING_VHEIGHT() <= 600 && GET_INPUT_TIMING_VFREQ() <= 710)
#endif
		{
			temp*=2;
			//i-=1;
			pData[--i] =_i_;		
		}
	}
		
	while(1)
	{
		pData[--i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{	//++i;
			break;
		}
		//i--;
	}
	pData[--i] = _X_;
	//i-=1;

	temp = GET_INPUT_TIMING_HWIDTH();

	while(1)//write HWIDTH number
	{
		pData[--i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{	//++i;
			break;
		}
		//i--;
	}

	return pData;
}

