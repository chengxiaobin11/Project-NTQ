//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
BYTE OsdPropGetFontPointer(BYTE ucPointerSelect)
{
    BYTE ucPointer = 0;

    if(ucPointerSelect == _PFONT_PAGE_0)
    {
        ucPointer = GET_OSD_INFO_FONT_POINTER_0();
    }
    else if(ucPointerSelect == _PFONT_PAGE_1)
    {
        ucPointer = GET_OSD_INFO_FONT_POINTER_1();
    }
    else if(ucPointerSelect == _PFONT_PAGE_2)
    {
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_1)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_1);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_2)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_2);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_3)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_3);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_4)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_4);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_5)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_5);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_6)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_6);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_7)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_7);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_8)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_8);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_9)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_9);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }

#if((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))
	
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_10)
    {
        SET_OSD_INFO_FONT_POINTER_2(_SUB_PAGE_ITEM_10);
        ucPointer = GET_OSD_INFO_FONT_POINTER_2();
    }

#endif	
    else if(ucPointerSelect == _PFONT_PAGE_INFORMATION)
    {
        ucPointer = GET_OSD_INFO_FONT_POINTER_1();
    }

    return ucPointer;
}


//--------------------------------------------------
// Description  :
// Input Value  : None
// Output Value : None
//--------------------------------------------------
BYTE OsdPropSetFontPointer(BYTE ucPointerSelect, BYTE ucPointer)
{
    ucPointer++;

    if(ucPointerSelect == _PFONT_PAGE_0)
    {
        if(ucPointer > _OSD_PAGE_0_END)
        {
            ucPointer = _OSD_PAGE_0_START;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_1)
    {
        if(ucPointer > _OSD_PAGE_1_END)
        {
            ucPointer = _OSD_PAGE_1_START;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_2)
    {
        if(ucPointer > _OSD_PAGE_2_END)
        {
            ucPointer = _OSD_PAGE_2_START;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_1)
    {
        if(ucPointer > _SUB_PAGE_ITEM_1_END)
        {
            ucPointer = _SUB_PAGE_ITEM_1;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_2)
    {
        if(ucPointer > _SUB_PAGE_ITEM_2_END)
        {
            ucPointer = _SUB_PAGE_ITEM_2;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_3)
    {
        if(ucPointer > _SUB_PAGE_ITEM_3_END)
        {
            ucPointer = _SUB_PAGE_ITEM_3;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_4)
    {
        if(ucPointer > _SUB_PAGE_ITEM_4_END)
        {
            ucPointer = _SUB_PAGE_ITEM_4;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_5)
    {
        if(ucPointer > _SUB_PAGE_ITEM_5_END)
        {
            ucPointer = _SUB_PAGE_ITEM_5;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_6)
    {
        if(ucPointer > _SUB_PAGE_ITEM_6_END)
        {
            ucPointer = _SUB_PAGE_ITEM_6;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_7)
    {
        if(ucPointer > _SUB_PAGE_ITEM_7_END)
        {
            ucPointer = _SUB_PAGE_ITEM_7;
        }
    }
    else if(ucPointerSelect == _PFONT_PAGE_ITEM_8)
    {
        if(ucPointer > _SUB_PAGE_ITEM_8_END)
        {
            ucPointer = _SUB_PAGE_ITEM_8;
        }
    }    
	else if(ucPointerSelect == _PFONT_PAGE_ITEM_9)
    {
        if(ucPointer > _SUB_PAGE_ITEM_9_END)
        {
            ucPointer = _SUB_PAGE_ITEM_9;
        }
    }
#if((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))
	
	else if(ucPointerSelect == _PFONT_PAGE_ITEM_10)
    {
        if(ucPointer > _SUB_PAGE_ITEM_10_END)
        {
            ucPointer = _SUB_PAGE_ITEM_10;
        }
    }
#endif
	
    else if(ucPointerSelect == _PFONT_PAGE_INFORMATION)
    {
        if(ucPointer > _OSD_PAGE_INFORMATION_END)
        {
            ucPointer = _OSD_PAGE_INFORMATION_START;
        }
    }

    return ucPointer;
}

//--------------------------------------------------
// Description  :	
// Input Value  : 
// Output Value : 
//--------------------------------------------------
BYTE GetOsdShowType(BYTE ucStateIndex)
{
	switch(ucStateIndex)
	{
		 
		case _MENU_FUN_BACKLIGHT:
		case _MENU_FUN_CONTRAST:	
		case _MENU_FUN_BRIGHTNESS:	
		case _MENU_FUN_SHARPNESS:	
		case _MENU_FUN_VGA_HPOSITON:	
		case _MENU_FUN_VGA_VPOSITON:	
		case _MENU_FUN_VGA_CLK:	
		case _MENU_FUN_VGA_PHASE: 
		case _MENU_FUN_R: 
		case _MENU_FUN_G: 
		case _MENU_FUN_B: 
		case _MENU_FUN_OSD_HPOSITON:
		case _MENU_FUN_OSD_VPOSITON: 
		case _MENU_FUN_OSD_TIME: 
		case _MENU_FUN_OSD_TRANS: 
		case _MENU_FUN_HUE:
		case _MENU_FUN_AUDOIVOLUME:
		case _MENU_FUN_SATURATION:	
#if(_DCC_PROGRESS_BAR)
		case _MENU_FUN_DCC:
#endif

#if(_DEF_STA_SIX_COLOR)
		case _MENU_FUN_SAT_RED:
		case _MENU_FUN_SAT_GREEN:
		case _MENU_FUN_SAT_BLUE:
		case _MENU_FUN_SAT_CYAN:
		case _MENU_FUN_SAT_MAGENTA:
		case _MENU_FUN_SAT_YELLOW:

		case _MENU_FUN_HUE_RED:
		case _MENU_FUN_HUE_GREEN:
		case _MENU_FUN_HUE_BLUE:
		case _MENU_FUN_HUE_CYAN:
		case _MENU_FUN_HUE_MAGENTA:
		case _MENU_FUN_HUE_YELLOW:
#endif
			 return _TYPE_SLIDER;
		break;


#if(!_DCC_PROGRESS_BAR)
		case _MENU_FUN_DCC:
#endif
		case _MENU_FUN_ECO:
		case _MENU_FUN_DCR:
		case _MENU_FUN_HDR:
		case _MENU_FUN_ASPECT:
		case _MENU_FUN_COLORTEMP:	
		case _MENU_FUN_LED:
		case _MENU_FUN_POWER_OFF:
		case _MENU_FUN_OD:
        #if _FREESYNC_SUPPORT
		case _MENU_FUN_FREESYNC:
        #endif
		case _MENU_FUN_AUDOIMUTE:
		case _MENU_FUN_SIGNAL:	
		case _MENU_FUN_HOTLEFT:
		case _MENU_FUN_HOTRIGHT:
		case _MENU_FUN_FLICKER_FREE:
		case _MENU_FUN_MPRT:
		case _MENU_FUN_GAMMA:		
		case _MENU_FUN_COLORGAMUT:		
		case _MENU_FUN_OVERCLOCK:		
		case _MENU_FUN_LANGUAGE:
		case _MENU_FUN_OSD_RORATE:

		case _MENU_FUN_VIVID:
		case _MENU_FUN_DDCCI:
		case _MENU_FUN_FV_INFORMATION:
		case _MENU_FUN_DP_VER:
		case _MENU_FUN_AUDIO_SOURCE:
		case _MENU_FUN_CHAOPING_TISHI:
		case _MENU_FUN_KVM:
		case _MENU_FUN_HDR_COLOR:
#if(_DEF_OPPOSITE_DCR)
		case _MENU_FUN_DCR_OPPOSITE:
#endif
#if(_DEF_HOTKEY_REPLACE)			
		case _MENU_FUN_HOT_REPLACE_LEFT:
		case _MENU_FUN_HOT_REPLACE_RIGHT:
		case _MENU_FUN_HOT_REPLACE_EXIT:
#endif
#if(_DEF_STA_SIX_COLOR)
		case _MENU_FUN_SAT_STATE:
		case _MENU_FUN_HUE_STATE:
#endif			
#if(_LED_EFFECT_TJMODE14)
                case _MENU_FUN_LIGHTMODE:
                case _MENU_FUN_COLOR:
#endif
        case _MENU_FUN_LOWBLUE:
        case _MENU_FUN_CROSS:
			 return _TYPE_ARROW;
		break;

		case _MENU_FUN_AUTO_ADJUST:
		case _MENU_FUN_AUTO_COLOR:	
		case _MENU_FUN_RESET:
			 return _TYPE_NONE;
		break;

		default:
			return _TYPE_NONE;
		break;
	}
	
	return _TYPE_NONE;
}





#if(_REMIND_ENERGY_EFFICIENCY_FUNCTION==_ON)

//--------------------------------------------------
// Description  :	
// Input Value  : 
// Output Value : 
//--------------------------------------------------

BYTE GetOSDMSG(BYTE ucStateIndex)
{
	switch(ucStateIndex)
	{
		case _MENU_FUN_BACKLIGHT:	
//		case _MENU_FUN_CONTRAST:	
            if(GET_OSD_BACKLIGHT()!=100)			
               return 1;
			break;
        case _MENU_FUN_AUDOIVOLUME:    
            if(GET_OSD_VOLUME()!=100)			
			return 1;
			break;
//		case _MENU_FUN_POWER_OFF:
		case _MENU_FUN_ECO:
			return 2;
			break;
//		case _MENU_FUN_COLORTEMP:
		case _MENU_FUN_DCR:
            
		if(GET_OSD_DCR_STATUS()==_OFF)
            {

                return 2;
            }
            break;
//		case _MENU_FUN_OD:
//		case _MENU_FUN_GAMMA:
//        case _MENU_FUN_COLORGAMUT:// new add
//		case _MENU_FUN_LOWBLUE:
		case _MENU_FUN_HDR:
			if(GET_OSD_HDR_MODE() == _HDR10_MODE_OFF)
            {
                return 2;
            }

			break;
		default:
			return _FALSE;
			break;
	}
		
}


#endif

//--------------------------------------------------
// Description  :	
// Input Value  : 
// Output Value : 
//--------------------------------------------------

BYTE GetOsdValue(BYTE ucStateIndex)
{
#if((_HDR10_SUPPORT == _OFF)&&((_PROJECT == _RL6463_PROJECT)||(_PROJECT == _RL6369_PROJECT)))
	BYTE pucHDRInfoData[_HW_DP_INFOFRAME_RSV0_LENGTH];
#endif
	switch(ucStateIndex)
	{
		 
		case _MENU_FUN_BACKLIGHT:
#if((_HDR10_SUPPORT == _OFF)&&((_PROJECT == _RL6463_PROJECT)||(_PROJECT == _RL6369_PROJECT)))
			ScalerGetHDR10Data_MOCK(pucHDRInfoData);
			if(((GET_OSD_HDR_MODE() == _HDR10_MODE_AUTO)&&(pucHDRInfoData[0] == 1)&&(pucHDRInfoData[1] == 0x1A)&&(pucHDRInfoData[2] == 2))||(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084)) 		
#elif(_HDR10_SUPPORT == _ON)
			if(((GET_OSD_HDR_MODE() == _HDR10_MODE_AUTO)&&(GET_HDR10_EOTF_SETTING() == _HDR_TARGET_STATUS_SMPTE_ST_2084))||(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084))
#else
			if(0)//((GET_OSD_HDR_MODE() == _HDR10_MODE_AUTO)&&(GET_HDR10_EOTF_SETTING() == _HDR_TARGET_STATUS_SMPTE_ST_2084))||(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084))
		
#endif
			{
				return 100;
			}
			else
			{
				return GET_OSD_BACKLIGHT();
			}
		break;
		
		case _MENU_FUN_CONTRAST:	
			return GET_OSD_CONTRAST();
		break;
		

		case _MENU_FUN_BRIGHTNESS:	
		
			return GET_OSD_BRIGHTNESS();
		break;
		
		case _MENU_FUN_SHARPNESS:	
#if(_DEF_ECO_SET) || (_CUSTOMER_TYPE == _HUASHUOHUI_CUSTOMER)
			if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_MOVIE )
				return _ECO_MOVIE_SHARPNESS;
			else if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_GAME )
				return _ECO_GAME_SHARPNESS;
			else
#endif
				return GET_OSD_SHARPNESS();
		break;		
		case _MENU_FUN_HUE:	
		
			return GET_OSD_HUE();
		break;

#if(_VGA_SUPPORT == _ON)
		
		case _MENU_FUN_VGA_HPOSITON:
		
			return GET_VGA_MODE_ADJUST_H_POSITION();
		break;
		
		case _MENU_FUN_VGA_VPOSITON:
		
			return GET_VGA_MODE_ADJUST_V_POSITION();
		break;
		
		case _MENU_FUN_VGA_CLK:	
		
			return GET_VGA_MODE_ADJUST_CLOCK();
		break;
		
		case _MENU_FUN_VGA_PHASE: 
		
			return GET_VGA_MODE_ADJUST_PHASE();
		break;
#endif		
		case _MENU_FUN_R: 

			return GET_COLOR_TEMP_TYPE_USER_R();
		break;
		
		case _MENU_FUN_G: 
		
			return GET_COLOR_TEMP_TYPE_USER_G();
		break;
		
		case _MENU_FUN_B: 
		
			return GET_COLOR_TEMP_TYPE_USER_B();
		break;
		
		case _MENU_FUN_OSD_HPOSITON:

			return GET_OSD_HPOS();
		break;
		
		case _MENU_FUN_OSD_VPOSITON: 
		
			return GET_OSD_VPOS();
		break;
		
		case _MENU_FUN_OSD_TIME: 
		
			return GET_OSD_TIME_OUT();
		break;
		
		case _MENU_FUN_OSD_TRANS: 
		
			return GET_OSD_TRANSPARENCY_STATUS();
		break;
		
		case _MENU_FUN_CROSS:
			
			return GET_OSD_CROSS_STATUS();
		break;
		case _MENU_FUN_LOWBLUE:
			
			return GET_OSD_LOW_BLUE();
		break;
		
		case _MENU_FUN_AUDOIVOLUME:
			{
				return GET_OSD_VOLUME();
			}
		break;
		
		
		case _MENU_FUN_ECO:
			
			return GET_OSD_COLOR_EFFECT();
		break;
		
		case _MENU_FUN_DCR:
			
			return GET_OSD_DCR_STATUS();
		break;
		
		case _MENU_FUN_HDR:
			
			return GET_OSD_HDR_MODE();
		break;

		case _MENU_FUN_DP_VER:
			if(SysSourceGetSourceType() == _SOURCE_DP)
			{
#if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
			if(GET_OSD_INPUT_PORT_OSD_ITEM()==_OSD_INPUT_D0)
				return GET_OSD_DP_D0_VERSION();
			else if(SysSourceGetSourceType() == _SOURCE_DP)
				return GET_OSD_DP_D0_VERSION();
			else
				return 0;
#endif
#if(_D1_INPUT_PORT_TYPE== _D1_DP_PORT)
			if(GET_OSD_INPUT_PORT_OSD_ITEM()==_OSD_INPUT_D1)
				return GET_OSD_DP_D1_VERSION();
#endif	
#if(_D2_INPUT_PORT_TYPE == _D2_DP_PORT)
			if(GET_OSD_INPUT_PORT_OSD_ITEM()==_OSD_INPUT_D2)
				return GET_OSD_DP_D2_VERSION();
#endif	
#if(_D6_INPUT_PORT_TYPE == _D6_DP_PORT)
			if(GET_OSD_INPUT_PORT_OSD_ITEM()==_OSD_INPUT_D6)
				return GET_OSD_DP_D6_VERSION();
#endif	
			}
			else
			{
#if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
				return GET_OSD_DP_D0_VERSION();
#endif
#if(_D1_INPUT_PORT_TYPE == _D1_DP_PORT)
				return GET_OSD_DP_D1_VERSION();
#endif	
#if(_D2_INPUT_PORT_TYPE == _D2_DP_PORT)
				return GET_OSD_DP_D2_VERSION();
#endif	
#if(_D6_INPUT_PORT_TYPE== _D6_DP_PORT)
				return GET_OSD_DP_D6_VERSION();
#endif	
			}
		break;

		case _MENU_FUN_VIVID:
#if(_DEF_ECO_SET)
			if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_GAME )
				return _ULTRA_VIVID_H;
			else if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_MOVIE)	
				return _ULTRA_VIVID_L;
			else			
#endif
				return GET_OSD_ULTRA_VIVID_STATUS();
		break;

		case _MENU_FUN_AUDIO_SOURCE:
			return GET_FUN_AUDIO_SOURCE();
		break;

		case _MENU_FUN_KVM:
			return GET_FUN_KVM();
		break;

#if(_DEF_STA_SIX_COLOR)
		case _MENU_FUN_SAT_STATE:
			return GET_SAT_STATE();
		break;

		case _MENU_FUN_SAT_RED:
			return GET_SIX_COLOR_SAT_R();
			break;
			
		case _MENU_FUN_SAT_GREEN:
			return GET_SIX_COLOR_SAT_G();
			break;
			
		case _MENU_FUN_SAT_BLUE:
			return GET_SIX_COLOR_SAT_B();
			break;

		case _MENU_FUN_SAT_CYAN:
			return GET_SIX_COLOR_SAT_C();
			break;

		case _MENU_FUN_SAT_MAGENTA:
			return GET_SIX_COLOR_SAT_M();
			break;

		case _MENU_FUN_SAT_YELLOW:
			return GET_SIX_COLOR_SAT_Y();
			break;



		case _MENU_FUN_HUE_STATE:
			return GET_HUE_STATE();
		break;

		case _MENU_FUN_HUE_RED:
			return GET_SIX_COLOR_HUE_R();
			break;
			
		case _MENU_FUN_HUE_GREEN:
			return GET_SIX_COLOR_HUE_G();
			break;
			
		case _MENU_FUN_HUE_BLUE:
			return GET_SIX_COLOR_HUE_B();
			break;

		case _MENU_FUN_HUE_CYAN:
			return GET_SIX_COLOR_HUE_C();
			break;

		case _MENU_FUN_HUE_MAGENTA:
			return GET_SIX_COLOR_HUE_M();
			break;

		case _MENU_FUN_HUE_YELLOW:
			return GET_SIX_COLOR_HUE_Y();
			break;
#endif			

		case _MENU_FUN_CHAOPING_TISHI:
			return GET_FUN_OVERCLOCK_HINT();
		break;

		case _MENU_FUN_FV_INFORMATION:
			return GET_OSD_FV_INFORMATION();
		break;

		case _MENU_FUN_DDCCI:
		    return GET_OSD_DDCCI_STATUS();
		break;
		
		case _MENU_FUN_ASPECT:
			
			return GET_OSD_ASPECT_RATIO_TYPE();
		break;
		
		case _MENU_FUN_COLORTEMP:	
			
			return GET_COLOR_TEMP_TYPE();
		break;
		
		case _MENU_FUN_LED:
		
			return GET_OSD_LED_TYPE();
		break;
		
		case _MENU_FUN_POWER_OFF:

			
			return GET_OSD_AUTO_POWEROFF();
		break;

		case _MENU_FUN_HDR_COLOR:
#if(_HDR10_COLOR_ENHANCE_SUPPORT == _ON)
			return GET_OSD_HDR_COLOR_ENHANCE();
#endif
			return 0;
		break;
		
		case _MENU_FUN_OD:

			return GET_OSD_OD_STATUS();
		break;
		#if _FREESYNC_SUPPORT
		case _MENU_FUN_FREESYNC:
			return GET_OSD_FREE_SYNC_STATUS();
		break;
        #endif
		
		case _MENU_FUN_AUDOIMUTE:

			return GET_OSD_VOLUME_MUTE();
		break;
		
		case _MENU_FUN_SIGNAL:	

			return GET_OSD_INPUT_PORT_OSD_ITEM();
		break;
		
		case _MENU_FUN_HOTLEFT:	

			return GET_OSD_HOTKEY_LEFT();
		break;
		
		case _MENU_FUN_HOTRIGHT:	

			return GET_OSD_HOTKEY_RIGHT();
		break;
		
#if(_VGA_SUPPORT == _ON)

		case _MENU_FUN_AUTO_ADJUST:
		case _MENU_FUN_AUTO_COLOR:	
#endif
		case _MENU_FUN_RESET:
		
			 return 0;
		break;

		case _MENU_FUN_LANGUAGE:
		
			 return GET_OSD_LANGUAGE();
		break;

	
		case _MENU_FUN_FLICKER_FREE:
		
			 return GET_OSD_FLICKER_FREE_STATUS();
		break;

		case _MENU_FUN_MPRT:
		
			 return GET_OSD_MPRT();
		break;
		
        case _MENU_FUN_GAMMA: 
			return GET_OSD_GAMMA();
			
		break;

#if(_DEF_HOTKEY_REPLACE)
		case _MENU_FUN_HOT_REPLACE_RIGHT:
			return GET_OSD_HOT_REPLACE_RIGHT();
		break;	
		
		case _MENU_FUN_HOT_REPLACE_EXIT:
			return GET_OSD_HOT_REPLACE_EXIT();
		break;
		
		case _MENU_FUN_HOT_REPLACE_LEFT:
			return GET_OSD_HOT_REPLACE_LEFT();
		break;
#endif

#if(_DEF_OPPOSITE_DCR)
		case _MENU_FUN_DCR_OPPOSITE:
			return GET_OSD_DCR_OPPOSITE();
		break;
#endif

		case _MENU_FUN_DCC:
			return GET_OSD_DCC();
		break;
			
        case _MENU_FUN_COLORGAMUT: 
			return GET_OSD_PCM_STATUS();
			
		break;
		
		case _MENU_FUN_SATURATION:
#if(_DEF_ECO_SET && (!_DEF_COLORFUL))	//
			if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_GAME)
				return 126;//63;
			else if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_MOVIE)	
				return 116;//58;
			else
#elif(_DEF_COLORFUL)
			if(GET_OSD_COLOR_EFFECT()==_COLOREFFECT_COLORFUL)
				return 100;//50;
			else
#endif
				return GET_OSD_SATURATION();
			
		break;
		
		case _MENU_FUN_OSD_RORATE:
			return g_ucOsdRorateState ;
		break;


		case _MENU_FUN_OVERCLOCK: 
			return GET_OSD_OVERCLOCK();
		break;
#if(_LED_EFFECT_TJMODE14)
         case _MENU_FUN_LIGHTMODE:
         
             return GET_OSD_LED_LIGHTMODE();
         break;
 
 
 
         case _MENU_FUN_COLOR:
         
             return GET_OSD_LED_COLOR();
         break;      
#endif
		 default:
		 	 return 0;
	     break;
	}
}


