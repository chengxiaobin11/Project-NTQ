#if(_DEF_REAL_TIME_HZ)
BYTE* RTDOsdRealTimeHz(void)
{
	WORD temp = 0;
	BYTE i = 0;
	
	temp = GET_INPUT_TIMING_VFREQ();
	if(GET_INPUT_TIMING_VFREQ() >= 1000)
	{
		i = 2;
	}
	else
	{
		i = 1;
	}

pData[i+1] = _END_;


	if((temp % 10) >=5)
		temp = temp / 10 + 1;
	else	
		temp /= 10;
	
	while(1)
	{
		pData[i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{
			break;
		}
		i--;
	}

	return pData;
}
#endif


#if ((_FREESYNC_SUPPORT == _ON)&&(_OSD_VFREQ_CHANGE == _ON))

BYTE* RTDOsdTableFuncGetShowResolutionStringAddress(void)
{
	WORD temp = 0;
	BYTE i = 0;
	

	if(GET_INPUT_TIMING_HWIDTH() >= 1000)
	{
		i = 3;
	}
	else
	{
		i = 2;
	}

	temp = GET_INPUT_TIMING_HWIDTH();

	while(1)//write HWIDTH number
	{
		pData[i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{
			break;
		}
		i--;
	}

	if(GET_INPUT_TIMING_HWIDTH() >= 1000)
	{
		pData[4] = _X_;
	}
	else
	{
		pData[3] = _X_;   
	}

	temp = GET_INPUT_TIMING_VHEIGHT();

	if((GET_INPUT_TIMING_HWIDTH() >= 1000) && (GET_INPUT_TIMING_VHEIGHT() >= 1000))
	{
		  i = 8;
		  pData[9] =_xfb_;		   
	}
	else if((GET_INPUT_TIMING_HWIDTH() < 1000) && (GET_INPUT_TIMING_VHEIGHT() < 1000))
	{
		  i = 6;
		  pData[7] =_xfb_;	
	}	 
	else
	{
		  i = 7;
		  pData[8] =_xfb_;
	}
	
	while(1)
	{
		pData[i] = temp % 10 + _0_;
		temp /= 10;

		if(temp <= 0)
		{
			break;
		}
		i--;
	}
	
	temp = GET_INPUT_TIMING_VFREQ();

	if((GET_INPUT_TIMING_HWIDTH() >= 1000) && (GET_INPUT_TIMING_VHEIGHT() >= 1000))
	{
		if(GET_INPUT_TIMING_VFREQ() >= 1000)
		{
			i = 12;
				pData[10] = _x4f_ ;
                          pData[11] = _x4f_ ;
				pData[12] = _x4f_;
		
			pData[13] = _H_;
			pData[14] = _z_;
			pData[15] = _END_;		   
		}
		else
		{
			i = 11;

				pData[10] = _x4f_ ;
				pData[11] = _x4f_;
	
			pData[12] = _H_;
			pData[13] = _z_;
			pData[14] = _END_;		   
		}
	}
	else if((GET_INPUT_TIMING_HWIDTH() < 1000) && (GET_INPUT_TIMING_VHEIGHT() < 1000))
	{
		if(GET_INPUT_TIMING_VFREQ() >= 1000)
		{
			i = 10;

			       pData[8] = _x4f_;
                          pData[9] = _x4f_;
				pData[10] = _x4f_ ;
		
			pData[11] = _H_;
			pData[12] = _z_;
			pData[13] = _END_;		 
		}
		else
		{
			i = 9;

				pData[8] = _x4f_ ;
				pData[9] = _x4f_;
			
			pData[10] = _H_;
			pData[11] = _z_;
			pData[12] = _END_;		 
		}
	}	 
	else
	{	
		if(GET_INPUT_TIMING_VFREQ() >= 1000)
		{
			i = 11;

				pData[9] = _x4f_;

				pData[10] = _x4f_;
				pData[11] = _x4f_;

			
			pData[12] = _H_;
			pData[13] = _z_;
			pData[14] = _END_;
		}
		else
		{
			i = 10;


				pData[9] = _x4f_ ;
				pData[10] = _x4f_ ;
			
			pData[11] = _H_;
			pData[12] = _z_;
			pData[13] = _END_;
		}
	}
/*	
//  ˢ���� �ֽ� �㷨
	if((temp % 10) >=5)
		temp = temp / 10 + 1;
	else	
		temp /= 10;//75
	
	while(1)
	{
		pData[i] = temp % 10 + _0_;   
		temp /= 10;

		if(temp <= 0)
		{
			break;
		}
		i--;
	}


*/
	return pData;
}

