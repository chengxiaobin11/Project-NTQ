#include "SysInclude.h"
extern void BANK0(char *str, ...);
extern void BANK1(char *str, ...);
extern void BANK2(char *str, ...);
extern void BANK3(char *str, ...);
extern void BANK4(char *str, ...);
extern void BANK5(char *str, ...);
extern void BANK6(char *str, ...);
extern void BANK7(char *str, ...);
extern void BANK8(char *str, ...);
extern void BANK9(char *str, ...);
extern void BANK10(char *str, ...);
extern void BANK11(char *str, ...);
extern void BANK12(char *str, ...);
extern void BANK13(char *str, ...);
extern void BANK14(char *str, ...);
extern void BANK15(char *str, ...);
extern void BANK16(char *str, ...);
extern void BANK17(char *str, ...);
extern void BANK18(char *str, ...);
extern void BANK19(char *str, ...);
extern void BANK20(char *str, ...);
extern void BANK21(char *str, ...);
