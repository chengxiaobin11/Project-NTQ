1125   1          {
1126   2              usDVTotal = (DWORD)1000 * g_stMDomainOutputData.usVHeight / ((ulFrameDiff * 100 / 125) + ((DWORD)1
             -000 * g_stMDomainInputData.usVHeight / usIHF)) * 1000 / g_usDVFreq;
1127   2          }
1128   1          else if((DWORD)g_stMDomainOutputData.usVHeight * 1066 / 1000 < _PANEL_DV_TOTAL)
1129   1          {
