 346          // Description  : Switch DDC pin to GPIO or viceversa
 347          // Input Value  : ucPinType -->
 348          //                PIN65-65/212-213/214-215 for GPIO/DDC
 349          // Output Value : None
 350          //--------------------------------------------------
 351          void ScalerPinshareGpioDdcPinSwitch(BYTE ucPinType)
 352          {
 353   1          switch(ucPinType)
 354   1          {
 355   2              case _DDC_VGA_SWITCH_GPIO:
 356   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_65
 357   2                  ScalerSetByte(P10_03_PIN_SHARE_CTRL13__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_66
 358   2                  break;
 359   2      
 360   2              case _DDC_VGA_SWITCH_DDC:
 361   2                  ScalerSetBit(P10_02_PIN_SHARE_CTRL12__ADION, ~_BIT7, 0x00); // Pin_65-66, DDCVGA
 362   2                  break;
 363   2      
 364   2              case _DDC2_SWITCH_GPIO:
 365   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_212
 366   2                  ScalerSetByte(P10_4A_PIN_SHARE_CTRLB2__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_213
 367   2                  break;
 368   2      
 369   2              case _DDC2_SWITCH_DDC:
 370   2                  ScalerSetBit(P10_49_PIN_SHARE_CTRLB1__ADION, ~_BIT7, 0x00); // Pin_212/213, DDC2
 371   2                  break;
 372   2      
 373   2              case _DDC3_SWITCH_GPIO:
 374   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~(_BIT7 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | ((BYTE
             -)_GPIO_OPEN_DRAIN))); // Pin_214
 375   2                  ScalerSetByte(P10_4C_PIN_SHARE_CTRLB4__ADION, (BYTE)_GPIO_OPEN_DRAIN); // Pin_215
 376   2                  break;
 377   2      
 378   2              case _DDC3_SWITCH_DDC:
 379   2                  ScalerSetBit(P10_4B_PIN_SHARE_CTRLB3__ADION, ~_BIT7, 0x00); // Pin_214/215, DDC3
 380   2                  break;
 381   2      
 382   2              default:
 383   2                  break;
 384   2          }
 385   1      }
