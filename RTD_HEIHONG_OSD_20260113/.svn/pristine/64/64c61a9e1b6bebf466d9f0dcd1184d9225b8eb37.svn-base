                  if((ucTconLevel !=_OFF)&&(SysModeGetModeState() ==_MODE_STATUS_ACTIVE)&&(GET_INPUT_TIMING_VFREQ()> _MP
             -RT_MIN_FRAME_RATE)&&(GET_OSD_FREE_SYNC_STATUS() == _OFF))
                  {
                  
                    UserAdjustBacklight(GET_OSD_BACKLIGHT());
                  
                      // set GPIO pin = TCON output
                      PCB_MPRT_TCON_PIN_SHARE_CONFIG(_ON);
              
                      // Set TCON on
                      ScalerTconGlobalEnable(_ON);
                      PCB_MPRT_TCON_ENABLE(_ON);
              
                      // Set TCON Inverted output
                      PCB_MPRT_TCON_INVERTED_OUTPUT();
              
                      // Set TCON PWM
              #if(_MPRT_WEAK_MID_HIGH)
                  if(ucTconLevel==1)
                    g_MPRTValue = (DWORD)(GET_MDOMAIN_OUTPUT_VBSTART() + GET_MDOMAIN_OUTPUT_VBHEIGHT())*_MPRT_RATIO/100;    
             - 
                  else if(ucTconLevel==2)
                    g_MPRTValue = (DWORD)(GET_MDOMAIN_OUTPUT_VBSTART() + GET_MDOMAIN_OUTPUT_VBHEIGHT())*_MPRT_MID_RATIO/100
             -;     
                  else if(ucTconLevel==3)
                    g_MPRTValue = (DWORD)(GET_MDOMAIN_OUTPUT_VBSTART() + GET_MDOMAIN_OUTPUT_VBHEIGHT())*_MPRT_HIGH_RATIO/10
             -0;     
              #else
                  g_MPRTValue = (DWORD)(GET_MDOMAIN_OUTPUT_VBSTART() + GET_MDOMAIN_OUTPUT_VBHEIGHT())*_MPRT_RATIO/100;     
              #endif
                  ScalerTimerWaitForEvent(_EVENT_DVS);
                  PCB_MPRT_TCON_PWM_ADJUST();     
                  }
                  else
                  {
                      // Set TCON off
                      PCB_MPRT_TCON_ENABLE(_OFF);
              
                      // set GPIO pin = PP output
                      PCB_MPRT_TCON_PIN_SHARE_CONFIG(_OFF);
                  
                      UserAdjustBacklight(GET_OSD_BACKLIGHT());   
              
                  }
              
              }
