 417          // Description  : Check Audio whether Audio LPCM By Audio Data
 418          // Input Value  : ucSourceType
 419          // Output Value : _TRUE => LPCM
 420          //--------------------------------------------------
 421          bit ScalerAudioLPCMCheckData(void)
 422          {
 423   1          switch(ScalerAudioGetDigitalAudioPort(_AUDIO_DAC_OUT))
 424   1          {
 425   2              case _AUDIO_FROM_D0_PORT:
 426   2      
 427   2      #if(_D0_DP_EXIST == _ON)
 428   2                  // Check Audio Packet
 429   2                  if(ScalerAudioD0GetAudioDetected() == _FALSE)
 430   2                  {
 431   3                      // Reset Coding Type Detect
 432   3                      SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_CODING_TYPE_NONE);
 433   3      
 434   3                      return _FALSE;
 435   3                  }
 436   2      
 437   2                  // Check First Time Check or Coding Type Change before Playback
 438   2                  if((GET_DP_D0_AUDIO_CODING_TYPE_FORMAT() == _AUDIO_CODING_TYPE_NONE) ||
 439   2                     ((ScalerGetBit(PB6_3B_DP_IRQ_CTRL1, _BIT0) == 0x00) && (ScalerGetBit(PB6_36_DP_GLB_STATUS, 
             -_BIT2) == _BIT2)))
 440   2                  {
 441   3                      // =================================
 442   3                      // Flag Reset
 443   3                      // =================================
 444   3      
 445   3                      // Disable Audio Coding Type Change INT
 446   3                      ScalerSetBit(PB6_3B_DP_IRQ_CTRL1, ~_BIT0, 0x00);
 447   3      
 448   3                      // Clear Audio Coding Type Change Flag
 449   3                      ScalerSetBit(PB6_36_DP_GLB_STATUS, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1
             -), _BIT2);
 450   3      
 451   3      
 452   3                      // =================================
 453   3                      // Detect Coding Type at First Time
 454   3                      // =================================
 455   3      
 456   3                      DebugMessageAudio("[Audio] Rx0 Coding Type First Time Detect", 0);
 457   3      
 458   3      
 459   3                      // ---------------------------------
 460   3                      // Valid_Bit Detect at First
 461   3                      // ---------------------------------
 462   3      
 463   3                      // Set Audio Coding Type Source to Valid_Bit
 464   3                      ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~_BIT5, _BIT5);
 465   3      
 466   3                      // Update Detect Result
 467   3                      if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT4) == 0x00)
 468   3                      {
 469   4                          DebugMessageAudio("[Audio] Rx0 initial at LPCM via Valid_Bit", 0);
 470   4      
 471   4                          SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_LPCM);
 472   4                      }
 473   3                      else
 474   3                      {
 475   4                          WORD usDelayTime = 12;
 476   4                          EnumAudioSamplingFreqType enumAudioFreq = ScalerAudioD0SamplingFreqDetect();
C51 COMPILER V9.60.0.0   RL6449_SERIES_AUDIO                                               10/18/2025 16:25:38 PAGE 9   

 477   4                          EnumAudioSamplingFreqPacket enumAudioPacket = ScalerAudioGetSamplingFreqPacket(enumAud
             -ioFreq);
 478   4      
 479   4                          // -----------------------------
 480   4                          // Channel Status Detect Flow
 481   4                          // -----------------------------
 482   4      
 483   4                          // Set Audio Coding Type Source to Channel_Status
 484   4                          ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~_BIT5, 0x00);
 485   4      
 486   4                          // Calculate Minimum Delay for Receiving 192*2 Audio Samples
 487   4                          // Avoid 0Hz Value
 488   4                          if(enumAudioPacket == _AUDIO_FREQ_PACKET_NO_AUDIO)
 489   4                          {
 490   5                              enumAudioPacket = _AUDIO_FREQ_PACKET_32K;
 491   5                          }
 492   4      
 493   4                          // (192Samples * 2) / AudioFreq
 494   4                          usDelayTime = (192 * 2) / enumAudioPacket;
 495   4      
 496   4                          // Delay with 2ms margin added
 497   4                          ScalerTimerDelayXms(usDelayTime + 2);
 498   4      
 499   4                          // Update Detect Result
 500   4                          if(ScalerGetBit(PB6_B0_DP_AUD_CTRL, _BIT4) == _BIT4)
 501   4                          {
 502   5                              DebugMessageAudio("[Audio] Rx0 initial at Non-LPCM via Channel_Status", 1);
 503   5      
 504   5                              SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_NON_LPCM);
 505   5                          }
 506   4                          else
 507   4                          {
 508   5                              DebugMessageAudio("[Audio] Rx0 initial at LPCM via Channel_Status", 0);
 509   5      
 510   5                              SET_DP_D0_AUDIO_CODING_TYPE_FORMAT(_AUDIO_LPCM);
 511   5                          }
 512   4                      }
 513   3                  }
 514   2      
 515   2                  // =================================
 516   2                  // Return Coding Type Status
 517   2                  // =================================
 518   2                  if(GET_DP_D0_AUDIO_CODING_TYPE_FORMAT() == _AUDIO_NON_LPCM)
 519   2                  {
 520   3                      return _FALSE;
 521   3                  }
 522   2      
 523   2                  return _TRUE;
 524   2      #endif
 525   2                  break;
