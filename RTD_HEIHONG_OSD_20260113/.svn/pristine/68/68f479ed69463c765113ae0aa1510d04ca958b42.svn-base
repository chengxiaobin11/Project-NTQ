                          ScalerAudioD2FwTrackingEventSet();
                          break;
              #endif
              #if(_D3_HDMI_SUPPORT == _ON)
              
                      case _SCALER_TIMER_EVENT_AUDIO_D3_FW_TRACKING_PREPARING:
              
                          ScalerAudioD3FwTrackingEventSet();
                          break;
              #endif
              
                      default:
                          break;
                  }
              }
              
              //--------------------------------------------------
