                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_03_PORT_PAGE71_HDMI_AFCR, ~(_BIT6 | _BIT4 | _BIT3 
             -| _BIT2 | _BIT1 | _BIT0), (_BIT6 | _BIT2 | _BIT1));
              #endif
                  }
              }
              
