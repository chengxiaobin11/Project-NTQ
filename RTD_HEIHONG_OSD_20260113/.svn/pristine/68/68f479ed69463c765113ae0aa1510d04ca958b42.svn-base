2791          //--------------------------------------------------
2792          // Description  : D1 Audio Watch Dog Proc
2793          // Input Value  : bOn
2794          // Output Value : None
2795          //--------------------------------------------------
2796          void ScalerAudioD1WatchDogProc(bit bOn)
2797          {
2798   1          if(bOn == _ON)
2799   1          {
2800   2              // Clear audio buffer overflow and underflow status
2801   2              ScalerSetBit(PB9_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2802   2      
2803   2              // Enable Audio Watch Dog for Buffer Overflow/Underflow
2804   2              ScalerSetBit(PB9_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
2805   2          }
2806   1          else
2807   1          {
2808   2              // Disable Audio Watch Dog for Buffer Overflow/Underflow
2809   2              ScalerSetBit(PB9_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), 0x00);
2810   2      
2811   2              if(ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
2812   2              {
2813   3                  DebugMessageAudio("WD : D1 DP Audio Over/Underflow", ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, (_
             -BIT1 | _BIT0)));
2814   3      
2815   3                  // Reset Audio FSM
2816   3                  ScalerSetBit(PB9_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
2817   3      
2818   3                  // Clear audio FIFO overflow and underflow status
2819   3                  ScalerSetBit(PB9_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2820   3      
2821   3                  // Enable Audio FSM
2822   3                  ScalerSetBit(PB9_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
2823   3      
2824   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
             -Audio Stable Time Count = 5 x 200us)
2825   3                  ScalerTimerDelayXms(3);
2826   3              }
2827   2          }
2828   1      }
