2291          // Output Value : None
2292          //--------------------------------------------------
2293          void ScalerAudioD0WatchDogProc(bit bOn)
2294          {
2295   1          if(bOn == _ON)
2296   1          {
2297   2              // Clear audio buffer overflow and underflow status
2298   2              ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2299   2      
2300   2              // Enable Audio Watch Dog for Buffer Overflow/Underflow
2301   2              ScalerSetBit(PB6_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
2302   2          }
2303   1          else
2304   1          {
2305   2              // Disable Audio Watch Dog for Buffer Overflow/Underflow
2306   2              ScalerSetBit(PB6_39_DP_AWD_CTRL, ~(_BIT7 | _BIT6), 0x00);
2307   2      
2308   2              if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
2309   2              {
2310   3                  DebugMessageAudio("WD : D0 DP Audio Over/Underflow", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_
             -BIT1 | _BIT0)));
2311   3      
2312   3                  // Reset Audio FSM
2313   3                  ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
2314   3      
2315   3                  // Clear audio FIFO overflow and underflow status
2316   3                  ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2317   3      
2318   3                  // Enable Audio FSM
2319   3                  ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
2320   3      
2321   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
             -Audio Stable Time Count = 5 x 200us)
2322   3                  ScalerTimerDelayXms(3);
2323   3              }
2324   2          }
2325   1      }
