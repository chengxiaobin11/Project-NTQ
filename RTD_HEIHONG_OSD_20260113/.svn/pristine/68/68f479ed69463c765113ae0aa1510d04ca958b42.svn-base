2166   1      
2167   1          // Check Audio FSM
2168   1          if(ScalerGetBit(PB6_74_AUD_FSM_CTRL_0, _BIT7) == 0x00)
2169   1          {
2170   2              DebugMessageAudio("False : D0 DP Audio Fsm Disable", 0);
2171   2      
2172   2              return _FALSE;
2173   2          }
2174   1      
2175   1          // Check Audio Tracking
