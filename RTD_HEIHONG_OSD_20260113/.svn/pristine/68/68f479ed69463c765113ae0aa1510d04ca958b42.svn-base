2847   3                  ScalerTimerDelayXms((ScalerGetBit(PB9_50_AUD_FREQUENY_DET_0, (_BIT3 | _BIT2)) >> 2) + 1);
2848   3      
2849   3                  DebugMessageAudio("Dp D1 HBR Mode Detect Enable", _ENABLE);
2850   3              }
2851   2          }
2852   1          else
2853   1          {
2854   2              // Check Current Detect Mode
2855   2              if(ScalerGetBit(PB9_B0_DP_AUD_CTRL, _BIT6) != 0x00)
2856   2              {
2857   3                  // Disable Audio HBR Mode Detect
2858   3                  ScalerAudioD1HbrModeControl(_OFF);
2859   3      
2860   3                  // Wait for New Audio Packet Recived via detect interval + 1ms
2861   3                  ScalerTimerDelayXms((ScalerGetBit(PB9_50_AUD_FREQUENY_DET_0, (_BIT3 | _BIT2)) >> 2) + 1);
2862   3      
2863   3                  DebugMessageAudio("Dp D1 HBR Mode Detect Disable", _DISABLE);
2864   3              }
2865   2          }
2866   1      }
