              #if(_D2_HDMI_SUPPORT == _OFF)
                          // Power Down D2 DPLL
                          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_38_PORT_PAGE71_HDMI_DPCR0, ~_BIT7, _BIT7);
              #endif
              #endif
                          break;
              
                      case _D2_INPUT_PORT:
                      case _D3_INPUT_PORT:
                      case _D4_INPUT_PORT:
                      case _D5_INPUT_PORT:
