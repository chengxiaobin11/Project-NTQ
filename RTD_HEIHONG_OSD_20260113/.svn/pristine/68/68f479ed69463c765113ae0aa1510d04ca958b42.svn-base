2656          //--------------------------------------------------
2657          // Description  : Get D1 Audio Detected
2658          // Input Value  : None
2659          // Output Value : TRUE => Audio Detected
2660          //--------------------------------------------------
2661          bit ScalerAudioD1GetAudioDetected(void)
2662          {
2663   1          // Check audio packet
2664   1          if(GET_AUDIO_D1_PACKET_DETECT() == _FALSE)
2665   1          {
2666   2              DebugMessageAudio("False : D1 Audio Packet", 0);
2667   2              return _FALSE;
2668   2          }
2669   1      
2670   1          // Check Audio FSM
2671   1          if(ScalerGetBit(PB9_74_AUD_FSM_CTRL_0, _BIT7) == 0x00)
2672   1          {
2673   2              DebugMessageAudio("False : D1 DP Audio Fsm Disable", 0);
2674   2      
2675   2              return _FALSE;
2676   2          }
2677   1      
2678   1          // Check Audio Tracking
2679   1          if(ScalerGetBit(PB9_81_AUD_BDRY_0, _BIT7) == 0x00)
2680   1          {
2681   2              DebugMessageAudio("False : D1 DP Audio Tracking Disable", 0);
2682   2      
2683   2              return _FALSE;
2684   2          }
2685   1      
2686   1          // Check DP audio buffer overflow and underflow
2687   1          if(ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
2688   1          {
2689   2              DebugMessageAudio("False : D1 DP Audio Buffer", ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, (_BIT1 | _B
             -IT0)));
2690   2      
2691   2              if(ScalerGetBit(PB9_39_DP_AWD_CTRL, (_BIT7 | _BIT6)) == 0x00)
2692   2              {
2693   3                  // Clear audio FIFO overflow and underflow status
2694   3                  ScalerSetBit(PB9_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2695   3      
2696   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
             -Audio Stable Time Count = 5 x 200us)
2697   3                  ScalerTimerDelayXms(3);
2698   3      
2699   3                  if(ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
2700   3                  {
2701   4                      DebugMessageAudio("False : D1 DP Audio FSM Reset", ScalerGetBit(PB9_70_AUD_BUFFER_CTRL_0, 
             -(_BIT1 | _BIT0)));
2702   4      
2703   4                      // Reset Audio FSM
2704   4                      ScalerSetBit(PB9_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
2705   4      
2706   4                      // Clear audio FIFO overflow and underflow status
2707   4                      ScalerSetBit(PB9_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2708   4      
2709   4                      // Enable Audio FSM
2710   4                      ScalerSetBit(PB9_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
2711   4      
2712   4                      // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 
C51 COMPILER V9.60.0.0   RL6449_SERIES_AUDIO                                               10/18/2025 16:25:38 PAGE 46  

             -1ms(Audio Stable Time Count = 5 x 200us)
2713   4                      ScalerTimerDelayXms(3);
2714   4                  }
2715   3              }
2716   2      
2717   2              return _FALSE;
2718   2          }
2719   1      
2720   1          return _TRUE;
2721   1      }
