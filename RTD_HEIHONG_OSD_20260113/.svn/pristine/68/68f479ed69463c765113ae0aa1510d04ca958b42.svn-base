2398   1      
2399   1          // Set O code
2400   1          ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~(_BIT1 | _BIT0), 0x00);
2401   1      
2402   1          // Set N(K) code and enable double buffer
2403   1          ScalerSetByte(PB9_D2_MN_SCLKG_DIVN, (_AUDIO_PLL_K - 2));
2404   1      
2405   1          // Initial VCO Band = 10
2406   1          ScalerSetBit(PB9_D5_MN_SCLKG_PLL_WD, ~(_BIT4 | _BIT3), _BIT4);
C51 COMPILER V9.60.0.0   RL6449_SERIES_AUDIO                                               10/18/2025 16:25:38 PAGE 41  

2407   1      
2408   1          // Set MN PLL Path1 => [2]: 1 = Path1, 0 = Path2
2409   1          ScalerSetBit(PB9_D5_MN_SCLKG_PLL_WD, ~(_BIT7 | _BIT2), _BIT2);
2410   1      
2411   1      #if(_HW_PLL_EDGE_SELECT_TYPE == _PLL_EDGE_GEN_1_DEFAULT_POSITIVE)
2412   1          // Set PLL Edge = Negative
2413   1          ScalerSetBit(PB9_D7_MN_SCLKG_PLL_RESERVE, ~_BIT1, _BIT1);
2414   1      #endif
2415   1      
2416   1          // DPLL VCORSTB Set to Normal
2417   1          ScalerSetBit(PB9_D6_MN_SCLKG_PLL_INSEL, ~_BIT0, _DPLL_VCORSTB_NORMAL_VALUE);
2418   1      
2419   1          // DPLL power up
2420   1          ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~_BIT7, 0x00);
2421   1      
2422   1          // Delay 2000us
2423   1          ScalerTimerDelayXms(2);
2424   1      
2425   1          // DPLL CMP enable
2426   1          ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~_BIT2, _BIT2);
2427   1      
2428   1          // Delay 1000us
2429   1          ScalerTimerDelayXms(2);
2430   1      
2431   1          // DPLL latch calibration enable
2432   1          ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~_BIT3, _BIT3);
2433   1      
2434   1          // Delay 1000us
2435   1          ScalerTimerDelayXms(2);
2436   1      
2437   1          // DPLL calibration validated
2438   1          ScalerSetBit(PB9_D3_MN_SCLKG_PLL_PWR, ~_BIT4, _BIT4);
2439   1      }
