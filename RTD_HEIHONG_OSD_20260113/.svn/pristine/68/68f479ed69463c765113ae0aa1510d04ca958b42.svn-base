2191   3                  ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2192   3      
2193   3                  // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 1ms(
             -Audio Stable Time Count = 5 x 200us)
2194   3                  ScalerTimerDelayXms(3);
2195   3      
2196   3                  if(ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, (_BIT1 | _BIT0)) != 0x00)
2197   3                  {
2198   4                      DebugMessageAudio("False : D0 DP Audio FSM Reset", ScalerGetBit(PB6_70_AUD_BUFFER_CTRL_0, 
             -(_BIT1 | _BIT0)));
2199   4      
2200   4                      // Reset Audio FSM
2201   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, 0x00);
2202   4      
2203   4                      // Clear audio FIFO overflow and underflow status
2204   4                      ScalerSetBit(PB6_70_AUD_BUFFER_CTRL_0, ~(_BIT1 | _BIT0), (_BIT1 | _BIT0));
2205   4      
2206   4                      // Enable Audio FSM
2207   4                      ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, _BIT7);
2208   4      
2209   4                      // Waiting for 2ms(Audio Freq. Detect || Audio FIFO Write (1/2 FIFO depth = 64 packet)) + 
             -1ms(Audio Stable Time Count = 5 x 200us)
2210   4                      ScalerTimerDelayXms(3);
2211   4                  }
2212   3              }
2213   2      
2214   2              return _FALSE;
2215   2          }
2216   1      
2217   1          return _TRUE;
2218   1      }
