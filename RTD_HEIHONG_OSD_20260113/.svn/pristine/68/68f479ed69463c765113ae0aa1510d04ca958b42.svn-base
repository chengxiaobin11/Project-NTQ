2723          //--------------------------------------------------
2724          // Description  : Detect D1 Audio Sampling Freq
2725          // Input Value  : None
2726          // Output Value : Audio Sampling Freq
2727          //--------------------------------------------------
2728          EnumAudioSamplingFreqType ScalerAudioD1SamplingFreqDetect(void)
2729          {
2730   1          EnumAudioSamplingFreqType enumAudioFreq = _AUDIO_FREQ_NO_AUDIO;
2731   1      
2732   1      #if(_INTERNAL_AUDIO_TEST_SUPPORT == _ON)
                  if(ScalerAudioDpGetInternalAudioGenEnable() == _ENABLE)
                  {
                      // For Audio test pattern
                      SET_AUDIO_D1_SAMPLING_FREQ(_AUDIO_FREQ_48K);
                      return _AUDIO_FREQ_48K;
                  }
              #endif
2740   1      
2741   1          // HBR Audio Detect
2742   1          ScalerAudioD1HbrAudioDetect();
2743   1      
2744   1          // Get Audio Sample Count
2745   1          enumAudioFreq = (ScalerGetBit(PB9_61_AUD_SAMPLE_CNT_0, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) >> 4);
2746   1      
2747   1          if(enumAudioFreq != GET_AUDIO_D1_SAMPLING_FREQ())
2748   1          {
2749   2      #if(_EMBEDDED_DAC_SUPPORT == _ON)
2750   2              if(enumAudioFreq <= _AUDIO_FREQ_64K)
2751   2              {
2752   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), 0x00);
2753   3              }
2754   2              else if(enumAudioFreq <= _AUDIO_FREQ_128K)
2755   2              {
2756   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT6);
2757   3              }
2758   2              else
2759   2              {
2760   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), _BIT7);
2761   3              }
2762   2      #endif
2763   2      
2764   2              // Audio DVC Setting
2765   2              ScalerAudioD1DPSetDVCWindowSize(_DP_DVC_ADJUST_TYPE, ScalerAudioGetSamplingFreqPacket(enumAudioFre
             -q));
2766   2          }
2767   1      
2768   1          SET_AUDIO_D1_SAMPLING_FREQ(enumAudioFreq);
2769   1      
2770   1          return enumAudioFreq;
2771   1      }
