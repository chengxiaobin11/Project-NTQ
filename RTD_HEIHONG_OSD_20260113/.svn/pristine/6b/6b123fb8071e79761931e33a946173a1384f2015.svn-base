C51 COMPILER V9.60.0.0   RL6449_SERIES_DDOMAIN                                             10/18/2025 16:25:39 PAGE 2   

  48          //****************************************************************************
  49          //--------------------------------------------------
  50          // Description  : Display Force to Background Enable
  51          // Input Value  : _ENABLE or _DISABLE
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerDDomainBackgroundEnable(bit bEnable)
  55          {
  56   1          if(bEnable == _ENABLE)
  57   1          {
  58   2              // M1 Enable Force to Back Ground
  59   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT5, _BIT5);
  60   2          }
  61   1          else
  62   1          {
  63   2              // M1 Disable Force to Back Ground
  64   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~_BIT5, 0x00);
  65   2          }
  66   1      }
  67          
  68          //--------------------------------------------------
  69          // Description  : Set Display Background Color
  70          // Input Value  : RGB Color
  71          // Output Value : None
  72          //--------------------------------------------------
  73          void ScalerDDomainBackgroundSetColor(BYTE ucRed, BYTE ucGreen, BYTE ucBlue)
  74          {
  75   1          // M1 Reset Port index
  76   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
  77   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, _BIT5);
  78   1      
  79   1          // 10bits RGB color, Use MSB 8bits, LSB 2bits == 00
  80   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucRed);
  81   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucGreen);
  82   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ucBlue);
  83   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, 0x00);
  84   1      
  85   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
  86   1      }
  87          
  88          #if((_OGC_SUPPORT == _ON) || (_OCC_SUPPORT == _ON) || (_OGC_DICOM_SUPPORT == _ON))
  89          //--------------------------------------------------
  90          // Description  : Set Display Background Color (10bit)
  91          // Input Value  : RGB Color
  92          // Output Value : None
  93          //--------------------------------------------------
  94          void ScalerDDomainBackgroundSetColor10bit(WORD usRed, WORD usGreen, WORD usBlue) // 10bit
  95          {
  96   1          // M1 Reset Port index
  97   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
  98   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, _BIT5);
  99   1      
 100   1          // 10bits RGB color, Use MSB 8bits, LSB 2bits == 00
 101   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, (usRed >> 2));
 102   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, (usGreen >> 2));
 103   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, (usBlue >> 2));
 104   1          ScalerSetByte(P0_6D_BG_COLOR_DATA_PORT_M1, ((usRed & 0x03) << 6) | ((usGreen & 0x03) << 4) | ((usBlue 
             -& 0x03) << 2));
 105   1      
 106   1          ScalerSetBit(P0_6C_OVERLAY_CTRL, ~_BIT5, 0x00);
 107   1      }
 108          #endif // End of #if((_OGC_SUPPORT == _ON) || (_OCC_SUPPORT == _ON) || (_OGC_DICOM_SUPPORT == _ON))
