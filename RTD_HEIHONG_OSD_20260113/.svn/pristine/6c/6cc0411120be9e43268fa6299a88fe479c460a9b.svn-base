 107   1          ScalerBurstWrite(pucAddress1, _SHARPNESS_TABLE_SIZE, ucBankNum, P0_36_USER_DEF_FILTER_ACCESS_PORT, _BU
             -RSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
