 497          //--------------------------------------------------
 498          DWORD ScalerMemoryGetDtMaxMin(void)
 499          {
 500   1          BYTE ucMax = 0;
 501   1          BYTE ucMin = 100;
 502   1          BYTE ucCount = 0;
 503   1          BYTE ucPhase = 0;
 504   1          WORD usDtMin = 0;
