 530   2              if(ucPhase < ucMin)
 531   2              {
 532   3                  ucMin = ucPhase;
 533   3              }
 534   2      
 535   2              ucCount++;
 536   2          }
 537   1          while(ucCount < 255);
 538   1      
 539   1          DebugMessageFS("7.Calculated Max", ucMax);
 540   1          DebugMessageFS("7.Calculated Min", ucMin);
 541   1      
 542   1          //-------------------------------------------------
 543   1          // Get FIFO Input Width: 13 bit
 544   1          //-------------------------------------------------
 545   1          usFIFOHWidth = ScalerMemoryGetFifoWidth();
 546   1      
 547   1          // VFCI * 100
 548   1          ulVFCI = (ulVFCI * 100) >> 7;
 549   1      
 550   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 551   1          if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
 552   1          {
