1102          
1103          //--------------------------------------------------
1104          // Description  : Get the free page number of flash
1105          // Input Value  : None
1106          // Output Value : Free page index
1107          //--------------------------------------------------
1108          BYTE RTDFlashGetFreePage(void)
1109          {
1110   1          BYTE ucPageID = _START_OF_PAGEID;
1111   1          BYTE ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1112   1      
1113   1          // If the _END_PAGE page has the biggest move count, suppose first page is free page
1114   1          if(g_ulFlashMoveCount > 0)
1115   1          {
1116   2              if(g_ucFlashLastPage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1117   2              {
1118   3                  ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1119   3              }
1120   2              else
1121   2              {
1122   3                  ucFreePage = g_ucFlashLastPage + 1;
1123   3              }
1124   2          }
1125   1      
1126   1          // Check the supposed free page is actual free page which has not been used ever
1127   1          do
1128   1          {
1129   2              if(ucFreePage == g_pucFlashPageArr[ucPageID])
1130   2              {
1131   3                  if(ucFreePage >= _SYSTEM_EEPROM_EMULATION_END_PAGE)
1132   3                  {
1133   4                      ucFreePage = _SYSTEM_EEPROM_EMULATION_START_PAGE;
1134   4                  }
1135   3                  else
1136   3                  {
1137   4                      ucFreePage += 1;
1138   4                  }
1139   3      
1140   3                  ucPageID = _START_OF_PAGEID;
1141   3              }
1142   2              else
1143   2              {
1144   3                  ucPageID++;
1145   3              }
1146   2          }
1147   1          while(ucPageID <= _END_OF_PAGEID);
1148   1      
1149   1          return ucFreePage;
1150   1      }
C51 COMPILER V9.60.0.0   RTD2014NVRAMOSD                                                   10/18/2025 16:26:19 PAGE 20  

1151          
1152          //--------------------------------------------------
1153          // Description  : Check the page is vaild or not
1154          // Input Value  : ucPage: The page to be check, must between 0 and (_END_PAGE - _START_PAGE)
1155          // Output Value : _TRUE means the page is valid, _FLASE is invalid
1156          //--------------------------------------------------
1157          bit RTDFlashIsPageInfoValid(BYTE ucPage)
