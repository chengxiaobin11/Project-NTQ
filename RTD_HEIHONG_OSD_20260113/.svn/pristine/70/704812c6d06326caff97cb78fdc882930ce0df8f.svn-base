              void RTDEepromSaveBriCon(BYTE ucSource)
              {
                  UserCommonEepromWrite(_BRICON_DATA_ADDRESS + ucSource * sizeof(StructBriConDataType), sizeof(StructBri
             -ConDataType), (BYTE *)(&g_stBriConData));
