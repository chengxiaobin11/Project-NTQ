 454          //--------------------------------------------------
 455          // Description  : Deal With Power Manage According To Input Pamater
 456          // Input Value  : ucSwitch    --> Power action description.
 457          // Output Value : None
 458          //--------------------------------------------------
 459          void SysPowerSwitch(EnumPowerAction enumSwitch)
 460          {
 461   1          switch(enumSwitch)
 462   1          {
 463   2              case _POWER_ACTION_NORMAL_TO_PS:
 464   2      
 465   2                  // User Power Process
 466   2                  UserInterfacePowerSwitch(enumSwitch);
 467   2      
 468   2      #if(_AUDIO_SUPPORT == _ON)
 469   2                  SysAudioPowerProc(enumSwitch);
 470   2      #endif
 471   2                  // Mode Power Saving Process
 472   2                  SysModeResetState(_MODE_ACTION_RESET_TO_POWER_SAVING);
 473   2      
 474   2      #if(_MEMORY_TYPE_CONFIG != _NO_MEMORY)
 475   2                  ScalerMemoryPowerControl(_OFF);
 476   2      #endif
 477   2      
 478   2      #if(_DP_TYPE_C_PORT_CTRL_SUPPORT == _ON)
                          SysTypeCPowerSwitch(enumSwitch);
              #endif
 481   2      
 482   2      #if(_DP_SUPPORT == _ON)
 483   2                  // DP Fake LT Protect
 484   2                  ScalerSyncDpFakeLTProtect();
 485   2      #endif
 486   2      
 487   2      #if(_HDMI_SUPPORT == _ON)
 488   2                  if((UserInterfaceGetForcePSStatus() == _TRUE) || (UserInterfaceForcePSWakeupTmdsHpdToggle() ==
             - _USER_FORCE_PS_TMDS_HPD_TOGGLE))
 489   2                  {
 490   3                      SysTMDSRxSetPsWakeupHpdToggle();
 491   3                  }
 492   2      #endif
 493   2      
 494   2      #if(_SYSTEM_LOW_POWER_GEN == _POWER_FLOW_GEN_1)
 495   2                  // Interface Power Saving Process
 496   2                  ScalerSyncPowerProc(enumSwitch);
 497   2      #endif
 498   2      
 499   2                  // Set mcu module to power saving state
 500   2                  ScalerMcuPwmControl(_POWER_STATUS_SAVING);
 501   2      
 502   2                  // Set Pin configure to power saving state
 503   2                  ScalerPinshareConfig(_POWER_STATUS_SAVING);
 504   2      
 505   2      #if(_THERMAL_SENSOR_SUPPORT == _ON)
                          // Thermal Sensor to power off state.
                          ScalerThermalSensorControl(enumSwitch);
              #endif
 509   2      
 510   2                  // Some Case Power Fake Saving Proc
 511   2      #if(_MHL_PS_WITHOUT_POWERCUT_SUPPORT == _ON)
