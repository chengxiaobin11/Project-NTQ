 290          void SysPowerHandler(void)
 291          {
 292   1          // The process will deal with all kinds of power changing by power action flag.
 293   1          switch(GET_TARGET_POWER_STATUS())
 294   1          {
 295   2              case _POWER_STATUS_NORMAL:
 296   2      
 297   2                  switch(GET_POWER_STATUS())
 298   2                  {
 299   3                      case _POWER_STATUS_OFF:
 300   3      
 301   3                          if(SysPowerCheckNormal() == _TRUE)
 302   3                          {
 303   4                              SysPowerSwitch(_POWER_ACTION_OFF_TO_NORMAL);
 304   4                          }
 305   3                          else
 306   3                          {
 307   4                              SysPowerSwitch(_POWER_ACTION_OFF_TO_FAKE_OFF);
 308   4                          }
 309   3                          break;
 310   3      
 311   3                      case _POWER_STATUS_SAVING:
 312   3      
 313   3                          SysPowerSwitch(_POWER_ACTION_PS_TO_NORMAL);
 314   3      
 315   3      #if(_AIO_MODERN_STANDBY_SUPPORT == _ON)
                                  if(UserInterfaceGetAIOModernStandbyMode() == _AIO_MODERN_STANDBY_MODE_ENABLE)
                                  {
                                      SET_AIO_MODERN_STANDBY_MODE();
                                      ScalerTimerReactiveTimerEvent(SEC(0.5), _SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MOD
             -E_TIMEOUT);
                                  }
                                  else
                                  {
                                      CLR_AIO_MODERN_STANDBY_MODE();
                                      ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MODE_TIMEOUT);
                                  }
              #endif
 327   3                          break;
 328   3      
 329   3                      case _POWER_STATUS_AC_ON:
 330   3                          SysPowerSwitch(_POWER_ACTION_AC_ON_TO_NORMAL);
 331   3                          break;
 332   3      
 333   3                      case _POWER_STATUS_NORMAL:
 334   3      
C51 COMPILER V9.60.0.0   SYSPOWER                                                          10/18/2025 16:52:28 PAGE 7   

 335   3                          if((GET_MODE_STATE() == _MODE_STATUS_POWER_OFF) || (GET_POWER_SWITCH_TO_FAKE_OFF() == 
             -_TRUE))
 336   3                          {
 337   4                              CLR_POWER_SWITCH_TO_FAKE_OFF();
 338   4                              ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_POWER_FAKE_OFF_TO_OFF);
 339   4                              SysPowerSwitch(_POWER_ACTION_FAKE_OFF_TO_NORMAL);
 340   4                          }
 341   3                          else if(GET_POWER_SWITCH_TO_FAKE_SAVING() == _TRUE)
 342   3                          {
 343   4                              CLR_POWER_SWITCH_TO_FAKE_SAVING();
 344   4                              SysPowerSwitch(_POWER_ACTION_FAKE_PS_TO_NORMAL);
 345   4      
 346   4      #if(_AIO_MODERN_STANDBY_SUPPORT == _ON)
                                      if(UserInterfaceGetAIOModernStandbyMode() == _AIO_MODERN_STANDBY_MODE_ENABLE)
                                      {
                                          SET_AIO_MODERN_STANDBY_MODE();
                                          ScalerTimerReactiveTimerEvent(SEC(0.5), _SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY
             -_MODE_TIMEOUT);
                                      }
                                      else
                                      {
                                          CLR_AIO_MODERN_STANDBY_MODE();
                                          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AIO_MODERN_STANDBY_MODE_TIMEOU
             -T);
                                      }
              #endif
 358   4                          }
 359   3      
 360   3                          break;
 361   3      
 362   3                      default:
 363   3                          break;
 364   3                  }
 365   2      
 366   2                  SET_POWER_STATUS(_POWER_STATUS_NORMAL);
 367   2      
 368   2                  break;
 369   2      
 370   2              case _POWER_STATUS_OFF:
 371   2      
 372   2                  CLR_POWER_SWITCH_TO_FAKE_SAVING();
 373   2      
 374   2                  // Clear Mode change flag
 375   2                  CLR_MODE_STATE_CHANGE_MODE();
 376   2      
 377   2                  switch(GET_POWER_STATUS())
 378   2                  {
 379   3                      case _POWER_STATUS_SAVING:
 380   3                          SysPowerSwitch(_POWER_ACTION_PS_TO_OFF);
 381   3                          SET_POWER_STATUS(_POWER_STATUS_OFF);
 382   3                          break;
 383   3      
 384   3                      case _POWER_STATUS_AC_ON:
 385   3                          SysPowerSwitch(_POWER_ACTION_AC_ON_TO_OFF);
 386   3                          SET_POWER_STATUS(_POWER_STATUS_OFF);
 387   3                          break;
 388   3      
 389   3                      case _POWER_STATUS_NORMAL:
