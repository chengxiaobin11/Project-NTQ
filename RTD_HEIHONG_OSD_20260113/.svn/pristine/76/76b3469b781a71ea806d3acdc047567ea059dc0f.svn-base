 705          //                ucHwIICPinNum --> HW IIC Pin Used
 706          // Output Value : Reading result (Fail/Success)
 707          //--------------------------------------------------
 708          bit UserCommonEepromIICRead(BYTE ucSlaveAddr, DWORD ulSubAddr, BYTE ucSubAddrLength, DWORD ulLength, BYTE 
             -*pucReadArray, BYTE ucSWIICStatus, BYTE ucHwIICPinNum)
 709          {
 710   1          BYTE ucSlaveAddress = ucSlaveAddr;
 711   1          BYTE ucDataCnt = 0;
 712   1      
 713   1          ucSWIICStatus = ucSWIICStatus;
