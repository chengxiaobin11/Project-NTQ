 717   2              if(ucSubAddrLength == 1)
 718   2              {
 719   3                  ucSlaveAddress = ucSlaveAddr + (BYTE)((ulSubAddr & 0xFF00) >> 7);
 720   3              }
 721   2              else if(ucSubAddrLength == 2)
 722   2              {
 723   3                  ucSlaveAddress = ucSlaveAddr + (BYTE)((ulSubAddr & 0x00FF0000) >> 15);
 724   3              }
 725   2      
 726   2              // Receive 24 bytes each time
 727   2              ucDataCnt = _EEPROM_READ_SIZE;
 728   2      
 729   2              // Check if more than 24 bytes are needed to be received
 730   2              if(ulLength > ucDataCnt)
 731   2              {
 732   3                  ulLength -= ucDataCnt;
 733   3              }
 734   2              else
 735   2              {
 736   3                  ucDataCnt = ulLength;
 737   3                  ulLength = 0;
 738   3              }
 739   2      
 740   2              // Execute Hardware IIC Read Command
 741   2              if(ucHwIICPinNum == _SW_IIC_PIN_GPIO)
 742   2              {
 743   3      #if(_SW_IIC_SUPPORT == _ON)
 744   3                  SET_SW_IIC_STATUS(ucSWIICStatus);
 745   3      
 746   3                  if(ScalerMcuIICRead(ucSlaveAddress, ucSubAddrLength, (WORD)ulSubAddr, ucDataCnt, pucReadArray)
             - == _FAIL)
 747   3                  {
 748   4                      return _FAIL;
 749   4                  }
 750   3      #endif // End of #if(_SW_IIC_SUPPORT == _ON)
 751   3      
 752   3              }
 753   2              else if(ucHwIICPinNum != _NO_IIC_PIN)
 754   2              {
 755   3      #if(_HW_IIC_SUPPORT == _ON)
 756   3                  if(ScalerMcuHwIICRead(ucSlaveAddress, ucSubAddrLength, (WORD)ulSubAddr, ucDataCnt, pucReadArra
             -y, ucHwIICPinNum) == _FAIL)
 757   3                  {
 758   4                      return _FAIL;
 759   4                  }
 760   3      #endif // End of #if(_HW_IIC_SUPPORT == _ON)
 761   3      
 762   3              }
 763   2      
 764   2              // Increase data location
 765   2              pucReadArray += ucDataCnt;
 766   2      
 767   2              // Increment Sub-Addr for next Read
 768   2              ulSubAddr += ucDataCnt;
 769   2          }
 770   1      
 771   1          return _SUCCESS;
 772   1      }
