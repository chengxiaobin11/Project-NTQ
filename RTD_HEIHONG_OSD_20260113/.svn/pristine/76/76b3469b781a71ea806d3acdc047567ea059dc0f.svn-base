                  StructVGAModeUserDataType stVGAModeUserData;
                  memset(&stVGAModeUserData, 0, sizeof(StructVGAModeUserDataType));
              
                  if(UserCommonFlashLoadItem(_FLASH_ITEMID_MODE_USER_DATA + ucSlotIndex, (BYTE *)(&stVGAModeUserData), s
             -izeof(StructVGAModeUserDataType)) == _TRUE)
