                  BYTE ucModeNumber = 0xFF;
              
                  UserCommonEepromRead(_MODE_USER_DATA_ADDRESS + (ucSlotIndex % _MODE_SLOT_AMOUNT) * sizeof(StructVGAMod
             -eUserDataType) + 1,
