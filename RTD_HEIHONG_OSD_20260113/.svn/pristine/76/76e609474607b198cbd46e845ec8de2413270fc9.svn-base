 287          void ScalerScalingSetScalingDownCoef(void)
 288          {
 289   1          // M1
 290   1          // Set Coefficient table 1
 291   1          ScalerSetBit(P0_26_SD_FILTER_CONTROL_REG_M1, ~(_BIT7 | _BIT6), _BIT7);
 292   1          ScalerBurstWrite(tSD_H_COEF_128_TAPS, _HSD_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P0_27_SD_USER_FILTER
             -_ACCESS_PORT_M1, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 293   1          // Set Coefficient table 2
 294   1          ScalerSetBit(P0_26_SD_FILTER_CONTROL_REG_M1, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 295   1          ScalerBurstWrite(tSD_V_COEF_64_TAPS, _VSD_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P0_27_SD_USER_FILTER_
             -ACCESS_PORT_M1, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 296   1      
 297   1          // M2
 298   1          // Set Coefficient table 1
 299   1          ScalerSetBit(P40_26_SD_FILTER_CONTROL_REG_M2, ~(_BIT7 | _BIT6), _BIT7);
 300   1          ScalerBurstWrite(tSD_H_COEF_128_TAPS, _HSD_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P40_27_SD_USER_FILTE
             -R_ACCESS_PORT_M2, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 301   1          // Set Coefficient table 2
 302   1          ScalerSetBit(P40_26_SD_FILTER_CONTROL_REG_M2, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 303   1          ScalerBurstWrite(tSD_V_COEF_64_TAPS, _VSD_TABLE_SIZE, GET_CURRENT_BANK_NUMBER(), P40_27_SD_USER_FILTER
             -_ACCESS_PORT_M2, _BURSTWRITE_DATA_COMMON, _BURSTWRITE_FROM_FLASH);
 304   1      }
