 116          //--------------------------------------------------
 117          // Description  : Decide which scaling up function should be performed
 118          // Input Value  : Input/Output H/V Active Region
 119          // Output Value : None
 120          //--------------------------------------------------
 121          void ScalerScalingSetScalingUp(const StructSDRAMDataInfo *pstFIFOScaling)
 122          {
 123   1          CLR_V_SCALE_UP();
 124   1          CLR_H_SCALE_UP();
 125   1      
 126   1          // Disable Scale Up
 127   1          ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~(_BIT1 | _BIT0), 0x00);
 128   1      
 129   1      #if(_SHARPNESS_SUPPORT == _OFF)
                  // Disable Scale Up FixCoef
                  ScalerSetBit(P0_37_SCALE_UP_FOR_LINE_INTERLEAVE, ~(_BIT5 | _BIT4), 0x00);
              #endif
 133   1      
 134   1          //===============================
 135   1          // Decide V direction scaling up
 136   1          //===============================
 137   1          // Set V Scaling Up Factor
 138   1          if(pstFIFOScaling->usOutputVHeight < g_stMDomainOutputData.usVHeight)
 139   1          {
 140   2              SET_V_SCALE_UP();
 141   2      
 142   2              // Calculate Scaling Factor
 143   2              PDATA_DWORD(0) = GET_DWORD_MUL_DIV((1UL << (_VSU_FACTOR_BIT + 1)), pstFIFOScaling->usOutputVHeight
             -, g_stMDomainOutputData.usVHeight);
 144   2              PDATA_DWORD(0) = (PDATA_DWORD(0) + 1) >> 1;
 145   2      
 146   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, ((PDATA_DWORD(0) >> 16)
             - & 0x0F));
 147   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_04_VER_SCALE_FACTOR_M, ((PDATA_DWORD(0) >> 8) 
             -& 0xFF));
 148   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_05_VER_SCALE_FACTOR_L, (PDATA_DWORD(0) & 0xFF)
             -);
 149   2      
 150   2              // Set V Initial Phase
 151   2              // R = Input Height /Output Height
 152   2              // ideal initial phase: for 4line SU = (1+R)*16*8
 153   2              PDATA_DWORD(0) = (DWORD)(pstFIFOScaling->usOutputVHeight + g_stMDomainOutputData.usVHeight) * 16 *
             - 8 / g_stMDomainOutputData.usVHeight;
 154   2      
 155   2              // Check for enabling video compensation
 156   2              if((GET_INTERLACED_MODE() == _FALSE) ||
 157   2      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 158   2                 ((GET_ROT_TYPE() == _ROT_CW90) || (GET_ROT_TYPE() == _ROT_CW270)) ||
 159   2      #endif
 160   2                 (ScalerFmtCnvGetSourceType() == _FC_SOURCE_ADC) ||
 161   2                 (BYPASS_VIDEO_COMPENSATION(pstFIFOScaling->usOutputVHeight, g_stMDomainOutputData.usVHeight) ==
             - _TRUE))
 162   2              {
 163   3                  ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, pData[3]);
 164   3              }
 165   2              else
C51 COMPILER V9.60.0.0   RL6449_SERIES_SCALING                                             10/18/2025 16:25:55 PAGE 4   

 166   2              {
 167   3                  if(pData[3] > 0xBF)
 168   3                  {
 169   4                      pData[3] = 0xFF;
 170   4                  }
 171   3                  else
 172   3                  {
 173   4                      pData[3] = pData[3] + 0x40;
 174   4                  }
 175   3      
 176   3                  ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, pData[3]);
 177   3              }
 178   2          }
 179   1          else
 180   1          {
 181   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_03_VER_SCALE_FACTOR_H, 0x0F);
 182   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_04_VER_SCALE_FACTOR_M, 0xFF);
 183   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_05_VER_SCALE_FACTOR_L, 0xFF);
 184   2      
 185   2              ScalerSetDataPortByte(P0_33_SF_ADDR_PORT, _P0_34_PT_11_VER_FILTER_COEF_INI, 0xFF);
 186   2      
 187   2      #if(_SHARPNESS_SUPPORT == _OFF)
                      // Enable V Scale Up FixCoef
                      ScalerSetBit(P0_37_SCALE_UP_FOR_LINE_INTERLEAVE, ~_BIT4, _BIT4);
              #endif
 191   2          }
 192   1      
 193   1          if(GET_V_SCALE_UP() == _TRUE)
 194   1          {
 195   2              // Enable V Scale Up
 196   2              ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT1, _BIT1);
 197   2      
 198   2              if(GET_INTERLACED_MODE() == _TRUE)
 199   2              {
 200   3                  // VGA Input or Prefered Timing
 201   3                  if((ScalerFmtCnvGetSourceType() == _FC_SOURCE_ADC) ||
 202   3      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 203   3                     ((GET_ROT_TYPE() == _ROT_CW90) || (GET_ROT_TYPE() == _ROT_CW270)) ||
 204   3      #endif
 205   3                     (BYPASS_VIDEO_COMPENSATION(pstFIFOScaling->usOutputVHeight, g_stMDomainOutputData.usVHeight
             -) == _TRUE))
 206   3                  {
 207   4                      // Disable Video Compensation
 208   4                      ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, 0x00);
 209   4                  }
 210   3                  else
 211   3                  {
 212   4                      // Enable Video Compensation According to Odd Field Delay One Line
 213   4                      ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, _BIT7);
 214   4      
 215   4      #if(_DISPLAY_ROTATION_SUPPORT == _ON)
 216   4                      // Check video compensation polarity for rotation
 217   4                      ScalerRotationCheckVideoCompensation();
 218   4      #endif
 219   4                  }
 220   3              }
 221   2              else
 222   2              {
 223   3                  // Disable Video Compensation
 224   3                  ScalerSetBit(P0_32_SCALE_CONTROL_REG, ~_BIT7, 0x00);
 225   3              }
 226   2          }
