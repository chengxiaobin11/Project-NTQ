 334   2              if(((((1UL << _HSD_FACTOR_BIT) % pstFIFOScaling->usInputHWidth) *
 335   2                   (g_stMDomainInputData.usHWidth % pstFIFOScaling->usInputHWidth)) % pstFIFOScaling->usInputHWi
             -dth) != 0)
