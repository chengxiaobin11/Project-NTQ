 179          //--------------------------------------------------
 180          // Description  : All Group Power reset
 181          // Input Value  : ON --> Reset ; OFF --> Release
 182          // Output Value : None
 183          //--------------------------------------------------
 184          void ScalerPowerAllGroupPowerCutReset(BYTE ucOn)
 185          {
 186   1          if(ucOn == _ON)
 187   1          {
 188   2              // Group A Power Cut block Reset
 189   2              ScalerSetBit(P0_09_GA_POWER_CTRL, ~_BIT0, _BIT0);
 190   2      
 191   2              // Group ADI Power Cut block Reset
 192   2              ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT0, _BIT0);
 193   2      
 194   2              if((ScalerGetBit(P6F_20_D0_POWER_CTRL, _BIT1) == _BIT1) || (ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _
             -BIT0) == _BIT0))
 195   2              {
 196   3                  // Group D0 Power Cut block Reset
 197   3                  ScalerSetBit(P6F_20_D0_POWER_CTRL, ~_BIT0, _BIT0);
 198   3              }
 199   2      
 200   2              if((ScalerGetBit(P6F_21_D1_POWER_CTRL, _BIT1) == _BIT1) || (ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _
             -BIT1) == _BIT1))
 201   2              {
 202   3                  // Group D1 Power Cut block Reset
 203   3                  ScalerSetBit(P6F_21_D1_POWER_CTRL, ~_BIT0, _BIT0);
 204   3              }
 205   2      
 206   2              if((ScalerGetBit(P6F_22_D2_POWER_CTRL, _BIT1) == _BIT1) || (ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _
             -BIT2) == _BIT2))
 207   2              {
 208   3                  // Group D2 Power Cut block Reset
 209   3                  ScalerSetBit(P6F_22_D2_POWER_CTRL, ~_BIT0, _BIT0);
 210   3              }
 211   2      
 212   2              if((ScalerGetBit(P6F_23_D3_POWER_CTRL, _BIT1) == _BIT1) || (ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _
             -BIT3) == _BIT3))
 213   2              {
 214   3                  // Group D3 Power Cut block Reset
 215   3                  ScalerSetBit(P6F_23_D3_POWER_CTRL, ~_BIT0, _BIT0);
 216   3              }
 217   2          }
 218   1          else
 219   1          {
 220   2              // Group A Power Cut block Relase
 221   2              ScalerSetBit(P0_09_GA_POWER_CTRL, ~_BIT0, 0x00);
 222   2      
 223   2              // Group ADI Power Cut block Relase
 224   2              ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT0, 0x00);
 225   2      
 226   2              // Group D0 Power Cut block Relase
 227   2              ScalerSetBit(P6F_20_D0_POWER_CTRL, ~_BIT0, 0x00);
 228   2      
 229   2              // Group D1 Power Cut block Relase
C51 COMPILER V9.60.0.0   RL6449_SERIES_POWER                                               10/18/2025 16:25:54 PAGE 5   

 230   2              ScalerSetBit(P6F_21_D1_POWER_CTRL, ~_BIT0, 0x00);
 231   2      
 232   2              // Group D2 Power Cut block Relase
 233   2              ScalerSetBit(P6F_22_D2_POWER_CTRL, ~_BIT0, 0x00);
 234   2      
 235   2              // Group D3 Power Cut block Relase
 236   2              ScalerSetBit(P6F_23_D3_POWER_CTRL, ~_BIT0, 0x00);
 237   2          }
 238   1      }
