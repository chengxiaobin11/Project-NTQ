  66          //--------------------------------------------------
  67          // Description  : Power cut block flow
  68          // Input Value  : enumSwitch    --> Power action description.
  69          // Output Value : return power group enter isolation area
  70          //--------------------------------------------------
  71          BYTE ScalerPowerIsolation(EnumPowerAction enumSwitch)
  72          {
  73   1          BYTE ucPowerIsoFlg = 0x00;
  74   1      
  75   1          switch(enumSwitch)
  76   1          {
  77   2              case _POWER_ACTION_NORMAL_TO_PS:
  78   2              case _POWER_ACTION_NORMAL_TO_OFF:
  79   2              case _POWER_ACTION_AC_ON_TO_OFF:
  80   2              case _POWER_ACTION_AC_ON_INITIAL:
  81   2      
  82   2                  // Group A block isolation control
  83   2                  ScalerPowerGroupAIsolation(_ON);
  84   2      
  85   2                  ucPowerIsoFlg |= _BIT0;
  86   2      
  87   2                  // Group B block isolation control
  88   2                  ScalerPowerGroupBIsolation(_ON);
  89   2                  ucPowerIsoFlg |= _BIT1;
  90   2      
  91   2                  // Group ADI block isolation control
  92   2                  ScalerPowerGroupADIIsolation(_ON);
  93   2                  ucPowerIsoFlg |= _BIT2;
  94   2      
  95   2                  // Group D2 to D3 block isolation control
  96   2                  ScalerPowerGroupD2Isolation(_ON);
  97   2                  ScalerPowerGroupD3Isolation(_ON);
  98   2                  ucPowerIsoFlg |= _BIT3;
  99   2      
 100   2                  // Group D0 to D1 block isolation control
 101   2                  ScalerPowerGroupD0Isolation(_ON);
 102   2                  ScalerPowerGroupD1Isolation(_ON);
 103   2                  ucPowerIsoFlg |= _BIT4;
 104   2      
 105   2                  // Group ADI power control
 106   2                  ScalerPowerGroupADIPowerCut(_ON);
 107   2      
 108   2                  // Group D2 to D3 power control
 109   2                  ScalerPowerGroupD2PowerCut(_ON);
C51 COMPILER V9.60.0.0   RL6449_SERIES_POWER                                               10/18/2025 16:25:54 PAGE 3   

 110   2                  ScalerPowerGroupD3PowerCut(_ON);
 111   2      
 112   2                  // Group D0 to D1 power control
 113   2                  ScalerPowerGroupD0PowerCut(_ON);
 114   2                  ScalerPowerGroupD1PowerCut(_ON);
 115   2      
 116   2                  // Group A power control control by GPIO
 117   2                  ScalerPowerGroupAPowerCut(_ON);
 118   2      
 119   2                  break;
 120   2      
 121   2              case _POWER_ACTION_AC_ON_TO_NORMAL:
 122   2              case _POWER_ACTION_OFF_TO_NORMAL:
 123   2              case _POWER_ACTION_PS_TO_NORMAL:
 124   2      
 125   2                  // All power group Reset
 126   2                  ScalerPowerAllGroupPowerCutReset(_ON);
 127   2      
 128   2                  // Group A power supply control by GPIO
 129   2                  ScalerPowerGroupAPowerCut(_OFF);
 130   2      
 131   2                  // Group ADI power control
 132   2                  ScalerPowerGroupADIPowerCut(_OFF);
 133   2      
 134   2                  // Group D2 to D3 power control
 135   2                  ScalerPowerGroupD2PowerCut(_OFF);
 136   2                  ScalerPowerGroupD3PowerCut(_OFF);
 137   2      
 138   2                  // Group D0 to D1 power control
 139   2                  ScalerPowerGroupD0PowerCut(_OFF);
 140   2                  ScalerPowerGroupD1PowerCut(_OFF);
 141   2      
 142   2                  // Group A block isolation control
 143   2                  ScalerPowerGroupAIsolation(_OFF);
 144   2      
 145   2                  // Group B block isolation control
 146   2                  ScalerPowerGroupBIsolation(_OFF);
 147   2      
 148   2                  // Group ADI block isolation control
 149   2                  ScalerPowerGroupADIIsolation(_OFF);
 150   2      
 151   2                  // Group D2 to D3 block isolation control
 152   2                  ScalerPowerGroupD2Isolation(_OFF);
 153   2                  ScalerPowerGroupD3Isolation(_OFF);
 154   2      
 155   2                  // Group D0 to D1 block isolation control
 156   2                  ScalerPowerGroupD0Isolation(_OFF);
 157   2                  ScalerPowerGroupD1Isolation(_OFF);
 158   2      
 159   2                  // All power group Relase
 160   2                  ScalerPowerAllGroupPowerCutReset(_OFF);
 161   2      
 162   2                  break;
 163   2      
 164   2              case _POWER_ACTION_NORMAL_TO_FAKE_PS:
 165   2      
 166   2                  break;
 167   2      
 168   2              case _POWER_ACTION_PS_TO_OFF:
 169   2      
 170   2                  break;
 171   2      
C51 COMPILER V9.60.0.0   RL6449_SERIES_POWER                                               10/18/2025 16:25:54 PAGE 4   

 172   2              default:
 173   2                  break;
 174   2          }
 175   1      
 176   1          return ucPowerIsoFlg;
 177   1      }
