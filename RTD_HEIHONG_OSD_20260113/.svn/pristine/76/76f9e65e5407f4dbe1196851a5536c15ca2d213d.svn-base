 245          void ScalerPowerGroupAIsolation(BYTE ucOn)
 246          {
 247   1          if(ucOn == _ON)
 248   1          {
 249   2              // Analog isolation on
 250   2              ScalerSetBit(P0_F0_VCCKOFF_CONTROL0, ~_BIT4, _BIT4);
 251   2      
 252   2              // Digital isolation on
 253   2              ScalerSetBit(P0_09_GA_POWER_CTRL, ~_BIT1, _BIT1);
 254   2          }
 255   1          else
 256   1          {
 257   2              // Digital isolation off
 258   2              ScalerSetBit(P0_09_GA_POWER_CTRL, ~_BIT1, 0x00);
 259   2      
 260   2              // Analog isolation off
 261   2              ScalerSetBit(P0_F0_VCCKOFF_CONTROL0, ~_BIT4, 0x00);
 262   2      
 263   2              // Wait for VCCK_OFF Power On Stable
 264   2              POLLING_VCCK_OFF_STATUS(_VCCK_OFF_TIME_POLLING_POWER_ON);
 265   2          }
 266   1      }
