 416          //--------------------------------------------------
 417          void ScalerPowerGroupAPowerCut(BYTE ucOn)
 418          {
 419   1          if(ucOn == _ON)
 420   1          {
 421   2              PCB_VCCK_OFF_POWER(_VCCK_OFF_POWER_OFF);
 422   2      
 423   2              PCB_DDR_POWER(_DDR_POWER_OFF);
 424   2      
 425   2              PCB_DDR_POWER_RELEASE_TIME(_DDR_POWER_OFF_TIME);
 426   2          }
 427   1          else
 428   1          {
 429   2              // Group A power block power cut on
 430   2              if((ScalerGetBit(P0_F0_VCCKOFF_CONTROL0, _BIT4) == _BIT4) || (ScalerGetBit(P0_09_GA_POWER_CTRL, _B
             -IT1) == _BIT1))
 431   2              {
 432   3                  PCB_DDR_POWER(_DDR_POWER_ON);
 433   3      
 434   3                  // Wait for DDR stable, can't delete
 435   3                  ScalerTimerDelayXms(10);
 436   3      
 437   3                  PCB_VCCK_OFF_POWER(_VCCK_OFF_POWER_ON);
 438   3      
 439   3                  // Wait for 1.1V stable, can't delete
 440   3                  ScalerTimerDelayXms(10);
 441   3              }
 442   2          }
 443   1      }
 444          
 445          //--------------------------------------------------
 446          // Description  : Group ADI Power on/off
 447          // Input Value  : ON --> Group ADI(Low Power) ; OFF --> Group ADI (Normal Operation)
 448          // Output Value : None
 449          //--------------------------------------------------
 450          void ScalerPowerGroupADIPowerCut(BYTE ucOn)
 451          {
 452   1          if(ucOn == _ON)
 453   1          {
 454   2              // Strong power off
 455   2              ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT5, 0x00);
 456   2      
 457   2              // Weak power off
 458   2              ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT4, 0x00);
 459   2          }
 460   1          else
 461   1          {
 462   2              // Group C power block power cut on
 463   2              if((ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _BIT6) == _BIT6) || (ScalerGetBit(P6F_26_ADI_POWER_CTRL, 
             -_BIT1) == _BIT1))
 464   2              {
 465   3                  // Weak power on
 466   3                  ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT4, _BIT4);
 467   3      
 468   3                  // Wait for weak power on flag
 469   3                  pData[0] = 50;
 470   3      
 471   3                  while((ScalerGetBit(P6F_26_ADI_POWER_CTRL, _BIT6) != _BIT6) && (pData[0]-- > 0))
 472   3                  {
 473   4                      DELAY_5US();
 474   4                  }
 475   3      
C51 COMPILER V9.60.0.0   RL6449_SERIES_POWER                                               10/18/2025 16:25:54 PAGE 9   

 476   3                  // Strong power on
 477   3                  ScalerSetBit(P6F_26_ADI_POWER_CTRL, ~_BIT5, _BIT5);
 478   3      
 479   3                  // Wait for strong power on flag
 480   3                  pData[0] = 50;
 481   3      
 482   3                  while((ScalerGetBit(P6F_26_ADI_POWER_CTRL, _BIT7) != _BIT7) && (pData[0]-- > 0))
 483   3                  {
 484   4                      DELAY_5US();
 485   4                  }
 486   3              }
 487   2          }
 488   1      }
 489          
 490          //--------------------------------------------------
 491          // Description  : Group D0 Power on/off
 492          // Input Value  : ON --> Group D0(Low Power) ; OFF --> Group D0 (Normal Operation)
 493          // Output Value : None
 494          //--------------------------------------------------
 495          void ScalerPowerGroupD0PowerCut(BYTE ucOn)
 496          {
 497   1          if(ucOn == _ON)
 498   1          {
 499   2              // D0 Strong power off
 500   2              ScalerSetBit(P6F_20_D0_POWER_CTRL, ~_BIT5, 0x00);
 501   2      
 502   2              // D0 Weak power off
 503   2              ScalerSetBit(P6F_20_D0_POWER_CTRL, ~_BIT4, 0x00);
 504   2          }
 505   1          else
 506   1          {
 507   2              // Group D0 power block power cut on
 508   2              if((ScalerGetBit(P0_F1_VCCKOFF_CONTROL1, _BIT0) == _BIT0) || (ScalerGetBit(P6F_20_D0_POWER_CTRL, _
             -BIT1) == _BIT1))
 509   2              {
 510   3                  // Weak power on
 511   3                  ScalerSetBit(P6F_20_D0_POWER_CTRL, ~_BIT4, _BIT4);
 512   3      
 513   3                  // Wait for weak power on flag
 514   3                  pData[0] = 50;
 515   3      
