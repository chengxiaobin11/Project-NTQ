 161          //--------------------------------------------------
 162          void ScalerAudioDisable(void)
 163          {
 164   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
 165   1      
C51 COMPILER V9.60.0.0   SCALERAUDIO                                                       10/18/2025 16:24:50 PAGE 4   

 166   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_VCM_INITIAL);
 167   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_DEPOP_TO_NORMAL);
 168   1          ScalerTimerCancelTimerEvent(_SYSTEM_TIMER_EVENT_AUDIO_DAC_WAIT_VCM_CHARGE);
 169   1      
 170   1          ScalerAudioDACNormalToDepop();
 171   1      
 172   1          ScalerAudioDACSetVcmReady(_OFF);
 173   1      
 174   1          // Power Down Depop CLK
 175   1          ScalerSetBit(P6_D4_DA_CLK_CTRL, ~_BIT4, 0x00);
 176   1      
 177   1          // Power Down DAC
 178   1          ScalerSetByte(P6_C0_REG_DAC_POWER0, 0x00);
 179   1          ScalerSetBit(P6_C1_REG_DAC_POWER1, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), 0x00);
