1522          //--------------------------------------------------
1523          // Description  : Set ZCD Timeout
1524          // Input Value  : bMute, usVolume, bAdjustType
1525          // Output Value : None
1526          //--------------------------------------------------
1527          void ScalerAudioDVCSetMuteZCDTimeout(bit bMute, WORD usVolume, bit bAdjustType)
1528          {
1529   1          EnumAudioSamplingFreqPacket enumSamplingFreqPacket = _AUDIO_FREQ_PACKET_NO_AUDIO;
1530   1      
1531   1          // Get Sampling Rate
1532   1      #if(_LINE_IN_SUPPORT == _ON)
1533   1          if(ScalerAudioGetInputSource() == _LINE_IN_AUDIO)
1534   1          {
1535   2              enumSamplingFreqPacket = _AUDIO_FREQ_PACKET_48K;
1536   2          }
1537   1          else
1538   1      #endif
1539   1          {
1540   2              enumSamplingFreqPacket = ScalerAudioSamplingFreqDetect(ScalerAudioGetDigitalAudioPortMapping());
1541   2          }
1542   1      
1543   1          if(bAdjustType == _DB_GAIN)
1544   1          {
1545   2              // Get down or up step
1546   2              pData[0] = (bMute == _ON) ? (ScalerGetBit(P8_A0_DVC_EN, (_BIT3 | _BIT2)) >> 2) : ScalerGetBit(P8_A
             -0_DVC_EN, (_BIT1 | _BIT0));
1547   2      
1548   2              // Get numbers of the volume step for mute or unmute
1549   2              PDATA_WORD(0) = _DVC_DB_STEP_NUMBER << pData[0];
1550   2          }
1551   1          else
1552   1          {
1553   2              PDATA_WORD(0) = usVolume / _VOLUME_STEP_SIZE_VALUE + 1;
1554   2          }
1555   1      
1556   1          // Calculate samples of ZCD timeout
1557   1          PDATA_DWORD(1) = (DWORD)enumSamplingFreqPacket * _DVC_VOLUME_MUTE_TIMER / PDATA_WORD(0);
1558   1      
1559   1          // Avoid Overflow
1560   1          if(PDATA_DWORD(1) > 0x0FFF)
1561   1          {
1562   2              PDATA_WORD(0) = 0x0FFF;
1563   2          }
1564   1          else
1565   1          {
1566   2              PDATA_WORD(0) = (WORD)PDATA_DWORD(1);
1567   2          }
1568   1      
1569   1          // Set DVC ZCD window size
1570   1          ScalerSetBit(P8_A3_DVC_ZC_WIN_CTRL_0, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(PDATA_WORD(0)));
1571   1          ScalerSetByte(P8_A4_DVC_ZC_WIN_CTRL_1, LOBYTE(PDATA_WORD(0)));
1572   1      }
