 333   2                  return _AUDIO_FREQ_PACKET_192K;
 334   2      #endif
 335   2      
 336   2              default:
 337   2                  break;
 338   2          }
 339   1      
 340   1          return _AUDIO_FREQ_PACKET_NO_AUDIO;
 341   1      }
