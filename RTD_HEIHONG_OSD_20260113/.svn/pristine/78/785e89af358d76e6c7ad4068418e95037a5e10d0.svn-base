 232          //--------------------------------------------------
 233          // Description  : Get Current Audio Port For Output Type
 234          // Input Value  : None
 235          // Output Value : audio port
 236          //--------------------------------------------------
 237          BYTE ScalerAudioGetDigitalAudioPort(EnumAudioOutputType enumAudioOutput)
 238          {
 239   1          switch(enumAudioOutput)
 240   1          {
 241   2              case _AUDIO_DAC_OUT:
 242   2      
 243   2                  return (ScalerGetBit(P6F_01_MUX_DA_DVC_IN, (_BIT2 | _BIT1 | _BIT0)));
 244   2      
 245   2              case _AUDIO_I2S_OUT:
 246   2      
 247   2                  return (ScalerGetBit(P6F_00_MUX_DIG_OUT, (_BIT6 | _BIT5 | _BIT4)) >> 4);
 248   2      
 249   2              case _AUDIO_SPDIF_OUT:
 250   2      
 251   2                  return (ScalerGetBit(P6F_00_MUX_DIG_OUT, (_BIT2 | _BIT1 | _BIT0)));
 252   2      
 253   2      #if(_DP_TX_SUPPORT == _ON)
                      case _AUDIO_DPTX_OUT:
              
                          return (ScalerGetBit(P6F_02_MUX_DP_I2S_IN, (_BIT2 | _BIT1 | _BIT0)));
              #endif
 258   2      
 259   2              default:
 260   2                  break;
 261   2          }
 262   1      
 263   1          return _AUDIO_FROM_D0_PORT;
 264   1      }
