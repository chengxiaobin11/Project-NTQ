                  ScalerSetBit(P6_B0_REG_ADC_POWER, ~_BIT7, 0x00);
              #else
 191   1          // Power Down ADC
 192   1          ScalerSetBit(P6_B0_REG_ADC_POWER, ~(_BIT7 | _BIT6), 0x00);
 193   1      #endif
 194   1      
 195   1          // Power Down Input Buffer and Mbias
 196   1          ScalerSetBit(P6_C0_REG_DAC_POWER0, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 197   1      #endif
 198   1      
