1633          // Description  : DVC Reset Process
1634          // Input Value  : None
1635          // Output Value : None
1636          //--------------------------------------------------
C51 COMPILER V9.60.0.0   SCALERAUDIO                                                       10/18/2025 16:24:50 PAGE 28  

1637          void ScalerAudioDVCResetProc(void)
1638          {
1639   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
1640   1          if(ScalerAudioDACGetState() == _AUDIO_DAC_READY)
1641   1          {
1642   2              // Switch Audio DAC State to _AUDIO_DAC_DEPOP
1643   2              ScalerAudioDACNormalToDepop();
1644   2          }
1645   1      #endif
1646   1      
1647   1          // Reset DVC Counter
1648   1          ScalerSetBit(P8_A0_DVC_EN, ~_BIT6, _BIT6);
1649   1      
1650   1          // At Least Delay 2 Cycle of 1 / 256 * FS (= 32KHz)
1651   1          DELAY_5US();
1652   1      
1653   1          // Enable DVC Counter
1654   1          ScalerSetBit(P8_A0_DVC_EN, ~_BIT6, 0x00);
1655   1      
1656   1      #if(_DIGITAL_AUDIO_OUTPUT_FIX_I2S_PHASE_DELAY == _ON)
                  // Disable I2S Block
                  ScalerSetBit(P6_E7_AD_I2S_CTRL, ~_BIT7, 0x00);
              
                  // At Least Delay 2 Cycle of 1 / FS (= 32KHz)
                  DELAY_XUS(70);
              
                  // Enable I2S Block
                  ScalerSetBit(P6_E7_AD_I2S_CTRL, ~_BIT7, _BIT7);
              #endif
1666   1      }
