1237          //****************************************************************************
1238          // FUNCTION DEFINITIONS
1239          //****************************************************************************
1240          //--------------------------------------------------
1241          // Description  : Cache Control
1242          // Input Value  : bControl
1243          // Output Value : None
1244          //--------------------------------------------------
1245          //--------------------------------------------------
1246          // Description  : DDC Debounce Settings
1247          // Input Value  : Clock --> _EXT_XTAL_CLK/_IOSC_CLK
1248          // Output Value : None
1249          //--------------------------------------------------
1250          void ScalerMcuDdcDebounceSel(EnumClkSel enumClock)
1251          {
1252   1          if(enumClock == _EXT_XTAL_CLK)
1253   1          {
1254   2              // VGA_DDC De-bounce Reference Clock(Xtal = 14.318M) div by 2, latch 3 stages
1255   2              MCU_FF1C_ADC_DDC_CONTROL_1 &= ~_BIT7;
1256   2              MCU_FF1C_ADC_DDC_CONTROL_1 |= (_BIT6 | _BIT5 | _BIT4);
1257   2      
1258   2      #if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
1259   2              // DDC0 De-bounce Reference Clock(Xtal = 14.318M) div by 1, latch 1 stages
1260   2              MCU_FF1F_DDC0_DDC_CONTROL_1 &= ~(_BIT7 | _BIT6);
1261   2              MCU_FF1F_DDC0_DDC_CONTROL_1 |= _BIT4;
1262   2      #endif
1263   2      
1264   2      #if(_D1_INPUT_PORT_TYPE == _D1_DP_PORT)
1265   2              // DDC1 De-bounce Reference Clock(Xtal = 14.318M) div by 1, latch 1 stages
1266   2              MCU_FF2D_DDC1_DDC_CONTROL_1 &= ~(_BIT7 | _BIT6);
1267   2              MCU_FF2D_DDC1_DDC_CONTROL_1 |= _BIT4;
1268   2      #endif
1269   2      
1270   2      #if((_D2_INPUT_PORT_TYPE == _D2_DVI_PORT) || (_D2_INPUT_PORT_TYPE == _D2_HDMI_PORT) || (_D2_INPUT_PORT_TYP
             -E == _D2_MHL_PORT))
1271   2              // DDC2 De-bounce Reference Clock(Xtal = 14.318M) div by 2, latch 3 stages
