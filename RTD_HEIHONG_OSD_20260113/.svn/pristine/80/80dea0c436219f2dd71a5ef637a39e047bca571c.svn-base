                     (GET_OSD_ROTATE_STATUS() == _OSD_ROTATE_DEGREE_270))
                  {
                      ucTmp = 0x4E;  // 18 Pixel
                  }
                  else
              #endif
2152   1          {
2153   2              ucTmp = 0x4C;  // 12 Pixel
2154   2          }
