              bit OsdFuncCheckFreezeDisable(void)
              {
                  if(((((GET_OSD_STATE() >= _MENU_DISPLAY_AUTO) &&
                        (GET_OSD_STATE() <= _MENU_DISPLAY_PHASE)) ||
                       (GET_OSD_STATE() == _MENU_COLOR_FORMAT) ||
                       (GET_OSD_STATE() == _MENU_ADVANCE_ITEM) ||
                       (GET_OSD_STATE() == _MENU_OTHER_RESET) ||
