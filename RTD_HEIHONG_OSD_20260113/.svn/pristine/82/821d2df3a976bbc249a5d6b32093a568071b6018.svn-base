//****************************************************************************
// FUNCTION DEFINITIONS
//****************************************************************************
//--------------------------------------------------
// Description	:
// Input Value	: None
// Output Value : None
//--------------------------------------------------

void OsdHotKeyFuncSpacialProc(void)
{
	switch(OSD_SubMenuCur)
	{ 
		#if _FREESYNC_SUPPORT
		case _MENU_FUN_FREESYNC:
			if((GET_KEYMESSAGE() == _MENU_KEY_MESSAGE) && (g_usBackupValue != g_usAdjustValue))
			{
				#if(_FREESYNC_SUPPORT == _ON)
					UserCommonInterfaceFreeSyncSupportSwitch();
				#endif
			}
			else if(GET_KEYMESSAGE() == _EXIT_KEY_MESSAGE)
			{
				SET_OSD_FREE_SYNC_STATUS(g_usBackupValue);
			}
			break;
		#endif
	
    case _MENU_FUN_CROSS:
        if((GET_KEYMESSAGE() == _MENU_KEY_MESSAGE) && (g_usBackupValue != g_usAdjustValue))
        {
                if(GET_OSD_CROSS_STATUS()==_ON)
                {
                	MenuCross();
                }
        }
        else if((GET_KEYMESSAGE() == _EXIT_KEY_MESSAGE) && (g_usBackupValue != g_usAdjustValue))
        {   
    
            SET_OSD_CROSS_STATUS(g_usBackupValue);
    
        
        }
        
        break;
		case _MENU_FUN_SIGNAL:	
			
			if((GET_KEYMESSAGE() == _MENU_KEY_MESSAGE) && (g_usBackupValue != g_usAdjustValue))
			{
			 
#if(_DEF_2795E06)
				g_SouceSelect = 0;
#endif

				SET_FORCE_POW_SAV_STATUS(_FALSE);
				SysModeSetResetTarget(_MODE_ACTION_RESET_TO_SEARCH);
		
	#if(_SOURCE_AUTO_ON)
				if(GET_OSD_INPUT_PORT_OSD_ITEM() == _OSD_INPUT_AUTO)
				{
					SysSourceSetScanType(_SOURCE_SWITCH_AUTO_IN_GROUP);
					
					if(UserCommonNVRamGetSystemData(_SOURCE_SCAN_TYPE) != SysSourceGetScanType())
					{
						UserCommonNVRamSetSystemData(_SOURCE_SCAN_TYPE, SysSourceGetScanType());
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG);
					}
				}
				else
				{		
					SysSourceSwitchInputPort(OsdFuncGetOsdItemFlag());
					SysSourceSetScanType(_SOURCE_SWITCH_FIXED_PORT);
					if((UserCommonNVRamGetSystemData(_SEARCH_PORT) != SysSourceGetInputPort()) ||
					   (UserCommonNVRamGetSystemData(_SOURCE_SCAN_TYPE) != SysSourceGetScanType()))
					{
						UserCommonNVRamSetSystemData(_SEARCH_PORT, SysSourceGetInputPort());
						UserCommonNVRamSetSystemData(_SOURCE_SCAN_TYPE, SysSourceGetScanType());
						SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG);
					}
				}
	#else					
				SysSourceSwitchInputPort(OsdFuncGetOsdItemFlag());
				SysSourceSetScanType(_SOURCE_SWITCH_AUTO_IN_GROUP);
				if((UserCommonNVRamGetSystemData(_SEARCH_PORT) != SysSourceGetInputPort()) ||
				   (UserCommonNVRamGetSystemData(_SOURCE_SCAN_TYPE) != SysSourceGetScanType()))
				{
					UserCommonNVRamSetSystemData(_SEARCH_PORT, SysSourceGetInputPort());
					UserCommonNVRamSetSystemData(_SOURCE_SCAN_TYPE, SysSourceGetScanType());
					SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_SYSTEMDATA_MSG);
				}						
	#endif				
			}
			else
			{
				
				SET_OSD_INPUT_PORT_OSD_ITEM(g_usBackupValue);
			}
				break;
				
#if(_VGA_SUPPORT == _ON)

		case _MENU_FUN_AUTO_ADJUST:
			if(GET_KEYMESSAGE() == _MENU_KEY_MESSAGE)
			{
				if((SysModeGetModeState() == _MODE_STATUS_ACTIVE)&& (SysSourceGetSourceType() == _SOURCE_VGA))
				{
					SET_OSD_EVENT_MESSAGE(_OSDEVENT_DO_AUTO_CONFIG_MSG);
				}
			}
			break;
		
		case _MENU_FUN_AUTO_COLOR:
			if(GET_KEYMESSAGE() == _MENU_KEY_MESSAGE)
			{
				if((SysModeGetModeState() == _MODE_STATUS_ACTIVE)&& (SysSourceGetSourceType() == _SOURCE_VGA))
				{
					OsdDisplayAutoBalanceProc();
				}
			}
			break;	
#endif
		case _MENU_FUN_RESET:
		
			if(GET_KEYMESSAGE() == _MENU_KEY_MESSAGE)
			{
				OsdDispOsdReset();
			}
			break;

		case _MENU_FUN_LANGUAGE:		
			
			if(GET_KEYMESSAGE() == _EXIT_KEY_MESSAGE)
			{		
				SET_OSD_LANGUAGE(g_usBackupValue);
			}
			break;
	}
	
	SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_OSDUSERDATA_MSG);
}

//--------------------------------------------------
// Description	:
// Input Value	: None
// Output Value : None
//--------------------------------------------------
void OsdFuncAdjHotKey(void)
{
#if(_DEF_STA_SIX_COLOR)
	BYTE i = 0;
#endif
	BYTE OSD_fun_hot_num = 0;

	g_usAdjustValue = GetOsdValue(OSD_SubMenuCur);

	switch(OSD_SubMenuCur)
	{ 
		case _MENU_FUN_ECO:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _COLOREFFECT_AMOUNT, _COLOREFFECT_STANDARD, _ON);
			SET_OSD_COLOR_EFFECT(g_usAdjustValue);		
			if((GET_OSD_COLOR_EFFECT()!= _COLOREFFECT_STANDARD))
			{
				SET_OSD_DCR_STATUS(_OFF);
			}
		
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
#if(_DEF_COLORFUL)
			UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
			UserAdjustContrast(GET_OSD_CONTRAST());
#endif

			UserAdjustBrightness(GET_OSD_BRIGHTNESS()); 

#if(_DEF_STA_SIX_COLOR)&&(_SIX_COLOR_SUPPORT == _ON)
			ScalerColorICMEnable(_FUNCTION_ON);//�޸���ɫ����ʧЧ
			for(i = 0; i < 6; i++)
			{
				SET_OSD_SIX_COLOR(i);
				OsdDisplaySixColorGetOneColor(i);
				ScalerColorSixColorAdjust(i, GET_OSD_SIX_COLOR_HUE(), GET_OSD_SIX_COLOR_SATURATION());
			}

#endif

#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
			UserAdjustColorEffectMode();
#endif
	break;
		
		case _MENU_FUN_DCR:
			
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _ON, _OFF, _ON);
			SET_OSD_DCR_STATUS(g_usAdjustValue);
#if(_DEF_ECO_SET)
			if(GET_OSD_DCR_STATUS())
			{
				SET_OSD_DCROFF_ECO(GET_OSD_COLOR_EFFECT());
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);
			}
			else
			{
				SET_OSD_COLOR_EFFECT(GET_OSD_DCROFF_ECO());
			}	
			
			UserAdjustBacklight(GET_OSD_BACKLIGHT());

#if(_DEF_COLORFUL)
			UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
			UserAdjustContrast(GET_OSD_CONTRAST());
#endif
			UserAdjustBrightness(GET_OSD_BRIGHTNESS());
#if(_ULTRA_VIVID_SUPPORT == _ON)
			UserInterfaceAdjustUltraVivid();
#endif
			UserCommonAdjustSharpness(SysSourceGetInputPort()); 		
			UserAdjustGlobalHueSat((SWORD)GET_OSD_HUE(), GetOsdValue(_MENU_FUN_SATURATION)); //GetSaturationValue());
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
			UserAdjustColorEffectMode();
#endif

#else
			
			if(GET_OSD_DCR_STATUS() != _OFF)
			{
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);

#if(_DEF_COLORFUL)
				UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
				UserAdjustContrast(GET_OSD_CONTRAST());
#endif

				UserAdjustBrightness(GET_OSD_BRIGHTNESS()); 
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
				UserAdjustColorEffectMode();
#endif
			}	
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
#endif
			break;


#if(_DEF_OPPOSITE_DCR)
		case _MENU_FUN_DCR_OPPOSITE:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 2, _OFF, _ON);
			SET_OSD_DCR_OPPOSITE(g_usAdjustValue);
#if(_DEF_ECO_SET)
			if(GET_OSD_DCR_OPPOSITE())
			{
				SET_OSD_DCROFF_ECO(GET_OSD_COLOR_EFFECT());
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);
			}
			else
			{
				SET_OSD_COLOR_EFFECT(GET_OSD_DCROFF_ECO());
			}	
			
			UserAdjustBacklight(GET_OSD_BACKLIGHT());

#if(_DEF_COLORFUL)
			UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
			UserAdjustContrast(GET_OSD_CONTRAST());
#endif
			UserAdjustBrightness(GET_OSD_BRIGHTNESS());
#if(_ULTRA_VIVID_SUPPORT == _ON)
			UserInterfaceAdjustUltraVivid();
#endif
			UserCommonAdjustSharpness(SysSourceGetInputPort()); 		
			UserAdjustGlobalHueSat((SWORD)GET_OSD_HUE(), GetOsdValue(_MENU_FUN_SATURATION)); //GetSaturationValue());
			
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
			UserAdjustColorEffectMode();
#endif

#else
			
			if(GET_OSD_DCR_OPPOSITE() != _OFF)
			{
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);

#if(_DEF_COLORFUL)
				UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
				UserAdjustContrast(GET_OSD_CONTRAST());
#endif

				UserAdjustBrightness(GET_OSD_BRIGHTNESS()); 
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
				UserAdjustColorEffectMode();
#endif
			}	
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
#endif
			break;
#endif


		case _MENU_FUN_DCC:
		  g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,_ON,_OFF,_ON);
		  
		  SET_OSD_DCC(g_usAdjustValue);
		  UserAdjustDCC(GET_OSD_DCC());
		  ScalerColorDCCEnable(GET_OSD_DCC());
		break;
		case _MENU_FUN_VIVID:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _ULTRA_VIVID_AMOUNT, _ULTRA_VIVID_OFF, _ON);			
			SET_OSD_ULTRA_VIVID_STATUS(g_usAdjustValue);
#if(_ULTRA_VIVID_SUPPORT == _ON)
			UserInterfaceAdjustUltraVivid();
#endif
				break;

		case _MENU_FUN_AUDIO_SOURCE:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 2, _OFF, _ON);
			SET_FUN_AUDIO_SOURCE(g_usAdjustValue);
			break;
			
		case _MENU_FUN_HDR:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _HDR10_MODE_AUTO, _HDR10_MODE_OFF, _ON);			
			SET_OSD_HDR_MODE(g_usAdjustValue);
			
			if(GET_OSD_HDR_MODE() != _HDR10_MODE_OFF)
			{	
			
#if(!_TJ_GAMMA)
                SET_OSD_GAMMA(_GAMMA_OFF);
#endif
				SET_OSD_PCM_STATUS(_PCM_OSD_NATIVE);
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);
				SET_OSD_DCR_STATUS(_OFF);
				
				UserAdjustBrightness(GET_OSD_BRIGHTNESS()); 
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
				UserAdjustColorEffectMode();
#endif
			}
			
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
			
#if(_HDR10_SUPPORT == _ON)						
			ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
			UserCommonHDRAdjust(_HDR_FLOW_OSD_MODE_CHANGE);
			UserCommonHDR10SupportSwitch(); 
#endif	

#if((_HDR10_SUPPORT == _OFF)&&(_PROJECT == _RL6463_PROJECT))
			MockHdrEffect();
#endif

			break;
		case _MENU_FUN_ASPECT:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _OSD_ASPECT_RATIO_AMOUNT, 0, _ON);			
			
			SET_OSD_ASPECT_RATIO_TYPE(g_usAdjustValue);


	    // Set Backlight OFF to prevent garbage
    #if(_PANEL_TYPE==_AUO_M270HVR01_0_LVDS_FHD_144)
    UserCommonInterfacePanelPowerAction(_BACKLIGHT_OFF);
   #endif
		
			SysModeSetResetTarget(_MODE_ACTION_RESET_TO_DISPLAY_SETTING);
				break;
		
		case _MENU_FUN_COLORTEMP:	
			if(_CT_7500_5800_sRGB_SUPPRT)
			{
				g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _CT_USER, _CT_9300, _ON);
			}
			else
			{
				switch(GET_KEYMESSAGE())
				{
					case _LEFT_KEY_MESSAGE:
						if(g_usAdjustValue == _CT_USER)
						{
							g_usAdjustValue = _CT_9300;
						}
						else if(g_usAdjustValue == _CT_9300)
						{
							g_usAdjustValue = _CT_6500;
						}	
						else if(g_usAdjustValue == _CT_6500)
						{
							g_usAdjustValue = _CT_USER;
						}

						
						break;
					case _RIGHT_KEY_MESSAGE:
						if(g_usAdjustValue == _CT_USER)
						{
							g_usAdjustValue = _CT_6500;
						}
						else if(g_usAdjustValue == _CT_6500)
						{
							g_usAdjustValue = _CT_9300;
						}						
						else if(g_usAdjustValue == _CT_9300)
						{
							g_usAdjustValue = _CT_USER;
						}

						
						break;

					default:
						break;
				}
			}	
			
			SET_COLOR_TEMP_TYPE(g_usAdjustValue);
			
			RTDNVRamLoadColorSetting(GET_COLOR_TEMP_TYPE());

#if(_DEF_COLORFUL)
			UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
			UserAdjustContrast(GET_OSD_CONTRAST());
#endif
			g_usAdjustValue = GET_COLOR_TEMP_TYPE(); 
			break;
		
		case _MENU_FUN_LED:
			
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(GET_OSD_LED_TYPE() , _OSDLedType_END, _OSDLedType_OFF, _ON));
			SET_OSD_LED_TYPE(g_usAdjustValue);

			if(GET_OSD_LED_TYPE() == _OSDLedType_OFF)
			{
				ScalerTimerCancelTimerEvent( _USER_TIMER_EVENT_LED_MODE_FLICKER); 

				OSD_LED_CONTRL(_OSD_LED_OFF);
			}
			else if(GET_OSD_LED_TYPE() == _OSDLedType_ON)
			{
				ScalerTimerCancelTimerEvent( _USER_TIMER_EVENT_LED_MODE_FLICKER); 

				OSD_LED_CONTRL(_OSD_LED_ON);

			}
			else if(GET_OSD_LED_TYPE() == _OSDLedType_FLASH)
			{
				ScalerTimerActiveTimerEvent(SEC(0.5), _USER_TIMER_EVENT_LED_MODE_FLICKER); 
				
			}
			break;
			
		case _MENU_FUN_POWER_OFF:
		
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _AutoPowerOff_END, _AutoPowerOff_OFF, _ON));
			SET_OSD_AUTO_POWEROFF(g_usAdjustValue);
				break;
            case _MENU_FUN_LOWBLUE: 
                g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , 3, _OFF, _ON));
//                if(g_usAdjustValue = 0)
//                    SET_OSD_LOW_BLUE(0);
//                else if(g_usAdjustValue = 1)
//                    SET_OSD_LOW_BLUE(33);
//                else if(g_usAdjustValue = 2)
//                    SET_OSD_LOW_BLUE(66);
//                else if(g_usAdjustValue = 3)
//                    SET_OSD_LOW_BLUE(100);
                SET_OSD_LOW_BLUE(g_usAdjustValue);
#if(_DEF_COLORFUL)
                UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
                UserAdjustContrast(GET_OSD_CONTRAST()); 
#endif

                SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_OSDUSERDATA_MSG);
                break;  
		
		case _MENU_FUN_OD:
#if(_OD_WEAK_MID_HIGH)
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , 3, _OFF, _ON));
#else
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _ON, _OFF, _ON));
#endif

			SET_OSD_OD_STATUS(g_usAdjustValue); 		
#if(_OD_SUPPORT == _ON)
			ScalerODEnable(GET_OSD_OD_STATUS());

#if(_OD_WEAK_MID_HIGH)
			if(GET_OSD_OD_STATUS() == 1)
			{
				SET_OSD_OD_GAIN(_OD_WEAK);

			}
			else if(GET_OSD_OD_STATUS() == 2)
			{
				SET_OSD_OD_GAIN(_OD_MID);

			}
			else if(GET_OSD_OD_STATUS() == 3)
			{
				SET_OSD_OD_GAIN(_OD_STRONG);

			}
			ScalerODAdjustDeltaGain(GET_OSD_OD_GAIN());
#endif
#endif
			break;
		#if _FREESYNC_SUPPORT
		case _MENU_FUN_FREESYNC:
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _ON, _OFF, _ON));
			SET_OSD_FREE_SYNC_STATUS(g_usAdjustValue);
			break;
		#endif
		
		case _MENU_FUN_AUDOIMUTE:
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _ON, _OFF, _ON));
			SET_OSD_VOLUME_MUTE(g_usAdjustValue);
			UserAdjustAudioMuteSwitch();
			break;

		case _MENU_FUN_HOTLEFT:
			g_usAdjustValue = (BYTE)(DetOverRangeForHotkeySelect(g_usAdjustValue , _MENU_HOT_KEY_FUNC- _MENU_FUN_BACKLIGHT-1, 0, _ON));
			SET_OSD_HOTKEY_LEFT(g_usAdjustValue);
			break;

		case _MENU_FUN_HOTRIGHT:
			g_usAdjustValue = (BYTE)(DetOverRangeForHotkeySelect(g_usAdjustValue , _MENU_HOT_KEY_FUNC- _MENU_FUN_BACKLIGHT-1, 0, _ON));
			SET_OSD_HOTKEY_RIGHT(g_usAdjustValue);
			break;

    	
        case _MENU_FUN_CROSS:
            g_usAdjustValue = (BYTE)(OsdDisplayDetOverRange(g_usAdjustValue , _ON, _OFF, _ON));
            SET_OSD_CROSS_STATUS(g_usAdjustValue);
            RTDNVRamSaveOSDData();
            break;
		case _MENU_FUN_SIGNAL:	
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _OSD_INPUT_AMOUNT-1, 0, _ON));
			SET_OSD_INPUT_PORT_OSD_ITEM(g_usAdjustValue);
			break;
				
#if(_VGA_SUPPORT == _ON)

		case _MENU_FUN_AUTO_ADJUST:
			if((SysModeGetModeState() == _MODE_STATUS_ACTIVE)&& (SysSourceGetSourceType() == _SOURCE_VGA))
			{
				SET_OSD_EVENT_MESSAGE(_OSDEVENT_DO_AUTO_CONFIG_MSG);
			}
			break;
		
		case _MENU_FUN_AUTO_COLOR:
			if((SysModeGetModeState() == _MODE_STATUS_ACTIVE)&& (SysSourceGetSourceType() == _SOURCE_VGA))
			{
				OsdDisplayAutoBalanceProc();
			}
			break;	
#endif
		case _MENU_FUN_RESET:
			OsdDispOsdReset();
			break;

		case _MENU_FUN_LANGUAGE:
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _LANGUAGE_AMOUNT, 0, _ON));
			SET_OSD_LANGUAGE(g_usAdjustValue);			
			break;
			
		case _MENU_FUN_FLICKER_FREE:
			
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _ON, _OFF, _ON));
			SET_OSD_FLICKER_FREE_STATUS(g_usAdjustValue);
			ScalerMcuPwmAdjustFrequency(_BACKLIGHT_PWM, GET_OSD_FLICKER_FREE_STATUS()? 20000: (((DWORD)_PANEL_TYP_FRAME_RATE * 160) / 100));
			break;
			
		case _MENU_FUN_MPRT:
			
			g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , _ON, _OFF, _ON));
			SET_OSD_MPRT(g_usAdjustValue);



			#if(_CAIXIAOLI)
			PCB_BACKLIGHT_POWER(_LIGHT_CONTROL_OFF);
			PCB_BACKLIGHT_POWER(_LIGHT_CONTROL_ON);
			#endif


			
#if(_MPRT_SUPPORT == _ON)
			
			if(GET_OSD_MPRT())
			{
				UserAdjustLowMotionBlurDisplay(GET_OSD_MPRT());
	
			}
			else
			{
				PCB_BACKLIGHT_POWER(_LIGHT_CONTROL_OFF);
				UserAdjustLowMotionBlurDisplay(GET_OSD_MPRT());
				ScalerTimerActiveTimerEvent(SEC(0.1), _USER_TIMER_EVENT_MPRT);
			}
	
			 
			  SET_OSD_OD_STATUS(g_usAdjustValue);		  
#if(_OD_SUPPORT == _ON)
			  ScalerODEnable(GET_OSD_OD_STATUS());
#endif		
#endif
			break;


		case _MENU_FUN_GAMMA:
		   g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,_GAMMA_26,_GAMMA_OFF,_ON);
		   
		   SET_OSD_GAMMA(g_usAdjustValue);
	
    if(GET_OSD_GAMMA() != _GAMMA_OFF||_TJ_GAMMA)
			{
				UserAdjustGamma(GET_OSD_GAMMA());
				ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
				UserCommonAdjustGammaRegionEnable(_FUNCTION_ON);
			}
			else
			{
				UserCommonAdjustGammaRegionEnable(_FUNCTION_OFF);
	
			}
		 break;

		case _MENU_FUN_COLORGAMUT:
#if(_OCC_SUPPORT == _ON)
			g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,_PCM_OSD_NATIVE,_PCM_OSD_SRGB,_ON);
			SET_OSD_PCM_STATUS(g_usAdjustValue);
			OsdFuncColorPcmAdjust();
#endif

		break;

		case _MENU_FUN_FV_INFORMATION:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRange(g_usAdjustValue , _ON, _OFF, _ON);
			SET_OSD_FV_INFORMATION(g_usAdjustValue);
#if(_DEF_REAL_TIME_HZ)
			if(GET_OSD_FV_INFORMATION())
				SET_OSD_HZ_DISPLAYSTATUS((GET_OSD_HZ_DISPLAYSTATUS()|_BIT1));
#endif
			break;

		case _MENU_FUN_OVERCLOCK:
			g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,_ON,_OFF,_ON);
			SET_OSD_OVERCLOCK(g_usAdjustValue);

		break;

	}

	OSD_fun_hot_num = OSD_SubMenuCur;
	UpdateItemMaskValue();
	OSD_SubMenuCur = OSD_fun_hot_num;
	RTDNVRamSaveOSDData();
}
