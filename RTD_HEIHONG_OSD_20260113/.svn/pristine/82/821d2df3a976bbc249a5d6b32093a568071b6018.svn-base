				g_ucHotKey_Left = g_usAdjustValue/_PAGE_MAX_LANGUAGE_COUNT;
				for(i=0; i<_HENG_COUNT; i++)
					OsdFuncClearOsd(ROW(_ITEM_1_ROW+i*2), COL(_ITEM_3_COL), WIDTH(_ITEM_COL_LENGTH), HEIGHT(1));
				for(i=_PAGE_MAX_LANGUAGE_COUNT*g_ucHotKey_Left; i<(g_ucHotKey_Left+1)*_PAGE_MAX_LANGUAGE_COUNT; i++ )				
				{
					RTDOsdTableFuncPutStringProp(_ITEM_1_ROW+(i%_PAGE_MAX_LANGUAGE_COUNT)*2, _ITEM_3_COL, _PFONT_PAGE_2, _MENU_FUN_HOT_REPLACE_LEFT,	i, COLOR(_COLOR_MENU_FONT, _CP_BG),  GET_OSD_LANGUAGE());
					if(i==11)
						break;
				}
			}
			break;

		case _MENU_FUN_HOT_REPLACE_RIGHT:
			g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,11,_OFF,_ON);
			SET_OSD_HOT_REPLACE_RIGHT(g_usAdjustValue);
			if(g_ucHotKey_Right !=g_usAdjustValue/_PAGE_MAX_LANGUAGE_COUNT)
			{
				g_ucHotKey_Right = g_usAdjustValue/_PAGE_MAX_LANGUAGE_COUNT;
				for(i=0; i<_HENG_COUNT; i++)
					OsdFuncClearOsd(ROW(_ITEM_1_ROW+i*2), COL(_ITEM_3_COL), WIDTH(_ITEM_COL_LENGTH), HEIGHT(1));
				for(i=_PAGE_MAX_LANGUAGE_COUNT*g_ucHotKey_Right; i<(g_ucHotKey_Right+1)*_PAGE_MAX_LANGUAGE_COUNT; i++ ) 				
				{
					RTDOsdTableFuncPutStringProp(_ITEM_1_ROW+(i%_PAGE_MAX_LANGUAGE_COUNT)*2, _ITEM_3_COL, _PFONT_PAGE_2, _MENU_FUN_HOT_REPLACE_RIGHT,	i, COLOR(_COLOR_MENU_FONT, _CP_BG),  GET_OSD_LANGUAGE());
					if(i==11)
						break;
				}
			}
			break;

		case _MENU_FUN_HOT_REPLACE_EXIT:
			g_usAdjustValue = OsdDisplayDetOverRangeSelect(g_usAdjustValue,11,_OFF,_ON);
			SET_OSD_HOT_REPLACE_EXIT(g_usAdjustValue);
			if(g_ucHotKey_Exit!=g_usAdjustValue/_PAGE_MAX_LANGUAGE_COUNT)
			{
				g_ucHotKey_Exit = g_usAdjustValue/_PAGE_MAX_LANGUAGE_COUNT;
				for(i=0; i<_HENG_COUNT; i++)
					OsdFuncClearOsd(ROW(_ITEM_1_ROW+i*2), COL(_ITEM_3_COL), WIDTH(_ITEM_COL_LENGTH), HEIGHT(1));
				for(i=_PAGE_MAX_LANGUAGE_COUNT*g_ucHotKey_Exit; i<(g_ucHotKey_Exit+1)*_PAGE_MAX_LANGUAGE_COUNT; i++ )				
				{
					RTDOsdTableFuncPutStringProp(_ITEM_1_ROW+(i%_PAGE_MAX_LANGUAGE_COUNT)*2, _ITEM_3_COL, _PFONT_PAGE_2, _MENU_FUN_HOT_REPLACE_EXIT,	i, COLOR(_COLOR_MENU_FONT, _CP_BG),  GET_OSD_LANGUAGE());
					if(i==11)
						break;
				}
			}
			break;
#endif









		

	}
    DebugMessageOsd("_MENU_FUN_LANGUAGE3",OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);
#if(_DEF_PAGE8)
		OSD_PAGE_2 = OSD_SubMenuCur;
#endif
        UpdateItemMaskValue();
        DebugMessageOsd("_MENU_FUN_LANGUAGE4",OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);

		UpdateMaskValue();
        DebugMessageOsd("_MENU_FUN_LANGUAGE5",OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);
#if(_DEF_PAGE8)
		OSD_SubMenuCur = OSD_PAGE_2;
#endif
		
		RTDNVRamSaveOSDData();
DebugMessageOsd("_MENU_FUN_LANGUAGE6",OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);
}



