					 }
					 else if(g_usAdjustValue == _OSD_ROTATE_DEGREE_180)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_270;
					 }	 
					 else if(g_usAdjustValue == _OSD_ROTATE_DEGREE_270)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_0;
					 }
					 
					 break;
				 case _RIGHT_KEY_MESSAGE:
				 
					 if(g_usAdjustValue == _OSD_ROTATE_DEGREE_0)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_270;
					 }
					 else if(g_usAdjustValue == _OSD_ROTATE_DEGREE_270)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_180;
					 }						 
					 else if(g_usAdjustValue == _OSD_ROTATE_DEGREE_180)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_90;
					 }						 
					 else if(g_usAdjustValue == _OSD_ROTATE_DEGREE_90)
					 {
						 g_usAdjustValue = _OSD_ROTATE_DEGREE_0;
					 }
			 
					 
					 break;
			 
				 default:
					 break;
			 }
			 
             g_ucOsdRorateState = (g_usAdjustValue);

