void OsdFuncAdj(void)
{
#if(_DEF_STA_SIX_COLOR || _DEF_HOTKEY_REPLACE)
	BYTE i = 0;
#endif
#if(_DEF_PAGE8)
	BYTE OSD_PAGE_2 = 0;
#endif
    DebugMessageOsd("OsdFuncAdj",OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);

	g_usAdjustValue = GetOsdValue(OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur]);

	switch(OsdStateDefine[OSD_MAIN_MENU_ITEM][OSD_SubMenuCur])
	{ 
		case _MENU_FUN_ECO:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _COLOREFFECT_AMOUNT, _COLOREFFECT_STANDARD, _ON);
			SET_OSD_COLOR_EFFECT(g_usAdjustValue);
			if((GET_OSD_COLOR_EFFECT()!= _COLOREFFECT_STANDARD))
			{
				SET_OSD_DCR_STATUS(_OFF);
			}	
			
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
			UserAdjustContrast(GET_OSD_CONTRAST());
			UserAdjustBrightness(GET_OSD_BRIGHTNESS());
			
#if(_DEF_ECO_SET)
			//UserInterfaceAdjustUltraVivid();
			UserCommonAdjustSharpness(SysSourceGetInputPort());			
			UserAdjustGlobalHueSat((SWORD)GET_OSD_HUE(),GetOsdValue(_MENU_FUN_SATURATION)); //GetSaturationValue());
#endif

#if(_DEF_STA_SIX_COLOR)
			ScalerColorICMEnable(_FUNCTION_ON);//�޸���ɫ����ʧЧ
			for(i = 0; i < 6; i++)
			{
				SET_OSD_SIX_COLOR(i);
				OsdDisplaySixColorGetOneColor(i);
				ScalerColorSixColorAdjust(i, GET_OSD_SIX_COLOR_HUE(), GET_OSD_SIX_COLOR_SATURATION());
			}
#endif



#if(_GLOBAL_HUE_SATURATION == _ON && _DEF_COLORFUL)
			UserAdjustGlobalHueSat((SWORD)GET_OSD_HUE(), GET_OSD_SATURATION());
#endif

#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
			UserAdjustColorEffectMode();
#endif
				break;
		
#if(_LED_EFFECT_TJMODE14)
                    
            case _MENU_FUN_LIGHTMODE:
                g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(GET_OSD_LED_LIGHTMODE() , LightMode_END, LightMode_OFF, _ON);
                SET_OSD_LED_LIGHTMODE(g_usAdjustValue);
                SET_OSD_LED_PRE_LIGHTMODE(g_usAdjustValue);
    
           //     SysModeSetResetTarget(_MODE_ACTION_RESET_TO_DISPLAY_SETTING);
                led_start = 1;  //������Ч
                
                ScalerTimerDelayXms(150);// 50 30


    
                break;
    
    
    
            case _MENU_FUN_COLOR:
                g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(GET_OSD_LED_COLOR() , LightColorMode_END, LightColorMode_Spectrum, _ON));
                SET_OSD_LED_COLOR(g_usAdjustValue);
                SET_OSD_LED_PRE_COLOR(g_usAdjustValue);
    
          //    SysModeSetResetTarget(_MODE_ACTION_RESET_TO_DISPLAY_SETTING);
                led_start = 1;  //������Ч
                ScalerTimerDelayXms(150);// 50 30
    

              break;
#endif
        case _MENU_FUN_LOWBLUE: 
            g_usAdjustValue = (BYTE)(OsdDisplayDetOverRangeSelect(g_usAdjustValue , 3, _OFF, _ON));
//                if(g_usAdjustValue = 0)
//                    SET_OSD_LOW_BLUE(0);
//                else if(g_usAdjustValue = 1)
//                    SET_OSD_LOW_BLUE(33);
//                else if(g_usAdjustValue = 2)
//                    SET_OSD_LOW_BLUE(66);
//                else if(g_usAdjustValue = 3)
//                    SET_OSD_LOW_BLUE(100);
            SET_OSD_LOW_BLUE(g_usAdjustValue);
#if(_DEF_COLORFUL)
            UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
            UserAdjustContrast(GET_OSD_CONTRAST()); 
#endif

            SET_OSD_EVENT_MESSAGE(_OSDEVENT_SAVE_NVRAM_OSDUSERDATA_MSG);
            break;  
		case _MENU_FUN_DCR:
			
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _ON, _OFF, _ON);
			SET_OSD_DCR_STATUS(g_usAdjustValue);
#if(_DEF_ECO_SET)
			if(GET_OSD_DCR_STATUS())
			{
				SET_OSD_DCROFF_ECO(GET_OSD_COLOR_EFFECT());
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);
			}
			else
			{
				SET_OSD_COLOR_EFFECT(GET_OSD_DCROFF_ECO());
			}	
			
			UserAdjustBacklight(GET_OSD_BACKLIGHT());

#if(_DEF_COLORFUL)
			UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
			UserAdjustContrast(GET_OSD_CONTRAST());
#endif
			UserAdjustBrightness(GET_OSD_BRIGHTNESS());
#if(_ULTRA_VIVID_SUPPORT == _ON)
			UserInterfaceAdjustUltraVivid();
#endif
			UserCommonAdjustSharpness(SysSourceGetInputPort());			
			UserAdjustGlobalHueSat((SWORD)GET_OSD_HUE(), GetOsdValue(_MENU_FUN_SATURATION)); //GetSaturationValue());
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
			UserAdjustColorEffectMode();
#endif

#else
			
			if(GET_OSD_DCR_STATUS() != _OFF)
			{
				SET_OSD_COLOR_EFFECT(_COLOREFFECT_STANDARD);

#if(_DEF_COLORFUL)
				UserAdjustContrast(GetOsdValue(_MENU_FUN_CONTRAST));
#else
				UserAdjustContrast(GET_OSD_CONTRAST());
#endif

				UserAdjustBrightness(GET_OSD_BRIGHTNESS()); 
#if((_DCC_FUNCTION == _ON) || (_ICM_SUPPORT == _ON) || (_SCM_SUPPORT == _ON) || (_SIX_COLOR_SUPPORT == _ON))    
				UserAdjustColorEffectMode();
#endif
			}	
			UserAdjustBacklight(GET_OSD_BACKLIGHT());
#endif
			break;
		
		case _MENU_FUN_HDR:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _HDR10_MODE_AUTO, _HDR10_MODE_OFF, _ON);	//UserCommonHDRGetHDR10Status	
			SET_OSD_HDR_MODE(g_usAdjustValue);
			
			//��������HDR����HDRģʽΪǿ��
#if(_HDR10_SUPPORT == _ON)
			if(((GET_OSD_HDR_MODE() == _HDR10_MODE_AUTO)&&(GET_HDR10_EOTF_SETTING() == _HDR_TARGET_STATUS_SMPTE_ST_2084))||(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084))
#else
			if(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084)
#endif
			{
				OsdHdrAdj();
			}
			UserAdjustBacklight(GET_OSD_BACKLIGHT());

			
#if(_HDR10_SUPPORT == _ON)

#if(_DEF_HDR_COLOR_6432)

			if(((GET_OSD_HDR_MODE() == _HDR10_MODE_AUTO)&&(GET_HDR10_EOTF_SETTING() == _HDR_TARGET_STATUS_SMPTE_ST_2084))||(GET_OSD_HDR_MODE() == _HDR10_MODE_FORCE_2084))
			{
				UserCommonInterfacePanelPowerAction(_BACKLIGHT_OFF);

				
				ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
				UserCommonHDRAdjust(_HDR_FLOW_OSD_MODE_CHANGE);
				UserCommonHDR10SupportSwitch(); 

				
				UserCommonInterfacePanelPowerAction(_BACKLIGHT_ON);
			}
			else
			{
				ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
				UserCommonHDRAdjust(_HDR_FLOW_OSD_MODE_CHANGE);
				UserCommonHDR10SupportSwitch(); 
			}
										




#else
			ScalerTimerWaitForEvent(_EVENT_DEN_STOP);
			UserCommonHDRAdjust(_HDR_FLOW_OSD_MODE_CHANGE);
			UserCommonHDR10SupportSwitch(); 

#endif	//(_DEF_HDR_COLOR_6432)



#endif	





#if((_HDR10_SUPPORT == _OFF)&&(_PROJECT == _RL6463_PROJECT))
			MockHdrEffect();
#endif

			break;

		case _MENU_FUN_DDCCI:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRange(g_usAdjustValue, _ON, _OFF, _ON);
			SET_OSD_DDCCI_STATUS(g_usAdjustValue);
			break;
			
		case _MENU_FUN_FV_INFORMATION:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRange(g_usAdjustValue , _ON, _OFF, _ON);
			SET_OSD_FV_INFORMATION(g_usAdjustValue);
#if(_DEF_REAL_TIME_HZ)
			if(GET_OSD_FV_INFORMATION())
				SET_OSD_HZ_DISPLAYSTATUS((GET_OSD_HZ_DISPLAYSTATUS()|_BIT1));
#endif
			break;
					

		case _MENU_FUN_VIVID:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _ULTRA_VIVID_AMOUNT, _ULTRA_VIVID_OFF, _ON);			
			SET_OSD_ULTRA_VIVID_STATUS(g_usAdjustValue);

#if(_ULTRA_VIVID_SUPPORT == _ON)
			UserInterfaceAdjustUltraVivid();
#endif
				break;

		case _MENU_FUN_AUDIO_SOURCE:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 2, _OFF, _ON);
			SET_FUN_AUDIO_SOURCE(g_usAdjustValue);
			break;

		case _MENU_FUN_CHAOPING_TISHI:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _ON, _OFF, _ON);
			SET_FUN_OVERCLOCK_HINT(g_usAdjustValue);
			break;

#if(_DEF_STA_SIX_COLOR)
		case _MENU_FUN_SAT_STATE:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 5, _OFF, _ON);
			SET_SAT_STATE(g_usAdjustValue);
			break;

		case _MENU_FUN_HUE_STATE:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 5, _OFF, _ON);
			SET_HUE_STATE(g_usAdjustValue);
			break;
#endif

		case _MENU_FUN_KVM:
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, 2, _OFF, _ON);
			SET_FUN_KVM(g_usAdjustValue);

#if(_DEF_2795E06)
			if(GET_FUN_KVM() == _OFF)//�Զ�
			{
				if(SysSourceGetInputPort()== _D0_INPUT_PORT )
				  HUB_SWITCH(0);
				else
				  HUB_SWITCH(1);
			}
			else
			{
				if(GET_FUN_KVM() == 1)	//PC
					HUB_SWITCH(1);
				else if(GET_FUN_KVM() == 2)	//Type-c
					HUB_SWITCH(0);
				else
					HUB_SWITCH(0);
			}
#endif
			break;
				
		case _MENU_FUN_ASPECT:
		
			g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _OSD_ASPECT_RATIO_AMOUNT, 0, _ON);			
			SET_OSD_ASPECT_RATIO_TYPE(g_usAdjustValue);
// Set Backlight OFF to prevent garbage
#if(_PANEL_TYPE==_AUO_M270HVR01_0_LVDS_FHD_144 )
   		 	UserCommonInterfacePanelPowerAction(_BACKLIGHT_OFF);
#endif

#if 0//
			UserCommonInterfacePanelPowerAction(_PANEL_OFF);
#endif

#if(_DEF_SCREEN_SWITCHING)	//�л�����������
			UserCommonInterfacePanelPowerAction(_PANEL_OFF);
#endif

			SysModeSetResetTarget(_MODE_ACTION_RESET_TO_DISPLAY_SETTING);
				break;
		
		case _MENU_FUN_COLORTEMP:
#if(_DEF_CT_JX)
			if(g_usAdjustValue >= _CT_GAMMA18 && g_usAdjustValue <= _CT_GAMMA26)
			{
				g_usAdjustValue = _CT_USER;
			}
#endif
			if(_CT_7500_5800_sRGB_SUPPRT)
			{
				g_usAdjustValue = (BYTE)OsdDisplayDetOverRangeSelect(g_usAdjustValue, _CT_USER, _CT_9300, _ON);
			}
			else
			{
			    switch(GET_KEYMESSAGE())
				{
#if(_DEF_CT_JX)
					case _LEFT_KEY_MESSAGE:
						if(g_usAdjustValue == _CT_USER)
						{
							g_usAdjustValue = _CT_9300;
						}
						else if(g_usAdjustValue == _CT_9300)
						{
							g_usAdjustValue = _CT_8000;
						}
						else if(g_usAdjustValue == _CT_8000)
						{
							g_usAdjustValue = _CT_7500;
						}
						else if(g_usAdjustValue == _CT_7500)
						{
							g_usAdjustValue = _CT_7000;
						}	
						else if(g_usAdjustValue == _CT_7000)
						{
							g_usAdjustValue = _CT_6500;
						}						
						else if(g_usAdjustValue == _CT_6500)
						{
							g_usAdjustValue = _CT_5800;
						}
						else if(g_usAdjustValue == _CT_5800)
						{
							if(GET_OSD_GAMMA())
							{
								if(GET_OSD_GAMMA() == _GAMMA_18)
								{
									g_usAdjustValue = _CT_GAMMA18;
								}
								else if(GET_OSD_GAMMA() == _GAMMA_20)
								{
									g_usAdjustValue = _CT_GAMMA20;
								}
								else if(GET_OSD_GAMMA() == _GAMMA_22)
