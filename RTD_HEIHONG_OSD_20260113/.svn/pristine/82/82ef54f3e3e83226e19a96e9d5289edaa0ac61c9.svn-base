                  memcpy(&stMultiFunction, &tSMBusWrCmdSetDPMultiFunction[0], tSMBusWrCmdSetDPMultiFunction[0].ucDataLen
             -gth + 2);
              
                  // Only UFP Shoud Set Multi Function Preferred Bit
                  // BIT[7:5] Reserved, BIT[6] : Exit Mode, BIT[5] USB Config Req, BIT[4] Multi-Function, BIT[3] DP Enab
             -le, BIT[2] Power Low, BIT[1:0] Connect Status (b'10 UFP_D Connected)
                  if((GET_TYPE_C_5400_DATA_ROLE(ucInputPort) == _TYPE_C_UFP_U) && (enumMultiFunction == _TYPE_C_MULTI_FU
             -NC_PREFER))
                  {
                      // Set to Multifunction Prefer
                      stMultiFunction.ucDPCapVDOByte0 = 0x1A;
                  }
                  else
