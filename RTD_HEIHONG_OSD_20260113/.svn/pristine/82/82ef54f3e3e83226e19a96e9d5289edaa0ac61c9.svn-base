                      // RTS SMBUS Cmd Type Macro Reset
                      SET_TYPE_C_5400_SMBUS_CMD_TYPE(ucInputPort, _GET_5400_NONE);
              
                      DebugMessageSystem("8. IIC Write Command to 5400 Fail", 0);
              
