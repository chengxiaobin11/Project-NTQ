              #endif
              
                      case _GET_5400_DATA_ROLE:
              
                          if(((g_unSMBusRdDataPool.stRdGetStatus.ucByte10_DFP_UFP & (_BIT2 | _BIT1 | _BIT0)) == _BIT2) |
             -| ((g_unSMBusRdDataPool.stRdGetStatus.ucByte10_DFP_UFP & (_BIT2 | _BIT1 | _BIT0)) == _BIT1))
                          {
