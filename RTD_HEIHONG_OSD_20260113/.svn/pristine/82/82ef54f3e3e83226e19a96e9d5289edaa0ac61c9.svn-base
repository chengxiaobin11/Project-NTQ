                              *pucReadInfo = _TYPE_C_UNATTACH;
                          }
              
                          break;
              
                      case _GET_5400_ALT_MODE_READY:
              
                          if((g_unSMBusRdDataPool.stRdGetStatus.ucByte13_AltModeStatus & 0x07) == 0x06)
                          {
                              *pucReadInfo = _TYPE_C_ALT_MODE_READY;
