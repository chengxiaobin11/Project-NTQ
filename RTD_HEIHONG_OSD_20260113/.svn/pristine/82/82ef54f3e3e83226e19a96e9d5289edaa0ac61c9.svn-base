             -) << 7) | ((pucGetData1st[ucIndex * 4 + 4] & 0xFE) >> 1)));
                          SET_TYPE_C_5400_SRC_CAP_VOL_MIN(ucInputPort, ucIndex, pucGetData1st[ucIndex * 4 + 3]);
