 451          BYTE ScalerMcuDdcciIntGetData_EXINT1(BYTE *pucReadArray) using 2
 452          {
 453   1          BYTE ucDdcciCmdLength = 0;
 454   1      
 455   1          // Get DDC-CI Source Address
 456   1          if((MCU_FF27_IIC_STATUS & _BIT1) == _BIT1)
 457   1          {
 458   2              g_ucDdcciCountEXINT = 0;
 459   2      
 460   2              // Save Address
 461   2              pucReadArray[g_ucDdcciCountEXINT++] = MCU_FF24_IIC_SUB_IN;
 462   2      
 463   2              // Clear Flag
 464   2              MCU_FF27_IIC_STATUS &= ~_BIT1;
 465   2          }
 466   1      
 467   1          if((MCU_FF27_IIC_STATUS & _BIT2) == _BIT2)
 468   1          {
 469   2              // Save received data until buffer empty
 470   2              while((MCU_FF29_IIC_STATUS2 & _BIT1) == 0)
 471   2              {
 472   3                  if(g_ucDdcciCountEXINT >= _DDCCI_RXBUF_LENGTH)
 473   3                  {
 474   4                      // Reset data buffer
 475   4                      MCU_FF2A_IIC_IRQ_CONTROL2 |= _BIT6;
 476   4      
 477   4                      g_ucDdcciCountEXINT = 0;
C51 COMPILER V9.60.0.0   SCALERCOMMONMCU                                                   10/18/2025 16:25:25 PAGE 9   

 478   4      
 479   4                      break;
 480   4                  }
 481   3      
 482   3                  pucReadArray[g_ucDdcciCountEXINT++] = MCU_FF25_IIC_DATA_IN;
 483   3      
 484   3      #if(_SMBUS_BLOCK_READ_WRITE_COMMAND_SUPPORT == _ON)
                          // smbus
