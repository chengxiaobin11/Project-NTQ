 515   7                                  {
 516   8                                      MCU_FF26_IIC_DATA_OUT = g_pucDdcciTxBuf[pData_EXINT[0]++];
 517   8                                  }
 518   7                              }
 519   6                          }
 520   5                      }
 521   4                      else
 522   4                      {
 523   5                          for(pData_EXINT[0] = 32; pData_EXINT[0] > 0; pData_EXINT[0] --)
 524   5                          {
 525   6                              MCU_FF26_IIC_DATA_OUT = 0;
 526   6                          }
 527   5      
 528   5                          if(ucDdcciCmdLength <= sizeof(g_pucDdcciRxBackBuf))
 529   5                          {
 530   6                              memcpy(g_pucDdcciRxBackBuf, pucReadArray, ucDdcciCmdLength);
 531   6      
 532   6                              g_ucDdcciCmdLengthBack = ucDdcciCmdLength;
 533   6                          }
 534   5                          else
 535   5                          {
