 201          //--------------------------------------------------
 202          // Description  : Cache Control
 203          // Input Value  : bControl
 204          // Output Value : None
 205          //--------------------------------------------------
 206          void ScalerMcuCacheControl(bit bControl)
 207          {
 208   1          if(bControl == _ENABLE)
 209   1          {
 210   2              // Enable Cache
 211   2              MCU_FDA0_CACHE_FUNCTION |= _BIT0;
 212   2          }
 213   1          else
 214   1          {
 215   2              // Disable Cache
 216   2              MCU_FDA0_CACHE_FUNCTION &= ~_BIT0;
 217   2          }
 218   1      }
 219          
 220          //--------------------------------------------------
 221          // Description  : Send DDC Data
 222          // Input Value  : pWriteArray --> Data to be sent
 223          //                usTimeOutCnt --> Timeout
 224          // Output Value : None
 225          //--------------------------------------------------
 226          void ScalerMcuDdcciSendData(BYTE *pucWriteArray)
 227          {
 228   1          WORD usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 229   1          BYTE ucDdcciCount = 0;
C51 COMPILER V9.60.0.0   SCALERCOMMONMCU                                                   10/18/2025 16:25:25 PAGE 5   

 230   1      
 231   1          if((MCU_FF27_IIC_STATUS & _BIT0) == _BIT0)
 232   1          {
 233   2              g_bSrcReadDdcciAlready = _TRUE;
 234   2      
 235   2              // Clear Flag
 236   2              MCU_FF27_IIC_STATUS &= ~_BIT0;
 237   2          }
 238   1      
 239   1          // Enable mcu write
 240   1          MCU_FF2A_IIC_IRQ_CONTROL2 |= (_BIT6 | _BIT5);
 241   1      
 242   1      #if(_SMBUS_BLOCK_READ_WRITE_COMMAND_SUPPORT == _ON)
                  if(GET_SMBUS_BLOCK_RW_STATUS() == _TRUE)
                  {
                      MCU_FF26_IIC_DATA_OUT = g_stSmbusBlockRWCmd.ucDataLen;
                  }
              #endif
 248   1      
 249   1          while(ucDdcciCount < ((pucWriteArray[_DDCCI_LENGTH] & 0x7F) + 3))
 250   1          {
 251   2              // Load data to DDC-CI buffer until buffer full
 252   2              if((MCU_FF29_IIC_STATUS2 & _BIT2) == 0)
 253   2              {
 254   3                  MCU_FF26_IIC_DATA_OUT = pucWriteArray[ucDdcciCount++];
 255   3      
 256   3                  usTimeOutCnt = _DDCCI_TIMEOUT_LIMIT;
 257   3              }
 258   2              else
 259   2              {
 260   3                  ScalerTimerDelayXms(2);
 261   3      
 262   3                  usTimeOutCnt--;
 263   3              }
 264   2      
 265   2              if(usTimeOutCnt == 0)
 266   2              {
 267   3                  break;
 268   3              }
 269   2          }
 270   1      
 271   1          // Disable mcu write
 272   1          MCU_FF2A_IIC_IRQ_CONTROL2 &= ~_BIT5;
 273   1      }
 274          
