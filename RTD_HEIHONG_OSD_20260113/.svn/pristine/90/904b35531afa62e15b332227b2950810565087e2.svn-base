                          if((g_ucDdcciCountEXINT == 2) && ((pucReadArray[_DDCCI_LENGTH] & (_BIT7 | _BIT6 | _BIT5)) == 0
             -x00))
                          {
                              // Ignore SMBUS byte count.
                              g_ucDdcciCountEXINT--;
                          }
              #endif
 493   3      
 494   3                  ucDdcciCmdLength = (pucReadArray[_DDCCI_LENGTH] & 0x7F) + 3;
 495   3      
 496   3                  // All data are received
 497   3                  if(ucDdcciCmdLength == g_ucDdcciCountEXINT)
 498   3                  {
 499   4                      // Reset data buffer and Enable mcu write
 500   4                      MCU_FF2A_IIC_IRQ_CONTROL2 |= (_BIT6 | _BIT5);
 501   4      
 502   4                      g_ucDdcciCountEXINT = 0;
 503   4      
 504   4                      if((g_bSrcReadDdcciAlready == _TRUE) && (ucDdcciCmdLength <= sizeof(g_pucDdcciRxBackBuf)) 
             -&& (ucDdcciCmdLength == g_ucDdcciCmdLengthBack) && (memcmp(g_pucDdcciRxBackBuf, pucReadArray, ucDdcciCmdLength) == 0))
 505   4                      {
 506   5                          BYTE ucPreTxLength = (g_pucDdcciTxBuf[_DDCCI_LENGTH] & 0x7F) + 3;
 507   5      
 508   5                          if(ucPreTxLength <= _DDCCI_TXBUF_LENGTH)
 509   5                          {
 510   6                              pData_EXINT[0] = 0;
 511   6                              while(pData_EXINT[0] < ucPreTxLength)
 512   6                              {
