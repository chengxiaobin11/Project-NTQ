  17          #define __SCALER_COMMON_FW_INFO__
  18          #include "ScalerCommonFunctionInclude.h"
  19          
  20          #if(_CUSTOMER_FW_VERSION_SUPPORT == _ON)
              
              
              //****************************************************************************
              // DEFINITIONS / MACROS
              //****************************************************************************
              
              //****************************************************************************
              // STRUCT / TYPE / ENUM DEFINITTIONS
              //****************************************************************************
              
              
              //****************************************************************************
              // CODE TABLES
              //****************************************************************************
              BYTE code tFwVersionTable[] =
              {
                  _CUSTOMER_FW_VERSION,
                  _CUSTOMER_FW_SUB_VERSION,
              };
              
              //****************************************************************************
              // VARIABLE DECLARATIONS
              //****************************************************************************
              
              //****************************************************************************
