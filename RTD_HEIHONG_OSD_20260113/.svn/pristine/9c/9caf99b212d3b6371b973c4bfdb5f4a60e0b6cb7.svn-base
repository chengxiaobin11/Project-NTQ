 419          #if(_D0_DP_EXIST == _ON)
 420          //--------------------------------------------------
 421          // Description  : Initial D0 DP audio setting
 422          // Input Value  : None
 423          // Output Value : None
 424          //--------------------------------------------------
 425          void ScalerAudioD0DPAudioInitial(void)
 426          {
 427   1          ScalerAudioD0SetAudioPLL();
 428   1      
 429   1          // Disable Check VBID[4] to Mute Audio by HW and disable Audio FSM
 430   1          ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~(_BIT7 | _BIT1), 0x00);
 431   1      
 432   1          // Disable AFD, set 2ms for auto freq. detect and disable 44.1kHz as 48kHz
 433   1          ScalerSetBit(PB6_50_AUD_FREQUENY_DET_0, ~(_BIT7 | _BIT3 | _BIT2 | _BIT0), _BIT2);
 434   1      
 435   1          // Set threshold to separate sampling frequency
 436   1          ScalerSetByte(PB6_52_AUD_FREQUENY_TH_0, 0x00);
 437   1          ScalerSetByte(PB6_53_AUD_FREQUENY_TH_1, 0x00);
 438   1          ScalerSetByte(PB6_54_AUD_FREQUENY_TH_2, 0x28);
 439   1          ScalerSetByte(PB6_55_AUD_FREQUENY_TH_3, 0x4C);
 440   1          ScalerSetByte(PB6_56_AUD_FREQUENY_TH_4, 0x5C);
 441   1          ScalerSetByte(PB6_57_AUD_FREQUENY_TH_5, 0x70);
 442   1      
 443   1          // Enable RS Decode
 444   1          ScalerSetBit(PB6_2B_MN_RS_DEC_CTRL, ~(_BIT7 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT7 | _BIT3 | _BIT2 |
             - _BIT1 | _BIT0));
 445   1      
 446   1          // Set xtal divider for sampling freq. detection
 447   1          ScalerSetByte(PB6_51_AUD_FREQUENY_DET_1, _AUTO_FREQ_DETECT_XTAL_DIV);
 448   1      
 449   1          // Enable SDM control
 450   1          ScalerSetBit(PB6_80_AUD_PS_CTRL_0, ~_BIT7, _BIT7);
 451   1      
 452   1          // Disable Boundary Tracking Method
 453   1          ScalerSetBit(PB6_81_AUD_BDRY_0, ~_BIT7, 0x00);
 454   1      
 455   1          // Set I code of boundary tracking
 456   1          ScalerSetByte(PB6_83_AUD_BDRY_2, HIBYTE(_INITIAL_I_CODE));
 457   1          ScalerSetByte(PB6_84_AUD_BDRY_3, LOBYTE(_INITIAL_I_CODE));
 458   1      
 459   1          // Set P code of boundary tracking
 460   1          ScalerSetByte(PB6_85_AUD_BDRY_4, 0x7F);
 461   1          ScalerSetByte(PB6_86_AUD_BDRY_5, 0xFF);
 462   1      
 463   1          // Disable Trend Tracking Method
 464   1          ScalerSetBit(PB6_92_AUD_TRND_0, ~_BIT7, 0x00);
 465   1      
 466   1          // Set I code of trend tracking
 467   1          ScalerSetByte(PB6_99_AUD_TRND_7, 0x00);
 468   1          ScalerSetByte(PB6_9A_AUD_TRND_8, 0x02);
 469   1      
 470   1          // Set P code of trend tracking
 471   1          ScalerSetByte(PB6_9B_AUD_TRND_9, 0x7F);
 472   1          ScalerSetByte(PB6_9C_AUD_TRND_10, 0xFF);
 473   1      
 474   1          // Enable Audio Buffer & Valid_Bit Detect
 475   1          ScalerSetBit(PB6_B0_DP_AUD_CTRL, ~(_BIT7 | _BIT5), (_BIT7 | _BIT5));
 476   1      
