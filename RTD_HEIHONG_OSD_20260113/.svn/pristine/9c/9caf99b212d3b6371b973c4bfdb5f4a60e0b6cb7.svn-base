1296          bit ScalerAudioD2GetAudioDetected(void)
1297          {
1298   1          // Check audio packet
1299   1          if(GET_AUDIO_D2_PACKET_DETECT() == _FALSE)
1300   1          {
1301   2              DebugMessageAudio("False : D2 Audio Packet", 0);
1302   2              return _FALSE;
1303   2          }
1304   1      
1305   1          // Check FW tracking state
1306   1      #if(_HDMI_AUDIO_FW_TRACKING_MODE_SUPPORT == _ON)
                  if((GET_AUDIO_D2_FW_TRACKING_STATE() != _AUDIO_FW_TRACKING_PROCESS_PLAYBACK) &&
                     (GET_AUDIO_D2_SAMPLING_FREQ() <= _AUDIO_FREQ_48K))
