                              if(g_stHDMID4AudioFwTrackingInfo.ucAfifoTrackStableCnt < (_AUDIO_FW_TRCK_FIRST_STABLE_CNT 
             -/ 2))
                              {
                                  usbackupSumc -= (((_AUDIO_FW_TRCK_FIRST_STABLE_CNT / 2) - g_stHDMID4AudioFwTrackingInf
             -o.ucAfifoTrackStableCnt) * (ucAfifoCurrent - (g_stHDMID4AudioFwTrackingInfo.ucAfifoBackup + 0x01)));
                              }
