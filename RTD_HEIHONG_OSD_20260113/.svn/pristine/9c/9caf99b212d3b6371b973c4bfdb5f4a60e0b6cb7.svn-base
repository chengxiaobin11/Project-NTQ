1317   1          {
1318   2              DebugMessageAudio("False : D2 AVMute", 0);
1319   2              return _FALSE;
1320   2          }
1321   1      
1322   1          // Check Audio Tracking
1323   1          if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_15_PORT_PAGE71_HDMI_PSCR, (_BIT3 | _BIT2)) == 0x00)
1324   1          {
1325   2              DebugMessageAudio("False : D2 HDMI Audio Tracking Disable", 0);
1326   2              return _FALSE;
1327   2          }
1328   1      
1329   1          // Check HDMI audio FIFO overflow and underflow
1330   1          if(ScalerGetBit(P71_CB_HDMI_SR, (_BIT2 | _BIT1)) != 0x00)
1331   1          {
1332   2              DebugMessageAudio("False : D2 HDMI Audio FIFO", ScalerGetBit(P71_CB_HDMI_SR, (_BIT2 | _BIT1)));
1333   2      
1334   2              if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, (_BIT2 | _BIT1)) == 
             -0x00)
1335   2              {
1336   3                  // Clear HDMI audio FIFO overflow and underflow status
1337   3                  ScalerSetBit(P71_CB_HDMI_SR, ~(_BIT2 | _BIT1), (_BIT2 | _BIT1));
1338   3      
1339   3                  if(ScalerGetBit(P71_CB_HDMI_SR, (_BIT2 | _BIT1)) != 0x00)
1340   3                  {
1341   4                      DebugMessageAudio("False : D2 HDMI Audio DB Retry", ScalerGetBit(P71_CB_HDMI_SR, (_BIT2 | 
             -_BIT1)));
1342   4      
1343   4                      // Set Double Buffer bit
1344   4                      ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_10_PORT_PAGE71_HDMI_CMCR, ~_BIT4, _BIT4);
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               10/18/2025 16:25:10 PAGE 24  

1345   4      
1346   4                      // Clear HDMI audio FIFO overflow and underflow status
1347   4                      ScalerSetBit(P71_CB_HDMI_SR, ~(_BIT2 | _BIT1), (_BIT2 | _BIT1));
1348   4                  }
1349   3              }
1350   2      
1351   2              return _FALSE;
1352   2          }
1353   1      
1354   1          return _TRUE;
1355   1      }
