2374   1      #if(_EMBEDDED_DAC_SUPPORT == _ON)
2375   1          if(enumAudioFreq != GET_AUDIO_D3_SAMPLING_FREQ())
2376   1          {
2377   2              if(enumAudioFreq <= _AUDIO_FREQ_64K)
2378   2              {
2379   3                  ScalerSetBit(P6_D4_DA_CLK_CTRL, ~(_BIT7 | _BIT6), 0x00);
2380   3              }
2381   2              else if(enumAudioFreq <= _AUDIO_FREQ_128K)
