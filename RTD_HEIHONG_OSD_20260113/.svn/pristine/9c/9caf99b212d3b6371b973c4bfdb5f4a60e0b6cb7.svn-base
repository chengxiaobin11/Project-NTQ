                  // Bit2: When no audio or changing sampling rate, AFSM load double buffer one more.
                  ScalerSetDataPortBit(P74_C9_HDMI_AP, _P74_CA_PT_9F_PORT_PAGE74_PRESET_AFSM_MOD, ~(_BIT7 | _BIT6 | _BIT
             -5 | _BIT4 | _BIT2), (_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT2));
              
