2096          //--------------------------------------------------
2097          // Description  : Get D3 Audio Detected
2098          // Input Value  : None
2099          // Output Value : TRUE => Audio Detected
2100          //--------------------------------------------------
2101          bit ScalerAudioD3GetAudioDetected(void)
2102          {
2103   1          // Check audio packet
2104   1          if(GET_AUDIO_D3_PACKET_DETECT() == _FALSE)
2105   1          {
2106   2              DebugMessageAudio("False : D3 Audio Packet", 0);
2107   2              return _FALSE;
2108   2          }
2109   1      
2110   1          // Check FW tracking state
2111   1      #if(_HDMI_AUDIO_FW_TRACKING_MODE_SUPPORT == _ON)
                  if((GET_AUDIO_D3_FW_TRACKING_STATE() != _AUDIO_FW_TRACKING_PROCESS_PLAYBACK) &&
                     (GET_AUDIO_D3_SAMPLING_FREQ() <= _AUDIO_FREQ_48K))
                  {
                      DebugMessageAudio("False : D3 Audio FW Tracking preparing", 0);
                      return _FALSE;
                  }
              #endif
2119   1      
2120   1          // Check AVMute
2121   1          if(ScalerGetBit(P72_CB_HDMI_SR, _BIT6) == _BIT6)
2122   1          {
2123   2              DebugMessageAudio("False : D3 AVMute", 0);
2124   2              return _FALSE;
2125   2          }
2126   1      
2127   1          // Check Audio Tracking
2128   1          if(ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_15_PORT_PAGE72_HDMI_PSCR, (_BIT3 | _BIT2)) == 0x00)
2129   1          {
2130   2              DebugMessageAudio("False : D3 HDMI Audio Tracking Disable", 0);
2131   2              return _FALSE;
2132   2          }
2133   1      
2134   1          // Check HDMI audio FIFO overflow and underflow
2135   1          if(ScalerGetBit(P72_CB_HDMI_SR, (_BIT2 | _BIT1)) != 0x00)
2136   1          {
2137   2              DebugMessageAudio("False : D3 HDMI Audio FIFO", ScalerGetBit(P72_CB_HDMI_SR, (_BIT2 | _BIT1)));
2138   2      
2139   2              if(ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_31_PORT_PAGE72_HDMI_WDCR0, (_BIT2 | _BIT1)) == 
             -0x00)
2140   2              {
2141   3                  // Clear HDMI audio FIFO overflow and underflow status
2142   3                  ScalerSetBit(P72_CB_HDMI_SR, ~(_BIT2 | _BIT1), (_BIT2 | _BIT1));
2143   3      
2144   3                  if(ScalerGetBit(P72_CB_HDMI_SR, (_BIT2 | _BIT1)) != 0x00)
2145   3                  {
2146   4                      DebugMessageAudio("False : D3 HDMI Audio DB Retry", ScalerGetBit(P72_CB_HDMI_SR, (_BIT2 | 
             -_BIT1)));
2147   4      
2148   4                      // Set Double Buffer bit
2149   4                      ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_10_PORT_PAGE72_HDMI_CMCR, ~_BIT4, _BIT4);
2150   4      
2151   4                      // Clear HDMI audio FIFO overflow and underflow status
2152   4                      ScalerSetBit(P72_CB_HDMI_SR, ~(_BIT2 | _BIT1), (_BIT2 | _BIT1));
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               10/18/2025 16:25:10 PAGE 38  

2153   4                  }
2154   3              }
2155   2      
2156   2              return _FALSE;
2157   2          }
2158   1      
2159   1          return _TRUE;
2160   1      }
