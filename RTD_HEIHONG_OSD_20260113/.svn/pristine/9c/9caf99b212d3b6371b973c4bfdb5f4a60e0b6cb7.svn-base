 932          // Output Value : None
 933          //--------------------------------------------------
 934          void ScalerAudioD1DPSetDVCWindowSize(bit bAdjustType, EnumAudioSamplingFreqPacket enumSamplingFreqPacket)
 935          {
 936   1          if(enumSamplingFreqPacket == _AUDIO_FREQ_PACKET_NO_AUDIO)
 937   1          {
 938   2              enumSamplingFreqPacket = _AUDIO_FREQ_PACKET_48K;
 939   2          }
 940   1      
 941   1          if(bAdjustType == _DB_GAIN)
 942   1          {
 943   2              // Get numbers of the volume step for mute or unmute
 944   2              PDATA_WORD(0) = _DVC_DB_STEP_NUMBER << 3;
 945   2          }
 946   1          else
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               10/18/2025 16:25:10 PAGE 17  

 947   1          {
 948   2              // Volume Max = 0x3FFF
 949   2              PDATA_WORD(0) = 0x3FFF / _DP_VOLUME_STEP_SIZE_VALUE + 1;
 950   2          }
 951   1      
 952   1          // Calculate samples of ZCD timeout
 953   1          PDATA_DWORD(1) = (DWORD)enumSamplingFreqPacket * _DP_DVC_VOLUME_MUTE_TIMER / PDATA_WORD(0);
 954   1      
 955   1          // Avoid Overflow
 956   1          if(PDATA_DWORD(1) > 0x0FFF)
 957   1          {
 958   2              PDATA_WORD(0) = 0x0FFF;
 959   2          }
 960   1          else
 961   1          {
 962   2              PDATA_WORD(0) = (WORD)PDATA_DWORD(1);
 963   2          }
 964   1      
 965   1          // Set DVC ZCD window size
 966   1          ScalerSetBit(PB9_78_DVC_WINDOW_CONTROL_0, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(PDATA_WORD(0)));
 967   1          ScalerSetByte(PB9_79_DVC_WINDOW_CONTROL_1, LOBYTE(PDATA_WORD(0)));
 968   1      }
