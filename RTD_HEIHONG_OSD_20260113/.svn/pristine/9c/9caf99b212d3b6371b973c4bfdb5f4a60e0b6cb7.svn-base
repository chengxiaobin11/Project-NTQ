 355          //--------------------------------------------------
 356          // Description  : Enable DP audio FSM
 357          // Input Value  : Enable or Disable, Input Port
 358          // Output Value : None
 359          //--------------------------------------------------
 360          void ScalerAudioDpAudioEnable(bit bEnable, BYTE ucInputPort)
 361          {
 362   1          switch(ucInputPort)
 363   1          {
 364   2              case _D0_INPUT_PORT:
 365   2      
 366   2      #if((_D6_INPUT_PORT_TYPE != _D6_NO_PORT) && (_D6_INPUT_PORT_SWITCH_FROM == _SWITCH_FROM_D0))
                      case _D6_INPUT_PORT:
              #endif
 369   2      
 370   2      #if(_D0_DP_EXIST == _ON)
 371   2                  ScalerSetBit(PB6_74_AUD_FSM_CTRL_0, ~_BIT7, ((BYTE)bEnable) << 7);
 372   2      #endif
 373   2                  break;
 374   2      
 375   2              case _D1_INPUT_PORT:
 376   2      
 377   2      #if(_D1_DP_EXIST == _ON)
 378   2                  ScalerSetBit(PB9_74_AUD_FSM_CTRL_0, ~_BIT7, ((BYTE)bEnable) << 7);
 379   2      #endif
 380   2                  break;
 381   2      
 382   2              default:
 383   2                  break;
 384   2          }
 385   1      }
