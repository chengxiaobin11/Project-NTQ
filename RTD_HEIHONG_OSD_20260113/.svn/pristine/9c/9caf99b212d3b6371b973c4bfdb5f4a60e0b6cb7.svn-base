                  else
                  {
                      DebugMessageAudio("D3 Aduio Test Off", ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_03_PORT_PAG
             -E72_HDMI_AFCR, _BIT4));
              
