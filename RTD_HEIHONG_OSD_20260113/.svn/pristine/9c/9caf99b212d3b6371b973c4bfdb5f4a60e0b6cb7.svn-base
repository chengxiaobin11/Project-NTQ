 593          //--------------------------------------------------
 594          // Description  : Set ZCD Timeout for DP Audio
C51 COMPILER V9.60.0.0   SCALERAUDIO_SEPTPHY                                               10/18/2025 16:25:10 PAGE 11  

 595          // Input Value  : bAdjustType, enumSamplingFreqPacket
 596          // Output Value : None
 597          //--------------------------------------------------
 598          void ScalerAudioD0DPSetDVCWindowSize(bit bAdjustType, EnumAudioSamplingFreqPacket enumSamplingFreqPacket)
 599          {
 600   1          if(enumSamplingFreqPacket == _AUDIO_FREQ_PACKET_NO_AUDIO)
 601   1          {
 602   2              enumSamplingFreqPacket = _AUDIO_FREQ_PACKET_48K;
 603   2          }
 604   1      
 605   1          if(bAdjustType == _DB_GAIN)
 606   1          {
 607   2              // Get numbers of the volume step for mute or unmute
 608   2              PDATA_WORD(0) = _DVC_DB_STEP_NUMBER << 3;
 609   2          }
 610   1          else
 611   1          {
 612   2              // Volume Max = 0x3FFF
 613   2              PDATA_WORD(0) = 0x3FFF / _DP_VOLUME_STEP_SIZE_VALUE + 1;
 614   2          }
 615   1      
 616   1          // Calculate samples of ZCD timeout
 617   1          PDATA_DWORD(1) = (DWORD)enumSamplingFreqPacket * _DP_DVC_VOLUME_MUTE_TIMER / PDATA_WORD(0);
 618   1      
 619   1          // Avoid Overflow
 620   1          if(PDATA_DWORD(1) > 0x0FFF)
 621   1          {
 622   2              PDATA_WORD(0) = 0x0FFF;
 623   2          }
 624   1          else
 625   1          {
 626   2              PDATA_WORD(0) = (WORD)PDATA_DWORD(1);
 627   2          }
 628   1      
 629   1          // Set DVC ZCD window size
 630   1          ScalerSetBit(PB6_78_DVC_WINDOW_CONTROL_0, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), HIBYTE(PDATA_WORD(0)));
 631   1          ScalerSetByte(PB6_79_DVC_WINDOW_CONTROL_1, LOBYTE(PDATA_WORD(0)));
 632   1      }
