             -AIN_DOWN_VALUE << 2) | _DP_DB_GAIN_UP_VALUE));
 645   2      
 646   2              // Initial Volume Step Size for DB Gain Mode
 647   2              ScalerSetByte(PB6_77_DVC_VA, 0x01);
 648   2          }
 649   1          else // _VOLUME_STEP_SIZE
 650   1          {
 651   2              // Select Value Mode to Volume Setp
 652   2              ScalerSetBit(PB6_76_DVC_CTRL, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
 653   2      
 654   2              // Set Volume Step Size
 655   2              ScalerSetByte(PB6_77_DVC_VA, _DP_VOLUME_STEP_SIZE_VALUE);
