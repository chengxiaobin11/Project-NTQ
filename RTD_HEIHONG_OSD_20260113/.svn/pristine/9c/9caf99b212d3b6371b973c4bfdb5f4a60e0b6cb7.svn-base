2402          void ScalerAudioD3SetAudioPLL(void)
2403          {
2404   1          // DPLL power down
2405   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_38_PORT_PAGE72_HDMI_DPCR0, ~_BIT7, _BIT7);
2406   1      
