3687   1      
3688   1          // Pop Up CED Error For Clear Error Counter
3689   1          ScalerSetBit(P71_0C_HDMI_CTRL_0C, ~_BIT7, _BIT7);
3690   1      
3691   1          // Disable CED Lock Transition IRQ & Flag
3692   1          ScalerSetBit(P71_17_HDMI_CTRL_17, ~(_BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1 | _BIT0));
3693   1          ScalerSetBit(P71_18_HDMI_CTRL_18, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
3694   1      
3695   1          // Set Read Request 1ms reference clock to internal OSC
3696   1          ScalerSetBit(P71_1A_HDMI_CTRL_1A, ~_BIT3, _BIT3);
3697   1      
3698   1          // Set time interval form bus free to Read Request(4.7us~500us)
3699   1          ScalerSetBit(P71_1B_HDMI_CTRL_1B, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT4 | _BIT0));
