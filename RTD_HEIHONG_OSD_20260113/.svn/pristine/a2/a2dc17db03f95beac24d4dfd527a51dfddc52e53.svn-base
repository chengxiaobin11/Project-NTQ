3147   2      
3148   2              default:
3149   2      
3150   2                  return _FALSE;
3151   2          }
3152   1      
3153   1          // N <= (Fin / 7)
3154   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
3155   1      
3156   1          if(PDATA_WORD(0) < 2)
3157   1          {
3158   2              return _FALSE;
3159   2          }
3160   1          else if(PDATA_WORD(0) >= ucFactor)
3161   1          {
3162   2              // N: Multiple of factor
3163   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
3164   2          }
3165   1          else if(PDATA_WORD(0) > 255)
3166   1          {
3167   2              // N: Multiple of factor
3168   2              PDATA_WORD(0) = 255 - (255 % ucFactor);
3169   2          }
3170   1      
3171   1          ucN = PDATA_WORD(0);
