4154          //--------------------------------------------------
4155          // Description  : Check whether HDCP is enabled
4156          // Input Value  : None
4157          // Output Value : TRUE => HDCP Enabled
4158          //--------------------------------------------------
4159          bit ScalerTMDSRx2HdcpEnabled(void)
4160          {
4161   1          BYTE pucHDCPFrameCount[2];
4162   1          memset(pucHDCPFrameCount, 0, sizeof(pucHDCPFrameCount));
4163   1      
4164   1      #if(_TMDS_HDCP_2_2_SUPPORT == _ON)
4165   1          if((ScalerGetBit(P71_C0_HDCP_CR, _BIT0) == _BIT0) && (ScalerGetBit(P2D_26_HDCP_I2C_CTRL_0, _BIT7) == 0
             -x00))
4166   1      #endif
4167   1          {
4168   2              ScalerGetDataPortByte(P71_C3_HDCP_AP, _P71_C4_PT_C0_PORT_PAGE71_HDCP_FCR, 1, &pucHDCPFrameCount[0]
             -, _NON_AUTOINC);
4169   2      
4170   2              // Wait 2Vsync to make sure frame counter changing, and timeout 45ms (margin + 1/24 frame+rate)
4171   2              ScalerSetBit(P71_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), _BIT3);
4172   2              ScalerTimerPollingFlagProc(45, P71_A4_TMDS_CTRL, _BIT3, _TRUE);
4173   2              ScalerSetBit(P71_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), _BIT3);
4174   2              ScalerTimerPollingFlagProc(45, P71_A4_TMDS_CTRL, _BIT3, _TRUE);
4175   2      
4176   2              ScalerGetDataPortByte(P71_C3_HDCP_AP, _P71_C4_PT_C0_PORT_PAGE71_HDCP_FCR, 1, &pucHDCPFrameCount[1]
             -, _NON_AUTOINC);
4177   2      
4178   2              if(pucHDCPFrameCount[0] != pucHDCPFrameCount[1])
4179   2              {
4180   3                  return _TRUE;
4181   3              }
4182   2      
4183   2              return _FALSE;
4184   2          }
4185   1      #if(_TMDS_HDCP_2_2_SUPPORT == _ON)
4186   1          else if((ScalerGetBit(P71_C0_HDCP_CR, _BIT0) == 0x00) && (ScalerGetBit(P2D_26_HDCP_I2C_CTRL_0, _BIT7) 
             -== _BIT7))
4187   1          {
4188   2              if(ScalerGetByte(P2D_2C_HDCP_I2C_CTRL_6) == 0x10)
4189   2              {
4190   3                  return _TRUE;
4191   3              }
4192   2              else
4193   2              {
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX2                                             10/18/2025 16:25:58 PAGE 71  

4194   3                  return _FALSE;
4195   3              }
4196   2          }
4197   1          else
4198   1          {
4199   2              return _FALSE;
4200   2          }
4201   1      #endif
4202   1      }
