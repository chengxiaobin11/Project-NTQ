3553   2              // Enable AVMute Watch Dog
3554   2              ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_31_PORT_PAGE71_HDMI_WDCR0, ~_BIT7, _BIT7);
3555   2          }
3556   1      }
