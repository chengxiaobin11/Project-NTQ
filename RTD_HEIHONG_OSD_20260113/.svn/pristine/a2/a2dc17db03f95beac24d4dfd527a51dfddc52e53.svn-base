 300          //--------------------------------------------------
 301          // Description  : Initialize TMDS Interrupt Required Settings
 302          // Input Value  : None
 303          // Output Value : None
 304          //--------------------------------------------------
 305          void ScalerTMDSRx2InterruptInitial(void)
 306          {
 307   1          if(ScalerGetBit(P71_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 308   1          {
 309   2              CLR_TMDS_RX2_PHY_SET();
 310   2          }
 311   1      
 312   1          // Enable Rx_En for Clk pair Z0
 313   1          ScalerSetBit(P7B_1A_CMU_00, ~_BIT7, _BIT7);
 314   1      
 315   1          // Choose Measure Clk to TMDS Clk
 316   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 317   1      
 318   1          // Set Freq. Reference Counter = 2000
 319   1          ScalerSetBit(P71_F6_HDMI_FREQDET_BOUND_H, ~(_BIT1 | _BIT0), _BIT0);
 320   1      
 321   1          // Set Online Measure Input Clock Divider = /2 (No Matter if Input Clock >300Mhz or <=300Mhz)
 322   1          ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~_BIT6, _BIT6);
 323   1      
 324   1          // Settings for IRQ set PHY
 325   1          // Consider using table to fill all required initial settings
 326   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 327   1      
 328   1      #if(_D2_INPUT_PORT_TYPE == _D2_MHL_PORT)
                  if(GET_D2_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Set TMDS Offset = 1/32
                      ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                      // Set Upper Bound
                      ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                      ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                  }
                  else
              #endif
 340   1          {
 341   2              // Set TMDS Offset = 1/32
 342   2              ScalerSetBit(P71_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 343   2      
 344   2              // Set Upper Bound
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX2                                             10/18/2025 16:25:58 PAGE 7   

 345   2              ScalerSetByte(P71_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 346   2              ScalerSetByte(P71_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 347   2          }
 348   1      
 349   1          // Set Lower Bound
 350   1          ScalerSetByte(P71_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 351   1          ScalerSetByte(P71_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 352   1      
 353   1          // Set Stable Time (0x3F = about 5ms)
 354   1          ScalerSetByte(P71_EC_HDMI_FREQDET_STABLE, 0x3F);
 355   1      
 356   1          // Disable Freq. Unstable IRQ
 357   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~_BIT1, 0x00);
 358   1      
 359   1          // Enable Freq. Stable IRQ
 360   1          ScalerSetBit(P71_EF_HDMI_ERROR_TH, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 361   1      
 362   1      #if(_D2_HDMI_2_0_SUPPORT == _ON)
 363   1          // Enable SCDC 0x20 Change IRQ
 364   1          ScalerSetBit(P71_26_HDMI_CTRL_26, ~_BIT4, _BIT4);
 365   1      #endif
 366   1      
 367   1          // Clear IRQ Pending Flag
 368   1          ScalerSetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_60_PORT_PAGE71_HDMI_INTCR, ~_BIT7, _BIT7);
 369   1      
 370   1          // Internal IRQ Enable (Global)
 371   1          ScalerGlobalIRQControl(_ENABLE);
 372   1      
 373   1          EX0 = 1;
 374   1      
 375   1          // Start Freq. Detection
 376   1          ScalerSetBit(P71_E6_HDMI_FREQDET_CTRL, ~_BIT7, _BIT7);
 377   1      }
