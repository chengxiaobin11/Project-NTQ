4205          //--------------------------------------------------
4206          // Description  : DFE Adaptation in Normal Signal
4207          // Input Value  : None
4208          // Output Value : True --> DFE Normal
4209          //                False --> DFE Abnormal
4210          //--------------------------------------------------
4211          bit ScalerTMDSRx2CheckDataDFE(void)
4212          {
4213   1          BYTE ucTemp = 0;
4214   1          BYTE ucCnt = 0;
4215   1      
4216   1          // DFE Check only under HDMI Mode.
4217   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4218   1          if(ScalerGetBit(P7B_17_BANDGAP_03, _BIT1) != _BIT1)
4219   1          {
4220   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4221   2              {
4222   3                  // Sel lane
4223   3                  ScalerSetBit(P7B_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4224   3      
4225   3                  // Read VTH
4226   3                  ScalerSetBit(P7B_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
4227   3      
4228   3                  if((ScalerGetByte(P7B_F1_COEF_2) & 0x1F) == 0)
4229   3                  {
4230   4                      for(ucCnt = 0; ucCnt < 3; ucCnt++)
