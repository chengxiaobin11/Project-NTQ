2903          //--------------------------------------------------
2904          // Description  : Measure Clk
2905          // Input Value  : Clk Source to be measured
2906          // Output Value : Measured Clk Count
2907          //--------------------------------------------------
2908          WORD ScalerTMDSRx2MeasureClk(BYTE ucMeasureClk)
2909          {
2910   1          BYTE ucDelayCount = 0;
2911   1      
2912   1      #if(_D2_INPUT_PORT_TYPE == _D2_MHL_PORT)
                  if(GET_D2_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7B_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
                  }
                  else
              #endif
2920   1          {
2921   2              // Enable Rx_EN (Lane3)
2922   2              ScalerSetBit(P7B_1A_CMU_00, ~_BIT7, _BIT7);
2923   2          }
2924   1      
2925   1          // Disable Measure for Reset Measure Window
2926   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2927   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
2928   1      
2929   1          // Select reference clk to Xtal Clk and measure clk
2930   1          ScalerSetBit(P71_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
2931   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX2                                             10/18/2025 16:25:58 PAGE 50  

2932   1          // Start Measure
2933   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2934   1          ScalerSetBit(P71_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
2935   1      
2936   1          // Delay at least 40us at Xtal = 27MHz
2937   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
2938   1          {
2939   2              DELAY_5US();
2940   2      
2941   2              ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2942   2              if(ScalerGetBit(P71_CA_HDMI_DP, _BIT3) == 0x00)
2943   2              {
2944   3                  break;
2945   3              }
2946   2          }
2947   1      
2948   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0);
2949   1          pData[0] = ScalerGetByte(P71_CA_HDMI_DP);
2950   1      
2951   1          ScalerSetByte(P71_C9_HDMI_AP, _P71_CA_PT_29_PORT_PAGE71_HDMI_NTX1024TR1);
2952   1          pData[1] = ScalerGetByte(P71_CA_HDMI_DP);
2953   1      
2954   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
2955   1      }
