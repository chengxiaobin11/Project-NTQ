3078   1      
3079   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3080   1          // Fin = TMDS_clk
3081   1          // Fref = Fin / N
3082   1          // Fvco = Fin * M / N
3083   1          // Freq = Fvco / Divs
3084   1          //
3085   1          // Restriction
3086   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
3087   1          // B. 300MHz < Fvco < 600MHz
3088   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
3089   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
3090   1          //
3091   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
3092   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
3093   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
3094   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
3095   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
3096   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
3097   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3098   1      
3099   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
3100   1          if(ScalerGetDataPortBit(P71_C9_HDMI_AP, _P71_CA_PT_28_PORT_PAGE71_HDMI_NTX1024TR0, _BIT6) == _BIT6)
3101   1          {
3102   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
3103   2          }
3104   1          else
3105   1          {
3106   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
3107   2          }
3108   1      
3109   1      #if(_D2_HDMI_2_0_SUPPORT == _ON)
3110   1      
3111   1          if(GET_TMDS_RX2_HIGH_SPEED_MODE() == _TRUE)
3112   1          {
3113   2              ulTMDSClkValue = (ulTMDSClkValue << 2);
3114   2          }
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX2                                             10/18/2025 16:25:58 PAGE 53  

3115   1      
3116   1      #if(_HDMI_2_0_YCBCR420_SUPPORT == _ON)
3117   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420)
3118   1          {
3119   2              ucRatio = 2;
3120   2          }
3121   1      #endif
3122   1      
3123   1      #endif
3124   1      
3125   1          DebugMessageRx2("TMDS clk", ulTMDSClkValue);
3126   1          DebugMessageRx2("Color Depth", ucColorDepth);
3127   1      
3128   1          switch(ucColorDepth)
3129   1          {
3130   2              case _COLOR_DEPTH_10_BITS:
3131   2      
3132   2                  ucFactor = 5;
3133   2      
3134   2                  break;
3135   2      
3136   2              case _COLOR_DEPTH_12_BITS:
3137   2      
3138   2                  ucFactor = 3;
3139   2      
3140   2                  break;
3141   2      
3142   2              case _COLOR_DEPTH_16_BITS:
3143   2      
3144   2                  ucFactor = 2;
3145   2      
