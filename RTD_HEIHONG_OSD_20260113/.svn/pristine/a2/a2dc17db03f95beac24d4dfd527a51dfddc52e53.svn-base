 379          //--------------------------------------------------
 380          // Description  : TMDS DFE Initial Setting (EXINT0 Only)
 381          // Input Value  : None
 382          // Output Value : None
 383          //--------------------------------------------------
 384          void ScalerTMDSRx2SetDFEInitial_EXINT0(void) using 1
 385          {
 386   1          // [6] Enable Timer Control DFE Loop
 387   1          // [5:4] Reduce Gain to 1/4
 388   1          // [3] Disable Running Length Detection
