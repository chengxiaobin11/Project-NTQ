3175   1          {
3176   2              // N or Divs: Multiple of factor
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX2                                             10/18/2025 16:25:58 PAGE 54  

3177   2              if(((ucN % ucFactor) == 0x00) || ((pData[15] % ucFactor) == 0x00))
