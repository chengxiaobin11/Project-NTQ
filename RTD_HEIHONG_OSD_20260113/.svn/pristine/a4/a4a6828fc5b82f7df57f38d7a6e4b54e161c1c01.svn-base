C51 COMPILER V9.60.0.0   SCALERPINSHARE                                                    10/18/2025 16:25:04 PAGE 2   

  48          //****************************************************************************
  49          //--------------------------------------------------
  50          // Description  : Low Leakage or Normal Pin Config.
  51          // Input Value  : ON --> Low Leakage Config. ; OFF --> Normal Operation
  52          // Output Value : None
  53          //--------------------------------------------------
  54          void ScalerPinshareConfig(BYTE ucPorStatus)
  55          {
  56   1          // GPIO Config
  57   1          if(ucPorStatus == _POWER_STATUS_NORMAL)
  58   1          {
  59   2              PCB_GPIO_SETTING_POWER_NORMAL();
  60   2          }
  61   1          else if(ucPorStatus == _POWER_STATUS_SAVING)
  62   1          {
  63   2              PCB_GPIO_SETTING_POWER_SAVING();
  64   2          }
  65   1          else if(ucPorStatus == _POWER_STATUS_AC_ON)
  66   1          {
  67   2              ScalerPinshareAdjustFlashDrive(_CONFIG_PIN_SPI_CLK, _FLASH_CLK_DRIVE_CURRENT);
  68   2              ScalerPinshareAdjustFlashDrive(_CONFIG_PIN_SPI_SI_SO_CEB, _FLASH_SI_SO_CEB_DRIVE_CURRENT);
  69   2              ScalerPinshareAdjustFlashSlewRate();
  70   2          }
  71   1          else // Power Down
  72   1          {
  73   2              PCB_GPIO_SETTING_POWER_DOWN();
  74   2          }
  75   1      }


