 304          bit SysJudgeCheckStatus(void)
 305          {
 306   1          if(GET_MODE_STATE() != _MODE_STATUS_FACTORY)
 307   1          {
 308   2              if(GET_SOURCE_JUDGE(g_ucSearchIndex) == _TRUE)
 309   2              {
 310   3                  if(SysSourceStableCheck() == _FALSE)
 311   3                  {
 312   4                      DebugMessageSystem("Source Unstable!!", GET_SOURCE_TYPE(g_ucSearchIndex));
 313   4                      return _FALSE;
 314   4                  }
 315   3              }
 316   2      
 317   2              if(SysModeGetTimingConfirm() == _TRUE)
 318   2              {
 319   3                  // Check whether Input Timing changed
 320   3                  if(ScalerMeasureTimingChange(GET_SOURCE_TYPE(g_ucSearchIndex), SysSourceGetInputPort()) == _TR
             -UE)
 321   3                  {
 322   4                      DebugMessageSystem("Measured Input HV Changed", GET_SOURCE_TYPE(g_ucSearchIndex));
 323   4                      return _FALSE;
 324   4                  }
 325   3      
 326   3                  // double check input timing
 327   3                  if((GET_INPUT_TIMING_DOUBLE_CHECK() == _TRUE) &&
 328   3                     ((SysModeGetDisplaySettingReady() == _TRUE) || (GET_MODE_STATE() == _MODE_STATUS_NOSUPPORT)
             -))
 329   3                  {
 330   4                      if(GET_SOURCE_TYPE(g_ucSearchIndex) != _SOURCE_VGA)
 331   4                      {
 332   5                          if(ScalerMeasureInterlaceCheck(GET_SOURCE_TYPE(g_ucSearchIndex), SysSourceGetInputPort
             -()) != GET_INPUT_TIMING_INTERLACE_FLG())
 333   5                          {
 334   6                              DebugMessageSystem("Input Timing Double Check : Interlace Flag Change", GET_SOURCE
             -_TYPE(g_ucSearchIndex));
 335   6                              return _FALSE;
 336   6                          }
 337   5                      }
 338   4      
 339   4                      CLR_INPUT_TIMING_DOUBLE_CHECK();
 340   4                  }
 341   3              }
 342   2      
 343   2              if(SysModeGetDisplaySettingReady() == _TRUE)
 344   2              {
 345   3                  if((ScalerMDomainMemoryCheck() == _FALSE) ||
 346   3                     (ScalerMDomainDisplayTimingGenCheck() == _FALSE))
 347   3                  {
C51 COMPILER V9.60.0.0   SYSJUDGE                                                          10/18/2025 16:24:44 PAGE 7   

 348   4                      DebugMessageSystem("Memory Check Failed", GET_SOURCE_TYPE(g_ucSearchIndex));
 349   4                      return _FALSE;
 350   4                  }
 351   3      
 352   3      #if(_ULTRA_HDR_SUPPORT == _ON)
 353   3                  ScalerSyncGetColorInfoFrame(SysSourceGetInputPort(), _DP_GET_RSV0_INFO_ACTIVE);
 354   3      #endif
 355   3              }
 356   2      
 357   2      #if(_PANEL_STYLE == _PANEL_DPTX)
              #if(_PANEL_DPTX_HPD_DETECT == _ON)
                      if(GET_MODE_STATE() == _MODE_STATUS_ACTIVE)
