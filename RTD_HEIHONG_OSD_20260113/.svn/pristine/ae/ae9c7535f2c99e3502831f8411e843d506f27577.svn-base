  48          void ScalerOsdPositionOffset(EnumOsdPositionOffsetType enumOsdPositionOffsetType, BYTE ucHOffset, BYTE ucV
             -Offset);
  49          void ScalerOsdReset(void);
  50          bit ScalerOsdPositionCorrectSupport(void);
  51          
  52          //****************************************************************************
  53          // FUNCTION DEFINITIONS
  54          //****************************************************************************
  55          
  56          //--------------------------------------------------
  57          // Description  : Set osd position
  58          // Input Value  : EnumOsdPositionOffsetType -> _OSD_POSITION_OFFSET_GLOBAL or _OSD_POSITION_OFFSET_WINDOW
  59          //                usHOffset                 -> Horizontal Offset
  60          //                usVOffset                 -> Vertical  Offset
  61          // Output Value :
  62          //--------------------------------------------------
  63          void ScalerOsdPositionOffset(EnumOsdPositionOffsetType enumOsdPositionOffsetType, BYTE ucHOffset, BYTE ucV
             -Offset)
  64          {
  65   1          if(enumOsdPositionOffsetType == _OSD_POSITION_OFFSET_GLOBAL)
  66   1          {
  67   2      #if(_OSD_POSITION_OFFSET_CORRECTION == _OFF)
                      SET_OSD_POSITION_GOLOBAL_OFFSET_H(ucHOffset);
                      SET_OSD_POSITION_GOLOBAL_OFFSET_V(ucVOffset);
              
                      ucVOffset = ScalerOsdPositionOffsetVerticalAlignByDVBGStart(ucVOffset);
              #endif
  73   2      
  74   2              ScalerSetByte(P3A_2C_FRAME_CTRL_2C, ucVOffset);
  75   2              ScalerSetByte(P3A_2F_FRAME_CTRL_2F, ucHOffset);
  76   2          }
  77   1          else
  78   1          {
  79   2              // adjust OSD window V start
  80   2              ucVOffset = OSD_POSITION_OFFSET_WINDOW_V_OFFSET_ADJUST(ucVOffset);
  81   2      
  82   2              ScalerSetBit(P3A_32_FRAME_CTRL_32, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), ((ucVOffset & 0x0F) << 4));
  83   2              ScalerSetBit(P3A_32_FRAME_CTRL_32, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (ucHOffset & 0x0F));
  84   2          }
  85   1      }
  86          
  87          //--------------------------------------------------
  88          // Description  : Reset OSD
  89          // Input Value  :
  90          // Output Value :
  91          //--------------------------------------------------
  92          void ScalerOsdReset(void)
  93          {
  94   1          // Disable OSD Rotate (CW0)
  95   1          // Avoid fake power off to on, osd auto rotate fail.
  96   1          ScalerSetBit(P3A_0B_FRAME_CTRL_0B, ~(_BIT7 | _BIT6 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
  97   1          ScalerSetByte(P3A_41_FRAME_CTRL_41, 0x00);
  98   1      }
  99          
 100          //--------------------------------------------------
 101          // Description  : Return _OSD_POSITION_OFFSET_CORRECTION
 102          // Input Value  :
 103          // Output Value :
 104          //--------------------------------------------------
 105          bit ScalerOsdPositionCorrectSupport(void)
 106          {
 107   1          return _OSD_POSITION_OFFSET_CORRECTION;
