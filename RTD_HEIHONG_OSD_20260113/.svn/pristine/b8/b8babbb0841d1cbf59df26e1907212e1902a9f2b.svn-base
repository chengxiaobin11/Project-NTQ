 550          //--------------------------------------------------
 551          // Description  : Set Capture V Delay
 552          // Input Value  : usIHSDelay --> H Delay
 553          // Output Value : None
 554          //--------------------------------------------------
 555          void ScalerVgipSetCaptureHDelay(WORD usIHSDelay)
 556          {
 557   1          // IHdelay[9]: P0_1E[2]
 558   1          // IHdelay[8]: P0_1E[0]
 559   1          // IHwidth[7:0]: P0_1D[7:0]
 560   1          if(ScalerVgipGetDigitalCaptureStatus() == _TRUE)
 561   1          {
 562   2              return;
 563   2          }
 564   1      
 565   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 566   1          if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
 567   1          {
 568   2              usIHSDelay = (usIHSDelay >> 1);
 569   2          }
 570   1      #endif
 571   1      
 572   1          if(usIHSDelay > _VGIP_IH_DELAY_MAX_VALUE)
 573   1          {
 574   2              ScalerIDomainFineTuneHCaptureStart(usIHSDelay - _VGIP_IH_DELAY_MAX_VALUE);
 575   2      
 576   2              usIHSDelay = _VGIP_IH_DELAY_MAX_VALUE;
 577   2          }
 578   1      
 579   1          // Store effective values
 580   1          g_ucVgipDelaySetting = ((g_ucVgipDelaySetting & ~(_BIT2 | _BIT0)) | (((HIBYTE(usIHSDelay) & _BIT1) << 
             -1) | ((HIBYTE(usIHSDelay) & _BIT0))));
 581   1      
 582   1          // Set M1 capture H delay
 583   1          ScalerSetByte(P0_1E_M1_VGIP_HV_DELAY, g_ucVgipDelaySetting);
 584   1          ScalerSetByte(P0_1D_M1_IHS_DELAY, LOBYTE(usIHSDelay));
 585   1      
 586   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 587   1          // Set M2 capture H delay
 588   1          ScalerSetByte(P40_1E_M2_VGIP_HV_DELAY, g_ucVgipDelaySetting);
 589   1          ScalerSetByte(P40_1D_M2_IHS_DELAY, LOBYTE(usIHSDelay));
 590   1      #endif
 591   1      }
