  81          // Description  : Control VGIP capture enable status
  82          // Input Value  : bEnable -> _TRUE to enable capture
  83          // Output Value : None
  84          //--------------------------------------------------
  85          void ScalerVgipCaptureEnable(bit bEnable)
  86          {
  87   1          if(bEnable == _ENABLE)
  88   1          {
  89   2              ScalerSetBit(P0_10_M1_VGIP_CTRL, ~_BIT0, _BIT0);
  90   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
  91   2              ScalerSetBit(P40_10_M2_VGIP_CTRL, ~_BIT0, _BIT0);
  92   2      #endif
  93   2          }
  94   1          else
  95   1          {
  96   2              ScalerSetBit(P0_10_M1_VGIP_CTRL, ~_BIT0, 0x00);
  97   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
  98   2              ScalerSetBit(P40_10_M2_VGIP_CTRL, ~_BIT0, 0x00);
  99   2      #endif
 100   2          }
 101   1      }
