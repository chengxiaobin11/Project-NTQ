 725   2      #endif
 726   2      
 727   2              if(enumDBApply == _DB_APPLY_POLLING)
 728   2              {
 729   3      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 730   3                  // Wait VGIP double buffer
