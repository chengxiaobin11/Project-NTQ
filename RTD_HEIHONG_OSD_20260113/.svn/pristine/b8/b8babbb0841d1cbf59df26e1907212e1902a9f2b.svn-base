 686          void ScalerVgipVgipDoubleBufferApply(EnumDBApply enumDBApply)
 687          {
 688   1          if(enumDBApply != _DB_APPLY_NONE)
 689   1          {
 690   2              // Check if VGIP DB is enabled
 691   2              if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT4) == 0x00)
 692   2              {
 693   3                  return;
 694   3              }
 695   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 696   2              // Check if VGIP DB is enabled
 697   2              if(ScalerGetBit(P40_10_M2_VGIP_CTRL, _BIT4) == 0x00)
 698   2              {
 699   3                  return;
 700   3              }
 701   2      #endif
 702   2      
 703   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 704   2              // Check I domain status
 705   2              if((ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT0) == 0x00) || (ScalerGetBit(P40_10_M2_VGIP_CTRL, _BIT0) 
             -== 0x00))
 706   2      #else
                      if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT0) == 0x00)
              #endif
 709   2      
 710   2              {
 711   3                  // Disable Double Buffer
 712   3                  ScalerSetBit(P0_10_M1_VGIP_CTRL, ~_BIT4, 0x00);
 713   3      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 714   3                  ScalerSetBit(P40_10_M2_VGIP_CTRL, ~_BIT4, 0x00);
 715   3      #endif
 716   3      
 717   3                  return;
 718   3              }
 719   2      
 720   2              // Apply VGIP Double Buffer
 721   2              ScalerSetBit(P0_10_M1_VGIP_CTRL, ~_BIT5, _BIT5);
