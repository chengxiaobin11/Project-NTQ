 426          void ScalerVgipSetCaptureHStartPosition(WORD usIHstart)
 427          {
 428   1          // IHstart[11:8]: P0_14[3:0]
 429   1          // IHstart[7:0]: P0_15[7:0]
 430   1          // Modify H start under analog capture
 431   1          if(ScalerVgipGetDigitalCaptureStatus() == _FALSE)
 432   1          {
 433   2      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 434   2              if(ScalerFmtCnvFtoPGetStatus() == _TRUE)
 435   2              {
 436   3                  usIHstart = (usIHstart >> 1);
 437   3              }
 438   2      #endif
 439   2      
 440   2              if(usIHstart >= 2)
 441   2              {
 442   3                  // H-start in analog capture starts from 2
 443   3                  usIHstart -= 2;
 444   3              }
 445   2          }
 446   1      
 447   1          // Store effective values
 448   1          g_ucVgipHSetting = ((g_ucVgipHSetting & 0xF0) | (HIBYTE(usIHstart) & 0x0F));
 449   1      
 450   1          // Set M1 H capture start
 451   1          ScalerSetByte(P0_14_M1_IPH_ACT_STA_H, g_ucVgipHSetting);
 452   1          ScalerSetByte(P0_15_M1_IPH_ACT_STA_L, LOBYTE(usIHstart));
 453   1      
 454   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 455   1          // Set M2 H capture start
 456   1          ScalerSetByte(P40_14_M2_IPH_ACT_STA_H, g_ucVgipHSetting);
 457   1          ScalerSetByte(P40_15_M2_IPH_ACT_STA_L, LOBYTE(usIHstart));
 458   1      #endif
