 495   1          g_ucVgipMiscSetting = ScalerGetByte(P0_16_M1_IPH_ACT_WID_H);
 496   1      #endif
 497   1      
 498   1          // Store effective values
 499   1          g_ucVgipHSetting = ((g_ucVgipHSetting & 0x0F) | ((HIBYTE(usIHwidth) & 0x0F) << 4));
 500   1      
 501   1      #if(_HW_VGIP_H_WIDTH_BIT_WIDTH == _13_BIT)
 502   1          g_ucVgipMiscSetting = ((g_ucVgipMiscSetting & ~_BIT0) | ((HIBYTE(usIHwidth) & 0x10) >> 4));
 503   1      #endif
 504   1      
 505   1          // Set M1 H capture width
 506   1          ScalerSetByte(P0_14_M1_IPH_ACT_STA_H, g_ucVgipHSetting);
 507   1      
 508   1      #if(_HW_VGIP_H_WIDTH_BIT_WIDTH == _13_BIT)
 509   1          ScalerSetByte(P0_16_M1_IPH_ACT_WID_H, g_ucVgipMiscSetting);
 510   1      #endif
 511   1      
 512   1          ScalerSetByte(P0_17_M1_IPH_ACT_WID_L, LOBYTE(usIHwidth));
 513   1      
 514   1      #if(_FORMAT_CONVERSION_SUPPORT == _ON)
 515   1          // Set M2 H capture width
 516   1          ScalerSetByte(P40_14_M2_IPH_ACT_STA_H, g_ucVgipHSetting);
 517   1      
 518   1      #if(_HW_VGIP_H_WIDTH_BIT_WIDTH == _13_BIT)
 519   1          ScalerSetByte(P40_16_M2_IPH_ACT_WID_H, g_ucVgipMiscSetting);
 520   1      #endif
 521   1      
 522   1          ScalerSetByte(P40_17_M2_IPH_ACT_WID_L, LOBYTE(usIHwidth));
 523   1      #endif
 524   1      }
