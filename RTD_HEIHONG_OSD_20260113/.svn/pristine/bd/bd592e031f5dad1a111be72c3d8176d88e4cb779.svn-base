                      SET_PD_RX0_HPD_QUEUE(_PD_HPD_NONE);
                      SET_PD_RX0_HPD_SPACE_TIME(0);
                      ADD_PD_RX0_HPD_WPTR();
                  }
              
                  ScalerDpRx0HpdToggleAuxPhyResetProc(_LOW);
                  SET_PD_RX0_HPD_STATUS(_LOW);
                  CLR_PD_RX0_HPD_WPTR();
                  CLR_PD_RX0_HPD_RPTR();
                  CLR_PD_RX0_HPD_CNT();
              }
              
