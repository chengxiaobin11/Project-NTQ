                                                          SET_PD_RX0_ENTER_EPR_FAILED_REASON(_PD_EPR_MODE_ENTER_FAILED_C
             -ABLE_NOT_EPR_CAP);
                                                          ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_EPR_MODE, _
             -PD_VDM_CMD_RESERVED);
                                                      }
                                                      else
                                                      {
                                                          // Back to Ready State
                                                          ScalerTypeCRx0PdBackToReadyState_WDINT();
                                                          SET_PD_RX0_CBL_STATE(_PD_CBL_STATE_NONE);
                                                          SET_PD_RX0_AMS_STATUS(_PD_AMS_NONE);
                                                      }
              
                                                      break;
              
                                                  case _PD_CBL_INT_WAIT_DISCOVER_ID_RESP:
              
