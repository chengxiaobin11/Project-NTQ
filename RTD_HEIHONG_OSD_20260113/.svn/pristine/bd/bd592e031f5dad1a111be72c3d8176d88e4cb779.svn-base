             -[5] & (_BIT7 | _BIT6 | _BIT5 | _BIT4)) >> 4));
                  SET_PD_RX0_HP_OWN_AM_ADDR_H(g_pucDataObj_EXINT[5] & (_BIT1 | _BIT0));
