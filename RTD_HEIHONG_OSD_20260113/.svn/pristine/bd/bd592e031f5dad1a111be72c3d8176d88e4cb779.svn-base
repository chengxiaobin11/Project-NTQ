                      CLR_PD_RX0_HPD_QUEUE();
                      CLR_PD_RX0_HPD_SPACE_TIME();
              
                      // Adjust HPD Queue
                      ADD_PD_RX0_HPD_RPTR();
                      SUB_PD_RX0_HPD_CNT();
                  }
              }
              
