                                  CLR_PD_RX0_LENOVO_DOCK_EVENT();
                              }
                              else if(GET_PD_RX0_TRANSMIT_RESULT() == _PD_SENT_RETRY_FAIL)
                              {
                                  ScalerTypeCRx0PdSendSoftRst(_PD_SOP_PKT);
                              }
                          }
              
                          // Enable Rcv Msg. Int
                          ScalerTypeCRx0PdRxIntControl(_ENABLE);
                      }
