             - (Ver 2.0)
                          if(((enumPacketType == _PD_SOP_PKT) && (GET_PD_RX0_SPEC_VER() == _PD_VERSION_3_0)) ||
                             ((enumPacketType == _PD_SOP_P_PKT) && (GET_PD_RX0_SPEC_VER() == _PD_VERSION_3_0) && (GET_PD
             -_RX0_CBL_SPEC_VER() == _PD_VERSION_3_0)))
                          {
                              g_pucDataObject[2] = g_pucDataObject[2] | (_BIT5);
                          }
              
