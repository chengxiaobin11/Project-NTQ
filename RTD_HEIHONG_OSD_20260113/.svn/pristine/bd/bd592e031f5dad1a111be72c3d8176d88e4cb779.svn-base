              //--------------------------------------------------
              StructTypeCUserPDO ScalerTypeCRx0PdGetPdo(EnumTypeCPowerRole enumPowerRole, BYTE ucPdoIndex)
              {
                  StructTypeCUserPDO stTypeCPdo = {_PD_FIX_SUPPLY_PDO, _PD_PEAK_CUR_NONE, 0x00, 0x00, 0x00};
              
