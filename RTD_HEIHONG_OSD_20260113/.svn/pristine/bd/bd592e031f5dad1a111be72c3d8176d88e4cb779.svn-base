             -ET_PD_RX0_FW_STATE() == _PD_SNK_READY) && (GET_PD_RX0_SUB_STATE() == _PD_SUB_SNK_READY))) &&
                     (GET_PD_RX0_AMS_STATUS() == _PD_AMS_NONE) && (GET_PD_RX0_SYS_EVENT() == _PD_SYS_EVENT_NONE) && (GET
             -_PD_RX0_ATTENTION_WAIT() == _FALSE))
                  {
                      if(GET_PD_RX0_DATA_ROLE() == _PD_DATA_UFP)
