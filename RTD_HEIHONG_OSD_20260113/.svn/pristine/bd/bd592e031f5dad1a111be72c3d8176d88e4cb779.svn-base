                  ScalerTimerCancelTimerEvent_EXINT0(_SCALER_TIMER_EVENT_PD_RX0_CLR_CBL_WAIT);
                  ScalerTimerCancelTimerEvent_EXINT0(_SCALER_TIMER_EVENT_PD_RX0_CLR_GET_SNK_CAP_WAIT);
