                  if(GET_TYPE_C_RX0_PORT_ROLE() == _TYPE_C_PORT_SNK_ONLY)
                  {
                      ScalerTimerWDActivateTimerEvent_EXINT0(205, _SCALER_WD_TIMER_EVENT_PD_RX0_SEND_HARD_RST);
                  }
