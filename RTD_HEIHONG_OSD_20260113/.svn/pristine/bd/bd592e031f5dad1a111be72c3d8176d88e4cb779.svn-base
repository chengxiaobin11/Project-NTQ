              //--------------------------------------------------
              // Description  : Type C PD Vbus Powered Sink Start Up Process
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdVbusPoweredSnkStartUpProc_EXINT0(void) using 1
              {
                  // [0x6503] Reset Protocol Layer State, Enable Counter & Timer
                  ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT5 | _BIT2 | _BIT1 | _BIT0), (_BIT2 | _BIT1));
              
                  // Enable Vbus Detection For CC HW to Detect Unattach Event
