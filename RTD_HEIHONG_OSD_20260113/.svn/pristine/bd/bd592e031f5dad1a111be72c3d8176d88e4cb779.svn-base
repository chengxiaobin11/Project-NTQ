                              // If BIST Carrier Mode, Reset PHY State Machine and Turn Off BIST Mode
                              if(GET_PD_RX0_SUB_STATE() == _PD_SUB_BIST_MODE)
                              {
                                  // Reset PHY FSM
                                  ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT0), 0x00);
              
                                  // Turn Off BIST UUT Carrier Mode
                                  ScalerSetBit_EXINT(P65_F0_PD_BIST_CFG, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2), 0x00);
              
                                  // Begin PHY FSM
                                  ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT0), _BIT0);
              
                                  // Enable Rcv Msg INT
                                  ScalerTypeCRx0PdRxIntControl_WDINT(_ENABLE);
                              }
              
                              ScalerTypeCRx0PdBackToReadyState_WDINT();
                          }
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_SNK_SWITCH_TO_SRC:
              
                          SET_PD_RX0_SUB_STATE(_PD_SUB_INT_SEND_SRC_ON_PSRDY);
              
                          // 1. if(PD 3.0), Switch HW Rp to Default Rp [0x6637][7:6]
                          if(GET_PD_RX0_SPEC_VER() == _PD_VERSION_3_0)
                          {
              #if(_TYPE_C_SRC_DEF_CUR == _TYPE_C_SRC_DEF_USB)
                              ScalerSetBit_EXINT(P66_37_CC_HW_Z_CFG, ~(_BIT7 | _BIT6), (_SET_RP_DEF << 6));
              #elif(_TYPE_C_SRC_DEF_CUR == _TYPE_C_SRC_DEF_1P5A)
                              ScalerSetBit_EXINT(P66_37_CC_HW_Z_CFG, ~(_BIT7 | _BIT6), (_SET_RP_1P5A << 6));
              #else
                              ScalerSetBit_EXINT(P66_37_CC_HW_Z_CFG, ~(_BIT7 | _BIT6), (_SET_RP_3P0A << 6));
              #endif  // End of #if(_TYPE_C_SRC_DEF_CUR == _SRC_DEF_USB)
                          }
              
                          // 2. Change Rd -> Rp (Switch to Power SRC)
                          ScalerTypeCRx0CcSwitchPowerRole_WDINT(_PD_POWER_SRC);
              
              #if(_TYPE_C_EMB_VBUS_PROTECT_MODE == _VBUS_PROTECT_BY_USER)
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 184 

                          SET_RX0_OCP_CURRENT((WORD)(((DWORD)(GET_CC_RX0_DEF_CUR()) * (DWORD)(GET_RX0_OCP_RATIO(0))) / 1
             -00));
              #else
                          SET_RX0_OCP_CURRENT((WORD)((DWORD)(GET_CC_RX0_DEF_CUR()) * _TYPE_C_DEF_OCP_RATIO / 100));
              #endif
              
                          // 3. Turn On Vbus to vSafe5V (500 * 10mV) / Current = Default Current (10mA)
                          ScalerTypeCPowerRx0VbusControl_WDINT(_ON, _PD_POWER_SRC, _PD_FIX_SUPPLY_PDO, 500, GET_RX0_OCP_
             -CURRENT(), _PD_PEAK_CUR_NONE);
              
              #if(_TYPE_C_EIZO_CUSTOMIZED_PMIC_SIC437A_SUPPORT == _ON)
                          // [Eizo] SIC437A Customized Power Control : Sink Receive PS_RDY When Source Turn Off Vbus in 
             -PR Swap
                          ScalerTypeCPmicRx0PRSwapToSrcProc_WDINT();
              #endif
              
                          // 4. Check Vbus 35ms (10ms + 25ms) after Received PS_RDY, Then Start PMIC Protection and Send
             - "PS_RDY" if VbusSafe5V
                          *pucActiveWDID = _SCALER_WD_TIMER_EVENT_PD_RX0_CHECK_PSRDY;
                          *pucActiveWDTime = 25;
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_SEND_EPR_ENTER_FAILED:
              
                          if(GET_PD_RX0_FW_STATE() != _PD_HARDRESET)
                          {
                              SET_PD_RX0_SUB_STATE(_PD_SUB_INT_SEND_EPR_ENTER_FAILED);
              
                              // Send Enter Failed : Source Not Vconn Source
                              SET_PD_RX0_EPR_MODE_ACTION(_PD_EPR_MODE_ENTER_FAILED);
                              SET_PD_RX0_ENTER_EPR_FAILED_REASON(_PD_EPR_MODE_ENTER_FAILED_NOT_VCONN_SOURCE);
                              ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_EPR_MODE, _PD_VDM_CMD_RESERVED);
                          }
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_SEND_VCONN_SWAP:
              
                          if(GET_PD_RX0_FW_STATE() != _PD_HARDRESET)
                          {
                              SET_PD_RX0_SUB_STATE(_PD_SUB_INT_SEND_VCONN_SWAP);
                              ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_VCONN_SWAP, _PD_VDM_CMD_RESERVED);
                          }
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_CHUNK_SENDER_REQ_TIMEOUT:
              
                          if(GET_PD_RX0_FW_STATE() != _PD_HARDRESET)
                          {
                              SET_PD_RX0_FW_STATE(_PD_INT_SEND_SOFTRESET);
                              SET_PD_RX0_AMS_STATUS(_PD_AMS_INTERRUPTIBLE);
                              SET_PD_RX0_SUB_STATE(_PD_SUB_STATE_NONE);
                              ScalerTypeCRx0PdSendSoftRst_WDINT(_PD_SOP_PKT);
                          }
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_SEND_EPR_SRC_CAP:
              
                          if(GET_PD_RX0_FW_STATE() != _PD_HARDRESET)
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 185 

                          {
                              // Send EPR Source Cap
                              CLR_PD_RX0_TX_CHUNK_NUMBER();
                              SET_PD_RX0_SUB_STATE(_PD_SUB_INT_SEND_EPR_SRC_CAP);
                              ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_EPR_SRC_CAP, _PD_VDM_CMD_RESERVED);
                          }
              
                          break;
              
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_TX_AVALIABLE:
              
                          switch(GET_PD_RX0_SUB_STATE())
                          {
                              case _PD_SUB_SEND_DP_VDM_REQ:
              
                                  if(GET_PD_RX0_FORCE_HPD_IRQ() == _TRUE)
                                  {
                                      if(GET_PD_RX0_DATA_ROLE() == _PD_DATA_UFP)
                                      {
                                          SET_PD_RX0_DP_ALT_STATE(_PD_ALT_MODE_SEND_ATTENTION);
              
                                          // Send "Attention REQ"
                                          ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_VDM, _PD_VDM_CMD_ATTENTION_
             -REQ);
                                      }
                                      else
                                      {
                                          // Send "DP Status REQ"
                                          ScalerTypeCRx0PdSendMsg_WDINT(_PD_SOP_PKT, _PD_CMD_VDM, _PD_VDM_CMD_10);
                                      }
                                  }
              
                                  break;
              
                              default:
              
                                  break;
                          }
              
                          break;
              
              #if(_TYPE_C_VENDOR_ALT_MODE == _TYPE_C_DELL_ALT_MODE)
                      case _SCALER_WD_TIMER_EVENT_PD_RX0_DELL_AM_ENTER_TIMEOUT:
              
                          SET_PD_RX0_DELL_AM_ENTER_TIMEOUT();
              
                          break;
              #endif
                      default:
              
                          break;
                  }
              }
              
              //--------------------------------------------------
              // Description  : Rx0 PD Power Switch Proc
              // Input Value  : enumPowerAction : Power Switch Enum
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdPowerSwitch(EnumPowerAction enumPowerAction)
              {
                  switch(enumPowerAction)
