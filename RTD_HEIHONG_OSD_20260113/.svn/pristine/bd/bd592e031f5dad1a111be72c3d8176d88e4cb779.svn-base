              void ScalerTypeCRx0PdPopHpd(void)
              {
                  if(GET_PD_RX0_HPD_CNT() > 0)
                  {
                      // Update HPD Status For DP Usage
                      if(GET_PD_RX0_HPD_QUEUE(GET_PD_RX0_HPD_RPTR()) == _PD_HPD_LOW)
                      {
                          ScalerDpRx0HpdToggleAuxPhyResetProc(_LOW);
