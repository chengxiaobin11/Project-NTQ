                                  {
                                      stTypeCSrcPdo.enumPeakCurrent = (EnumPDPeakCurType)GET_PD_RX0_SRC_CAP_PEAK(GET_PD_
             -RX0_PARTNER_OBJ_POS() - 1);
              
