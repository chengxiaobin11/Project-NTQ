              //--------------------------------------------------
              EnumPDAltModeState ScalerTypeCRx0PdJudgeCableId_EXINT0(void) using 1
              {
                  // Judge Whether The Cable Supports DP Functionality, and Switch DP_ALT_STATE
                  if(GET_PD_RX0_CBL_PRODUCT_TYPE() == _PD_PASSIVE_CABLE)
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 225 

                  {
                      if(GET_PD_RX0_CBL_USB_HIGHEST_SPEED() == _PD_CBL_USB_2_ONLY)
                      {
                          // Stop Enter DP Alt Mode Flow Both for Device & Cable
                          return _PD_ALT_MODE_ERROR;
                      }
                      else if(GET_PD_RX0_CBL_MODAL_OPERATION_SUPPORT() == _FALSE)
                      {
                          if((GET_PD_RX0_CBL_USB_HIGHEST_SPEED() == _PD_CBL_USB_3_GEN1) || (GET_PD_RX0_CBL_USB_HIGHEST_S
             -PEED() == _PD_CBL_USB_3OR4_GEN2))
