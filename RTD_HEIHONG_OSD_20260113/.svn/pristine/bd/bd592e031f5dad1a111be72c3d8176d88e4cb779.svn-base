                      if((g_pucDataObj_EXINT[18] & (_BIT2 | _BIT1)) == (_BIT2 | _BIT1))
                      {
                          // Cable Max Voltage = 50V = 500 * 100mV
                          SET_PD_RX0_CBL_MAX_VOL(500);
