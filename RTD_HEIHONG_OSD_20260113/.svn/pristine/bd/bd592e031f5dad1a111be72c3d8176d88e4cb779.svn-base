             -ver Identity Takes Priority
                          SET_PD_RX0_CBL_ACTIVE_COMPONENT(_PD_CBL_COMPONENT_ACTIVE_REDRIVER);
                      }
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 208 

                      else if((g_pucDataObj_EXINT[22] & _BIT1) == _BIT1)
