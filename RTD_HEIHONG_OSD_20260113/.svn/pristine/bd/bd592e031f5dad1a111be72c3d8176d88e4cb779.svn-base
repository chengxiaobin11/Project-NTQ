              //--------------------------------------------------
              // Description  : Filter Un-wanted Msg. Before Selecting FIFO to Process
              // Input Value  : FifoUsed : BIT2 (FIFO_0) / BIT1 (FIFO_1) / BIT0 (FIFO_2)
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdRxInvlidPktFilter_EXINT0(void) using 1
              {
                  // Check FIFO0 Status (Drop Msg if : Invalid Pkt, CRC Err, Abn Msg, Msg ID Err, CRC Resp Fail)
                  if(ScalerGetBit_EXINT(P65_42_RX_FIFO_GENERAL_INFO, _BIT2) == _BIT2)
                  {
                      if((ScalerGetByte_EXINT(P65_51_RX_FIFO0_RCV_ERR_INT) & (_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT0)) !=
             - 0x00)
                      {
              #if(_HW_TYPE_C_PD_VERSION == _TYPE_C_PD_HW_VERSION_1_0)
                          // FW Solution : When goodcrc_fail_irq && tx_ch_busy_irq Triggered, Reset Phy & Protocol FSM t
             -o Prevent HW Issue. (MM1GENERAL-2329)
                          if((ScalerGetBit_EXINT(P65_51_RX_FIFO0_RCV_ERR_INT, _BIT0) == _BIT0) && (ScalerGetBit_EXINT(P6
             -5_DB_TX_PHY_TRANS_INT, _BIT1) == _BIT1))
                          {
                              // Reset Phy & Protocol FSM
                              ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT5 | _BIT0), 0x00);
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 333 

                              ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT5 | _BIT0), (_BIT5 | _BIT0));
                          }
              #endif
              
                          ScalerTypeCRx0PdRxFifoClear_EXINT0(_PD_RX_FIFO_0);
                      }
                  }
              
                  // Check FIFO1 Status (Drop Msg if : Invalid Pkt, CRC Err, Abn Msg, Msg ID Err, CRC Resp Fail)
                  if(ScalerGetBit_EXINT(P65_42_RX_FIFO_GENERAL_INFO, _BIT1) == _BIT1)
                  {
                      if((ScalerGetByte_EXINT(P65_71_RX_FIFO1_RCV_ERR_INT) & (_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT0)) !=
             - 0x00)
                      {
              #if(_HW_TYPE_C_PD_VERSION == _TYPE_C_PD_HW_VERSION_1_0)
                          // FW Solution : When goodcrc_fail_irq && tx_ch_busy_irq Triggered, Reset Phy & Protocol FSM t
             -o Prevent HW Issue. (MM1GENERAL-2329)
                          if((ScalerGetBit_EXINT(P65_71_RX_FIFO1_RCV_ERR_INT, _BIT0) == _BIT0) && (ScalerGetBit_EXINT(P6
             -5_DB_TX_PHY_TRANS_INT, _BIT1) == _BIT1))
                          {
                              // Reset Phy & Protocol FSM
                              ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT5 | _BIT0), 0x00);
                              ScalerSetBit_EXINT(P65_03_PD_TOP_RST, ~(_BIT5 | _BIT0), (_BIT5 | _BIT0));
                          }
              #endif
              
                          ScalerTypeCRx0PdRxFifoClear_EXINT0(_PD_RX_FIFO_1);
                      }
                  }
              
                  // Check FIFO2 Status (Drop Msg if : Invalid Pkt, CRC Err, Abn Msg, Msg ID Err, CRC Resp Fail)
                  if(ScalerGetBit_EXINT(P65_42_RX_FIFO_GENERAL_INFO, _BIT0) == _BIT0)
                  {
                      if((ScalerGetByte_EXINT(P65_91_RX_FIFO2_RCV_ERR_INT) & (_BIT6 | _BIT5 | _BIT4 | _BIT2 | _BIT0)) !=
             - 0x00)
                      {
              #if(_HW_TYPE_C_PD_VERSION == _TYPE_C_PD_HW_VERSION_1_0)
                          // FW Solution : When goodcrc_fail_irq && tx_ch_busy_irq Triggered, Reset Phy & Protocol FSM t
             -o Prevent HW Issue. (MM1GENERAL-2329)
                          if((ScalerGetBit_EXINT(P65_91_RX_FIFO2_RCV_ERR_INT, _BIT0) == _BIT0) && (ScalerGetBit_EXINT(P6
             -5_DB_TX_PHY_TRANS_INT, _BIT1) == _BIT1))
                          {
