                          stTypeCPdo.enumPdoType = GET_PD_RX0_SRC_PDO_TYPE(ucPdoIndex - 1);
              
                          if(GET_PD_RX0_SRC_PDO_TYPE(ucPdoIndex - 1) == _PD_FIX_SUPPLY_PDO)
                          {
