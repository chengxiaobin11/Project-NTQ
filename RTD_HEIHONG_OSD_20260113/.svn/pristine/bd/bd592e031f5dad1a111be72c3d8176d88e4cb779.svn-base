                      ScalerSetBit_EXINT(P65_E5_TX_FIFO_MSG_HEADER0, ~(_BIT2, _BIT1), GET_PD_RX0_CBL_SPEC_VER() << 1);
                      ScalerSetBit_EXINT(P65_E5_TX_FIFO_MSG_HEADER0, ~_BIT0, 0x00);
              
