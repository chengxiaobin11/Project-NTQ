                              stTypeCPdo.usMaxVoltage = (GET_PD_RX0_SRC_CAP_VOL_MAX(ucPdoIndex - 1) / 10);
                              stTypeCPdo.usMinVoltage = (GET_PD_RX0_SRC_CAP_VOL_MIN(ucPdoIndex - 1) / 10);
              
