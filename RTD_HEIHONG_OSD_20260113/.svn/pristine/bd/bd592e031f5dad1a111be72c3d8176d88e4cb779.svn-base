                  // Lecroy [COMMON.CHECK.PD.3 Check GoodCRC] TEST.PD.PROT.SRC.6_Rev2Src
                  ScalerSetBit_EXINT(P65_E5_TX_FIFO_MSG_HEADER0, ~(_BIT2 | _BIT1), (_BIT1));
              
                  if(enumPacketType == _PD_SOP_PKT)
