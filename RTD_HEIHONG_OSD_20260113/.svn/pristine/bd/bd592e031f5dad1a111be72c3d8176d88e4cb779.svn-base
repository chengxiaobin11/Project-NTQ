              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdSnkReadyProc(void)
              {
                  if((GET_PD_RX0_SYS_EVENT() & _PD_SYS_EVENT_SEND_HARD_RESET) == _PD_SYS_EVENT_SEND_HARD_RESET)
                  {
                      ScalerTypeCRx0PdSendHardRst();
                      CLR_PD_RX0_SYS_EVENT(_PD_SYS_EVENT_SEND_HARD_RESET);
                      return;
                  }
                  else if((GET_PD_RX0_SYS_EVENT() & (_PD_SYS_EVENT_POWER_OCP | _PD_SYS_EVENT_POWER_OVP | _PD_SYS_EVENT_P
             -OWER_UVP | _PD_SYS_EVENT_VCONN_OCP)) != _PD_SYS_EVENT_NONE)
                  {
                      ScalerTypeCRx0PdOcpOvpProc();
                      return;
                  }
                  else if((GET_PD_RX0_SYS_EVENT() & _PD_SYS_EVENT_ALERT_EVENT) == _PD_SYS_EVENT_ALERT_EVENT)
                  {
                      SET_PD_RX0_SUB_STATE(_PD_SUB_SEND_ALERT);
                      return;
                  }
              
                  // Wait For Source to do PS_RDY or Alt. Mode Flow, Otherwise, Initiate Certain Flow
                  if(GET_PD_RX0_DATA_ROLE() == _PD_DATA_UFP)
                  {
              #if(_SNK_REQUEST_SWAP_TO_SRC == _TRUE)
                      if(GET_TYPE_C_RX0_PORT_ROLE() == _TYPE_C_PORT_DRP)
                      {
                          if((GET_PD_RX0_PARTNER_ALT_SUPPORT() == _FALSE) || (GET_PD_RX0_DP_ALT_MODE_CONFIG() == _PD_DP_
             -CONFIG) || (GET_PD_RX0_ALT_MODE_FUNCTION() == _FALSE))
                          {
                              if(GET_PD_RX0_GET_SNK_CAP_SENT() == _FALSE)
                              {
                                  if(GET_PD_RX0_GET_SNK_CAP_WAIT_FLAG() == _FALSE)
                                  {
                                      SET_PD_RX0_SUB_STATE(_PD_SUB_SEND_GET_SNK_CAP);
                                  }
                                  else
                                  {
                                      // [Workshop #114] MQP BMC-PHY-MSG (Rev 2.0):Confirm that repeated incoming Messag
             -eID is ignored. Solution: Wait > 40ms to avoid check point.
                                      ScalerTimerActiveTimerEvent(_TYPE_C_SNK_GET_SNK_CAP_WAIT_TIMER, _SCALER_TIMER_EVEN
             -T_PD_RX0_CLR_GET_SNK_CAP_WAIT);
                                  }
                              }
              #if(_REFER_TO_PORT_PARTNER_CAP == _TRUE)
