                          {
                              SET_PD_RX0_CBL_MAX_DP_RATE(_PD_CBL_MAX_UHBR20);
                          }
              
                          // Stop Enter DP Alt Mode Flow Just for Cable
                          CLR_PD_RX0_CBL_ENTER_DP_MODE_SUPPORT();
              
                          return _PD_ALT_MODE_SEND_ENTER_MODE;
                      }
                      else
                      {
                          // On-going Enter DP Alt Mode Flow Both for Device & Cable
                          return _PD_ALT_MODE_SEND_DISCOVER_SVID_SOP_P;
                      }
                  }
                  else if(GET_PD_RX0_CBL_PRODUCT_TYPE() == _PD_ACTIVE_CABLE)
                  {
                      if(GET_PD_RX0_CBL_MODAL_OPERATION_SUPPORT() == _FALSE)
                      {
                          // Stop Enter DP Alt Mode Flow Both for Device & Cable
                          return _PD_ALT_MODE_ERROR;
                      }
                      else
                      {
                          // On-going Enter DP Alt Mode Flow Both for Device & Cable
                          return _PD_ALT_MODE_SEND_DISCOVER_SVID_SOP_P;
                      }
                  }
                  else
                  {
                      // If Cable Type is VPD, Stop Enter DP Alt Mode Flow Both for Device & Cable
                      return _PD_ALT_MODE_ERROR;
                  }
              }
              
              //--------------------------------------------------
              // Description  : Search Through All SVIDs to All Svid The Cable Supports
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdSearchCableSvid_EXINT0(void) using 1
              {
                  CLR_PD_RX0_CBL_SVID_SEARCH_FINISH();
              
                  for(pData_EXINT[0] = 0; pData_EXINT[0] < (GET_PD_RX0_RCV_NOD_CNT() * 4); pData_EXINT[0] = pData_EXINT[
             -0] + 2)
                  {
                      if((g_pucDataObj_EXINT[pData_EXINT[0]] == 0xFF) && (g_pucDataObj_EXINT[pData_EXINT[0] + 1] == 0x01
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 226 

             -))
                      {   // if SVID = DP_SID (0xFF01), Set Cable DP Svid Support
                          SET_PD_RX0_CBL_DP_SVID_SUPPORT();
                      }
                      else if((g_pucDataObj_EXINT[pData_EXINT[0]] == 0x80) && (g_pucDataObj_EXINT[pData_EXINT[0] + 1] ==
             - 0x87))
                      {   // if SVID = TBT3_SID (0x8087), Set Cable TBT3 Svid Support
                          SET_PD_RX0_CBL_TBT3_SVID_SUPPORT();
                      }
                      else if((g_pucDataObj_EXINT[pData_EXINT[0]] == 0x00) && (g_pucDataObj_EXINT[pData_EXINT[0] + 1] ==
             - 0x00))
                      {   // if SVID = 0x00, Search Finish
                          SET_PD_RX0_CBL_SVID_SEARCH_FINISH();
                      }
                  }
              }
              
              //--------------------------------------------------
              // Description  : Record Cable Info Of Discover Dp Mode Ack
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdSaveCableDpModeInfo_EXINT0(void) using 1
              {
                  // Bit[31:30] VDO Version
                  if((g_pucDataObj_EXINT[4] & (_BIT7 | _BIT6)) == 0x00)
                  {
                      SET_PD_RX0_CBL_VDO_VERSION(_PD_DPAM_VDO_VERSION_ORIGINAL);
                  }
                  else if((g_pucDataObj_EXINT[4] & (_BIT7 | _BIT6)) == _BIT6)
                  {
                      SET_PD_RX0_CBL_VDO_VERSION(_PD_DPAM_VDO_VERSION_1);
                  }
              
                  // Bit[29:28] Active Components.
                  // When In DPAM:  1.[31:30] VDO Version = 1, Discover Mode Ack Takes Priority;  2.[31:30] VDO Version 
             -= 0, Discover ID Ack Takes Priotity.
                  if(GET_PD_RX0_CBL_VDO_VERSION() == _PD_DPAM_VDO_VERSION_1)
                  {
                      if((g_pucDataObj_EXINT[4] & (_BIT5 | _BIT4)) == 0x00)
                      {
                          SET_PD_RX0_CBL_ACTIVE_COMPONENT(_PD_CBL_COMPONENT_PASSIVE);
                      }
                      else if((g_pucDataObj_EXINT[4] & (_BIT5 | _BIT4)) == _BIT4)
                      {
                          SET_PD_RX0_CBL_ACTIVE_COMPONENT(_PD_CBL_COMPONENT_ACTIVE_RETIMER);
                      }
                      else if((g_pucDataObj_EXINT[4] & (_BIT5 | _BIT4)) == _BIT5)
                      {
                          SET_PD_RX0_CBL_ACTIVE_COMPONENT(_PD_CBL_COMPONENT_ACTIVE_REDRIVER);
                      }
                      else if((g_pucDataObj_EXINT[4] & (_BIT5 | _BIT4)) == (_BIT5 | _BIT4))
                      {
                          SET_PD_RX0_CBL_ACTIVE_COMPONENT(_PD_CBL_COMPONENT_OPTICAL);
                      }
              
                      // Bit[26] Cable UHBR13.5 Support: Y/N
                      if((g_pucDataObj_EXINT[4] & _BIT2) == _BIT2)
                      {
                          SET_PD_RX0_CBL_UHBR13P5_SUPPORT();
                      }
              
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 227 

                      // Bit[15:8] DP Source Device Pin Assignments Supported
                      if(g_pucDataObj_EXINT[6] == 0x0C)
                      {
                          SET_PD_RX0_CBL_PIN_ASSIGNMENT(_PD_CBL_PIN_ASSIGNMENT_C_AND_D);
                      }
                      else if(g_pucDataObj_EXINT[6] == 0x10)
                      {
                          SET_PD_RX0_CBL_PIN_ASSIGNMENT(_PD_CBL_PIN_ASSIGNMENT_E);
                      }
              
                      // Bit[5:2] Signalling for Cable Information Transport of DisplayPort Protocol
                      if((g_pucDataObj_EXINT[7] & _BIT4) == _BIT4)
                      {
                          SET_PD_RX0_CBL_MAX_DP_RATE(_PD_CBL_MAX_UHBR20);
                      }
              
                      if((g_pucDataObj_EXINT[7] & _BIT3) == _BIT3)
                      {
                          SET_PD_RX0_CBL_MAX_DP_RATE(GET_PD_RX0_CBL_MAX_DP_RATE() | _PD_CBL_MAX_UHBR10);
                      }
              
                      if((g_pucDataObj_EXINT[7] & _BIT2) == _BIT2)
                      {
                          SET_PD_RX0_CBL_MAX_DP_RATE(GET_PD_RX0_CBL_MAX_DP_RATE() | _PD_CBL_MAX_HBR3);
                      }
                  }
              }
              
