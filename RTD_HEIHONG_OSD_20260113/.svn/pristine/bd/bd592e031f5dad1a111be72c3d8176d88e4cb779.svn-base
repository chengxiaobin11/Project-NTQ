                                  // ----(2) For Main loop : Clear Macro When Send Msg Has Been Interrupted (Sent Discar
             -ded)
                                  // ----(3) For EXINT0 : Clear Macro When Received any Msg before _SRC_INIT_AMS_TIMER T
             -imeout
                                  // 3. Sent Success :
                                  // ----(1) For Attention Req : Clear Macro When Tx Success
                                  // ----(2) For DP Status Req :
                                  // --------(a) Clear Macro When Received DP Status ACK or Other Msg
                                  // --------(b) Clear Macro When Not Received Msg within _SENDER_RESP_TIMER
                                  SET_PD_RX0_FORCE_HPD_IRQ();
              
                                  // Send "DP Status REQ"
                                  ScalerTypeCRx0PdSendMsg(_PD_SOP_PKT, _PD_CMD_VDM, _PD_VDM_CMD_10);
              
                                  // Read Transmit Result
                                  if(GET_PD_RX0_TRANSMIT_RESULT() == _PD_SENT_SUCCESS)
                                  {
                                      SET_PD_RX0_AMS_STATUS(_PD_AMS_INTERRUPTIBLE);
                                      SET_PD_RX0_SUB_STATE(_PD_SUB_INT_WAIT_VDM_RESP);
              
                                      // Turn On Sender Response Timer 24~30 ms, Timeout : back to Sub SRC/SNK Ready and
             - Re-Send DP_STATUS
                                      ScalerTimerActiveTimerEvent(_SENDER_RESP_TIMER, _SCALER_TIMER_EVENT_PD_RX0_VDM_RES
             -P_TIMEOUT);
              
                                      ucSendResult = _SUCCESS;
                                  }
                                  else if(GET_PD_RX0_TRANSMIT_RESULT() == _PD_SENT_RETRY_FAIL)
                                  {
                                      CLR_PD_RX0_FORCE_HPD_IRQ();
              
                                      ScalerTypeCRx0PdSendSoftRst(_PD_SOP_PKT);
                                  }
                                  else if(GET_PD_RX0_TRANSMIT_RESULT() == _PD_SENT_DISCARDED)
                                  {   // Sent Discarded will be Set When Send Msg Has Been Interrupted
                                      CLR_PD_RX0_FORCE_HPD_IRQ();
                                  }
              
                                  // Enable Rcv Msg. Int
                                  ScalerTypeCRx0PdRxIntControl(_ENABLE);
                              }
                          }
                      }
                  }
              
                  if(ucSendResult == _FAIL)
                  {
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 357 

                      // Push HPD_IRQ into HPD Queue When Force Sending HPD IRQ Failed, then PD will Re-Send HPD_IRQ in 
             -Main loop
                      ScalerTypeCRx0PdPushHpd(_PD_HPD_IRQ, 0);
                  }
              }
              
              //--------------------------------------------------
              // Description  : Force Sending HPD IRQ for DP CTS @ Interrupt
              // Input Value  : None
              // Output Value : None
              //--------------------------------------------------
              void ScalerTypeCRx0PdDpCTSForceHpdIrq_EXINT0(void) using 1
              {
                  BYTE ucSendResult = _FAIL;
                  EnumTypeCTxCheckResult enumTxCheckResult = _PD_TX_NOT_AVAILABLE;
              
                  if((GET_PD_RX0_HANDLER_ONGOING() == _FALSE) && (GET_PD_RX0_HPD_STATUS() == _HIGH) &&
