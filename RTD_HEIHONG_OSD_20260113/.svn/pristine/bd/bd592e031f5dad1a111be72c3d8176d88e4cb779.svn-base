                  CLR_PD_RX0_CBL_DISCOVER_ID_RETRY_FAIL_CNT();
                  CLR_PD_RX0_PARTNER_VDM_NO_RESP_CNT();
                  CLR_PD_RX0_CBL_VDM_NO_RESP_CNT();
C51 COMPILER V9.60.0.0   SCALERCOMMONTYPECRX0PD                                            10/18/2025 16:53:20 PAGE 31  

