                  }
              
                  // Bit[18:16] Cable Speed
                  if((g_pucDataObj_EXINT[5] & (_BIT2 | _BIT1 | _BIT0)) == _BIT0)
                  {
                      SET_PD_RX0_CBL_TBT3_SPEED(_PD_CBL_TBT3_U3P1_GEN1);
