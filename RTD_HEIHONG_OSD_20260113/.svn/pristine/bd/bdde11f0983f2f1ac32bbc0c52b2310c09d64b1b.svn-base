                   11957     ;Boot Code and No Dual bank case do this.
0003 41            11958                     DB      41H                        ; XData
0004 FFFF          11959                     DW      ?B_XDATAPORT               ; Init XDATA Port
0006 00            11960                     DB      0 ; Set to intial bank
                   11961     
                   11962     
                   11963                     PUBLIC  ?B_XDATAPORT
