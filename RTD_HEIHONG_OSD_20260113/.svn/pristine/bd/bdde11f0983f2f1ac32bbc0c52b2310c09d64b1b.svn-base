                   11416     $nomod51  NOLINES
                   11417     $nocond 
                   11418     ;------------------------------------------------------------------------------
                   11419     ;  This file is part of the BL51 / LX51 Banked Linker/Locater package
                   11420     ;  Copyright (c) 1988 - 2001 Keil Elektronik GmbH and Keil Software, Inc.
                   11421     ;  Version 2.21 (Code and Variable Banking for Classic 8051 Derivatives)
                   11422     ;------------------------------------------------------------------------------
                   11423     ;************************ Configuration Section *******************************
                   11424     ; Define maximum Number of Banks                                              *
  0010             11425     ?B_NBANKS       EQU  0x10;                  *
                   11426     ;                         ; following values are allowed: 2, 4, 8, 16, 32, 64 *
                   11427     ;                         ; for BL51 the maximum value for ?B_BANKS is 32     *
                   11428     ;                         ; for LX51 the maximum value for ?B_BANKS is 64     *
                   11429     ;                                                                             *
  0001             11430     ?B_MODE         EQU  1    ; 0 for Bank-Switching via 8051 Port                *
                   11431     ;                         ; 1 for Bank-Switching via XDATA Port               *
                   11432     ;                         ; 4 for user-provided bank switch code              *
                   11433     ;                                                                             *
  0000             11434     ?B_RTX          EQU  0    ; 0 for applications without real-time OS           *
                   11435     ;                         ; 1 for applications using the RTX-51 real-time OS  *
                   11436     ;                                                                             *
  0000             11437     ?B_VAR_BANKING  EQU  0    ; Variable Banking via L51_BANK (far memory support)*
                   11438     ;                         ; 0 Variable Banking does not use L51_BANK.A51      *
                   11439     ;                         ; 1 Variable Banking uses this L51_BANK.A51 module  *
                   11440     ; Notes: ?B_VAR_BANKING uses the 'far' and 'far const' C51 memory types to    *
                   11441     ;        extent the space for variables in RAM and/or ROM of classic 8051     *
                   11442     ;        device.  The same hardware as for code banking is used.  Program     *
                   11443     ;        code banking and variable banking share the same hardware I/O pins.  *
                   11444     ;        The C51 Compiler must be used with the VARBANKING directive.         *
                   11445     ;        Variable Banking is only supported with the LX51 linker/locater.     *
                   11446     ;                                                                             *
  00FF             11447     ?B_RST_BANK     EQU  0xFF ; specifies the active code bank number after CPU   *
                   11448     ;                         ; Reset.  Used to reduce the entries in the         *
                   11449     ;                         ; INTERBANK CALL TABLE.  The value 0xFF disables    *
                   11450     ;                         ; this LX51 linker/locater optimization.            *
                   11451     ; Note:  Interbank Call Table optimization is only possible with LX51.        *
                   11452     ;                                                                             *
                   11453     ;-----------------------------------------------------------------------------*
                   11454     ;                                                                             *
                             ENDIF;                                                                        *
                   11467     ;                                                                             *
                   11468     IF  ?B_MODE = 1;                                                              *
                   11469     ;-----------------------------------------------------------------------------*
                   11470     ; if ?BANK?MODE is 1 define the following values                              *
                   11471     ; For Bank-Switching via XDATA Port define XDATA Port Address / Bits          *
  FFFF             11472     ?B_XDATAPORT    EQU     0FFFFH   ; default is XDATA Port Address 0FFFFH       *
  0000             11473     ?B_FIRSTBIT     EQU     0        ; default is Bit 0                           *
                   11474     ;-----------------------------------------------------------------------------*
                   11475     ENDIF;                                                                        *
                   11476     ;                                                                             *
                             ENDIF;                                                                        *
A51 MACRO ASSEMBLER  L51_BANK                                                             10/18/2025 16:52:24 PAGE    50

                   11535     ;                                                                             *
                             ENDIF;                                                                        *
                   11556     ;                                                                             *
                   11557     ;******************************************************************************
                   11558     ;                                                                             *
                   11559     ; THEORY OF OPERATION                                                         *
                   11560     ; -------------------                                                         *
                   11561     ; The section below describes the code generated by BL51 or LX51 and the      *
                   11562     ; operation of the L51_BANK.A51 module.  BL51/LX51 generates for each         *
                   11563     ; function that is located in a code memory bank and called from the common   *
                   11564     ; area or a different code bank and entry into the INTRABANK CALL TABLE.  The *
                   11565     ; INTRABANK CALL TABLE is located in the SEGMENT ?BANK?SELECT and listed in   *
                   11566     ; the Linker MAP file. The entries in that TABLE have the following format:   *
                   11567     ;                                                                             *
                   11568     ;   ?FCT?1:  MOV  DPTR,#FCT     ; Load Address of target FCT                  *
                   11569     ;            JMP  ?B_BANKn      ; Switch to Bank and Jump to Target Code      *
                   11570     ;                                                                             *
                   11571     ; Instead of directly calling the function FCT, the Linker changes the entry  *
                   11572     ; to ?FCT?1.  This entry selects the bank where the function FCT is located   *
                   11573     ; and calls that function via the routines defined in this L51_BANK.A51 file. *
                   11574     ; The L51_BANK.A51 file contains two sets of functions for each bank:         *
                   11575     ;                                                                             *
                   11576     ; ?B_BANKn    is a routine which saves the entry of the ?B_SWITCHn function   *
                   11577     ;             for the current active bank on the STACK and switches to the    *
                   11578     ;             bank 'n'.  Then it jumps to the address specified by the DPTR   *
                   11579     ;             register.  It is allowed to modify the following registers in   *
                   11580     ;             the ?B_BANKn routine:  A, B, R0, DPTR, PSW                      *
                   11581     ;                                                                             *
                   11582     ; ?B_SWITCHn  is a function which selects the bank 'n'.  This function is     *
                   11583     ;             used at the end of a user function to return to the calling     *
                   11584     ;             code bank.  Only the following registers may be altered in the  *
                   11585     ;             ?B_SWITCHn function:  R0, DPTR                                  *
                   11586     ;                                                                             *
                   11587     ; The current active bank is stored in ?B_CURRENTBANK.  RTX-51 uses this      *
                   11588     ; variable to restore the code bank after a task switch.  To get correct      *
                   11589     ; results, ?B_CURRENTBANK must be set to the code bank before the hardware    *
                   11590     ; switch is done, or the code banking sequences must be interrupt protected.  *
                   11591     ;******************************************************************************
                   11592     
                   11593                     NAME    ?BANK?SWITCHING
                   11594     
                   11595                     PUBLIC  ?B_NBANKS, ?B_MODE, ?B_CURRENTBANK, ?B_MASK
                   11596                     PUBLIC  ?B_FACTOR, ?B_RST_BANK
                             ENDIF
                   11600     
                   11601     ; Standard SFR Symbols required in L51_BANK.A51
  00E0             11602     ACC     DATA    0E0H
  00F0             11603     B       DATA    0F0H
  0082             11604     DPL     DATA    82H
  0083             11605     DPH     DATA    83H
  00A8             11606     IE      DATA    0A8H
  00AF             11607     EA      BIT     IE.7
                   11608     
                   11609     
                   11610     ; generate Mask and Bank Number Information
                             ELSEIF  ?B_NBANKS <= 16
  000F             11618       MASK          EQU     00001111B
                             ENDIF
                   11624     
                             ENDIF  ; close block IF ?B_MODE = 0 *******************************************
                   11878     
                   11879     
                   11880     IF ?B_MODE = 1 ;***************************************************************
                   11881     
  0001             11882     ?B_FACTOR       EQU     1 SHL ?B_FIRSTBIT
                   11883     
A51 MACRO ASSEMBLER  L51_BANK                                                             10/18/2025 16:52:24 PAGE    51

  000F             11884     ?B_MASK         EQU     MASK SHL ?B_FIRSTBIT
                   11885     
                   11886     BANKN           MACRO   N
                   11887     BANK&N          EQU     N SHL ?B_FIRSTBIT
                   11888                     ENDM
                   11889     
  0000             11890     CNT             SET     0
                   11891     
                   11892                     REPT    ?B_NBANKS
                   11893                     BANKN   %CNT
                   11894     CNT             SET     CNT+1
                   11895                     ENDM
