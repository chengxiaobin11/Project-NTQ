                   11946     ?C_INITSEG      SEGMENT CODE            ; Segment for Variable Initialization
----               11947                     RSEG    ?C_INITSEG
0000 01            11948                     DB      01H             ; IData
0001 00       F    11949                     DB      ?B_CURRENTBANK  ; Init Current Bank
0002 00            11950                     DB      0               ; Set to Zero
                   11951     
                   11952     
                   11953     
                   11954     
                   11955     
