2907          // Description  : Measure Clk
2908          // Input Value  : Clk Source to be measured
2909          // Output Value : Measured Clk Count
2910          //--------------------------------------------------
2911          WORD ScalerTMDSRx3MeasureClk(BYTE ucMeasureClk)
2912          {
2913   1          BYTE ucDelayCount = 0;
2914   1      
2915   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Enable Rx_EN (Lane0,3)
                      ScalerSetBit(P7C_1A_CMU_00, ~(_BIT7 | _BIT4), (_BIT7 | _BIT4));
                  }
                  else
              #endif
2923   1          {
2924   2              // Enable Rx_EN (Lane3)
2925   2              ScalerSetBit(P7C_1A_CMU_00, ~_BIT7, _BIT7);
2926   2          }
2927   1      
2928   1          // Disable Measure for Reset Measure Window
2929   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2930   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), 0x00);
2931   1      
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX3                                             10/18/2025 16:53:47 PAGE 50  

2932   1          // Select reference clk to Xtal Clk and measure clk
2933   1          ScalerSetBit(P72_AD_TMDS_CPS, ~(_BIT6 | _BIT5 | _BIT4), ((ucMeasureClk << 5) | _BIT4));
2934   1      
2935   1          // Start Measure
2936   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2937   1          ScalerSetBit(P72_CA_HDMI_DP, ~(_BIT5 | _BIT4 | _BIT3), _BIT3);
2938   1      
2939   1          // Delay at least 40us at Xtal = 27MHz
2940   1          for(ucDelayCount = 0; ucDelayCount <= 8; ucDelayCount++)
2941   1          {
2942   2              DELAY_5US();
2943   2      
2944   2              ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2945   2              if(ScalerGetBit(P72_CA_HDMI_DP, _BIT3) == 0x00)
2946   2              {
2947   3                  break;
2948   3              }
2949   2          }
2950   1      
2951   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0);
2952   1          pData[0] = ScalerGetByte(P72_CA_HDMI_DP);
2953   1      
2954   1          ScalerSetByte(P72_C9_HDMI_AP, _P72_CA_PT_29_PORT_PAGE72_HDMI_NTX1024TR1);
2955   1          pData[1] = ScalerGetByte(P72_CA_HDMI_DP);
2956   1      
2957   1          return ((WORD)(pData[0] & 0x07) << 8) | pData[1];
2958   1      }
