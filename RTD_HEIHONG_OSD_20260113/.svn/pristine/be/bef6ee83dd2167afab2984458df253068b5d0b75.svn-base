3065          //--------------------------------------------------
3066          // Description  : Set Deep Color PLL
3067          // Input Value  : usTMDSClkCount, ucColorDepth
3068          // Output Value : None
3069          //--------------------------------------------------
3070          bit ScalerTMDSRx3HdmiSetDeepColorPll(WORD usTMDSClkCount, BYTE ucColorDepth)
3071          {
3072   1          DWORD ulTMDSClkValue = 0;
3073   1          WORD usM = 0;
3074   1          BYTE ucN = 0;
3075   1          BYTE ucDivS = 0;
3076   1          BYTE ucFactor = 0;
3077   1      
3078   1      #if((_D3_HDMI_2_0_SUPPORT == _ON) && (_HDMI_2_0_YCBCR420_SUPPORT == _ON))
3079   1          BYTE ucRatio = 1;
3080   1      #endif
3081   1      
3082   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3083   1          // Fin = TMDS_clk
3084   1          // Fref = Fin / N
3085   1          // Fvco = Fin * M / N
3086   1          // Freq = Fvco / Divs
3087   1          //
3088   1          // Restriction
3089   1          // A. BW = Kvco * Icp * R / (M * 2pi) = 700k (Band10 Kvco = 1880), R = 13k)
3090   1          // B. 300MHz < Fvco < 600MHz
3091   1          // C. (Fin / N) >= 10 * BW --> (Fin / N) >= 7MHz
3092   1          // D. YCbCr 420, Ratio = 2, other case Ratio = 1
3093   1          //
3094   1          // note 1.   According A, Icp = 2.5 ~ 20 --> 14 <= M <= 111
3095   1          // note 2.   According B and note 1. --> 3 <= (Fin / N) <= 42
3096   1          // note 3.   According C and note 2. --> 7 <= (Fin / N) <= 42
3097   1          // note 4_a. 10bit : (M / N / Divs) = (4 / 5 * Ratio) --> M = N * Divs * (4 / 5 * Ratio), N or Divs: m
             -ultiple of 5
3098   1          // note 4_b. 12bit : (M / N / Divs) = (2 / 3 * Ratio) --> M = N * Divs * (2 / 3 * Ratio), N or Divs: m
             -ultiple of 3
3099   1          // note 4_b. 16bit : (M / N / Divs) = (1 / 2 * Ratio) --> M = N * Divs * (1 / 2 * Ratio), N or Divs: m
             -ultiple of 2
3100   1          ////////////////////////////////////////////////////////////////////////////////////////////////
3101   1      
3102   1          // If Measure Divider = /2 then TMDS_CLK x 2, unit:kHz
3103   1          if(ScalerGetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_28_PORT_PAGE72_HDMI_NTX1024TR0, _BIT6) == _BIT6)
3104   1          {
3105   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 * 2 / usTMDSClkCount;
3106   2          }
3107   1          else
3108   1          {
3109   2              ulTMDSClkValue = (DWORD)_GDI_CLK_KHZ * 1024 / usTMDSClkCount;
3110   2          }
3111   1      
3112   1      #if(_D3_HDMI_2_0_SUPPORT == _ON)
3113   1      
3114   1          if(GET_TMDS_RX3_HIGH_SPEED_MODE() == _TRUE)
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX3                                             10/18/2025 16:53:47 PAGE 53  

3115   1          {
3116   2              ulTMDSClkValue = (ulTMDSClkValue << 2);
3117   2          }
3118   1      
3119   1      #if(_HDMI_2_0_YCBCR420_SUPPORT == _ON)
3120   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420)
3121   1          {
3122   2              ucRatio = 2;
3123   2          }
3124   1      #endif
3125   1      
3126   1      #endif
3127   1      
3128   1          DebugMessageRx3("TMDS clk", ulTMDSClkValue);
3129   1          DebugMessageRx3("Color Depth", ucColorDepth);
3130   1      
3131   1          switch(ucColorDepth)
3132   1          {
3133   2              case _COLOR_DEPTH_10_BITS:
3134   2      
3135   2                  ucFactor = 5;
3136   2      
3137   2                  break;
3138   2      
3139   2              case _COLOR_DEPTH_12_BITS:
3140   2      
3141   2                  ucFactor = 3;
3142   2      
3143   2                  break;
3144   2      
3145   2              case _COLOR_DEPTH_16_BITS:
3146   2      
3147   2                  ucFactor = 2;
3148   2      
3149   2                  break;
3150   2      
3151   2              default:
3152   2      
3153   2                  return _FALSE;
3154   2          }
3155   1      
3156   1          // N <= (Fin / 7)
3157   1          PDATA_WORD(0) = (ulTMDSClkValue / 7000);
3158   1      
3159   1          if(PDATA_WORD(0) < 2)
3160   1          {
3161   2              return _FALSE;
3162   2          }
3163   1          else if(PDATA_WORD(0) >= ucFactor)
3164   1          {
3165   2              // N: Multiple of factor
3166   2              PDATA_WORD(0) -= (PDATA_WORD(0) % ucFactor);
3167   2          }
3168   1          else if(PDATA_WORD(0) > 255)
3169   1          {
3170   2              // N: Multiple of factor
3171   2              PDATA_WORD(0) = 255 - (255 % ucFactor);
3172   2          }
3173   1      
3174   1          ucN = PDATA_WORD(0);
3175   1      
3176   1          // for differenct Divs, find suitable Divs and M
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX3                                             10/18/2025 16:53:47 PAGE 54  

3177   1          for(pData[15] = 0; pData[15] <= 254; pData[15] += 2)
3178   1          {
3179   2              // N or Divs: Multiple of factor
3180   2              if(((ucN % ucFactor) == 0x00) || ((pData[15] % ucFactor) == 0x00))
3181   2              {
3182   3      #if((_D3_HDMI_2_0_SUPPORT == _ON) && (_HDMI_2_0_YCBCR420_SUPPORT == _ON))
3183   3                  usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor * ucRatio;
3184   3      #else
                          usM = (WORD)ucN * ((pData[15] == 0) ? 1 : pData[15]) * (ucFactor - 1) / ucFactor;
              #endif
3187   3      
3188   3                  // Fvco = Fin * M / N
3189   3                  PDATA_DWORD(0) = (ulTMDSClkValue * usM / ucN);
3190   3      
3191   3                  if((PDATA_DWORD(0) >= 300000) && (PDATA_DWORD(0) <= 600000))
3192   3                  {
