4207          //--------------------------------------------------
4208          // Description  : DFE Adaptation in Normal Signal
4209          // Input Value  : None
4210          // Output Value : True --> DFE Normal
4211          //                False --> DFE Abnormal
4212          //--------------------------------------------------
4213          bit ScalerTMDSRx3CheckDataDFE(void)
4214          {
4215   1          BYTE ucTemp = 0;
4216   1          BYTE ucCnt = 0;
4217   1      
4218   1          // DFE Check only under HDMI Mode.
4219   1          // MHL has only 1 data Lane --> Skip DFE Check Process and Function return True!
4220   1          if(ScalerGetBit(P7C_17_BANDGAP_03, _BIT1) != _BIT1)
4221   1          {
4222   2              for(pData[0] = 0; pData[0] <= 2; pData[0]++)
4223   2              {
4224   3                  // Sel lane
4225   3                  ScalerSetBit(P7C_F2_COEF_3, ~(_BIT7 | _BIT6), pData[0] << 6);
4226   3      
4227   3                  // Read VTH
4228   3                  ScalerSetBit(P7C_F0_COEF_1, ~(_BIT5 | _BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), 0x00);
4229   3      
4230   3                  if((ScalerGetByte(P7C_F1_COEF_2) & 0x1F) == 0)
4231   3                  {
4232   4                      for(ucCnt = 0; ucCnt < 3; ucCnt++)
