 303          //--------------------------------------------------
 304          // Description  : Initialize TMDS Interrupt Required Settings
 305          // Input Value  : None
 306          // Output Value : None
 307          //--------------------------------------------------
 308          void ScalerTMDSRx3InterruptInitial(void)
 309          {
 310   1          if(ScalerGetBit(P72_E6_HDMI_FREQDET_CTRL, _BIT1) == 0x00)
 311   1          {
 312   2              CLR_TMDS_RX3_PHY_SET();
 313   2          }
 314   1      
 315   1          // Enable Rx_En for Clk pair Z0
 316   1          ScalerSetBit(P7C_1A_CMU_00, ~_BIT7, _BIT7);
 317   1      
 318   1          // Choose Measure Clk to TMDS Clk
 319   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~(_BIT7 | _BIT5 | _BIT4), 0x00);
 320   1      
 321   1          // Set Freq. Reference Counter = 2000
 322   1          ScalerSetBit(P72_F6_HDMI_FREQDET_BOUND_H, ~(_BIT1 | _BIT0), _BIT0);
 323   1      
 324   1          // Set Online Measure Input Clock Divider = /2 (No Matter if Input Clock >300Mhz or <=300Mhz)
 325   1          ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~_BIT6, _BIT6);
 326   1      
 327   1          // Settings for IRQ set PHY
 328   1          // Consider using table to fill all required initial settings
 329   1          // Set pre-set threshold (225MHz * 0.01 / 26.8KHz = 0x54)
 330   1      
 331   1      #if(_D3_INPUT_PORT_TYPE == _D3_MHL_PORT)
                  if(GET_D3_TMDS_MODE() == _TMDS_MHL_MODE)
                  {
                      // Set TMDS Offset = 1/32
                      ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
              
                      // Set Upper Bound
                      ScalerSetByte(P72_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                      ScalerSetByte(P72_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_MHL_FREQ_NORMAL_UPPER_BOUND));
                  }
                  else
              #endif
 343   1          {
 344   2              // Set TMDS Offset = 1/32
C51 COMPILER V9.60.0.0   RL6449_SERIES_TMDSRX3                                             10/18/2025 16:53:47 PAGE 7   

 345   2              ScalerSetBit(P72_E7_HDMI_FREQDET_OFFSET, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 346   2      
 347   2              // Set Upper Bound
 348   2              ScalerSetByte(P72_E8_HDMI_FREQDET_UPPER_M, HIBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 349   2              ScalerSetByte(P72_E9_HDMI_FREQDET_UPPER_L, LOBYTE(_TMDS_FREQ_NORMAL_HIGH_SPEED_UPPER_BOUND));
 350   2          }
 351   1      
 352   1          // Set Lower Bound
 353   1          ScalerSetByte(P72_EA_HDMI_FREQDET_LOWER_M, HIBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 354   1          ScalerSetByte(P72_EB_HDMI_FREQDET_LOWER_L, LOBYTE(_TMDS_FREQ_NORMAL_LOWER_BOUND));
 355   1      
 356   1          // Set Stable Time (0x3F = about 5ms)
 357   1          ScalerSetByte(P72_EC_HDMI_FREQDET_STABLE, 0x3F);
 358   1      
 359   1          // Disable Freq. Unstable IRQ
 360   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~_BIT1, 0x00);
 361   1      
 362   1          // Enable Freq. Stable IRQ
 363   1          ScalerSetBit(P72_EF_HDMI_ERROR_TH, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 364   1      
 365   1      #if(_D3_HDMI_2_0_SUPPORT == _ON)
 366   1          // Enable SCDC 0x20 Change IRQ
 367   1          ScalerSetBit(P72_26_HDMI_CTRL_26, ~_BIT4, _BIT4);
 368   1      #endif
 369   1      
 370   1          // Clear IRQ Pending Flag
 371   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_60_PORT_PAGE72_HDMI_INTCR, ~_BIT7, _BIT7);
 372   1      
 373   1          // Internal IRQ Enable (Global)
 374   1          ScalerGlobalIRQControl(_ENABLE);
 375   1      
 376   1          EX0 = 1;
 377   1      
 378   1          // Start Freq. Detection
 379   1          ScalerSetBit(P72_E6_HDMI_FREQDET_CTRL, ~_BIT7, _BIT7);
 380   1      }
