3200   3                  DebugMessageRx3("4. PLL Setting Error", 0);
3201   3                  return _FALSE;
3202   3              }
3203   2          }
3204   1      
3205   1          //////////////////////////////////////////////////////////////////////////////////////////////////
3206   1          // Precise formula of Chrage Pump Current depends on DPM, resistor, and band.                   //
3207   1          // If VCO band = 'b00, Icp = (700 * M * 2 * pi) / (778 * 0x01C1[7:5]).                          //
3208   1          // If VCO band = 'b01, Icp = (700 * M * 2 * pi) / (1340 * 0x01C1[7:5]).                         //
3209   1          // If VCO band = 'b10, Icp = (700 * M * 2 * pi) / (1880 * 0x01C1[7:5]).                         //
3210   1          // If VCO band = 'b11, Icp = (700 * M * 2 * pi) / (2340 * 0x01C1[7:5]).                         //
3211   1          // 700: DPLL max frequency design target is 700MHz; 778: Frequency curve in band00 is 778MHz.   //
3212   1          // Assume DPLL_M=0x13, DPM=0x13+2=21; DPN=2; reg_dpll_vcomd='b01; reg_dpll_rs[2:0]='b011;       //
3213   1          // Icp = (700 * 21 * 2 * 3.14) / (1340 * 13)                                                    //
3214   1          //////////////////////////////////////////////////////////////////////////////////////////////////
3215   1      
