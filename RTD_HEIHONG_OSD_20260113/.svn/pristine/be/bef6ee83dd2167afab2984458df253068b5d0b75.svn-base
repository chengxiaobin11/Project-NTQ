 382          //--------------------------------------------------
 383          // Description  : TMDS DFE Initial Setting (EXINT0 Only)
 384          // Input Value  : None
 385          // Output Value : None
 386          //--------------------------------------------------
 387          void ScalerTMDSRx3SetDFEInitial_EXINT0(void) using 1
 388          {
