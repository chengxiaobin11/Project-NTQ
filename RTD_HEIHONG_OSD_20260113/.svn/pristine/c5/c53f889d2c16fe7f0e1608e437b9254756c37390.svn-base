 304   1             (GET_MODE_STATE() != _MODE_STATUS_INITIAL) &&
 305   1             (UserInterfaceGetForcePSStatus() == _FALSE) &&
 306   1             (UserInterfaceSourceBypassDetection() == _SOURCE_DETECTION_NORMAL))
 307   1          {
 308   2              if(GET_SOURCE_JUDGE(g_ucSearchIndex) == _FALSE)
 309   2              {
