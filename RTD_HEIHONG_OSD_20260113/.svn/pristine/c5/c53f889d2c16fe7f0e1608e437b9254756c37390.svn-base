                     ((GET_SOURCE_SCAN_TYPE() == _SOURCE_SWITCH_HP_SOURCE_SCAN) ||
                      (GET_SOURCE_SCAN_TYPE() == _SOURCE_SWITCH_HP_OOR_SOURCE_SCAN) ||
                      (GET_SOURCE_SCAN_TYPE() == _SOURCE_SWITCH_HP_SCAN_SWITCH_PORT) ||
