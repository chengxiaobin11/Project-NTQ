              //--------------------------------------------------
              BYTE SysSourceBgGetInputPort(void)
              {
                  return SysSourceGetSpecificInputPort(g_ucBgDetectIndex);
              }
              
              //--------------------------------------------------
              // Description  : Get Background Detection Judge or Not
              // Input Value  : None
