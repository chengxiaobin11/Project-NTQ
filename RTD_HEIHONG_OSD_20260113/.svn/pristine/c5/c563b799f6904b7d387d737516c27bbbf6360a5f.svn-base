1136          // Input Value  : ucInputPort
1137          // Output Value : None
1138          //--------------------------------------------------
1139          void ScalerTMDSHdmiHpd5vPinCheck(BYTE ucInputPort)
1140          {
1141   1          DELAY_XUS(500);
1142   1      
1143   1          if(ScalerTMDSHdmiHpd5vPinDetect(ucInputPort) == _HIGH)
1144   1          {
1145   2              if((ScalerTMDSHdmiGetScdcInfoFlag(ucInputPort) == _FALSE) && (ScalerTMDSRxGetCableStatus(ucInputPo
             -rt) == _TRUE))
1146   2              {
1147   3                  ScalerTMDSHdmiSetScdcInfo(ucInputPort);
1148   3      
1149   3      #if(_HDMI_FREESYNC_SUPPORT == _ON)
                          if(ScalerTMDSHdmiGetFreeSyncSupport(ucInputPort) == _FREESYNC_SUPPORT_ON)
                          {
                              ScalerTMDSHdmiSetAmdAupiScdcInfo(ucInputPort, _ENABLE);
                          }
                          else
                          {
                              ScalerTMDSHdmiSetAmdAupiScdcInfo(ucInputPort, _DISABLE);
                          }
              #endif
1159   3              }
1160   2      
1161   2              ScalerTMDSHdmiSetHpd5vPinHighFlag(ucInputPort, _ON);
1162   2          }
1163   1          else if((ScalerTMDSHdmiHpd5vPinDetect(ucInputPort) == _LOW) && (ScalerTMDSHdmiGetHpd5vPinHighFlag(ucIn
             -putPort) == _TRUE))
1164   1          {
1165   2              ScalerTMDSHdmiResetScdcInfo(ucInputPort);
1166   2      
1167   2              // 5V Low then Reset Scramble Status
1168   2              ScalerTMDSHdmiScrambleStatusReset(ucInputPort);
1169   2      
1170   2              ScalerTMDSHdmiSetScdcInfoFlag(ucInputPort, _OFF);
1171   2      
1172   2              ScalerTMDSHdmiSetHpd5vPinHighFlag(ucInputPort, _OFF);
1173   2          }
1174   1      
1175   1          ScalerTMDSHdmiHpd5vPinCheckEvent(ucInputPort, _ENABLE);
1176   1      }
