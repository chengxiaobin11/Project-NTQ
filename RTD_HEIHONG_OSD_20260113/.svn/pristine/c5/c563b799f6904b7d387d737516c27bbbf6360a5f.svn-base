                      case _D5_INPUT_PORT:
                          enumFreeSyncSupport = GET_TMDS_RX5_FREESYNC_SUPPORT();
                          break;
              
                      default:
                          break;
                  }
              
                  return enumFreeSyncSupport;
              }
              
