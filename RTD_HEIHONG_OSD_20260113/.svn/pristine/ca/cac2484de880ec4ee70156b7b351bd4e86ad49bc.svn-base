                              break;
              
                          case _AVI_COLORIMETRY_01:
              
                              DebugMessageRx4("Get Colorimetry YCC_SMPTE_170M", 0x00);
              
                              SET_TMDS_RX4_COLORIMETRY_PREVALUE(_AVI_COLORIMETRY_01);
              
                              SET_COLORIMETRY(_COLORIMETRY_YCC_SMPTE_170M);
              
                              break;
              
                          case _AVI_COLORIMETRY_10:
              
