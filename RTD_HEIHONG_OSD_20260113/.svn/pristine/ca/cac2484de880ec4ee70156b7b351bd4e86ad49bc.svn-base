              void ScalerSyncHdcpDownLoadDPTxAKey(WORD usLength, BYTE *pucReadArray)
              {
                  ScalerWrite(PBB_32_DP_HDCP_KEY_DL_PORT, usLength, pucReadArray, _NON_AUTOINC);
              }
