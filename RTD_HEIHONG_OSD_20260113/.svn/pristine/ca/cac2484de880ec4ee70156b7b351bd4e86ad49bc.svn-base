                          pucTemp[1] = GET_TMDS_RX0_COLORIMETRY_PREVALUE();
              
                          ScalerSyncTMDSRx0HdmiColorimetrySetting();
              
                          if((GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422
             -) || (GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR444))
                          {
                              if(!(((pucTemp[0] == _AVI_COLORIMETRY_00) && (pucTemp[1] == _AVI_COLORIMETRY_01)) || ((puc
             -Temp[0] == _AVI_COLORIMETRY_01) && (pucTemp[1] == _AVI_COLORIMETRY_00))))
                              {
                                  SET_TMDS_RX0_COLORIMETRY_CHANGED();
                              }
