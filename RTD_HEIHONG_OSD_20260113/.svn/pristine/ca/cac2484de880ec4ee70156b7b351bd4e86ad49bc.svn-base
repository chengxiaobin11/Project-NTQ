              #endif
              
                      SET_TMDS_RX1_AVI_PIXEL_REPETITION(_AVI_PIXEL_REPETITION_0);
              
                      // Waiting for down sampling  effect
                      ScalerTimerDelayXms(20);
                  }
              
                  ScalerTMDSRx1SetPorchColor(GET_COLOR_SPACE());
