              #endif
              
              #if(_D1_DP_EXIST == _ON)
                  if(GET_DP_RX_HDCP2_UPSTREAM_PORT() == _HDCP_D1_PORT)
                  {
                      return GET_DP_RX1_HDCP2_MODE();
                  }
              #endif
              
                  return _FALSE;
              }
              
