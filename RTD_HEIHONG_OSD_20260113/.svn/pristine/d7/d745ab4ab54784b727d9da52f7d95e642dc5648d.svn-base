 242          //--------------------------------------------------
 243          // Description  : Get DPF Edid Extersion Data Block Start Address
 244          // Input Value  : enumOutputPort (Px), Cta Ext DB Addr Arrary
 245          // Output Value :
 246          //--------------------------------------------------
 247          void ScalerSyncGetCtaExtDbAddress(WORD *pusCtaDataBlockAddr, BYTE *pucDdcRamAddr)
 248          {
 249   1          WORD usEDIDDataBlockStartAddress = 0x84;
 250   1          WORD usCtaBlockDtdStartAddr = 0x84;
 251   1      
 252   1          BYTE ucReadVSDBDataBlockNum = 0x00;
 253   1          BYTE ucEDIDBlockBytesNum = 0x00;
 254   1          EnumEdidCtaDbTagCode enumTag = _CTA_DBTAG_NONE;
 255   1      
 256   1          // With Extension Block
 257   1          if(pucDdcRamAddr[0x7E] != 0x00)
 258   1          {
 259   2              WORD usIndex = 0;
 260   2              BYTE ucExtBlockNum = 0;
 261   2      
 262   2              // Check HF EEODB
 263   2              if(((pucDdcRamAddr[0x84] & 0xE0) == 0xE0) && (pucDdcRamAddr[0x85] == 0x78))
 264   2              {
 265   3                  ucExtBlockNum = pucDdcRamAddr[0x86];
 266   3              }
 267   2              else
 268   2              {
 269   3                  ucExtBlockNum = pucDdcRamAddr[0x7E];
 270   3              }
 271   2      
 272   2              for(usIndex = 0; usIndex < ucExtBlockNum; usIndex++)
 273   2              {
 274   3                  // Stop Extension Analysis if Not CEA Type, Check tag = 0x02
 275   3                  if(pucDdcRamAddr[(usIndex + 1) * 0x80] == _CTA_EXTENSION_TAG)
 276   3                  {
 277   4                      usEDIDDataBlockStartAddress = ((usIndex + 1) * 0x80) + 0x04;
 278   4      
 279   4                      usCtaBlockDtdStartAddr = pucDdcRamAddr[((usIndex + 1) * 0x80) + 0x02] + ((usIndex + 1) * 0
             -x80);
 280   4      
 281   4                      if((pucDdcRamAddr[((usIndex + 1) * 0x80) + 0x02] == 4) || (pucDdcRamAddr[((usIndex + 1) * 
             -0x80) + 0x02] == 0))
 282   4                      {
 283   5                          // No Data Block Situation => d = 4, Record Cta Extend Block 1st DTD Start Addr, Searc
             -h other Block.
 284   5                          // No DTD & No Data Block Situation => d = 0, Record Cta Extend Block 1st DTD Start Ad
             -dr, Search other Block.
 285   5                          // Generally, the _FIRST_EXT_DTD_ADDR also meaning the last Data Block + 1.
 286   5                          pusCtaDataBlockAddr[_FIRST_EXT_DTD_ADDR] = usEDIDDataBlockStartAddress;
 287   5                          continue;
 288   5                      }
 289   4      
C51 COMPILER V9.60.0.0   SCALERSYNC                                                        10/18/2025 16:52:50 PAGE 6   

 290   4                      // Data Block Address Scan
 291   4                      while((usEDIDDataBlockStartAddress < usCtaBlockDtdStartAddr) && (ucReadVSDBDataBlockNum <=
             - 0x0F))
 292   4                      {
 293   5                          ucReadVSDBDataBlockNum = (ucReadVSDBDataBlockNum + 1);
 294   5                          enumTag = (pucDdcRamAddr[usEDIDDataBlockStartAddress] & 0xE0) >> 5;
 295   5      
 296   5                          switch(enumTag)
 297   5                          {
 298   6                              // Extension Data Block, Check Tag Code
 299   6                              case _CTA_DBTAG_EXTTAG:
 300   6      
 301   6                                  ucEDIDBlockBytesNum = (pucDdcRamAddr[usEDIDDataBlockStartAddress] & 0x1F);
 302   6      
 303   6                                  // Check Tag Code of Extension Data Block
 304   6                                  switch(pucDdcRamAddr[usEDIDDataBlockStartAddress + 1])
 305   6                                  {
 306   7                                      case _CTA_EXTDBTAG_VCDB:
 307   7                                          pusCtaDataBlockAddr[_CTA_VCDB] = usEDIDDataBlockStartAddress;
 308   7                                          break;
 309   7      
 310   7                                      case _CTA_EXTDBTAG_COLORDB:
 311   7      
 312   7                                          pusCtaDataBlockAddr[_CTA_CDB] = usEDIDDataBlockStartAddress;
 313   7                                          break;
 314   7      
 315   7                                      case _CTA_EXTDBTAG_SHDR_DB:
 316   7      
 317   7                                          pusCtaDataBlockAddr[_CTA_SHDR_DB] = usEDIDDataBlockStartAddress;
 318   7                                          break;
 319   7      
 320   7                                      case _CTA_EXTDBTAG_420VDB:
 321   7      
 322   7                                          pusCtaDataBlockAddr[_CTA_420VDB] = usEDIDDataBlockStartAddress;
 323   7                                          break;
 324   7      
 325   7                                      case _CTA_EXTDBTAG_420CMDB:
 326   7      
 327   7                                          pusCtaDataBlockAddr[_CTA_420CMDB] = usEDIDDataBlockStartAddress;
 328   7                                          break;
 329   7      
 330   7                                      case _CTA_EXTDBTAG_HFEEODB:
 331   7      
 332   7                                          pusCtaDataBlockAddr[_CTA_HF_EEODB] = usEDIDDataBlockStartAddress;
 333   7                                          break;
 334   7      
 335   7                                      // HF-SCDB (same as HF-VSDB)
 336   7                                      case _CTA_EXTDBTAG_HFSCDB:
 337   7      
 338   7                                          pusCtaDataBlockAddr[_CTA_HF_VSDB] = usEDIDDataBlockStartAddress;
 339   7                                          break;
 340   7      
 341   7                                      case _CTA_EXTDBTAG_T7_VTDB:
 342   7      
 343   7                                          pusCtaDataBlockAddr[_CTA_T7_VTDB] = usEDIDDataBlockStartAddress;
 344   7                                          break;
 345   7      
 346   7                                      default:
 347   7                                          break;
 348   7                                  }
 349   6      
 350   6                                  usEDIDDataBlockStartAddress = (usEDIDDataBlockStartAddress + 1 + ucEDIDBlockBy
C51 COMPILER V9.60.0.0   SCALERSYNC                                                        10/18/2025 16:52:50 PAGE 7   

             -tesNum);
 351   6      
 352   6                                  break;
 353   6      
 354   6                              // Vender-Specific Data Block
 355   6                              case _CTA_DBTAG_VSDB:
 356   6      
 357   6                                  ucEDIDBlockBytesNum = (pucDdcRamAddr[usEDIDDataBlockStartAddress] & 0x1F);
 358   6      
 359   6                                  // HF-VSDB Analysis
 360   6                                  if((pucDdcRamAddr[usEDIDDataBlockStartAddress + 1] == 0xD8) &&
 361   6                                     (pucDdcRamAddr[usEDIDDataBlockStartAddress + 2] == 0x5D) &&
 362   6                                     (pucDdcRamAddr[usEDIDDataBlockStartAddress + 3] == 0xC4))
 363   6                                  {
