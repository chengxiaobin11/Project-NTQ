 364          //--------------------------------------------------
 365          // Description  : Settings for Vbyone Digital Phy
 366          // Input Value  : _ON or _OFF
 367          // Output Value : None
 368          //--------------------------------------------------
 369          void ScalerDisplayVboPhy(bit bOn)
 370          {
 371   1          if(bOn == _ON)
 372   1          {
 373   2              // Set Vby1 Digital Phy
 374   2              ScalerSetBit(P38_00_VIDEO_FORMAT_H, ~_BIT4, _BIT4);
 375   2      
 376   2              // Enable Digital Phy output
 377   2              ScalerSetByte(P38_8E_PHY0_TXBIST_02_H1, 0xFF);
 378   2          }
 379   1          else
 380   1          {
 381   2              // Disable Digital Phy output
 382   2              ScalerSetByte(P38_8E_PHY0_TXBIST_02_H1, 0x00);
C51 COMPILER V9.60.0.0   SCALERDISPLAY                                                     10/18/2025 16:24:53 PAGE 8   

 383   2      
 384   2              // Reset Vby1 Digital Phy
 385   2              ScalerSetBit(P38_00_VIDEO_FORMAT_H, ~_BIT4, 0x00);
 386   2          }
 387   1      }
