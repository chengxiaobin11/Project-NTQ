 891          //--------------------------------------------------
 892          // Description  : Adjust Vbo Ref DPLL Spread Spectrum
 893          // Input Value  : Spread Spectrum Range
 894          // Output Value : None
 895          //--------------------------------------------------
 896          void ScalerDisplaySetVboPLLSSC(bit bDclkSpreadSpeed, BYTE ucSpreadRange)
 897          {
 898   1          bDclkSpreadSpeed = bDclkSpreadSpeed;
 899   1      
 900   1          // Disable Dpll Dclk Spread Range
 901   1          ScalerSetBit(P1_C6_DCLK_SPREAD_SPECTRUM, ~0xF0, 0x00);
 902   1      
 903   1          // Set Dpll Dclk Double Buffer
 904   1          ScalerSetBit(P1_C6_DCLK_SPREAD_SPECTRUM, ~_BIT2, _BIT2);
 905   1      
 906   1          if(ucSpreadRange != 0x00)
 907   1          {
 908   2              PDATA_WORD(0) = (WORD)((ScalerGetBit(P38_DC_DPTX_CMU12, 0x1F) << 4) | (ScalerGetByte(P38_DD_DPTX_C
             -MU13) >> 4));
 909   2              PDATA_WORD(1) = (WORD)((ScalerGetBit(P38_DD_DPTX_CMU13, 0x0F) << 8) | ScalerGetByte(P38_DE_DPTX_CM
             -U14));
 910   2      
 911   2              // Calculate Spread Spectrum FMDIV: 30kHz
 912   2              PDATA_WORD(3) = (((_EXT_XTAL / 31) + 2) & 0xFFFC);
 913   2      
 914   2              // Calculate SSC
 915   2              PDATA_WORD(2) = ((((DWORD)PDATA_WORD(0) + 4) * 4096 + PDATA_WORD(1))) * 16 / 100 / PDATA_WORD(3) /
             - 15 * ucSpreadRange;
