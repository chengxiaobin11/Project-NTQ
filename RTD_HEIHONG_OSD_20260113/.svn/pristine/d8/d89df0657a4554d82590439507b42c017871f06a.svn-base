 704          // Output Value : None
 705          //--------------------------------------------------
 706          void ScalerDisplayVboCtsFifoHandler(void)
 707          {
 708   1          BYTE ucCount = 0;
 709   1      
 710   1          // Set CTS FIFO Initial Address For Reading
 711   1          ScalerSetBit(P38_15_CTS_FIFO_H, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT0);
 712   1      
 713   1          // Set CTS FIFO PLL Tracking Boundary
 714   1          ScalerSetByte(P38_16_CTS_FIFO_M, 0x00);
 715   1      
 716   1          // Toggle Vby1 MAC
 717   1          ScalerSetBit(P38_0A_TRANSMIT_CONTROL_H1, ~_BIT7, 0x00);
 718   1          ScalerTimerDelayXms(2);
 719   1          ScalerSetBit(P38_0A_TRANSMIT_CONTROL_H1, ~_BIT7, _BIT7);
 720   1      
 721   1          // Toggle Vby1 Cts Fifo 4 Times
 722   1          for(ucCount = 0; ucCount < 4; ucCount++)
 723   1          {
 724   2              ScalerSetBit(P38_17_CTS_FIFO_L, ~_BIT3, 0x00);
 725   2              ScalerTimerDelayXms(2);
 726   2      
 727   2              ScalerSetBit(P38_17_CTS_FIFO_L, ~_BIT3, _BIT3);
 728   2              ScalerTimerDelayXms(2);
 729   2          }
 730   1      
 731   1          // Reset CTS FIFO PLL Tracking Boundary
 732   1          ScalerSetByte(P38_16_CTS_FIFO_M, 0x11);
 733   1      }
