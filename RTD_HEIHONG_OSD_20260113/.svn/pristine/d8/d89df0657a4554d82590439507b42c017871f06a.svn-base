 330          //--------------------------------------------------
 331          // Description  : Settings for Vbyone MAC
 332          // Input Value  : _ON or _OFF
 333          // Output Value : None
 334          //--------------------------------------------------
 335          void ScalerDisplayVboMac(bit bOn)
 336          {
 337   1          BYTE ucCount = 0;
 338   1      
 339   1          if(bOn == _ON)
 340   1          {
 341   2              // Set Vby1 MAC
 342   2              ScalerSetBit(P38_0A_TRANSMIT_CONTROL_H1, ~_BIT7, _BIT7);
 343   2      
 344   2              // Check Vby1 Cts Fifo Status Twice
 345   2              for(ucCount = 0; ucCount < 2; ucCount++)
 346   2              {
 347   3                  ScalerTimerDelayXms(2);
 348   3      
 349   3                  // Check Vbyone Cts Fifo Condiction
 350   3                  if(ScalerGetBit(P38_17_CTS_FIFO_L, (_BIT1 | _BIT0)) != 0x00)
 351   3                  {
 352   4                      // Cts Fifo Handler
 353   4                      ScalerDisplayVboCtsFifoHandler();
 354   4                  }
 355   3              }
 356   2          }
 357   1          else
 358   1          {
 359   2              // Reset Vby1 MAC
 360   2              ScalerSetBit(P38_0A_TRANSMIT_CONTROL_H1, ~_BIT7, 0x00);
 361   2          }
 362   1      }
