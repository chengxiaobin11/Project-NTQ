3444   2              // Latch Current Counter and not clear any WD timer counter
3445   2              MCU_FFEB_WDT_TEST = (MCU_FFEB_WDT_TEST & (~_BIT7)) | _BIT3;
3446   2      
3447   2              g_bWDTimer2Update = _TRUE;
3448   2      
3449   2              // Add to Prevent INT Lock Reset
3450   2              if((MCU_FFAD_WATCHDOG_CNT1_VALUE & 0x07) > 0x04)
3451   2              {
3452   3                  // Clear watchdog
3453   3                  CLR_MCU_WATCH_DOG();
3454   3              }
3455   2      #endif
3456   2              g_bNotifyTimer2Int = _TRUE;
3457   2      
3458   2              usTimer += 1;
3459   2          }
3460   1      
3461   1          return usTimer;
3462   1      }
3463          #endif
