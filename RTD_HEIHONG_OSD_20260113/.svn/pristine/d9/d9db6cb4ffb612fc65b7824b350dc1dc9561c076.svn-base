 470   1      
 471   1          // Clear Counter
 472   1          MCU_FFEA_WATCHDOG_TIMER |= _BIT6;
 473   1      
 474   1          // Clear WD Timer IRQ flag
 475   1          MCU_FFEB_WDT_TEST = (MCU_FFEB_WDT_TEST & (~_BIT7)) | _BIT7;
 476   1      
 477   1          // Enable WD Timer IRQ
 478   1          MCU_FFEB_WDT_TEST = (MCU_FFEB_WDT_TEST & (~_BIT7)) | _BIT2;
 479   1      }
