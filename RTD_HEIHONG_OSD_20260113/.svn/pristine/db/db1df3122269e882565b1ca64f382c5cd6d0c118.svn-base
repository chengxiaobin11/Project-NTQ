 221          BYTE ScalerTimerGetEventStatusbyReg(EnumWaitEventType enumEvent)
 222          {
 223   1          switch(enumEvent)
 224   1          {
 225   2              case _EVENT_IVS:
 226   2              case _EVENT_IEN_STOP:
 227   2                  if(ScalerFmtCnvFtoPGetStatus() == _FALSE)
 228   2                  {
 229   3                      // Wait M1 if format convertion E/O mode is disabled
 230   3                      return (ScalerGetByte(P0_03_STATUS1) & enumEvent);
