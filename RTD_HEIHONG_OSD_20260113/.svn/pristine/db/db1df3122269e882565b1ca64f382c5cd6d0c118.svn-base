  56          // Description  : Clear Event Status
  57          // Input Value  : enumEvent   --> Specified event
  58          // Output Value : None
  59          //--------------------------------------------------
  60          void ScalerTimerClrEventStatus(EnumWaitEventType enumEvent)
  61          {
  62   1          switch(enumEvent)
  63   1          {
  64   2              case _EVENT_IVS:
  65   2              case _EVENT_IEN_STOP:
  66   2              case _EVENT_ALL:
  67   2              default:
  68   2                  ScalerTimerClrEventStatusbyReg(enumEvent);
  69   2                  break;
  70   2      
  71   2              case _EVENT_DEN_START:
  72   2                  // Total
  73   2      #if((_OD_SUPPORT == _ON) && (_FRC_SUPPORT == _ON))
  74   2                  if(ScalerGetBit(P0_05_IRQ_CTRL1, _BIT3) == _BIT3)
  75   2                  {
  76   3                      ScalerTimerClrEventStatusbyFlag(enumEvent);
  77   3                  }
  78   2                  else
  79   2      #endif
  80   2                  {
  81   3                      ScalerTimerClrEventStatusbyReg(enumEvent);
  82   3                  }
  83   2      
  84   2                  break;
  85   2      
  86   2              case _EVENT_DEN_STOP:
  87   2      #if(_DRR_MOTION_BLUR_REDUCTION_SUPPORT == _ON)
                          if(ScalerGetBit(P0_05_IRQ_CTRL1, _BIT5) == _BIT5)
                          {
                              ScalerTimerClrEventStatusbyFlag(enumEvent);
                          }
                          else
              #endif
  94   2                  {
  95   3                      ScalerTimerClrEventStatusbyReg(enumEvent);
  96   3                  }
  97   2      
  98   2                  break;
  99   2          }
 100   1      }
