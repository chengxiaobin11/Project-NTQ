 107          void ScalerTimerClrEventStatusbyReg(EnumWaitEventType enumEvent)
 108          {
 109   1          switch(enumEvent)
C51 COMPILER V9.60.0.0   RL6449_SERIES_TIMERFUNCTION                                       10/18/2025 16:25:57 PAGE 3   

 110   1          {
 111   2              case _EVENT_IVS:
 112   2              case _EVENT_IEN_STOP:
 113   2                  if(ScalerFmtCnvFtoPGetStatus() == _FALSE)
 114   2                  {
 115   3                      // M1
 116   3                      ScalerSetByte(P0_03_STATUS1, enumEvent);
 117   3                  }
 118   2                  else
 119   2                  {
 120   3                      // M2
 121   3                      ScalerSetByte(P40_03_M2_STATUS1, enumEvent);
 122   3                  }
 123   2                  break;
 124   2      
 125   2              case _EVENT_DEN_START:
 126   2                  // Total
 127   2                  ScalerSetBit(P0_05_IRQ_CTRL1, ~(_BIT6 | _BIT4 | _BIT2), _BIT2);
 128   2                  break;
 129   2      
 130   2              case _EVENT_DEN_STOP:
 131   2                  // Total
 132   2                  ScalerSetBit(P0_05_IRQ_CTRL1, ~(_BIT6 | _BIT4 | _BIT2), _BIT4);
 133   2                  break;
 134   2      
 135   2              case _EVENT_ALL:
 136   2                  ScalerSetByte(P40_03_M2_STATUS1, 0xF7);
 137   2                  ScalerSetBit(P0_05_IRQ_CTRL1, ~(_BIT6 | _BIT4 | _BIT2), (_BIT4 | _BIT2));
 138   2                  ScalerSetByte(P0_03_STATUS1, 0xFF);
 139   2                  break;
 140   2      
 141   2              default:
 142   2                  ScalerSetByte(P0_03_STATUS1, enumEvent);
 143   2                  break;
 144   2          }
 145   1      }
