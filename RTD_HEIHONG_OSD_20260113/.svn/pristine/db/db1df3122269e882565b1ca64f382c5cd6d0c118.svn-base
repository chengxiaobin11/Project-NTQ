 250   3                              ((ScalerGetByte(P0_05_IRQ_CTRL1) & _BIT4) << 1) |
 251   3                              (ScalerGetByte(P0_03_STATUS1) & (_BIT7 | _BIT6 | _BIT3 | _BIT2 | _BIT1 | _BIT0)));
 252   3                  }
 253   2                  else
 254   2                  {
 255   3                      return ((ScalerGetByte(P40_03_M2_STATUS1) & (_BIT2 | _BIT0)) |
 256   3                              ((ScalerGetByte(P0_05_IRQ_CTRL1) & _BIT2) << 2) |
 257   3                              ((ScalerGetByte(P0_05_IRQ_CTRL1) & _BIT4) << 1) |
 258   3                              (ScalerGetByte(P0_03_STATUS1) & (_BIT7 | _BIT6 | _BIT3 | _BIT1)));
 259   3                  }
 260   2      
 261   2              default:
