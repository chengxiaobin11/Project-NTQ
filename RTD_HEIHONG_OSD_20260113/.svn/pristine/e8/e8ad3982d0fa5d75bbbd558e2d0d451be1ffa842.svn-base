              void ScalerDpRx1LinkRateChangeRebuildPhy(void)
              {
                  SET_DP_RX1_AUX_MANUAL_MODE();
              
                  if((GET_DP_RX1_LINK_TRAINING_STATUS() == _DP_NORMAL_LINK_TRAINING_PASS) && (ScalerDpRx1LinkRateChange(
