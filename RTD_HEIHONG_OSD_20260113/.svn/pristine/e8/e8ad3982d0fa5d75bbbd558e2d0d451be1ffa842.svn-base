                          PDATA_WORD(0) = usDpVtotal - PDATA_WORD(2) - GET_DP_RX1_MST_TO_SST_VFRONT_PORCH();
                          ScalerSetByte(PA_4A_MN_DPF_VST_M, pData[0]);
                          ScalerSetByte(PA_4B_MN_DPF_VST_L, pData[1]);
              
