 426          //--------------------------------------------------
 427          // Description  : DP Scramble Setting
 428          // Input Value  : None
 429          // Output Value : None
 430          //--------------------------------------------------
 431          void ScalerDpRx1ScrambleSetting(void)
 432          {
 433   1          BYTE ucBackUp = ScalerGetByte(PBA_D0_AUX_MODE_SET);
 434   1          bit bEnhanceChange = _FALSE;
 435   1          bit bScrambleChange = _FALSE;
 436   1      
 437   1          SET_DP_RX1_AUX_MANUAL_MODE();
 438   1      
 439   1          if((ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7) != (ScalerGetBit(PB0_01_PHY_DIG_RESET
             -_CTRL, _BIT2) == _BIT2))
 440   1          {
 441   2              bEnhanceChange = _TRUE;
 442   2      
 443   2              if(ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7)
 444   2              {
 445   3                  // Enable Enhancement Control Mode --> MAC
 446   3                  ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 447   3              }
 448   2              else
 449   2              {
 450   3                  // Disable Enhancement Control Mode --> MAC
 451   3                  ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT2, 0x00);
 452   3              }
 453   2          }
 454   1      
 455   1          if((ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5) != (ScalerGetBit(PB0_07_SCRAMBLE_CTRL
             -, _BIT5) == _BIT5))
 456   1          {
 457   2              bScrambleChange = _TRUE;
 458   2      
 459   2              if(ScalerDpRx1GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5)
 460   2              {
 461   3                  // Disable Scrambling
 462   3                  ScalerSetBit(PB0_07_SCRAMBLE_CTRL, ~_BIT5, _BIT5);
 463   3              }
 464   2              else
 465   2              {
 466   3                  // Enable Scrambling
 467   3                  ScalerSetBit(PB0_07_SCRAMBLE_CTRL, ~_BIT5, 0x00);
 468   3              }
 469   2          }
 470   1      
 471   1          if((bEnhanceChange == _TRUE) || (bScrambleChange == _TRUE))
