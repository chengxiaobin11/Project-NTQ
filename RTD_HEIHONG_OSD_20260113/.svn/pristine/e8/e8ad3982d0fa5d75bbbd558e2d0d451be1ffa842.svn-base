 258          #if(_D1_DP_EXIST == _ON)
 259          //--------------------------------------------------
 260          // Description  : DP RGB Output Disable
 261          // Input Value  : None
 262          // Output Value : None
 263          //--------------------------------------------------
 264          void ScalerDpRx1AVMute(void)
 265          {
 266   1          if(ScalerGetBit(PB9_3A_DP_IRQ_CTRL0, (_BIT1 | _BIT0)) == (_BIT1 | _BIT0))
 267   1          {
 268   2              // Set free run & force to BG
 269   2              ScalerSetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, ~(_BIT5 | _BIT3), _BIT5);
 270   2          }
 271   1      
 272   1          // Disable fifo overflwo/ underflwo IRQ
 273   1          ScalerSetBit(PB9_3A_DP_IRQ_CTRL0, ~(_BIT1 | _BIT0), 0x00);
 274   1      
 275   1          // Disable RGB Output
 276   1          ScalerSetBit(PB8_31_DP_OUTPUT_CTRL, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 277   1      
 278   1      #if(_AUDIO_SUPPORT == _ON)
 279   1          // Disable Audio Channel
 280   1          ScalerAudioDpAudioEnable(_DISABLE, _D1_INPUT_PORT);
 281   1      #endif
 282   1      }
 283          //--------------------------------------------------
 284          // Description  : DP Adjust Vsync Delay
 285          // Input Value  : None
 286          // Output Value : None
 287          //--------------------------------------------------
 288          void ScalerDpRx1AdjustVsyncDelay(void)
 289          {
C51 COMPILER V9.60.0.0   SCALERDPRX1_SEPTPHY                                               10/18/2025 16:52:57 PAGE 6   

 290   1          DWORD ulBStoVSDelayDeltaOverflow = 0;
 291   1          DWORD ulBStoVSDelayDeltaUnderflow = 0;
 292   1      
 293   1          if(ScalerGetBit(PB8_21_PG_CTRL_1, (_BIT1 | _BIT0)) == 0x00)// Fifo Ok
 294   1          {
 295   2              return;
 296   2          }
 297   1          else if(ScalerGetBit(PB8_21_PG_CTRL_1, _BIT0) == _BIT0) // Fifo Overflow
 298   1          {
 299   2              // Get Htotal
 300   2              ScalerRead(PB9_08_MSA_HTT_0, 2, &pData[0], _AUTOINC);
 301   2      
 302   2              // ((Link Clk * 256)/ Stream CLK) * Htotal / 256 --> 1 Line
 303   2              ulBStoVSDelayDeltaOverflow = (((DWORD)ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) * 270UL) * 256) / (
             -(DWORD)GET_INPUT_PIXEL_CLK()) * ((DWORD)PDATA_WORD(0)) / 256;
 304   2      
 305   2              DebugMessageRx1("7. Fifo Overflow --> nVidia Case", ulBStoVSDelayDeltaOverflow);
 306   2          }
 307   1          else if(ScalerGetBit(PB8_21_PG_CTRL_1, _BIT1) == _BIT1) // Fifo Underflow
 308   1          {
 309   2              // Get Hactive
 310   2              ScalerRead(PB9_0C_MSA_HWD_0, 2, &pData[0], _AUTOINC);
 311   2      
 312   2              if(PDATA_WORD(0) != 1366)
 313   2              {
 314   3                  return;
 315   3              }
 316   2      
 317   2              PDATA_WORD(0) = PDATA_WORD(0) - 2;
 318   2      
 319   2              // Set Hactive
 320   2              ScalerSetByte(PB8_45_MN_DPF_HWD_M, pData[0]);
 321   2              ScalerSetByte(PB8_46_MN_DPF_HWD_L, pData[1]);
 322   2      
 323   2              // ((Link Clk * 2)/ Stream CLK) --> 2 pixels
 324   2              ulBStoVSDelayDeltaUnderflow = (((DWORD)ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) * 270) * 2) / ((DW
             -ORD)GET_INPUT_PIXEL_CLK());
 325   2      
 326   2              DebugMessageRx1("7. Fifo Underflow --> QD882 Case", ulBStoVSDelayDeltaUnderflow);
 327   2          }
 328   1      
 329   1          // For Initial Value Before Use PDATA_DWORD(0)
 330   1          pData[0] = 0;
 331   1      
 332   1          // Get BStoVSDelay Even
 333   1          ScalerRead(PB8_32_EVBLK2VS_H, 3, &pData[1], _AUTOINC);
 334   1      
 335   1          // For Initial Value Before Use PDATA_DWORD(1)
 336   1          pData[4] = 0;
 337   1      
 338   1          // Get BStoVSDelay Odd
 339   1          ScalerRead(PB8_35_OVBLK2VS_H, 3, &pData[5], _AUTOINC);
 340   1      
 341   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 342   1          PDATA_DWORD(0) = PDATA_DWORD(0) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 343   1      
 344   1          // BStoVSDelay = BStoVSDelay + (Nvid * 256 / Mvid) * ((DWORD)Htotal) / 256;
 345   1          PDATA_DWORD(1) = PDATA_DWORD(1) - ((ulBStoVSDelayDeltaOverflow + ulBStoVSDelayDeltaUnderflow) / 2);
 346   1      
 347   1          // Set Even Field BS to VS Delay
 348   1          ScalerSetByte(PB8_32_EVBLK2VS_H, pData[1]);
 349   1          ScalerSetByte(PB8_33_EVBLK2VS_M, pData[2]);
C51 COMPILER V9.60.0.0   SCALERDPRX1_SEPTPHY                                               10/18/2025 16:52:57 PAGE 7   

 350   1          ScalerSetByte(PB8_34_EVBLK2VS_L, pData[3]);
 351   1      
 352   1          // Set Odd Field BS to VS Delay
 353   1          ScalerSetByte(PB8_35_OVBLK2VS_H, pData[5]);
 354   1          ScalerSetByte(PB8_36_OVBLK2VS_M, pData[6]);
 355   1          ScalerSetByte(PB8_37_OVBLK2VS_L, pData[7]);
 356   1      
 357   1          // Enable Double Buffer
 358   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT6, _BIT6);
 359   1      
 360   1          // Reset Display Format Gen
 361   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT7, 0x00);
 362   1          ScalerSetBit(PB8_30_DPF_CTRL_0, ~_BIT7, _BIT7);
 363   1      
 364   1          // Polling Vertical BS
 365   1          if(ScalerDpRx1PollingFlagLinkCheck(50, PB9_01_DP_VBID, _BIT0, _TRUE) == _FALSE)
 366   1          {
 367   2              return;
 368   2          }
 369   1      
 370   1          // Delay for PG Stable
 371   1          if(ScalerDpRx1TimerDelayXmsLinkCheck(_DP_ONE_FRAME_TIME_MAX) == _FALSE)
 372   1          {
 373   2              return;
 374   2          }
 375   1      }
 376          //--------------------------------------------------
 377          // Description  : Check Valid Lane Alignment
 378          // Input Value  : None
 379          // Output Value : True --> Align
 380          //--------------------------------------------------
 381          bit ScalerDpRx1AlignCheck(void)
 382          {
 383   1      #if(_DP_ILLEGAL_IDLE_PATTERN_CHECK_SUPPORT == _ON)
              
                  if(GET_DP_ILLEGAL_IDLE_PATTERN_CHECK() == _TRUE)
                  {
                      if(GET_DP_RX1_SOURCE_TYPE_JUDGE() == _FALSE)
                      {
              #if(_HW_DP_LANE_VALID_CHECK_SUPPORT == _ON)
                          if(ScalerDpRx1LaneValidCheck() == _FALSE)
                          {
                              return _TRUE;
                          }
              #else
                          return _TRUE;
              #endif
                      }
                  }
              
              #endif
 401   1      
 402   1          if((ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x01) & 0x1F) == _DP_ONE_LANE)
 403   1          {
 404   2              return _TRUE;
 405   2          }
 406   1          else
 407   1          {
 408   2              if(ScalerGetBit(PB0_0E_DESKEW_PHY, _BIT4) == 0x00)
 409   2              {
 410   3                  if(ScalerGetBit(PB0_0E_DESKEW_PHY, (_BIT7 | _BIT6)) != (_BIT7 | _BIT6))
 411   3                  {
C51 COMPILER V9.60.0.0   SCALERDPRX1_SEPTPHY                                               10/18/2025 16:52:57 PAGE 8   

 412   4                      ScalerSetBit(PB0_0E_DESKEW_PHY, ~(_BIT7 | _BIT6), (_BIT7 | _BIT6));
 413   4      
 414   4                      ScalerTimerDelayXms(3);
 415   4                  }
 416   3                  else
 417   3                  {
 418   4                      return _FALSE;
 419   4                  }
 420   3              }
 421   2          }
 422   1      
 423   1          return _TRUE;
 424   1      }
