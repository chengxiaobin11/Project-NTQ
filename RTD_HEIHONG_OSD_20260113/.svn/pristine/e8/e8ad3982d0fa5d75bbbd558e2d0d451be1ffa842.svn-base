 472   1          {
 473   2              SET_DP_RX1_AUX_AUTO_MODE();
 474   2      
 475   2              // Delay 2ms for Scramble
 476   2              ScalerTimerDelayXms(2);
 477   2      
 478   2              SET_DP_RX1_AUX_MANUAL_MODE();
 479   2          }
 480   1      
 481   1          if((ucBackUp & _BIT1) == _BIT1)
 482   1          {
 483   2              SET_DP_RX1_AUX_AUTO_MODE();
 484   2          }
 485   1      }
