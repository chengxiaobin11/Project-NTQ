              #endif
6707   2              // If usNum = 1ms, it will delay 2ms (Cause 1ms is inaccurate)
6708   2              ScalerTimerDelayXms((usNum == 1) ? 2 : usNum);
6709   2          }
6710   1      
6711   1          return _TRUE;
6712   1      }
