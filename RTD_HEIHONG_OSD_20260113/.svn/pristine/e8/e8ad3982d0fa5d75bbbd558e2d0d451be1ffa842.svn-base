                  ScalerDpRx1SetDpcdBitValue(0x00, 0x00, 0x07, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), 0x01);
              
                  ScalerDpRx1SetDpcdValue(0x00, 0x00, 0x80, (_BIT6 | _BIT4 | _BIT3));
              #endif
              }
              #endif
              
