              #endif
6694   2              ScalerTimerDelayXms(_DP_RX_LINK_LOSS_CHECK_INTERVAL);
6695   2      
6696   2              usNum -= _DP_RX_LINK_LOSS_CHECK_INTERVAL;
6697   2          }
6698   1      
6699   1          if(usNum > 0)
6700   1          {
6701   2      #if(_DP_LINK_INTERVAL_CHECK_SUPPORT == _ON)
                      if(ScalerDpRx1LinkStatusLoss() == _TRUE)
                      {
                          return _FALSE;
