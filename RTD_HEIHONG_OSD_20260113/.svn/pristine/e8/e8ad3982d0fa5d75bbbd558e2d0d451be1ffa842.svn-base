                          else // Progressive
                          {
                              DebugMessageRx1("7. MST PPPPProgressive", 0);
              
                              SET_DP_TX_INPUT_INTERLACE_MODE(_OFF);
                          }
              
                          // Set Vtotal
                          ScalerSetByte(PA_48_MN_DPF_VTT_M, (usDpVtotal >> 8));
                          ScalerSetByte(PA_49_MN_DPF_VTT_L, (usDpVtotal & 0xFF));
              
