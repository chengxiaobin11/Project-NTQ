5279   3                  PDATA_WORD(0) = 0x4E20;
5280   3              }
5281   2              else if(ScalerDpRx1GetDpcdInfo(0x00, 0x01, 0x00) == _DP_LINK_HBR)
5282   2              {
5283   3                  PDATA_WORD(0) = 0x2710;
5284   3              }
5285   2              else // Both Default && _DP_LINK_RBR Case
5286   2              {
