                              if((PDATA_WORD(1) - usDpHactive - PDATA_WORD(2)) <= _DP_HSYNC_FRONT_PORCH)
                              {
                                  // HSW < HSW min
                                  if(PDATA_WORD(2) < PDATA_WORD(3))
