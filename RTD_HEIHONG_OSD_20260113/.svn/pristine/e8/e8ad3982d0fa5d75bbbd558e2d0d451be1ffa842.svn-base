6735   3              }
6736   2      
6737   2              usTimeout -= _DP_RX_LINK_LOSS_CHECK_INTERVAL;
6738   2          }
6739   1      
6740   1          if(usTimeout > 0)
6741   1          {
6742   2      #if(_DP_LINK_INTERVAL_CHECK_SUPPORT == _ON)
                      if(ScalerDpRx1LinkStatusLoss() == _TRUE)
                      {
                          return _FALSE;
                      }
              #endif
6748   2              if(ScalerTimerPollingFlagProc(usTimeout, usRegister, ucBit, bSuccess) == _TRUE)
6749   2              {
6750   3                  return _TRUE;
6751   3              }
6752   2          }
6753   1      
6754   1          return _FALSE;
6755   1      }
