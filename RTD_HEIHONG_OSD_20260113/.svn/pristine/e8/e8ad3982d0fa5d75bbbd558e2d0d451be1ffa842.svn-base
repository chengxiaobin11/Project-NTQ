                  ScalerSetBit(PB0_30_SHA_CONTRL, ~_BIT2, _BIT2);
              
                  ScalerTimerPollingFlagProc(5, PB0_30_SHA_CONTRL, _BIT4, _TRUE);
              
                  // Disable First Run and Disable SHA-1 Circuit
                  ScalerSetBit(PB0_30_SHA_CONTRL, ~(_BIT2 | _BIT1), 0x00);
              }
              
