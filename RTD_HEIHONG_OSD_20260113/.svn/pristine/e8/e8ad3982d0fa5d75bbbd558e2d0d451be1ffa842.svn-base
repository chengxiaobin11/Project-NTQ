                      ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT1, _BIT1);
                      ScalerSetBit(PB0_01_PHY_DIG_RESET_CTRL, ~_BIT1, 0x00);
              
                      // Delay for Lane Alignment after Mac Reset
                      ScalerTimerDelayXms(2);
                  }
              
                  SET_DP_RX1_AUX_AUTO_MODE();
              }
              
