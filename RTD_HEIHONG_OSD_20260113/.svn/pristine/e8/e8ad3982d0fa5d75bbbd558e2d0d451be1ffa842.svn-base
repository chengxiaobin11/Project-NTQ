C51 COMPILER V9.60.0.0   SCALERDPRX1_SEPTPHY                                               10/18/2025 16:52:57 PAGE 123 

                          ScalerSetByte(PA_39_EVBLK2VS_L, (BYTE)(ulBs2VsDelay >> 0));
              
