6683          //--------------------------------------------------
6684          bit ScalerDpRx1TimerDelayXmsLinkCheck(WORD usNum)
6685          {
6686   1          while(usNum >= _DP_RX_LINK_LOSS_CHECK_INTERVAL)
6687   1          {
6688   2      #if(_DP_LINK_INTERVAL_CHECK_SUPPORT == _ON)
