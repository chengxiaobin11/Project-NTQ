              #else
                  if(GET_DP_TX_HDCP_DOWNSTREAM_SUPPORTED() == _TRUE)
              #endif
                  {
                      if(GET_DP_TX_HDCP_DOWNSTREAM_REPEATER() == _TRUE)
                      {
                          PDATA_WORD(1) = (WORD) GET_DP_TX_HDCP_DOWNSTREAM_DEVICE_COUNT() * 5;
