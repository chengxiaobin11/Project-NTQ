              bit ScalerDpTxCloneCheckInputPortSupport(EnumSourceSearchPort enumInputPort);
              BYTE ScalerDpTxAudioGetSamplingFreqRange(void);
              void ScalerDpTxSSTAudioPlaySetting(EnumDPTxAudioPlayState enumPlayState);
              
              //****************************************************************************
