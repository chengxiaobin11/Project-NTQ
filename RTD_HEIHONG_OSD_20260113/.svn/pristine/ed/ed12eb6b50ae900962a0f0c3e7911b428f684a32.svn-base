#include "ScalerOSDLibInternalInclude.h"

//****************************************************************************
// DEFINITIONS / MACROS
//****************************************************************************


//****************************************************************************
// STRUCT / TYPE / ENUM DEFINITTIONS
//****************************************************************************


//****************************************************************************
// CODE TABLES
//****************************************************************************


//****************************************************************************
// VARIABLE DECLARATIONS
//****************************************************************************


//****************************************************************************
// FUNCTION DECLARATIONS
//****************************************************************************
bit ScalerOsdGet2FontFunction(void);


//****************************************************************************
// FUNCTION DEFINITIONS
//****************************************************************************
//--------------------------------------------------
// Description  : Get Osd 2 font function
// Input Value  : None
// Output Value :  _ENABLE or _DISABLE
//--------------------------------------------------
bit ScalerOsdGet2FontFunction(void)
{
    return ((bit)ScalerGetBit(P3A_18_FRAME_CTRL_18, _BIT3));
}
