 350          void ScalerDpRx0ScrambleSetting(void)
 351          {
 352   1          BYTE ucBackUp = ScalerGetByte(PB7_D0_AUX_MODE_SET);
 353   1          bit bEnhanceChange = _FALSE;
 354   1          bit bScrambleChange = _FALSE;
 355   1      
 356   1          SET_DP_RX0_AUX_MANUAL_MODE();
 357   1      
 358   1          if((ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7) != (ScalerGetBit(PB_01_PHY_DIG_RESET_
             -CTRL, _BIT2) == _BIT2))
 359   1          {
 360   2              bEnhanceChange = _TRUE;
 361   2      
 362   2              if(ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x01, _BIT7) == _BIT7)
 363   2              {
 364   3                  // Enable Enhancement Control Mode --> MAC
 365   3                  ScalerSetBit(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, _BIT2);
 366   3              }
 367   2              else
 368   2              {
 369   3                  // Disable Enhancement Control Mode --> MAC
 370   3                  ScalerSetBit(PB_01_PHY_DIG_RESET_CTRL, ~_BIT2, 0x00);
 371   3              }
 372   2          }
 373   1      
 374   1          if((ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5) != (ScalerGetBit(PB_07_SCRAMBLE_CTRL,
             - _BIT5) == _BIT5))
 375   1          {
 376   2              bScrambleChange = _TRUE;
 377   2      
 378   2              if(ScalerDpRx0GetDpcdBitInfo(0x00, 0x01, 0x02, _BIT5) == _BIT5)
 379   2              {
 380   3                  // Disable Scrambling
 381   3                  ScalerSetBit(PB_07_SCRAMBLE_CTRL, ~_BIT5, _BIT5);
 382   3              }
 383   2              else
 384   2              {
 385   3                  // Enable Scrambling
 386   3                  ScalerSetBit(PB_07_SCRAMBLE_CTRL, ~_BIT5, 0x00);
 387   3              }
 388   2          }
 389   1      
 390   1          if((bEnhanceChange == _TRUE) || (bScrambleChange == _TRUE))
 391   1          {
 392   2              SET_DP_RX0_AUX_AUTO_MODE();
 393   2      
 394   2              // Delay 2ms for Scramble
 395   2              ScalerTimerDelayXms(2);
 396   2      
 397   2              SET_DP_RX0_AUX_MANUAL_MODE();
 398   2          }
 399   1      
C51 COMPILER V9.60.0.0   SCALERDPRX0                                                       10/18/2025 16:24:54 PAGE 8   

 400   1          if((ucBackUp & _BIT1) == _BIT1)
 401   1          {
 402   2              SET_DP_RX0_AUX_AUTO_MODE();
 403   2          }
 404   1      }
