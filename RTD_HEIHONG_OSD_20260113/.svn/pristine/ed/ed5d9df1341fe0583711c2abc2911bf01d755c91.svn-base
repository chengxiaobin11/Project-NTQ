             -_SCALER_LANE2))) &&
                              (ScalerGetBit(PB_00_HD_DP_SEL, (_BIT5 | _BIT4)) == 0x00)))
                          {
                              return _FALSE;
                          }
              
                          break;
              
                      case _DP_FOUR_LANE:
              
                          if(ScalerGetBit(PB_00_HD_DP_SEL, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) == 0x00)
