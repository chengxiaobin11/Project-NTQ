 508          //--------------------------------------------------
 509          // Description  : DP CRC Calculate
 510          // Input Value  : None
 511          // Output Value : None
 512          //--------------------------------------------------
 513          void ScalerDpRx0CrcCalculate(void)
 514          {
 515   1          if(GET_DP_RX0_CRC_CALCULATE() == _TRUE)
 516   1          {
 517   2              DebugMessageRx0("7. DP CRC Test Start", 0);
 518   2      
 519   2              if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR422)
 520   2              {
 521   3                  ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT4, _BIT4);
 522   3              }
 523   2              else
 524   2              {
 525   3                  ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT4, 0x00);
 526   3              }
 527   2      
 528   2              // Start CRC Calculation
 529   2              ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT7, _BIT7);
 530   2      
 531   2              if((ScalerTimerPollingFlagProc(_DP_MEASURE_POLLING_TIMEOUT, PB5_70_DP_CRC_CTRL, _BIT6, _TRUE) && (
             -ScalerDpRx0FifoCheck(_DP_FIFO_POLLING_CHECK))) == _TRUE)
 532   2              {
 533   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x40, ScalerGetByte(PB5_72_DP_CRC_R_L));
 534   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x41, ScalerGetByte(PB5_71_DP_CRC_R_M));
 535   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x42, ScalerGetByte(PB5_74_DP_CRC_G_L));
 536   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x43, ScalerGetByte(PB5_73_DP_CRC_G_M));
 537   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x44, ScalerGetByte(PB5_76_DP_CRC_B_L));
 538   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x45, ScalerGetByte(PB5_75_DP_CRC_B_M));
 539   3      
 540   3                  CLR_DP_RX0_CRC_CALCULATE();
 541   3      
 542   3                  // Update _TEST_CRC_COUNT
 543   3                  ScalerDpRx0SetDpcdValue(0x00, 0x02, 0x46, 0x21);
 544   3              }
 545   2      
 546   2              // Stop CRC Calculation
 547   2              ScalerSetBit(PB5_70_DP_CRC_CTRL, ~_BIT7, 0x00);
 548   2          }
 549   1      }
