              // Output Value : None
              //--------------------------------------------------
              void ScalerDpRx0Hdcp2ClearDpcdRepeaterInfo(void)
              {
                  BYTE ucIndex = 0x00;
              
                  // Clear HDCP2: seq_num_V, V', Receiver ID List
                  ScalerDpRx0Hdcp2ClearDpcdReadValue(_HDCP_2_2_RX_V_PRIME, 190);
              
                  // Clear HDCP14: Bstatus, Binfo, V', KSV FIFO
                  if((ScalerDpRx0GetDpcdInfo(0x06, 0x80, 0x2A) != 0x00) || (ScalerDpRx0GetDpcdInfo(0x06, 0x80, 0x2B) != 
             -0x00))
                  {
                      ScalerDpRx0SetDpcdValue(0x06, 0x80, 0x29, 0x00);
                      ScalerDpRx0SetDpcdValue(0x06, 0x80, 0x2A, 0x00);
                      ScalerDpRx0SetDpcdValue(0x06, 0x80, 0x2B, 0x00);
              
                      for(ucIndex = 0; ucIndex < 20; ucIndex++)
                      {
                          // DPCD [0x68014 ~ 0x68027]
                          ScalerDpRx0SetDpcdValue(0x06, 0x80, (0x14 + ucIndex), 0x00);
                      }
              
                      for(ucIndex = 0; ucIndex < 15; ucIndex++)
                      {
                          // DPCD [0x6802C ~ 0x6803A]
                          ScalerDpRx0SetDpcdValue(0x06, 0x80, (0x2C + ucIndex), 0x00);
                      }
                  }
              }
              
              #endif // End of #if(_DP_TX_SUPPORT == _ON)
2306          #endif // End of #if(_D0_DP_EXIST == _ON)
2307          #endif // End of #if(_DP_HDCP_2_2_SUPPORT == _ON)


