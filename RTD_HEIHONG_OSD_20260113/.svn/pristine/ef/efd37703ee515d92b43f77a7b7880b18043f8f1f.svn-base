              //--------------------------------------------------
              // Description  : HDCP 1.4 Repeater Capability Switch
              // Input Value  : Input Port
              // Output Value : None
              //--------------------------------------------------
              bit ScalerDpRxHdcp14RepeaterCapabilitySwitchProc(EnumSourceSearchPort enumInputPort, bit bEnable)
              {
                  switch(enumInputPort)
                  {
              #if(_D0_INPUT_PORT_TYPE == _D0_DP_PORT)
                      case _D0_INPUT_PORT:
              
                          if((ScalerDpRxGetDpcdBitInfo(enumInputPort, 0x06, 0x80, 0x28, _BIT1) >> 1) != bEnable)
                          {
                              SET_DP_RX0_HDCP14_REPEATER_SUPPORT(bEnable);
              
                              // Enable Hdcp Repeater, _BIT1: Repeater,  _BIT0: HDCP Capable
                              ScalerDpRxSetDpcdBitValue(enumInputPort, 0x06, 0x80, 0x28, ~_BIT1, ((BYTE)GET_DP_RX0_HDCP1
             -4_REPEATER_SUPPORT() << 1));
              
                              return _TRUE;
                          }
              
                          break;
              #endif
              
              #if(_D1_INPUT_PORT_TYPE == _D1_DP_PORT)
                      case _D1_INPUT_PORT:
              
                          if((ScalerDpRxGetDpcdBitInfo(enumInputPort, 0x06, 0x80, 0x28, _BIT1) >> 1) != bEnable)
                          {
                              SET_DP_RX1_HDCP14_REPEATER_SUPPORT(bEnable);
              
                              // Enable Hdcp Repeater, _BIT1: Repeater,  _BIT0: HDCP Capable
                              ScalerDpRxSetDpcdBitValue(enumInputPort, 0x06, 0x80, 0x28, ~_BIT1, ((BYTE)GET_DP_RX1_HDCP1
             -4_REPEATER_SUPPORT() << 1));
              
                              return _TRUE;
                          }
              
                          break;
              #endif
              
                      default:
              
C51 COMPILER V9.60.0.0   SCALERDP_SEPTPHY                                                  10/18/2025 16:25:10 PAGE 35  

                          break;
                  }
              
                  return _FALSE;
              }
