 128          //--------------------------------------------------
 129          // Description  : Set Config of TMDS Mac Deonly mode
 130          // Input Value  : None
 131          // Output Value : enumInputPort, enumDeonlyConfig
 132          //--------------------------------------------------
 133          void ScalerTMDSRx3SetDeOnlyModeConfig(EnumDeOnlyConfig enumDeonlyConfig)
 134          {
 135   1          // De only enable?
 136   1          if((enumDeonlyConfig & _DE_ONLY_DISABLE) == _DE_ONLY_DISABLE)
 137   1          {
 138   2              ScalerSetBit(P72_A7_TMDS_PWDCTL, ~_BIT7, 0x00);
 139   2          }
 140   1          else if((enumDeonlyConfig & _DE_ONLY_ENABLE) == _DE_ONLY_ENABLE)
 141   1          {
 142   2              ScalerSetBit(P72_A7_TMDS_PWDCTL, ~_BIT7, _BIT7);
 143   2          }
 144   1      
 145   1          // Set HS
 146   1          if((enumDeonlyConfig & _DE_ONLY_HS_8T) == _DE_ONLY_HS_8T)
 147   1          {
 148   2              ScalerSetBit(P72_AB_TMDS_ACC2, ~_BIT7, _BIT7);
 149   2          }
 150   1          else if((enumDeonlyConfig & _DE_ONLY_HS_72T) == _DE_ONLY_HS_72T)
 151   1          {
 152   2              ScalerSetBit(P72_AB_TMDS_ACC2, ~_BIT7, 0x00);
 153   2          }
 154   1      }
 155          
 156          //--------------------------------------------------
 157          // Description  : Get Config of TMDS Mac Deonly mode
 158          // Input Value  : None
 159          // Output Value : EnumDeOnlyConfig
 160          //--------------------------------------------------
 161          EnumDeOnlyConfig ScalerTMDSRx3GetDeOnlyModeConfig(void)
 162          {
 163   1          EnumDeOnlyConfig enumDeConfig = _DE_NO_INDICATED;
 164   1      
 165   1          if(ScalerGetBit(P72_A7_TMDS_PWDCTL, _BIT7) == _BIT7)
 166   1          {
 167   2              enumDeConfig = _DE_ONLY_ENABLE;
 168   2          }
 169   1          else
C51 COMPILER V9.60.0.0   SCALERTMDSRX3_SEPTPHY                                             10/18/2025 16:53:02 PAGE 4   

 170   1          {
 171   2              enumDeConfig = _DE_ONLY_DISABLE;
 172   2          }
 173   1      
 174   1          if(ScalerGetBit(P72_AB_TMDS_ACC2, _BIT7) == _BIT7)
 175   1          {
 176   2              enumDeConfig |= _DE_ONLY_HS_8T;
 177   2          }
 178   1          else
 179   1          {
 180   2              enumDeConfig |= _DE_ONLY_HS_72T;
 181   2          }
 182   1      
 183   1          return enumDeConfig;
 184   1      }
