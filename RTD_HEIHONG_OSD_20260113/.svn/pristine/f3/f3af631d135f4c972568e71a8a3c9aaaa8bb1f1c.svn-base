 202          //--------------------------------------------------
 203          // Description  : Detect TMDS video mode
 204          // Input Value  : bWait => Whether to wait then read
 205          // Output Value : TMDS video type
 206          //--------------------------------------------------
 207          BYTE ScalerTMDSRx3TMDSVideoDetect(bit bWait)
 208          {
 209   1          BYTE ucTemp = _TMDS_VIDEO_DATA_NONE;
 210   1      
 211   1          if(bWait == _WAIT)
 212   1          {
 213   2              // Wait at least 1 frame for HW auto update TMDS video RGBHV valid value
 214   2              ScalerTimerPollingFlagProc(45, P72_A4_TMDS_CTRL, _BIT3, _TRUE);
 215   2      
 216   2              // Wait for HW update DE flag
 217   2              if(ScalerTimerPollingFlagProc(20, P72_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5), _TRUE) == _TRUE)
 218   2              {
 219   3                  // H/Vsync received
 220   3                  if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 221   3                  {
 222   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 223   4                  }
 224   3                  else
 225   3                  {
 226   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 227   4                  }
 228   3              }
 229   2              else
 230   2              {
 231   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
C51 COMPILER V9.60.0.0   SCALERTMDSRX3_SEPTPHY                                             10/18/2025 16:53:02 PAGE 5   

 232   3              }
 233   2      
 234   2              CLR_TMDS_RX3_RGBHV_DETECTING();
 235   2      
 236   2              return ucTemp;
 237   2          }
 238   1          else
 239   1          {
 240   2              // R/G/B data detected
 241   2              if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT7 | _BIT6 | _BIT5)) == (_BIT7 | _BIT6 | _BIT5))
 242   2              {
 243   3                  // H/Vsync received
 244   3                  if(ScalerGetBit(P72_A4_TMDS_CTRL, (_BIT4 | _BIT3)) == (_BIT4 | _BIT3))
 245   3                  {
 246   4                      ucTemp = _TMDS_VIDEO_DATA_RGBHV;
 247   4                  }
 248   3                  else
 249   3                  {
 250   4                      ucTemp = _TMDS_VIDEO_DATA_DE_ONLY;
 251   4                  }
 252   3              }
 253   2              else
 254   2              {
 255   3                  ucTemp = _TMDS_VIDEO_DATA_NONE;
 256   3              }
 257   2      
 258   2              // Clear video Detection Flag
 259   2              ScalerSetBit(P72_A4_TMDS_CTRL, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4 | _BIT3), (_BIT7 | _BIT6 | _BIT5 | 
             -_BIT4 | _BIT3));
 260   2      
 261   2              SET_TMDS_RX3_RGBHV_DETECTING();
 262   2      
 263   2              // Activate TMDS video Detection Event
 264   2              ScalerTimerActiveTimerEvent(45, _SCALER_TIMER_EVENT_RX3_TMDS_VIDEO_DETECT);
 265   2      
 266   2              return ucTemp;
 267   2          }
 268   1      }
