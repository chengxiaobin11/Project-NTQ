  97          //--------------------------------------------------
  98          // Description  : TMDS Video Setting
  99          // Input Value  : Source Type
 100          // Output Value : None
 101          //--------------------------------------------------
 102          void ScalerTMDSRx3DviVideoSetting(void)
 103          {
 104   1          // Manual Set Color Space and disable pixel repetition
 105   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_51_PORT_PAGE72_HDMI_ACRCR, ~(_BIT6 | _BIT5 | _BIT4 | _
             -BIT3 | _BIT2), 0x00);
 106   1      
 107   1          // Disable Down Sampling
 108   1          ScalerSetDataPortBit(P72_C9_HDMI_AP, _P72_CA_PT_50_PORT_PAGE72_HDMI_VCR, ~(_BIT3 | _BIT2 | _BIT1 | _BI
C51 COMPILER V9.60.0.0   SCALERTMDSRX3_SEPTPHY                                             10/18/2025 16:53:02 PAGE 3   

             -T0), 0x00);
 109   1      
 110   1          // Waiting for Down Sampling Effect
 111   1          ScalerTimerDelayXms(20);
 112   1      
 113   1          SET_COLOR_SPACE(_COLOR_SPACE_RGB);
 114   1          SET_COLOR_RGB_QUANTIZATION_RANGE(_RGB_QUANTIZATION_FULL_RANGE);
 115   1      
 116   1          ScalerTMDSRx3SetPorchColor(GET_COLOR_SPACE());
 117   1      }
