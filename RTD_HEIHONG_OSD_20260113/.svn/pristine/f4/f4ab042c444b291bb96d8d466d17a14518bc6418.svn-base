  58          //--------------------------------------------------
  59          // Description  : Let Upper Layer Get I-domain Pixel Clk
  60          // Input Value  : None
  61          // Output Value : Input Pixel Clk (in 0.1MHz)
  62          //--------------------------------------------------
  63          WORD ScalerSyncGetInputPixelClk(void)
  64          {
  65   1          switch(ScalerFmtCnvGetSourceType())
  66   1          {
  67   2      #if(_D2_HDMI_2_0_SUPPORT == _ON)
  68   2              case _FC_SOURCE_D2:
  69   2              case _FC_SOURCE_D3:
  70   2      
  71   2                  // Check 420 status
  72   2                  if(ScalerGetBit(P31_32_YUV420_TO_YUV422, _BIT7) == _BIT7)
  73   2                  {
  74   3                      return (GET_INPUT_PIXEL_CLK() << 1);
  75   3                  }
  76   2                  break;
  77   2      #endif
  78   2      
  79   2      
  80   2      #if(_D4_INPUT_PORT_TYPE == _D4_DUAL_DVI_PORT)
                      case _FC_SOURCE_DUAL_DVI:
                          // Check dual DVI status
                          if(ScalerDualLinkDVIRx4GetDualDVIMode() == _TRUE)
                          {
                              return (GET_INPUT_PIXEL_CLK() << 1);
                          }
                          break;
              #endif
  89   2      
  90   2              default:
  91   2      
  92   2                  break;
  93   2          }
  94   1      
  95   1          return GET_INPUT_PIXEL_CLK();
  96   1      }
