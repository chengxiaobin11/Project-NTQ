 235          //--------------------------------------------------
 236          // Description  : Final format conversion setting
 237          // Input Value  : None
 238          // Output Value : None
 239          //--------------------------------------------------
 240          void ScalerFmtCnvFinalSetting(void)
 241          {
 242   1      #if(_VGA_SUPPORT == _ON)
                  if(ScalerFmtCnvGetSourceType() == _FC_SOURCE_ADC)
                  {
                      // Enable VS edge align
                      ScalerSetBit(P31_0E_FC_SYNC_CTRL, ~(_BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT3 | _BIT2 | _BIT1 | _BIT0
             -));
                  }
              #endif
 249   1      
 250   1      #if(_HDMI_2_0_SUPPORT == _ON)
 251   1          if(GET_COLOR_SPACE() == _COLOR_SPACE_YCBCR420)
 252   1          {
 253   2              // Set main F-to-P FIFO
 254   2              ScalerFmtCnvFtoPSetFifo((GET_INPUT_TIMING_HWIDTH() << 1), GET_INPUT_TIMING_VSTART());
 255   2          }
 256   1          else
 257   1      #endif
 258   1          {
 259   2              // Set main F-to-P FIFO
 260   2              ScalerFmtCnvFtoPSetFifo(GET_INPUT_TIMING_HWIDTH(), GET_INPUT_TIMING_VSTART());
 261   2          }
 262   1      
 263   1          if(ScalerFmtCnvHalfSDGetStatus() == _TRUE)
 264   1          {
 265   2              // Disable 1/2 scaling down
 266   2              ScalerFmtCnvHalfSDControl(_DISABLE);
 267   2          }
 268   1      
 269   1          // Enable main F-to-P
 270   1          ScalerFmtCnvFtoPControl(_ENABLE);
 271   1      
 272   1      #if(_AIO_MODERN_STANDBY_SUPPORT == _ON)
                  if(GET_AIO_MODERN_STANDBY_MODE() != _TRUE)
              #endif
 275   1          {
 276   2              if(ScalerFmtCnvGetSourceType() != _FC_SOURCE_ADC)
 277   2              {
 278   3                  // Wait 4 IVS after format conversion setting
 279   3                  ScalerTimerWaitForEvent(_EVENT_IVS);
 280   3                  ScalerTimerWaitForEvent(_EVENT_IVS);
 281   3                  ScalerTimerWaitForEvent(_EVENT_IVS);
 282   3                  ScalerTimerWaitForEvent(_EVENT_IVS);
 283   3      
 284   3                  // Clear VGIP Interlace Toggle Flag
 285   3                  ScalerSetBit(P0_1A_M1_IPV_ACT_LEN_H, ~_BIT5, _BIT5);
 286   3              }
 287   2          }
 288   1      
 289   1          // Enable clock gating for M2
 290   1          ScalerSetBit(P31_0D_FC_INPUT_CLK_GATING, ~_BIT1, 0x00);
 291   1      }
