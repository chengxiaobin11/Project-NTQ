 304          //--------------------------------------------------
 305          // Description  : Control for even/odd
 306          // Input Value  : _ENABLE or _DISABLE
 307          // Output Value : None
 308          //--------------------------------------------------
 309          void ScalerFmtCnvFtoPControl(bit bEnable)
 310          {
 311   1          if(bEnable == _ENABLE)
 312   1          {
 313   2      #if(_VGA_SUPPORT == _ON)
                      if(ScalerFmtCnvGetSourceType() != _FC_SOURCE_ADC)
              #endif
 316   2              {
 317   3      #if(_HDMI_FREESYNC_ENLARGE_FRONT_PORCH == _ON)
                          if(GET_HDMI_FREESYNC_ENABLED() == _TRUE)
                          {
                              // Enable VS delay 4 line to enlarge front porch, 2 is margin
                              if(GET_ACTIVE_V_START() >= (2 + 2 * (_HDMI_FREESYNC_ENLARGE_FRONT_PORCH_LINE + 1)))
                              {
                                  ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT1, _BIT1);
              
                                  // Vsync delay 4 line
                                  ScalerSetBit(P31_0F_VS_DELAY_CTRL, ~(_BIT5 | _BIT4), (_HDMI_FREESYNC_ENLARGE_FRONT_POR
             -CH_LINE << 4));
                              }
                          }
                          else
              #endif
 331   3                  {
 332   4                      // Enable VS delay 8 line to enlarge front porch
 333   4                      if(GET_ACTIVE_V_START() >= (_VGIP_IV_CAPTURE_MIN_VALUE * 2 + 0x08))
 334   4                      {
 335   5                          ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~_BIT1, _BIT1);
 336   5      
 337   5                          // Vsync delay 8 line
 338   5                          ScalerSetBit(P31_0F_VS_DELAY_CTRL, ~(_BIT5 | _BIT4), (_BIT5 | _BIT4));
 339   5                      }
 340   4                  }
 341   3              }
 342   2      
 343   2              // Enable F-to-P
 344   2              ScalerSetBit(P31_06_FC_EO_LINE_CTRL, ~_BIT7, _BIT7);
 345   2      
 346   2              if(GET_INPUT_TIMING_INTERLACE_FLG() == _TRUE)
 347   2              {
 348   3                  // Set interlace for E/O mode
 349   3                  ScalerFmtCnvFtoPInterlaceSetting();
 350   3              }
 351   2          }
C51 COMPILER V9.60.0.0   RL6449_SERIES_FORMATCONVERSION                                    10/18/2025 16:53:33 PAGE 7   

 352   1          else
 353   1          {
 354   2              // Disable VS delay 8 line
 355   2              ScalerSetBit(P31_0B_FC_FPRMAT_PRO_OUTPUT, ~(_BIT7 | _BIT6 | _BIT1), 0x00);
 356   2      
 357   2              // Vsync delay 8 line
 358   2              ScalerSetBit(P31_0F_VS_DELAY_CTRL, ~(_BIT5 | _BIT4), (_BIT5 | _BIT4));
