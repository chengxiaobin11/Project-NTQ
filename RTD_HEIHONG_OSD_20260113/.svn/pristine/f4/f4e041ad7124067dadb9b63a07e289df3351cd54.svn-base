 414          // Description  : Set even/odd resolution
 415          // Input Value  : usHwidth, usVstart  --> resolution for even/odd
 416          // Output Value : None
 417          //--------------------------------------------------
 418          void ScalerFmtCnvFtoPSetFifo(WORD usHwidth, WORD usVstart)
 419          {
 420   1          if((LOBYTE(usVstart) & _BIT0) == _BIT0)
 421   1          {
 422   2              // Set vertical start field = even
 423   2              ScalerSetBit(P31_06_FC_EO_LINE_CTRL, ~_BIT4, _BIT4);
 424   2          }
 425   1          else
 426   1          {
 427   2              // Set vertical start field = odd
 428   2              ScalerSetBit(P31_06_FC_EO_LINE_CTRL, ~_BIT4, 0x00);
 429   2          }
 430   1      
 431   1          // Toggle vertical start field for VS bypass
 432   1          if(ScalerGetBit(P0_11_M1_VGIP_SIGINV, _BIT6) == _BIT6)
 433   1          {
 434   2              ScalerSetByte(P31_06_FC_EO_LINE_CTRL, (ScalerGetByte(P31_06_FC_EO_LINE_CTRL) ^ _BIT4));
 435   2          }
 436   1      
 437   1      #if(_HW_TMDS_YUV420_DUPLICATE_MODE_SUPPORT == _ON)
                  if(ScalerGlobalGetIDCode() >= _RL6449_VER_E_ID_CODE)
                  {
                      // Toggle vertical start field for 420 duplicate mode
                      if(((ScalerFmtCnvGetSourceType() == _FC_SOURCE_D2) &&
                          (ScalerGetBit(P31_32_YUV420_TO_YUV422, _BIT7) == _BIT7) &&
                          (ScalerGetBit(P31_31_YUV420_TO_422_CTL, _BIT1) == 0x00) &&
                          (ScalerGetBit(P31_34_YUV420_TO_YUV422_HSTM0, _BIT7) == _BIT7)) ||
                         ((ScalerFmtCnvGetSourceType() == _FC_SOURCE_D3) &&
                          (ScalerGetBit(P31_32_YUV420_TO_YUV422, _BIT7) == _BIT7) &&
                          (ScalerGetBit(P31_31_YUV420_TO_422_CTL, _BIT1) == _BIT1) &&
                          (ScalerGetBit(P31_34_YUV420_TO_YUV422_HSTM0, _BIT7) == _BIT7)))
                      {
                          ScalerSetByte(P31_06_FC_EO_LINE_CTRL, (ScalerGetByte(P31_06_FC_EO_LINE_CTRL) ^ _BIT4));
                      }
                  }
              #endif
 454   1      
 455   1          // Set horizontal width
 456   1          ScalerSetBit(P31_07_FC_FORMAT_PRO_MAIN_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (HIBYTE(usHwidth) 
             -& 0x1F));
 457   1          ScalerSetByte(P31_08_FC_FORMAT_PRO_MAIN_1, LOBYTE(usHwidth));
 458   1      }
