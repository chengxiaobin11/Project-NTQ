  97   2                  ScalerSetBit(P31_00_FC_INPUT_SEL_P01, ~(_BIT7 | _BIT6 | _BIT5 | _BIT4), (_FC_SOURCE_D2 << 4));
  98   2      
  99   2      #if(_D2_HDMI_2_0_SUPPORT == _ON)
 100   2                  // Disble 420-to-422
 101   2                  ScalerColor420To422D2D3Enable(enumSourceSearchPort, _FUNCTION_OFF);
 102   2      #endif
 103   2                  break;
 104   2      
 105   2              case _D3_INPUT_PORT:
 106   2      
 107   2                  // Set source index to D3
