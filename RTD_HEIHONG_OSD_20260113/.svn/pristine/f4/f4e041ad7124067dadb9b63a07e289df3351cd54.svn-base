 182          //--------------------------------------------------
 183          // Description  : 420To422 parameter setting for D2 source
 184          // Input Value  : usHStart, usHWidth
 185          // Output Value : None
 186          //--------------------------------------------------
 187          void ScalerFmtCnv420To422D2D3Setting(WORD usHStart, WORD usHWidth)
 188          {
 189   1          if(ScalerGetBit(P31_00_FC_INPUT_SEL_P01, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) == (_BIT6 | _BIT4)) // D2
 190   1          {
 191   2              ScalerSetBit(P31_31_YUV420_TO_422_CTL, ~_BIT1, 0x00);
 192   2          }
 193   1          else if(ScalerGetBit(P31_00_FC_INPUT_SEL_P01, (_BIT7 | _BIT6 | _BIT5 | _BIT4)) == (_BIT6 | _BIT5)) // 
             -D3
 194   1          {
 195   2              ScalerSetBit(P31_31_YUV420_TO_422_CTL, ~_BIT1, _BIT1);
 196   2          }
 197   1      
 198   1          if(GET_COLOR_DEPTH() > _COLOR_DEPTH_8_BITS)
 199   1          {
 200   2              ScalerSetBit(P31_31_YUV420_TO_422_CTL, ~_BIT7, _BIT7);
 201   2          }
 202   1          else
 203   1          {
 204   2              ScalerSetBit(P31_31_YUV420_TO_422_CTL, ~_BIT7, 0x00);
 205   2          }
 206   1      
 207   1          // Hstart should be modify when FC delay 2T enable
 208   1          if(ScalerGetBit(P31_0F_VS_DELAY_CTRL, _BIT6) == _BIT6)
 209   1          {
 210   2              usHStart += 2;
 211   2          }
 212   1      
 213   1          ScalerSetByte(P31_34_YUV420_TO_YUV422_HSTM0, (HIBYTE(usHStart) & 0x07) << 3);
 214   1          ScalerSetByte(P31_35_YUV420_TO_YUV422_HSTL0, LOBYTE(usHStart));
 215   1          ScalerSetByte(P31_37_YUV420_TO_YUV422_HWIDM0, (HIBYTE(usHWidth) & 0x0F) << 4);
 216   1          ScalerSetByte(P31_38_YUV420_TO_YUV422_HWIDL0, LOBYTE(usHWidth));
 217   1      
 218   1      #if(_HW_TMDS_YUV420_DUPLICATE_MODE_SUPPORT == _ON)
                  if(ScalerGlobalGetIDCode() >= _RL6449_VER_E_ID_CODE)
                  {
                      if(GET_COLOR_DEPTH() > _COLOR_DEPTH_8_BITS)
                      {
                          ScalerSetBit(P31_34_YUV420_TO_YUV422_HSTM0, ~_BIT7, _BIT7);
                      }
                      else
                      {
                          ScalerSetBit(P31_34_YUV420_TO_YUV422_HSTM0, ~_BIT7, 0x00);
                      }
                  }
              #endif
