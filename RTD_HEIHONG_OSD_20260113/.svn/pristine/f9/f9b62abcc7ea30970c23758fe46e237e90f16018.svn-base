              // Input Value  : enumDdcRamSel --> D0 or D1 DDCRAM; enumDdcAddr --> Point to Top or bottom address
              // Output Value : None
              //--------------------------------------------------
              void ScalerMcuDdcRamEDIDAddrSelect(EnumD0D1DDCRAMSelect enumDdcRamSel, EnumDDCAddrType enumDdcAddr)
