 396          //--------------------------------------------------
 397          // Description : DP Link Rate Detect
 398          // Input Value  : None
 399          // Output Value : Link Rate
 400          //--------------------------------------------------
 401          BYTE ScalerDpRx0LinkRateDetect(void)
 402          {
 403   1          BYTE ucDpLinkRate = 0;
 404   1          BYTE ucDpLinkRateDecide = _DP_LINK_NONE;
 405   1      
 406   1          do
 407   1          {
 408   2              if(ucDpLinkRate == 0)
 409   2              {
 410   3                  if(_HW_DP_D0_MAX_LINK_RATE_SUPPORT > ScalerDpRx0GetDpcdInfo(0x00, 0x00, 0x01))
 411   3                  {
 412   4                      ucDpLinkRate = _HW_DP_D0_MAX_LINK_RATE_SUPPORT;
 413   4                  }
 414   3                  else
 415   3                  {
C51 COMPILER V9.60.0.0   SCALERCOMMONDPRX0                                                 10/18/2025 16:25:19 PAGE 8   

 416   4                      ucDpLinkRate = ScalerDpRx0GetDpcdInfo(0x00, 0x00, 0x01);
 417   4                  }
 418   3              }
 419   2              else if(ucDpLinkRate == _DP_LINK_HBR3)
 420   2              {
 421   3                  ucDpLinkRate = _DP_LINK_HBR2;
 422   3              }
 423   2              else if(ucDpLinkRate == _DP_LINK_HBR2)
 424   2              {
 425   3                  ucDpLinkRate = _DP_LINK_HBR;
 426   3              }
 427   2              else if(ucDpLinkRate == _DP_LINK_HBR)
 428   2              {
 429   3                  ucDpLinkRate = _DP_LINK_RBR;
 430   3              }
 431   2      
 432   2              if(ScalerDpRx0LinkRateCheck(ucDpLinkRate) == _TRUE)
 433   2              {
 434   3                  ucDpLinkRateDecide = ucDpLinkRate;
 435   3      
 436   3                  break;
 437   3              }
 438   2          }
 439   1          while(ucDpLinkRate != _DP_LINK_RBR);
 440   1      
 441   1          return ucDpLinkRateDecide;
 442   1      }
