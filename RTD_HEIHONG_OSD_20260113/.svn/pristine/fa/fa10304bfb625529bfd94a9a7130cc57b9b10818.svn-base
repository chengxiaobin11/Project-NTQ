                      // Clear BUF0
                      CLR_REG_DP_RX_UP_REPLY_BUF0();
                      CLR_REG_DP_RX_UP_REPLY_BUF1();
              
                      // Enable UpReply Buf0 / Buf1 Receive Capability
                      SET_REG_DP_RX_UP_REPLY_BUF0_MSG_RECEIVE_ENABLE();
