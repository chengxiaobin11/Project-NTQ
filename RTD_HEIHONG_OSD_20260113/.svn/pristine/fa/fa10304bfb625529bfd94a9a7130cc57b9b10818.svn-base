 509          //--------------------------------------------------
 510          // Description : DP Signal Detection Measure
 511          //               It can not use pData to avoid cross-function usage
 512          // Input Value  : DP Lane Select, Measure target, Measure Period
 513          // Output Value : Measure Counter
 514          //--------------------------------------------------
 515          WORD ScalerDpRx0SignalDetectMeasureCount(BYTE ucDpLaneSel, EnumDpMeasureTarget enumDpMeasureTarget, EnumDp
             -MeasurePeriod enumDpMeasurePeriod)
 516          {
 517   1          WORD usDpMeasureCount = 0;
 518   1          BYTE ucCount = 0;
 519   1      
 520   1          // [1:0] freqdet_lane_sel
 521   1          ScalerSetBit(PB_51_DP_SIG_DET_1, ~(_BIT1 | _BIT0), (ucDpLaneSel & (_BIT1 | _BIT0)));
 522   1      
 523   1          // [5] ln_ck_sel
 524   1          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT5, enumDpMeasureTarget);
 525   1      
 526   1          switch(enumDpMeasurePeriod)
 527   1          {
 528   2              case _DP_MEASURE_PERIOD_1000_CYCLE:
 529   2      
 530   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
 531   2                  // [4:0] DP_XTAL_CYCLE = 5'b00011
 532   2                  ScalerSetBit(PB_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), (_BIT1 | _BIT0));
 533   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b0
                          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT0, 0x00);
              #endif
 537   2                  break;
C51 COMPILER V9.60.0.0   SCALERCOMMONDPRX0                                                 10/18/2025 16:25:19 PAGE 10  

 538   2      
 539   2              case _DP_MEASURE_PERIOD_2000_CYCLE:
 540   2              default:
 541   2      
 542   2      #if(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_1)
 543   2                  // [4:0] DP_XTAL_CYCLE = 5'b00100
 544   2                  ScalerSetBit(PB_50_DP_SIG_DET_0, ~(_BIT4 | _BIT3 | _BIT2 | _BIT1 | _BIT0), _BIT2);
 545   2      #elif(_HW_SIGNAL_MEASURE_GEN_TYPE == _SIGNAL_MEASURE_GEN_2)
                          // [0] DP_XTAL_CYCLE = 1'b1
                          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT0, _BIT0);
              #endif
 549   2                  break;
 550   2          }
 551   1      
 552   1          // [6] LANE_COUNT_CLEAR = 0 -> Keep the LANE_COUNT value
 553   1          ScalerSetBit(PB_52_DP_SIG_DET_2, ~_BIT6, 0x00);
 554   1      
 555   1          // [7] DP_SIG_DET_EN = 1'b1 -> Enable Signal Detection
 556   1          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 557   1          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT7, _BIT7);
 558   1      
 559   1          // Delay Time us [5,150] Polling for Measure Done
 560   1          for(ucCount = 0; ucCount <= 30; ucCount++)
 561   1          {
 562   2              DELAY_5US();
 563   2      
 564   2              if(ScalerGetBit(PB_50_DP_SIG_DET_0, _BIT6) == _BIT6)
 565   2              {
 566   3                  usDpMeasureCount = ((((WORD)ScalerGetByte(PB_53_DP_SIG_DET_3)) << 8) | ScalerGetByte(PB_54_DP_
             -SIG_DET_4));
 567   3      
 568   3                  break;
 569   3              }
 570   2          }
 571   1      
 572   1          // [7] DP_SIG_DET_EN = 0 -> Disable Signal Detection
 573   1          ScalerSetBit(PB_50_DP_SIG_DET_0, ~_BIT7, 0x00);
 574   1      
 575   1          return usDpMeasureCount;
 576   1      }
