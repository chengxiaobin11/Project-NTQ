 181          //--------------------------------------------------
 182          // Description  : Reset 8b10b Error Count value
 183          // Input Value  : None
 184          // Output Value : None
 185          //--------------------------------------------------
 186          void ScalerDpRx0DecodeErrorCountReset(void)
 187          {
 188   1          // Reset 8b10b Error Count Value
 189   1          ScalerSetBit(PB_08_BIST_PATTERN_SEL, ~(_BIT2 | _BIT1 | _BIT0), 0x00);
 190   1      
 191   1          // Start Record 8b10b Error Count Value
 192   1          ScalerSetBit(PB_08_BIST_PATTERN_SEL, ~(_BIT2 | _BIT1 | _BIT0), _BIT1);
 193   1      }
 194          
 195          //--------------------------------------------------
 196          // Description  : Get 8b10b Error Count value
 197          // Input Value  : Lane
 198          // Output Value : Error Count
 199          //--------------------------------------------------
 200          WORD ScalerDpRx0GetDecodeErrorCount(BYTE ucDpRx0LaneNumber)
 201          {
 202   1          // Select Lane
 203   1          ScalerSetBit(PB_08_BIST_PATTERN_SEL, ~(_BIT4 | _BIT3), (ucDpRx0LaneNumber << 3));
 204   1      
 205   1          return ((((WORD)ScalerGetByte(PB_0B_BIST_PATTERN3)) << 8) | ScalerGetByte(PB_0C_BIST_PATTERN4));
 206   1      }
