                                  {
                                      return _FALSE;
                                  }
                                  break;
              
                              case (_BIT7 | _BIT1):
                                  if(GET_DP_TX_INPUT_COLOR_SPACE() != _COLOR_SPACE_RAW)
                                  {
                                      return _FALSE;
                                  }
                                  break;
              
                              default:
                                  if(GET_DP_TX_INPUT_COLOR_SPACE() != _COLOR_SPACE_RGB)
                                  {
                                      return _FALSE;
                                  }
                                  break;
                          }
                      }
                      else
