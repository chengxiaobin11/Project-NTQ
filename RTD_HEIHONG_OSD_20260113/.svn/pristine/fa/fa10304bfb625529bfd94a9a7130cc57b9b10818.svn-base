              #if(_HW_DP_VSC_SDP_REG_SUPPORT == _ON)
              
                      // Read DB16~18 --> pData[0:2]
                      ScalerRead(PBC_59_VSC_RX_DB16, 3, pData, _AUTOINC);
              #else
                      // Delay 2 frames for SRAM ready (worst case)
                      ScalerTimerDelayXms(_DP_ONE_FRAME_TIME_MAX * 2);
              
