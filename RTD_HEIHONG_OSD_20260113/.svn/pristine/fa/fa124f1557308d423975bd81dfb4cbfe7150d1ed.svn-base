                          {
                              SET_OSD_STATE(_MENU_NAVIGAT_NONE);
                      
                      OsdDispNavigatMenu();        
                          }
                          break;
                  case _EXIT_KEY_MESSAGE:
                          if((SysModeGetModeState() == _MODE_STATUS_ACTIVE) && (GET_OSD_FACTORY_MODE() == _OFF))
                     {
