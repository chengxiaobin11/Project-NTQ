C51 COMPILER V9.60.0.0   SCALERTIMERFUNCTION                                               10/18/2025 16:52:51 PAGE 2   

  48          //--------------------------------------------------
  49          // Description  : Hold until the specified event occurs
  50          // Input Value  : enumEvent   --> Specified event
  51          // Output Value : Return _TRUE if event occurs
  52          //--------------------------------------------------
  53          bit ScalerTimerWaitForEvent(EnumWaitEventType enumEvent)
  54          {
  55   1          WORD usTimeElapsed = 0;
  56   1          WORD usPreviousTime = 0;
  57   1      
  58   1          switch(enumEvent)
  59   1          {
  60   2              case _EVENT_DVS:
  61   2              case _EVENT_DEN_START:
  62   2              case _EVENT_DEN_STOP:
  63   2                  // Check if D-domain events do occur
  64   2                  if((ScalerGetBit(P0_28_VIDEO_DISPLAY_CONTROL_REG, _BIT0) == 0x00) ||
  65   2                     (GET_DPLL_POWER_STATUS() == _FALSE))
  66   2                  {
  67   3                      return _FALSE;
  68   3                  }
  69   2                  break;
  70   2      
  71   2              case _EVENT_IEN_START:
  72   2              case _EVENT_IEN_STOP:
  73   2                  // Check if I-domain events do occur
  74   2                  if(ScalerGetBit(P0_10_M1_VGIP_CTRL, _BIT0) == 0x00)
  75   2                  {
  76   3                      return _FALSE;
  77   3                  }
  78   2                  break;
  79   2      
  80   2              default:
  81   2                  break;
  82   2          }
  83   1      
  84   1          // Clear status (status register will be cleared after write)
  85   1          ScalerTimerClrEventStatus(enumEvent);
  86   1      
  87   1          usPreviousTime = g_usTimerCounter;
  88   1      
  89   1          do
  90   1          {
  91   2              if(ScalerTimerGetEventStatus(enumEvent) == enumEvent)
  92   2              {
  93   3                  return _TRUE;
  94   3              }
  95   2      
  96   2              if(usPreviousTime != g_usTimerCounter)
  97   2              {
  98   3                  usTimeElapsed++;
  99   3                  usPreviousTime = g_usTimerCounter;
 100   3              }
 101   2          }
 102   1          while(usTimeElapsed <= _TIMER_WAIT_EVENT_TIMEOUT);
 103   1      
 104   1          return _FALSE;
 105   1      }
 106          


